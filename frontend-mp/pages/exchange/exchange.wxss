/**
 * 积分兑换页面样式
 * 设计风格：轻透清新风
 */

/* 页面容器 */
.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F7FAF8 20%);
}

/* ==================== 积分展示区 ==================== */
.points-section {
  padding: 24rpx 32rpx;
}

.points-card {
  position: relative;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.3);
}

.points-bg-decoration {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
}

.points-bg-decoration::after {
  content: '';
  position: absolute;
  top: 60rpx;
  left: 60rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.points-content {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.points-value-wrapper {
  display: flex;
  align-items: baseline;
}

.points-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.points-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 8rpx;
}

.points-actions {
  display: flex;
}

.action-btn {
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  backdrop-filter: blur(10rpx);
}

.action-text {
  font-size: 26rpx;
  color: #FFFFFF;
}

/* ==================== 活动轮播区 ==================== */
.banner-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.activity-swiper {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
}

.banner-image-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx 24rpx 20rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5) 0%, transparent 100%);
}

.banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.banner-indicators {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
  gap: 10rpx;
}

.indicator-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: rgba(91, 189, 114, 0.3);
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 28rpx;
  background: var(--color-primary);
}

/* ==================== 商品分类 ==================== */
.category-section {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.category-list {
  display: flex;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  padding: 8rpx;
}

.category-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
  transition: all 0.3s ease;
}

.category-name {
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.3s ease;
}

.category-item.active .category-name {
  color: var(--color-primary);
  font-weight: 600;
}

.category-indicator {
  position: absolute;
  bottom: 8rpx;
  width: 32rpx;
  height: 6rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
}

/* ==================== 商品列表滚动区 ==================== */
.goods-scroll-view {
  flex: 1;
  height: calc(100vh - 520rpx);
}

.goods-section {
  padding: 0 32rpx 120rpx;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.goods-card {
  width: calc(50% - 10rpx);
  flex: 0 0 calc(50% - 10rpx);
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  position: relative;
  transition: all 0.3s ease;
}

.goods-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 30rpx rgba(91, 189, 114, 0.15);
}

/* 商品标签 */
.goods-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 8rpx;
  z-index: 1;
}

.tag-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 商品图片 */
.goods-image-wrapper {
  width: 100%;
  height: 280rpx;
  background: #F5F5F5;
  overflow: hidden;
}

.goods-image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.goods-card:active .goods-image {
  transform: scale(1.05);
}

/* 商品信息 */
.goods-info {
  padding: 20rpx;
}

.goods-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goods-price {
  display: flex;
  align-items: baseline;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.price-unit {
  font-size: 22rpx;
  color: var(--color-primary);
  margin-left: 4rpx;
}

.original-price {
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-decoration: line-through;
  margin-left: 8rpx;
}

.goods-sales {
  display: flex;
  align-items: center;
}

.sales-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 兑换按钮 */
.exchange-btn {
  width: 100%;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.exchange-btn.disabled {
  background: #E8E8E8;
}

.exchange-btn.loading {
  opacity: 0.7;
}

.btn-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
  width: 100%;
  text-align: center;
  line-height: 64rpx;
}

.exchange-btn.disabled .btn-text {
  color: var(--text-tertiary);
}

.btn-loading {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 列表底部 */
.list-footer {
  padding: 48rpx 0 32rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ==================== 回到顶部按钮 ==================== */
.back-top-btn {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  opacity: 0;
  transform: scale(0.8);
  transition: all 0.3s ease;
  pointer-events: none;
}

.back-top-btn.show {
  opacity: 1;
  transform: scale(1);
  pointer-events: auto;
}

.back-top-icon {
  font-size: 36rpx;
  color: var(--color-primary);
  font-weight: 600;
}

/* ==================== 积分规则弹窗 ==================== */
.rules-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.rules-modal.show {
  opacity: 1;
  visibility: visible;
}

.rules-content {
  width: 85%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: all 0.3s ease;
}

.rules-modal.show .rules-content {
  transform: scale(1);
}

.rules-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.rules-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.rules-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.rules-body {
  max-height: 65vh;
  padding: 24rpx 32rpx 60rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.rules-section {
  margin-bottom: 32rpx;
}

.rules-section:last-child {
  margin-bottom: 0;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-emoji {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.rules-list {
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 8rpx 0;
}

.rule-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
}

.rule-name {
  font-size: 28rpx;
  color: #333333;
}

.rule-points {
  font-size: 28rpx;
  font-weight: 600;
  color: #5BBD72;
}

.rules-desc {
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.desc-item {
  display: flex;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.desc-item:last-child {
  margin-bottom: 0;
}

.desc-num {
  font-size: 26rpx;
  color: #666666;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.desc-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* ==================== Tab 切换栏 ==================== */
.badge-tabs-section {
  padding: 0 32rpx 16rpx;
}

.badge-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.08);
}

.badge-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  position: relative;
}

.badge-tab.active {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  box-shadow: 0 4rpx 12rpx rgba(91, 189, 114, 0.3);
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
  transition: all 0.3s ease;
}

.badge-tab.active .tab-text {
  color: #FFFFFF;
  font-weight: 600;
}

.badge-tabs.only-badges {
  background: transparent;
  box-shadow: none;
  padding: 0;
  margin-top: 8rpx;
}

.badge-tab.only-badge {
  flex: none;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0;
  background: linear-gradient(135deg, rgba(243, 156, 18, 0.08), rgba(91, 189, 114, 0.08));
  border: 2rpx dashed rgba(91, 189, 114, 0.3);
}

.badge-tab.only-badge .tab-icon {
  font-size: 30rpx;
}

.badge-tab.only-badge .tab-text {
  font-size: 30rpx;
  color: #5BBD72;
  font-weight: 600;
}

/* 儿童模式提示条 */
.child-mode-notice {
  margin: 16rpx 32rpx 0;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(243, 156, 18, 0.1), rgba(91, 189, 114, 0.1));
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border: 2rpx solid rgba(243, 156, 18, 0.15);
}

.notice-icon {
  font-size: 44rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notice-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #E67E22;
}

.notice-desc {
  font-size: 22rpx;
  color: #8E8E93;
}

/* ==================== 儿童模式提示卡片 ==================== */
.child-mode-tip-card {
  margin: 16rpx 32rpx;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.1) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid rgba(91, 189, 114, 0.2);
}

.tip-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.tip-icon {
  font-size: 64rpx;
}

.tip-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.tip-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
  text-align: center;
}

.tip-suggest {
  font-size: 26rpx;
  color: #5BBD72;
  font-weight: 500;
  text-align: center;
}

/* ==================== 勋章列表区 ==================== */
.badges-section {
  padding: 0 32rpx 120rpx;
}

.badges-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 16rpx 0;
}

.badges-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.badges-count {
  font-size: 26rpx;
  color: #5BBD72;
  font-weight: 500;
}

.badges-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.badge-card {
  width: calc(50% - 10rpx);
  flex: 0 0 calc(50% - 10rpx);
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
}

.badge-card:active {
  transform: scale(0.97);
}

.badge-card.locked {
  background: rgba(245, 245, 245, 0.9);
}

.badge-status-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 1;
}

.status-emoji {
  font-size: 28rpx;
}

.badge-icon-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.badge-card.locked .badge-icon-wrapper {
  filter: grayscale(100%);
  opacity: 0.6;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.badge-icon {
  font-size: 72rpx;
}

.badge-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
  text-align: center;
  line-height: 1.3;
}

.badge-card.locked .badge-name {
  color: #999999;
}

.badge-progress-wrapper {
  background: rgba(91, 189, 114, 0.1);
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  margin-top: 4rpx;
}

.badge-progress-text {
  font-size: 22rpx;
  color: #5BBD72;
  font-weight: 500;
}

.badge-obtained-time {
  margin-top: 8rpx;
}

.obtained-time-text {
  font-size: 20rpx;
  color: #999999;
}

/* ==================== 勋章详情弹窗 ==================== */
.badge-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.badge-modal.show {
  opacity: 1;
  visibility: visible;
}

.badge-modal-content {
  width: 85%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: all 0.3s ease;
}

.badge-modal.show .badge-modal-content {
  transform: scale(1);
}

.badge-modal-header {
  position: relative;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F7FAF8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.badge-modal-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
}

.badge-modal-icon {
  font-size: 88rpx;
}

.badge-modal-status {
  margin-bottom: 8rpx;
}

.status-text {
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.status-text.unlocked {
  background: rgba(91, 189, 114, 0.15);
  color: #5BBD72;
}

.status-text.locked {
  background: rgba(153, 153, 153, 0.15);
  color: #999999;
}

.badge-modal-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
}

.badge-modal-body {
  padding: 32rpx;
  max-height: 55vh;
  overflow-y: auto;
}

.badge-modal-name {
  text-align: center;
  margin-bottom: 32rpx;
}

.name-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.badge-modal-section {
  margin-bottom: 28rpx;
}

.badge-modal-section:last-child {
  margin-bottom: 0;
}

.section-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.label-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.label-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
}

.section-content {
  padding-left: 36rpx;
}

.content-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.progress-bar-wrapper {
  width: 100%;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #5BBD72;
  font-weight: 500;
}

.badge-modal-footer {
  padding: 20rpx 32rpx 32rpx;
  border-top: 1rpx solid #F0F0F0;
}

.badge-close-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(91, 189, 114, 0.3);
  transition: all 0.3s ease;
}

.badge-close-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(91, 189, 114, 0.2);
}

.close-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ==================== 抽奖 & 盲盒入口卡片 ==================== */
.lottery-entry-section {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx 0;
}

.entry-card {
  flex: 1;
  border-radius: 20rpx;
  padding: 24rpx;
  position: relative;
  overflow: hidden;
  min-height: 200rpx;
  transition: all 0.2s ease;
}

.entry-card:active {
  transform: scale(0.98);
}

.entry-card.lottery {
  background: linear-gradient(135deg, #FFE8E8 0%, #FFF8E6 100%);
  box-shadow: 0 4rpx 16rpx rgba(232, 93, 93, 0.12);
}

.entry-card.blindbox {
  background: linear-gradient(135deg, #F0E6FF 0%, #E8F8FF 100%);
  box-shadow: 0 4rpx 16rpx rgba(155, 89, 182, 0.12);
}

.entry-bg-icon {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  font-size: 110rpx;
  opacity: 0.15;
  transform: rotate(15deg);
}

.entry-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.entry-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1D2129;
}

.entry-hot-tag {
  background: linear-gradient(135deg, #E85D5D, #F39C12);
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
  letter-spacing: 1rpx;
}

.festival-tag {
  position: absolute;
  top: 18rpx;
  right: 20rpx;
  z-index: 3;
  background: linear-gradient(135deg, #E85D5D, #9B59B6);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(155, 89, 182, 0.3);
}

.entry-desc {
  display: block;
  font-size: 22rpx;
  color: #4E5969;
  line-height: 1.4;
  margin-bottom: 16rpx;
  flex: 1;
}

.entry-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.entry-cost {
  font-size: 24rpx;
  font-weight: 600;
  color: #B54900;
  background: rgba(243, 156, 18, 0.12);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.entry-card.blindbox .entry-cost {
  color: #8E44AD;
  background: rgba(155, 89, 182, 0.12);
}

.entry-arrow {
  font-size: 24rpx;
  font-weight: 600;
  color: #1D2129;
}
