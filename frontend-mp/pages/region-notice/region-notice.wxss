.page-container {
  min-height: 100vh;
  background: #F7FAF8;
}

.header-section {
  position: relative;
  padding: 60rpx 32rpx 80rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #5BBD72 0%, #4A90D9 100%);
  z-index: 0;
}

.header-bg::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.header-bg::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -80rpx;
  width: 250rpx;
  height: 250rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
}

.city-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.city-emoji {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.city-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #B2BEC3;
  text-align: center;
}

.notice-list {
  padding: 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.notice-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.1);
}

.notice-header {
  margin-bottom: 24rpx;
}

.notice-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.notice-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  flex: 1;
  margin-right: 16rpx;
}

.notice-badge {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #E74C3C 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.notice-date {
  display: flex;
  align-items: center;
}

.date-label {
  font-size: 24rpx;
  color: #B2BEC3;
}

.date-value {
  font-size: 24rpx;
  color: #5BBD72;
  font-weight: 500;
}

.notice-desc {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.changes-section {
  margin-bottom: 24rpx;
}

.change-list {
  padding-left: 8rpx;
}

.change-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.change-dot {
  font-size: 24rpx;
  color: #5BBD72;
  margin-right: 12rpx;
  line-height: 1.6;
}

.change-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.6;
  flex: 1;
}

.types-section {
  margin-bottom: 24rpx;
}

.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  transition: transform 0.2s ease;
}

.type-tag:active {
  transform: scale(0.95);
}

.type-emoji {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.type-name {
  font-size: 24rpx;
  font-weight: 500;
}

.notice-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-primary,
.btn-share {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  line-height: 1.4;
  padding: 0;
  margin: 0;
}

.btn-primary {
  background: linear-gradient(135deg, #5BBD72 0%, #4A90D9 100%);
  color: #fff;
}

.btn-primary::after {
  border: none;
}

.btn-share {
  background: #F7FAF8;
  color: #5BBD72;
  border: 2rpx solid #5BBD72;
}

.btn-share::after {
  border: none;
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 26rpx;
}

.tips-card {
  background: linear-gradient(135deg, #FFF9E6 0%, #FFF3CD 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-top: 8rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8B7355;
  margin-bottom: 16rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #8B7355;
  line-height: 1.6;
}

.safe-area-bottom {
  height: 48rpx;
}
