<view class="page-container">
  <view class="header-section" wx:if="{{currentCityInfo}}">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="city-badge">
        <text class="city-emoji">{{currentCityInfo.emoji}}</text>
        <text class="city-name">{{currentCityInfo.name}}</text>
      </view>
      <view class="header-title">垃圾分类新标准</view>
      <view class="header-subtitle">即将实施，提前了解</view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!hasUpcoming}}">
    <view class="empty-icon">📋</view>
    <view class="empty-title">暂无新标准预告</view>
    <view class="empty-desc">{{currentCityInfo.name}}目前使用的是最新分类标准</view>
  </view>

  <view class="notice-list" wx:if="{{hasUpcoming}}">
    <view class="notice-card" wx:for="{{upcomingStandards}}" wx:key="id">
      <view class="notice-header">
        <view class="notice-title-row">
          <text class="notice-title">{{item.title}}</text>
          <view class="notice-badge">{{getDaysLeft(item.effectiveDate)}}天后实施</view>
        </view>
        <view class="notice-date">
          <text class="date-label">实施日期：</text>
          <text class="date-value">{{formatDate(item.effectiveDate)}}</text>
        </view>
      </view>

      <view class="notice-desc">{{item.description}}</view>

      <view class="changes-section" wx:if="{{item.keyChanges && item.keyChanges.length > 0}}">
        <view class="section-title">主要变化</view>
        <view class="change-list">
          <view class="change-item" wx:for="{{item.keyChanges}}" wx:for-item="change" wx:key="*this">
            <text class="change-dot">•</text>
            <text class="change-text">{{change}}</text>
          </view>
        </view>
      </view>

      <view class="types-section" wx:if="{{item.affectedTypes && item.affectedTypes.length > 0}}">
        <view class="section-title">受影响分类</view>
        <view class="type-list">
          <view 
            class="type-tag" 
            wx:for="{{item.affectedTypes}}" 
            wx:for-item="typeId" 
            wx:key="*this"
            bindtap="onTypeTap"
            data-type-id="{{typeId}}"
            style="background: {{cityTrashTypes[typeId-1]?.bgColor || '#E8F5E9'}}; color: {{cityTrashTypes[typeId-1]?.color || '#5BBD72'}};"
          >
            <text class="type-emoji">{{cityTrashTypes[typeId-1]?.emoji || '📦'}}</text>
            <text class="type-name">{{cityTrashTypes[typeId-1]?.name || '分类' + typeId}}</text>
          </view>
        </view>
      </view>

      <view class="notice-actions">
        <view class="btn-primary" bindtap="onRemindMe">
          <text class="btn-icon">🔔</text>
          <text class="btn-text">实施前提醒我</text>
        </view>
        <button 
          class="btn-share" 
          open-type="share"
        >
          <text class="btn-icon">📤</text>
          <text class="btn-text">分享给朋友</text>
        </button>
      </view>
    </view>

    <view class="tips-card">
      <view class="tips-title">💡 温馨提示</view>
      <view class="tips-content">
        <text class="tips-item">• 新标准实施后，搜索、练习、答题将自动切换为新标准</text>
        <text class="tips-item">• 历史记录中的分类标签将按新标准重新展示</text>
        <text class="tips-item">• 如有疑问，可在意见反馈中告知我们</text>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
