<view class="page-container">
  <!-- 状态筛选标签 -->
  <view class="tabs-section">
    <scroll-view scroll-x="{{true}}" class="tabs-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="tabs-wrapper">
        <view
          wx:for="{{statusTabs}}"
          wx:key="id"
          class="tab-item {{currentStatus === item.id ? 'active' : ''}}"
          bindtap="onTabTap"
          data-id="{{item.id}}"
        >
          <text class="tab-name">{{item.name}}</text>
          <view wx:if="{{ticketCount[item.id] > 0}}" class="tab-badge">
            <text class="badge-text">{{ticketCount[item.id]}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 工单列表 -->
  <view class="ticket-list" wx:if="{{ticketList.length > 0}}">
    <view
      wx:for="{{ticketList}}"
      wx:key="id"
      class="ticket-card"
      bindtap="onTicketTap"
      data-item="{{item}}"
    >
      <view class="card-header">
        <view class="ticket-type" style="background: {{item.typeConfig.bgColor}};">
          <text class="type-emoji">{{item.typeConfig.emoji}}</text>
          <text class="type-name">{{item.typeConfig.name}}</text>
        </view>
        <view class="ticket-status" style="color: {{item.statusConfig.color}}; background: {{item.statusConfig.bgColor}};">
          <text class="status-emoji">{{item.statusConfig.emoji}}</text>
          <text class="status-name">{{item.statusConfig.name}}</text>
        </view>
      </view>

      <view class="card-body">
        <view class="ticket-title-row">
          <text class="ticket-title">{{item.title}}</text>
          <view wx:if="{{item.hasNewReply}}" class="new-dot"></view>
        </view>
        <text class="ticket-desc">{{item.description}}</text>
      </view>

      <view class="card-footer">
        <view class="footer-left">
          <text class="create-time">{{item.createdAt}}</text>
        </view>
        <view class="footer-right" wx:if="{{item.lastReply}}">
          <text class="last-reply-text">{{item.lastReply.isStaff ? '客服回复' : '您回复'}} · {{item.lastReply.createdAt}}</text>
        </view>
      </view>

      <view wx:if="{{item.isUrgent}}" class="urgent-badge">
        <text class="urgent-text">紧急</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!isLoading}}">
    <view class="empty-icon-wrapper">
      <text class="empty-emoji">📋</text>
    </view>
    <text class="empty-title">暂无工单</text>
    <text class="empty-desc">{{currentStatus === 'all' ? '您还没有提交过工单' : '当前状态下暂无工单'}}</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="safe-area-bottom"></view>
</view>
