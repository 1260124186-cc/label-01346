.review-page {
  min-height: 100vh;
  background: var(--bg-page);
}

.tab-section {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  background: var(--bg-page);
  position: relative;
  transition: all 0.2s ease;
}

.tab-item.tab-active {
  background: var(--color-primary);
}

.tab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.tab-item.tab-active .tab-text {
  color: #fff;
}

.tab-badge {
  position: absolute;
  top: 8rpx;
  right: 16rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: #E85D5D;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

.correction-list {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.correction-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.card-item-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-item-emoji {
  font-size: 36rpx;
}

.card-item-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.card-status {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.status-pending {
  background: rgba(243, 156, 18, 0.1);
}

.status-pending .status-text {
  color: #F39C12;
}

.status-approved {
  background: rgba(91, 189, 114, 0.1);
}

.status-approved .status-text {
  color: #5BBD72;
}

.status-rejected {
  background: rgba(232, 93, 93, 0.1);
}

.status-rejected .status-text {
  color: #E85D5D;
}

.status-text {
  font-size: 24rpx;
  font-weight: 600;
}

.card-body {
  padding: 24rpx 28rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
  flex: 1;
}

.info-value.description {
  line-height: 1.6;
}

.info-value.time {
  color: var(--text-tertiary);
}

.info-value.reward {
  color: #5BBD72;
  font-weight: 700;
}

.info-value.reject-reason {
  color: #E85D5D;
}

.type-change {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.type-old {
  font-size: 26rpx;
  color: #E85D5D;
  text-decoration: line-through;
}

.type-arrow {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.type-new {
  font-size: 26rpx;
  color: #5BBD72;
  font-weight: 600;
}

.image-preview {
  display: flex;
  gap: 12rpx;
  margin: 16rpx 0 0 156rpx;
}

.preview-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  border-top: 1rpx solid var(--border-light);
  background: var(--bg-page);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 40rpx;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.97);
}

.btn-reject {
  background: rgba(232, 93, 93, 0.1);
  border: 2rpx solid rgba(232, 93, 93, 0.3);
}

.btn-reject .btn-text {
  color: #E85D5D;
  font-weight: 600;
}

.btn-approve {
  flex: 2;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.3);
}

.btn-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

.btn-approve .btn-text {
  color: #fff;
  font-weight: 600;
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.reject-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.reject-modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.reject-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.reject-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.reject-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reject-modal-close .close-icon {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.reject-reason-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.reject-reason-item {
  padding: 16rpx 24rpx;
  background: var(--bg-page);
  border-radius: 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.reject-reason-item.reject-reason-active {
  background: rgba(232, 93, 93, 0.08);
  border-color: #E85D5D;
}

.reject-reason-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.reject-reason-active .reject-reason-text {
  color: #E85D5D;
  font-weight: 600;
}

.reject-textarea {
  width: 100%;
  min-height: 120rpx;
  background: var(--bg-page);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.reject-modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  text-align: center;
}

.modal-btn-cancel {
  background: var(--bg-page);
}

.modal-btn-cancel .modal-btn-text {
  color: var(--text-secondary);
}

.modal-btn-confirm {
  background: #E85D5D;
}

.modal-btn-confirm .modal-btn-text {
  color: #fff;
}

.modal-btn-text {
  font-size: 28rpx;
  font-weight: 600;
}
