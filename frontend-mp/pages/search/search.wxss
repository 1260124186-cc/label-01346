.search-page {
  min-height: 100vh;
  background: var(--bg-page);
}

.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  gap: 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--bg-page);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.search-icon {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  height: 48rpx;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-icon {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.cancel-btn {
  padding: 10rpx 0;
}

.cancel-text {
  font-size: 28rpx;
  color: var(--color-primary);
}

.default-content {
  padding: 24rpx;
}

.history-section,
.hot-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.clear-history {
  padding: 8rpx 16rpx;
}

.clear-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 20rpx;
  border-radius: 32rpx;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.history-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-delete {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 32rpx;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.hot-item:active {
  transform: scale(0.96);
}

.hot-emoji {
  font-size: 32rpx;
}

.hot-name {
  font-size: 26rpx;
  color: var(--text-primary);
}

.hot-tag {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #E85D5D 0%, #F39C12 100%);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.search-results {
  padding: 24rpx;
}

.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.results-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.results-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-radius: 20rpx;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.result-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.result-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.result-emoji {
  font-size: 40rpx;
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.corrected-tag {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 12rpx;
  background: rgba(91, 189, 114, 0.1);
  border-radius: 8rpx;
  flex-shrink: 0;
}

.corrected-tag-text {
  font-size: 20rpx;
  font-weight: 500;
  color: #5BBD72;
}

.result-type {
  font-size: 24rpx;
  font-weight: 500;
}

.result-correction-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.result-correction-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.result-correction-icon {
  font-size: 22rpx;
  color: #fff;
}

.result-correction-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
}

.result-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.no-results-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.no-results-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  text-align: center;
}

.no-results-tip {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: 40rpx;
}

.feedback-btn {
  background: linear-gradient(135deg, var(--color-primary) 0%, #4AA862 100%);
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.feedback-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.detail-content {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, var(--detail-bg) 0%, rgba(255, 255, 255, 0.8) 100%);
  gap: 24rpx;
}

.detail-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.detail-emoji {
  font-size: 56rpx;
}

.detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.detail-type-tag {
  align-self: flex-start;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.detail-body {
  padding: 32rpx;
  max-height: calc(85vh - 160rpx);
  overflow-y: auto;
}

.detail-section {
  margin-bottom: 40rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-content {
  padding-left: 44rpx;
}

.description-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.related-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: var(--bg-page);
  border-radius: 16rpx;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.related-item:active {
  transform: scale(0.95);
  background: rgba(91, 189, 114, 0.1);
}

.related-emoji {
  font-size: 40rpx;
}

.related-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.2;
}

.detail-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  border-radius: 48rpx;
  gap: 12rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn.primary {
  background: var(--btn-bg);
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.action-btn.primary .action-icon,
.action-btn.primary .action-text {
  color: #fff;
}

.action-btn.secondary {
  background: var(--bg-page);
}

.action-btn.correction {
  background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
  box-shadow: 0 8rpx 24rpx rgba(243, 156, 18, 0.3);
}

.action-btn.correction .action-icon,
.action-btn.correction .action-text {
  color: #fff;
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

.packaging-preview {
  background: #f9faf9;
  border-radius: 16rpx;
  padding: 24rpx;
}

.packaging-preview-desc {
  margin-bottom: 20rpx;
}

.packaging-desc-text {
  font-size: 26rpx;
  color: #4E5969;
  line-height: 1.6;
}

.packaging-components-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.packaging-comp-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 24rpx;
  gap: 6rpx;
  border: 2rpx solid transparent;
}

.comp-chip-emoji {
  font-size: 22rpx;
}

.comp-chip-name {
  font-size: 22rpx;
  color: #1D2129;
  font-weight: 500;
}

.comp-chip-required {
  font-size: 18rpx;
  color: #E85D5D;
  background: rgba(232, 93, 93, 0.1);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.packaging-wizard-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.packaging-wizard-entry:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.wizard-entry-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wizard-entry-icon {
  font-size: 36rpx;
}

.wizard-entry-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.wizard-entry-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.wizard-entry-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.wizard-entry-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 300;
}
