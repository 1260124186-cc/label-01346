/**
 * 兑换订单页面样式
 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F7FAF8 20%);
  padding-bottom: 48rpx;
}

/* 页面标题 */
.page-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
}

.header-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(91, 189, 114, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.success-emoji {
  font-size: 60rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #5BBD72;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999999;
}

/* 订单列表 */
.orders-section {
  padding: 0 32rpx;
}

.order-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 成功标识 */
.success-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  background: #5BBD72;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* 商品信息 */
.order-goods {
  display: flex;
  padding: 24rpx;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 8rpx;
  padding-right: 60rpx;
}

.goods-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-points {
  font-size: 32rpx;
  font-weight: 600;
  color: #5BBD72;
}

.goods-quantity {
  font-size: 26rpx;
  color: #999999;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #FAFAFA;
}

.order-time {
  font-size: 24rpx;
  color: #999999;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: rgba(91, 189, 114, 0.1);
  color: #5BBD72;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: #5BBD72;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #FFFFFF;
}
