.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 120rpx;
}

/* ==================== 顶部用户栏 ==================== */
.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-emoji {
  font-size: 48rpx;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.user-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.user-points {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.publish-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  backdrop-filter: blur(10rpx);
}

.publish-btn:active {
  opacity: 0.8;
}

.publish-icon {
  font-size: 28rpx;
}

.publish-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ==================== 话题标签 ==================== */
.topics-section {
  padding: 20rpx 0 16rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
}

.topics-scroll {
  padding: 0 24rpx;
  white-space: nowrap;
}

.topic-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.18);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  margin-right: 16rpx;
  transition: all 0.2s ease;
}

.topic-tag:last-child {
  margin-right: 0;
}

.topic-tag.active {
  background: rgba(255, 255, 255, 0.95);
}

.topic-tag.hot .topic-name {
  color: #FF6B6B;
}

.topic-tag.active.hot .topic-name {
  color: #E85D5D;
}

.topic-icon {
  font-size: 24rpx;
}

.topic-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.topic-tag.active .topic-name {
  color: #5BBD72;
  font-weight: 600;
}

.topic-count {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 4rpx;
}

.topic-tag.active .topic-count {
  color: #8E8E93;
}

/* ==================== 分类筛选 ==================== */
.filter-section {
  display: flex;
  padding: 20rpx 32rpx;
  gap: 16rpx;
  overflow-x: auto;
  background: #FFFFFF;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #F5F5F5;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.filter-item.active {
  background: color-mix(in srgb, var(--filter-color) 12%, transparent);
}

.filter-icon {
  font-size: 24rpx;
}

.filter-name {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.filter-item.active .filter-name {
  color: var(--filter-color);
  font-weight: 600;
}

/* ==================== 帖子列表 ==================== */
.posts-section {
  padding: 20rpx 32rpx;
}

.post-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  position: relative;
  transition: all 0.2s ease;
}

.post-card:active {
  transform: scale(0.98);
}

.post-official-badge {
  position: absolute;
  top: 0;
  right: 28rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #E67E22 0%, #D35400 100%);
  padding: 8rpx 20rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.badge-icon {
  font-size: 22rpx;
}

.badge-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.2) 0%, rgba(74, 144, 217, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.avatar-emoji {
  font-size: 36rpx;
}

.post-user-info {
  flex: 1;
}

.post-user-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.post-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.official-icon {
  font-size: 22rpx;
  color: #5BBD72;
  background: rgba(91, 189, 114, 0.15);
  border-radius: 50%;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.post-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.post-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.post-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.post-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
}

.post-image.single {
  grid-column: span 3;
  height: 360rpx;
  border-radius: 16rpx;
}

.post-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.post-topic {
  font-size: 22rpx;
  color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.post-actions {
  display: flex;
  align-items: center;
  gap: 48rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-item.liked .action-icon {
  animation: heartBeat 0.3s ease;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.action-icon {
  font-size: 32rpx;
}

.action-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.action-item.liked .action-count {
  color: #E85D5D;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ==================== 底部安全区域 ==================== */
.bottom-safe {
  height: 40rpx;
}

/* ==================== 浮动发布按钮 ==================== */
.fab-publish {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(91, 189, 114, 0.4);
  z-index: 100;
  transition: all 0.2s ease;
}

.fab-publish:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ==================== 创作者等级标识 ==================== */
.creator-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.creator-icon {
  font-size: 28rpx;
}

.creator-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #E67E22;
}

.creator-multiplier {
  font-size: 22rpx;
  color: #F39C12;
  background: rgba(255, 255, 255, 0.6);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
}

/* ==================== 每周达人榜 ==================== */
.expert-banner {
  margin: 16rpx 32rpx 0;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
}

.expert-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.expert-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.expert-crown {
  font-size: 28rpx;
}

.expert-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.expert-subtitle {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.75);
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 4rpx;
}

.expert-close {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.expert-close .close-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 1;
}

.expert-scroll {
  white-space: nowrap;
}

.expert-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 150rpx;
  padding: 16rpx 8rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 16rpx;
  margin-right: 12rpx;
  position: relative;
  vertical-align: top;
}

.expert-item:last-child {
  margin-right: 0;
}

.expert-rank {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.expert-rank.rank-1 {
  background: #FFD700;
  color: #8B4513;
}

.expert-rank.rank-2 {
  background: #C0C0C0;
  color: #FFFFFF;
}

.expert-rank.rank-3 {
  background: #CD7F32;
  color: #FFFFFF;
}

.expert-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.expert-avatar-emoji {
  font-size: 36rpx;
}

.expert-nickname {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
  max-width: 130rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.expert-badge-mini {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  margin-bottom: 4rpx;
}

.badge-icon-mini {
  font-size: 18rpx;
}

.badge-name-mini {
  font-size: 18rpx;
  font-weight: 500;
}

.expert-weeklikes {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ==================== 创作者徽章（帖子卡片内） ==================== */
.creator-badge {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  border: 1rpx solid;
}

.creator-badge-icon {
  font-size: 20rpx;
}

.creator-badge-text {
  font-size: 20rpx;
  font-weight: 600;
}

/* ==================== 精选标识 ==================== */
.post-card.featured {
  border: 2rpx solid rgba(243, 156, 18, 0.3);
  background: linear-gradient(180deg, rgba(255, 248, 225, 0.5) 0%, rgba(255, 255, 255, 0.95) 30%);
}

.post-featured-badge {
  position: absolute;
  top: 0;
  left: 28rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
  padding: 8rpx 20rpx;
  border-radius: 0 0 16rpx 16rpx;
  z-index: 5;
}

.featured-icon {
  font-size: 22rpx;
}

.featured-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
}
