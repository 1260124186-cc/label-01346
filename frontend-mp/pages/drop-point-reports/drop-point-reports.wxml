<view class="page-container">
  <!-- 状态筛选标签 -->
  <view class="status-tabs">
    <view
      class="status-tab {{currentStatus === item.id ? 'active' : ''}}"
      wx:for="{{statusTabs}}"
      wx:key="id"
      bindtap="onStatusTap"
      data-status="{{item.id}}"
    >
      <text class="tab-text" style="{{item.color ? 'color: ' + item.color : ''}}">{{item.name}}</text>
      <view class="tab-count" wx:if="{{reportCount[item.id] > 0}}">
        <text class="count-text">{{reportCount[item.id]}}</text>
      </view>
    </view>
  </view>

  <!-- 上报列表 -->
  <scroll-view class="report-list" scroll-y="{{true}}" wx:if="{{!isEmpty}}">
    <view
      class="report-card"
      wx:for="{{reportList}}"
      wx:key="id"
      bindtap="onReportTap"
      data-report="{{item}}"
    >
      <view class="report-header">
        <view class="report-type">
          <text class="type-emoji">{{item.typeInfo.emoji}}</text>
          <text class="type-name">{{item.typeInfo.name}}</text>
        </view>
        <view class="report-status" style="background: {{item.statusInfo.bgColor}}; color: {{item.statusInfo.color}};">
          <text class="status-text">{{item.statusInfo.name}}</text>
        </view>
      </view>

      <view class="report-point">
        <text class="point-name">{{item.pointName}}</text>
        <text class="point-address">{{item.pointAddress}}</text>
      </view>

      <view class="report-desc" wx:if="{{item.description}}">
        <text class="desc-text">{{item.description}}</text>
      </view>

      <view class="report-footer">
        <text class="report-time">{{item.formatTime}}</text>
        <text class="report-arrow">›</text>
      </view>
    </view>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <text class="empty-icon">📝</text>
    <text class="empty-title">暂无上报记录</text>
    <text class="empty-desc">您还没有上报记录，快去发现问题并反馈吧</text>
    <view class="empty-btn" bindtap="onGoToDropPoint">
      <text class="btn-text">前往投放点</text>
    </view>
  </view>
</view>
