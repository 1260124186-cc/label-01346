/**
 * 投放点上报记录页面样式
 * 设计风格：轻透清新风
 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F7FAF8 15%);
  display: flex;
  flex-direction: column;
}

/* 状态筛选标签 */
.status-tabs {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  gap: 12rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  position: relative;
}

.status-tab:active {
  transform: scale(0.96);
}

.status-tab.active {
  background: rgba(91, 189, 114, 0.1);
}

.tab-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.status-tab.active .tab-text {
  color: #5BBD72;
  font-weight: 600;
}

.tab-count {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #E85D5D;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

/* 上报列表 */
.report-list {
  flex: 1;
  padding: 24rpx;
}

.report-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.report-card:active {
  transform: scale(0.98);
}

.report-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.report-type {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.type-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.type-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.report-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-text {
  font-size: 22rpx;
  font-weight: 500;
}

.report-point {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.point-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.point-address {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.report-desc {
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.report-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.report-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.report-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 100rpx;
  line-height: 1;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: 48rpx;
}

.empty-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.3);
}

.empty-btn:active {
  transform: scale(0.96);
}

.empty-btn .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
}
