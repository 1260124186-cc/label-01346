.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 140rpx;
}

.tabs-section {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-list {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 32rpx;
  position: relative;
  flex-shrink: 0;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-item.active .tab-text {
  color: #5BBD72;
  font-weight: 500;
  font-size: 30rpx;
}

.tab-indicator {
  position: absolute;
  bottom: 8rpx;
  width: 48rpx;
  height: 6rpx;
  background: #5BBD72;
  border-radius: 3rpx;
}

.orders-section {
  padding: 20rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-status {
  font-size: 28rpx;
  font-weight: 500;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-content {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.category-emoji {
  font-size: 48rpx;
}

.category-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.category-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.category-quantity {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.appointment-time {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.time-label {
  font-size: 24rpx;
  color: #999;
}

.time-value {
  font-size: 24rpx;
  color: #666;
}

.points-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.points-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.points-value {
  font-size: 32rpx;
  color: #E85D5D;
  font-weight: 500;
}

.points-value.cancelled {
  color: #e74c3c;
  font-size: 28rpx;
}

.order-card.cancelled {
  opacity: 0.85;
}

.order-card.cancelled .order-content {
  opacity: 0.75;
}

.collector-preview {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #f8fafb;
  border-top: 1rpx solid #f0f0f0;
}

.collector-avatar-sm {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #3498db, #2980b9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.avatar-emoji-sm {
  font-size: 28rpx;
}

.collector-brief {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.collector-name-sm {
  font-size: 26rpx;
  color: #2c3e50;
  font-weight: 500;
  margin-right: 12rpx;
}

.collector-level-sm {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #f39c12, #e67e22);
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
}

.collector-phone-sm {
  font-size: 24rpx;
  color: #7f8c8d;
  flex-shrink: 0;
}

.cancel-preview {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fdf4f4;
  border-top: 1rpx solid #f0e0e0;
}

.cancel-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.cancel-reason {
  font-size: 24rpx;
  color: #e74c3c;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0 80rpx;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.bottom-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
  z-index: 99;
}

.appointment-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #5BBD72, #4CAF50);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.appointment-btn .btn-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}
