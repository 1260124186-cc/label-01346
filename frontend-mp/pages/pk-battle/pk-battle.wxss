.pk-battle-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  display: flex;
  flex-direction: column;
}

.matching-phase {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 32rpx;
}

.matching-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 64rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(91, 189, 114, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.matching-avatars {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 60rpx;
}

.matching-avatar {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
  margin-bottom: 16rpx;
}

.opponent-avatar .avatar-circle {
  background: linear-gradient(135deg, #8E8E93 0%, #636E72 100%);
  box-shadow: 0 8rpx 24rpx rgba(142, 142, 147, 0.3);
}

.avatar-emoji {
  font-size: 52rpx;
}

.avatar-name {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
}

.matching-vs {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  position: relative;
}

.pulse-ring {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #5BBD72;
  opacity: 0;
  animation: pulse-ring 2s ease-out infinite;
}

.ring-2 {
  animation-delay: 0.5s;
}

.ring-3 {
  animation-delay: 1s;
}

@keyframes pulse-ring {
  0% {
    transform: scale(0.5);
    opacity: 0.8;
  }
  100% {
    transform: scale(2);
    opacity: 0;
  }
}

.vs-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #5BBD72;
  z-index: 1;
}

.matching-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 6rpx solid rgba(91, 189, 114, 0.2);
  border-top-color: #5BBD72;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.matching-text {
  font-size: 30rpx;
  color: #636E72;
  font-weight: 500;
}

.battle-phase {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24rpx 32rpx;
}

.vs-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.player-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  flex: 1;
  min-width: 0;
}

.player-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.opponent-card .player-avatar {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
}

.player-emoji {
  font-size: 36rpx;
}

.player-name {
  font-size: 24rpx;
  color: #2D3436;
  font-weight: 600;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
}

.player-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #5BBD72;
}

.vs-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B 0%, #E85D5D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(232, 93, 93, 0.3);
  flex-shrink: 0;
}

.vs-badge-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.progress-section {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
}

.progress-correct {
  font-size: 26rpx;
  color: #5BBD72;
  font-weight: 600;
}

.progress-bar {
  height: 10rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.timer-section {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.timer-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(91, 189, 114, 0.2);
  border-top-color: #5BBD72;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: timer-rotate 2s linear infinite;
  transition: border-color 0.3s ease;
}

.timer-ring.warning {
  border-color: rgba(232, 93, 93, 0.2);
  border-top-color: #E85D5D;
  animation-duration: 0.5s;
}

@keyframes timer-rotate {
  to { transform: rotate(360deg); }
}

.timer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timer-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  line-height: 1;
}

.timer-ring.warning .timer-number {
  color: #E85D5D;
}

.timer-unit {
  font-size: 18rpx;
  color: #636E72;
  margin-top: 2rpx;
}

.question-section {
  flex: 1;
}

.question-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  margin-bottom: 24rpx;
}

.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.6;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.selected {
  border-color: #5BBD72;
  background: rgba(91, 189, 114, 0.05);
}

.option-item.correct {
  border-color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
}

.option-item.wrong {
  border-color: #E85D5D;
  background: rgba(232, 93, 93, 0.1);
}

.option-item.dim {
  opacity: 0.5;
}

.option-label {
  flex: 1;
  font-size: 30rpx;
  color: #2D3436;
  line-height: 1.5;
}

.label-correct {
  color: #5BBD72;
  font-weight: 600;
}

.label-wrong {
  color: #E85D5D;
  font-weight: 600;
}

.option-feedback {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.feedback-icon {
  font-size: 36rpx;
  font-weight: 700;
}

.correct-icon {
  color: #5BBD72;
}

.wrong-icon {
  color: #E85D5D;
}

.feedback-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 32rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  backdrop-filter: blur(20rpx);
}

.feedback-correct {
  background: rgba(91, 189, 114, 0.95);
}

.feedback-wrong {
  background: rgba(232, 93, 93, 0.95);
}

.feedback-emoji {
  font-size: 36rpx;
}

.feedback-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}
