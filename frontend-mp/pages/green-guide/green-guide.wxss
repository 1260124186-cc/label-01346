.green-guide-page .page-container {
  padding-bottom: calc(var(--spacing-xl) + 120rpx);
}

.hero-section {
  position: relative;
  margin: 0 0 var(--spacing-lg);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #27AE60 0%, #5BBD72 40%, #81C784 100%);
  border-radius: var(--radius-lg);
  opacity: 0.9;
}

.hero-content {
  position: relative;
  padding: var(--spacing-xl);
  color: #fff;
}

.hero-title-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.hero-emoji {
  font-size: 56rpx;
  margin-right: var(--spacing-sm);
}

.hero-title {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: #fff;
}

.hero-subtitle {
  font-size: var(--font-sm);
  color: rgba(255,255,255,0.85);
  line-height: 1.5;
  margin-bottom: var(--spacing-md);
}

.hero-search {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10rpx);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
}

.hero-search .search-icon {
  font-size: var(--font-md);
  margin-right: var(--spacing-sm);
}

.hero-search .search-placeholder {
  font-size: var(--font-sm);
  color: rgba(255,255,255,0.7);
}

.quick-entries {
  display: flex;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.quick-entry-card {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
}

.quick-entry-card:active {
  transform: scale(0.97);
}

.entry-icon-bg {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.entry-emoji {
  font-size: 36rpx;
}

.entry-info {
  flex: 1;
  min-width: 0;
}

.entry-name {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.entry-desc {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.entry-arrow {
  color: var(--text-tertiary);
  font-size: var(--font-lg);
  flex-shrink: 0;
}

.category-scroll {
  margin: 0 0 var(--spacing-lg);
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: var(--spacing-sm);
  padding: 0 var(--spacing-xs);
}

.category-item {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-lg);
  background: var(--bg-card);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-light);
  transition: all var(--transition-fast) ease;
}

.category-item.active {
  background: var(--cat-color);
  border-color: var(--cat-color);
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.2);
}

.category-icon {
  font-size: var(--font-md);
  margin-right: var(--spacing-xs);
}

.category-name {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-secondary);
}

.category-item.active .category-name {
  color: #fff;
}

.comparison-section {
  margin-bottom: var(--spacing-lg);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title-row {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: var(--font-lg);
  margin-right: var(--spacing-sm);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.disclaimer-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.disclaimer-icon {
  font-size: var(--font-sm);
}

.disclaimer-text {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.comparison-scroll {
  white-space: nowrap;
}

.comparison-cards {
  display: inline-flex;
  gap: var(--spacing-md);
  padding: 0 var(--spacing-xs);
}

.comparison-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg) var(--spacing-xl);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  min-width: 280rpx;
  transition: all var(--transition-fast) ease;
}

.comparison-card:active {
  transform: scale(0.97);
}

.cmp-emoji {
  font-size: 48rpx;
}

.cmp-vs {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin: var(--spacing-xs) 0;
}

.cmp-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  margin-top: var(--spacing-sm);
  white-space: normal;
  text-align: center;
}

.cmp-subtitle {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  white-space: normal;
  text-align: center;
  margin-top: var(--spacing-xs);
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.product-card {
  display: flex;
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  transition: all var(--transition-fast) ease;
}

.product-card:active {
  transform: scale(0.98);
}

.score-ring-wrapper {
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.score-ring {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.5);
}

.score-level {
  font-size: var(--font-xl);
  font-weight: 700;
  line-height: 1.2;
}

.score-value {
  font-size: var(--font-xs);
  font-weight: 500;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.product-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: 4rpx;
}

.product-emoji {
  font-size: var(--font-md);
}

.product-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.product-brand {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-bottom: var(--spacing-xs);
}

.cert-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-xs);
}

.cert-tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 2rpx 10rpx;
  border-radius: var(--radius-xs);
  font-size: 20rpx;
  font-weight: 500;
}

.cert-icon {
  font-size: 18rpx;
}

.plastic-level {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-xs);
}

.plastic-icon {
  font-size: var(--font-sm);
}

.plastic-name {
  font-size: var(--font-xs);
  font-weight: 500;
}

.product-pros-cons {
  margin-bottom: var(--spacing-xs);
}

.pros-row, .cons-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: 4rpx;
}

.pros-label, .cons-label {
  font-size: var(--font-xs);
  flex-shrink: 0;
}

.pros-text, .cons-text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.green-alt-hint {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  background: rgba(91, 189, 114, 0.08);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-xs);
}

.alt-icon {
  font-size: var(--font-sm);
}

.alt-text {
  font-size: var(--font-xs);
  color: #5BBD72;
  font-weight: 500;
  flex: 1;
}

.alt-arrow {
  color: #5BBD72;
  font-size: var(--font-md);
}

.disclaimer-modal-mask,
.search-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.disclaimer-modal {
  width: 600rpx;
  background: var(--bg-card-solid);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-heavy);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--border-light);
}

.modal-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: var(--font-lg);
  color: var(--text-tertiary);
  padding: var(--spacing-xs);
}

.modal-body {
  padding: var(--spacing-lg);
}

.modal-text {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: var(--spacing-sm);
}

.modal-footer {
  padding: 0 var(--spacing-lg) var(--spacing-lg);
}

.modal-btn {
  background: linear-gradient(135deg, #5BBD72, #4AA862);
  color: #fff;
  text-align: center;
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: 500;
}

.search-modal {
  width: 100%;
  background: var(--bg-card-solid);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  max-height: 70vh;
  overflow-y: auto;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 1rpx solid var(--border-light);
}

.search-bar-icon {
  font-size: var(--font-md);
  margin-right: var(--spacing-sm);
}

.search-input {
  flex: 1;
  font-size: var(--font-md);
  color: var(--text-primary);
}

.search-cancel {
  padding: var(--spacing-xs) var(--spacing-sm);
  color: #5BBD72;
  font-size: var(--font-sm);
}

.search-results {
  padding: var(--spacing-md) var(--spacing-lg);
}

.search-result-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.result-emoji {
  font-size: var(--font-xl);
  margin-right: var(--spacing-md);
}

.result-info {
  flex: 1;
  min-width: 0;
}

.result-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
  display: block;
}

.result-brand {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  display: block;
}

.result-score {
  font-size: var(--font-lg);
  font-weight: 700;
}

.search-empty {
  padding: var(--spacing-xxl);
  text-align: center;
}

.search-empty-text {
  font-size: var(--font-md);
  color: var(--text-tertiary);
}
