/* 游戏大厅页面样式 */
.game-hall-container {
  min-height: 100vh;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* ============ 顶部状态栏 ============ */
.hall-header {
  position: relative;
  padding: 0 32rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 50%, #3D8F52 100%);
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
}

.header-content {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 40rpx;
}

.points-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(20rpx);
  padding: 16rpx 28rpx;
  border-radius: 48rpx;
}

.points-emoji {
  font-size: 36rpx;
}

.points-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.daily-info {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(20rpx);
  padding: 16rpx 24rpx;
  border-radius: 48rpx;
}

.daily-count {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.daily-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.daily-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ============ 标题区 ============ */
.hall-title-section {
  padding: 24rpx 32rpx 32rpx;
  text-align: center;
}

.hall-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.hall-subtitle {
  font-size: 26rpx;
  color: #636E72;
}

/* ============ 游戏列表 ============ */
.game-list-section {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.game-card {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.game-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.game-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
}

.game-card-content {
  position: relative;
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  gap: 24rpx;
}

.game-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.game-emoji {
  font-size: 60rpx;
}

.game-info {
  flex: 1;
  min-width: 0;
}

.game-name-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.game-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.game-english {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.game-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.game-stats {
  display: flex;
  gap: 16rpx;
}

.stat-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 32rpx;
}

.stat-emoji {
  font-size: 22rpx;
}

.stat-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.game-arrow {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 300;
  margin-left: 4rpx;
}

.play-tag {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--gradient-end);
}

/* ============ 道具区 ============ */
.powerup-section {
  padding: 48rpx 32rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.section-title-icon {
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.powerup-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.powerup-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.powerup-card:active {
  transform: scale(0.96);
}

.powerup-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 12rpx;
  background: linear-gradient(135deg, #FFF7E6 0%, #FFEFD1 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.powerup-emoji {
  font-size: 40rpx;
}

.powerup-name {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.powerup-cost {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(243, 156, 18, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.cost-emoji {
  font-size: 20rpx;
}

.cost-value {
  font-size: 22rpx;
  font-weight: 600;
  color: #F39C12;
}

/* ============ 规则区 ============ */
.rules-section {
  padding: 40rpx 32rpx 0;
}

.rules-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.rules-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 20rpx;
}

.rules-emoji {
  font-size: 28rpx;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.rule-dot {
  font-size: 28rpx;
  color: #5BBD72;
  font-weight: 700;
  line-height: 1.6;
}

.rule-text {
  flex: 1;
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.6;
}

.bottom-spacer {
  height: 60rpx;
}
