<view class="page-container">
  <!-- 发布类型选择 -->
  <view class="section">
    <view class="section-title">选择发布类型</view>
    <view class="type-list">
      <view
        wx:for="{{postTypes}}"
        wx:key="id"
        class="type-card {{currentType === item.id ? 'active' : ''}}"
        bindtap="onTypeTap"
        data-type="{{item.id}}"
        style="--type-color: {{item.color}};"
      >
        <view class="type-icon-wrapper">
          <text class="type-emoji">{{item.icon}}</text>
        </view>
        <view class="type-info">
          <text class="type-name">{{item.name}}</text>
          <text class="type-desc">{{item.desc}}</text>
        </view>
        <view class="type-check" wx:if="{{currentType === item.id}}">✓</view>
      </view>
    </view>
  </view>

  <!-- 话题选择 -->
  <view class="section">
    <view class="section-title">
      <text class="section-title-text">选择话题标签（可选，最多3个）</text>
    </view>
    <view class="topics-grid">
      <view
        wx:for="{{topicsWithSelected}}"
        wx:key="id"
        class="topic-item {{item.isSelected ? 'selected' : ''}} {{item.hot ? 'hot' : ''}}"
        bindtap="onTopicTap"
        data-topic="{{item}}"
      >
        <text class="topic-icon">{{item.icon}}</text>
        <text class="topic-name">#{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 内容输入 -->
  <view class="section">
    <view class="section-title">
      <text class="section-title-text">说点什么...</text>
      <text class="section-title-count">{{content.length}}/{{contentMaxLength}}</text>
    </view>
    <textarea
      class="content-textarea"
      placeholder="分享你的环保故事、分类技巧或生活瞬间..."
      placeholder-class="textarea-placeholder"
      maxlength="{{contentMaxLength}}"
      auto-height
      value="{{content}}"
      bindinput="onContentInput"
    />
  </view>

  <!-- 图片选择 -->
  <view class="section">
    <view class="section-title">
      <text class="section-title-text">添加图片（{{images.length}}/{{maxImages}}）</text>
    </view>
    <view class="images-grid">
      <view
        wx:for="{{images}}"
        wx:key="*this"
        class="image-item"
        bindtap="onPreviewImage"
        data-index="{{index}}"
      >
        <image src="{{item}}" mode="aspectFill" class="uploaded-image" />
        <view class="image-remove" catchtap="onRemoveImage" data-index="{{index}}">
          <text class="remove-icon">×</text>
        </view>
      </view>
      <view class="image-add" wx:if="{{images.length < maxImages}}" bindtap="onChooseImage">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 知识卡片 -->
  <view class="section">
    <view class="section-title">
      <text class="section-title-text">插入分类知识卡片（可选，最多3张）</text>
      <view class="insert-kc-btn" bindtap="onInsertKnowledgeCard">
        <text class="insert-icon">📑</text>
        <text class="insert-text">选择</text>
      </view>
    </view>

    <view class="selected-kc-list" wx:if="{{selectedKnowledgeCards.length > 0}}">
      <view
        wx:for="{{selectedKnowledgeCards}}"
        wx:key="id"
        class="kc-card"
        style="border-color: {{item.color}}30; background: linear-gradient(135deg, {{item.color}}08 0%, #FFFFFF 100%);"
      >
        <view class="kc-icon-wrapper" style="background: {{item.color}}1A;">
          <text class="kc-emoji">{{item.emoji}}</text>
        </view>
        <view class="kc-content">
          <view class="kc-header">
            <text class="kc-type-tag" style="background: {{item.color}}1A; color: {{item.color}};">
              {{item.type === 'course' ? '课程' : '百科'}}
            </text>
            <text class="kc-title">{{item.title}}</text>
          </view>
          <text class="kc-summary">{{item.summary}}</text>
          <view class="kc-meta">
            <text class="kc-meta-item" wx:if="{{item.relatedTrashCount}}">📚 关联{{item.relatedTrashCount}}种分类</text>
            <text class="kc-meta-item" wx:if="{{item.chaptersCount}}">🎓 {{item.chaptersCount}}节课</text>
          </view>
        </view>
        <view class="kc-remove" catchtap="onRemoveKnowledgeCard" data-card-id="{{item.id}}">
          <text class="remove-icon">×</text>
        </view>
      </view>
    </view>

    <view class="kc-empty-hint" wx:if="{{selectedKnowledgeCards.length === 0}}">
      <text class="hint-emoji">📑</text>
      <text class="hint-text">插入话题关联的分类百科或环保课程，帮助大家学习更多知识</text>
    </view>
  </view>

  <!-- 积分提示 -->
  <view class="points-hint">
    <text class="hint-icon">💡</text>
    <text class="hint-text">发布成功可获得 {{publishPoints}} 积分
      <text wx:if="{{currentCreatorLevel && currentCreatorLevel.pointsMultiplier > 1}}">
        （{{currentCreatorLevel.name}} x{{currentCreatorLevel.pointsMultiplier}} 系数）
      </text>
      ，优质内容还能获得额外奖励哦～
    </text>
  </view>

  <!-- 发布按钮 -->
  <view class="bottom-bar">
    <view class="community-guidelines">
      <text class="guidelines-icon">⚠️</text>
      <text class="guidelines-text">请遵守社区规范，共同维护绿色健康的交流环境</text>
    </view>
    <button class="publish-btn" bindtap="onPublish">
      <text>立即发布</text>
    </button>
  </view>

  <!-- 底部安全 -->
  <view class="bottom-safe"></view>

  <!-- 知识卡片选择弹窗 -->
  <view class="kc-picker-modal" wx:if="{{showKnowledgePicker}}" catchtap="onCloseKnowledgePicker">
    <view class="kc-picker-content" catchtap="">
      <view class="kc-picker-header">
        <text class="kc-picker-title">选择知识卡片</text>
        <view class="kc-picker-close" bindtap="onCloseKnowledgePicker">
          <text class="close-icon">×</text>
        </view>
      </view>
      <text class="kc-picker-subtitle">已选 {{selectedKnowledgeCards.length}}/3 张，卡片将与帖子关联展示</text>

      <scroll-view class="kc-picker-scroll" scroll-y>
        <view
          wx:for="{{availableKnowledgeCards}}"
          wx:key="id"
          class="kc-picker-item {{item.isSelected ? 'selected' : ''}}"
          bindtap="onKnowledgeCardTap"
          data-card="{{item}}"
          style="--kc-color: {{item.color}};"
        >
          <view class="kc-picker-icon" style="background: {{item.color}}15;">
            <text class="kc-emoji">{{item.emoji}}</text>
          </view>
          <view class="kc-picker-info">
            <view class="kc-picker-row">
              <text class="kc-picker-tag" style="background: {{item.color}}15; color: {{item.color}};">
                {{item.type === 'course' ? '课程' : '百科'}}
              </text>
              <text class="kc-picker-name">{{item.title}}</text>
            </view>
            <text class="kc-picker-summary">{{item.summary}}</text>
          </view>
          <view class="kc-picker-check">
            <text wx:if="{{item.isSelected}}">✓</text>
          </view>
        </view>
      </scroll-view>

      <view class="kc-picker-footer">
        <button class="kc-picker-confirm" bindtap="onCloseKnowledgePicker">确定</button>
      </view>
    </view>
  </view>
</view>
