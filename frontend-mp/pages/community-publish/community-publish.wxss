.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding: 24rpx 0 240rpx;
}

/* ==================== 通用区块 ==================== */
.section {
  background: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.06);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-title-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ==================== 发布类型 ==================== */
.type-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.type-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #F9FAFB;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.type-card.active {
  background: color-mix(in srgb, var(--type-color) 8%, transparent);
  border-color: color-mix(in srgb, var(--type-color) 30%, transparent);
}

.type-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: color-mix(in srgb, var(--type-color) 12%, transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.type-emoji {
  font-size: 36rpx;
}

.type-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.type-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.type-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.type-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--type-color);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 话题选择 ==================== */
.topics-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.topic-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 24rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  transition: all 0.2s ease;
}

.topic-item.selected {
  background: rgba(91, 189, 114, 0.15);
}

.topic-item.selected .topic-name {
  color: #5BBD72;
  font-weight: 600;
}

.topic-item.hot .topic-name {
  color: #FF6B6B;
}

.topic-item.selected.hot .topic-name {
  color: #E85D5D;
}

.topic-icon {
  font-size: 24rpx;
}

.topic-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ==================== 内容输入 ==================== */
.content-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
  padding: 0;
}

.textarea-placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ==================== 图片选择 ==================== */
.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-item {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 16rpx;
  overflow: hidden;
}

.uploaded-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.image-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.remove-icon {
  color: #FFFFFF;
  font-size: 28rpx;
  line-height: 1;
}

.image-add {
  width: 100%;
  padding-top: 100%;
  border-radius: 16rpx;
  border: 2rpx dashed #D0D5DD;
  background: #FAFBFC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.2s ease;
}

.image-add:active {
  opacity: 0.7;
}

.add-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -80%);
  font-size: 48rpx;
  color: #8E8E93;
  font-weight: 300;
}

.add-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, 60%);
  font-size: 22rpx;
  color: var(--text-tertiary);
  white-space: nowrap;
}

/* ==================== 积分提示 ==================== */
.points-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 48rpx;
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex: 1;
}

/* ==================== 底部发布栏 ==================== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.community-guidelines {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  justify-content: center;
}

.guidelines-icon {
  font-size: 24rpx;
}

.guidelines-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.publish-btn {
  width: 100%;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.publish-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.bottom-safe {
  height: 40rpx;
}

/* ==================== 知识卡片 ==================== */
.insert-kc-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(91, 189, 114, 0.12);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.insert-kc-btn:active {
  opacity: 0.8;
}

.insert-icon {
  font-size: 24rpx;
}

.insert-text {
  font-size: 24rpx;
  color: #5BBD72;
  font-weight: 500;
}

.selected-kc-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.kc-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid;
  position: relative;
}

.kc-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.kc-emoji {
  font-size: 40rpx;
}

.kc-content {
  flex: 1;
  min-width: 0;
}

.kc-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.kc-type-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.kc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.kc-summary {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.kc-meta {
  display: flex;
  gap: 16rpx;
}

.kc-meta-item {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.kc-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.kc-remove .remove-icon {
  color: #FFFFFF;
  font-size: 28rpx;
  line-height: 1;
}

.kc-empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
}

.kc-empty-hint .hint-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.kc-empty-hint .hint-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.5;
}

/* ==================== 知识卡片选择弹窗 ==================== */
.kc-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.kc-picker-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.kc-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.kc-picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.kc-picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
}

.kc-picker-close .close-icon {
  font-size: 36rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.kc-picker-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 24rpx;
}

.kc-picker-scroll {
  flex: 1;
  max-height: 55vh;
}

.kc-picker-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #F9FAFB;
  border: 2rpx solid transparent;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}

.kc-picker-item.selected {
  background: color-mix(in srgb, var(--kc-color) 8%, transparent);
  border-color: color-mix(in srgb, var(--kc-color) 30%, transparent);
}

.kc-picker-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.kc-picker-info {
  flex: 1;
  min-width: 0;
}

.kc-picker-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.kc-picker-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.kc-picker-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.kc-picker-summary {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.kc-picker-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-left: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
}

.kc-picker-item.selected .kc-picker-check {
  background: var(--kc-color);
}

.kc-picker-footer {
  padding-top: 16rpx;
}

.kc-picker-confirm {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  line-height: 88rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.kc-picker-confirm:active {
  opacity: 0.9;
}
