.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding: 24rpx 0 240rpx;
}

/* ==================== 通用区块 ==================== */
.section {
  background: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.06);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-title-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ==================== 发布类型 ==================== */
.type-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.type-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #F9FAFB;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.type-card.active {
  background: color-mix(in srgb, var(--type-color) 8%, transparent);
  border-color: color-mix(in srgb, var(--type-color) 30%, transparent);
}

.type-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: color-mix(in srgb, var(--type-color) 12%, transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.type-emoji {
  font-size: 36rpx;
}

.type-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.type-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.type-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.type-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--type-color);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 话题选择 ==================== */
.topics-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.topic-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 24rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  transition: all 0.2s ease;
}

.topic-item.selected {
  background: rgba(91, 189, 114, 0.15);
}

.topic-item.selected .topic-name {
  color: #5BBD72;
  font-weight: 600;
}

.topic-item.hot .topic-name {
  color: #FF6B6B;
}

.topic-item.selected.hot .topic-name {
  color: #E85D5D;
}

.topic-icon {
  font-size: 24rpx;
}

.topic-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ==================== 内容输入 ==================== */
.content-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
  padding: 0;
}

.textarea-placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ==================== 图片选择 ==================== */
.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-item {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 16rpx;
  overflow: hidden;
}

.uploaded-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.image-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.remove-icon {
  color: #FFFFFF;
  font-size: 28rpx;
  line-height: 1;
}

.image-add {
  width: 100%;
  padding-top: 100%;
  border-radius: 16rpx;
  border: 2rpx dashed #D0D5DD;
  background: #FAFBFC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.2s ease;
}

.image-add:active {
  opacity: 0.7;
}

.add-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -80%);
  font-size: 48rpx;
  color: #8E8E93;
  font-weight: 300;
}

.add-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, 60%);
  font-size: 22rpx;
  color: var(--text-tertiary);
  white-space: nowrap;
}

/* ==================== 积分提示 ==================== */
.points-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 48rpx;
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex: 1;
}

/* ==================== 底部发布栏 ==================== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.community-guidelines {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  justify-content: center;
}

.guidelines-icon {
  font-size: 24rpx;
}

.guidelines-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.publish-btn {
  width: 100%;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.publish-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.bottom-safe {
  height: 40rpx;
}
