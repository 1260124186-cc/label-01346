.page-container {
  min-height: 100vh;
  background: #F7FAF8;
}

.header-section {
  position: relative;
  padding: 40rpx 32rpx 60rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(135deg, #9B59B6 0%, #5BBD72 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.group-info {
  flex: 1;
}

.group-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.group-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.create-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.create-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  margin-right: 8rpx;
}

.create-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.status-filter-section {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 10;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.filter-item {
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  margin-right: 8rpx;
  transition: all 0.3s;
}

.filter-item:last-child {
  margin-right: 0;
}

.filter-item.active {
  background: #5BBD72;
}

.filter-name {
  font-size: 28rpx;
  color: #636E72;
  white-space: nowrap;
}

.filter-item.active .filter-name {
  color: #FFFFFF;
  font-weight: 500;
}

.template-btn {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  margin-left: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.template-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.template-text {
  font-size: 26rpx;
  color: #636E72;
}

.empty-group,
.empty-homework {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #B2BEC3;
  text-align: center;
}

.homework-list {
  padding: 24rpx 32rpx;
}

.homework-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.homework-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 40rpx;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-desc {
  font-size: 24rpx;
  color: #B2BEC3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.task-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.task-item {
  display: flex;
  align-items: center;
  background: #F7FAF8;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.task-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.task-name {
  font-size: 22rpx;
  color: #636E72;
}

.progress-section {
  margin-bottom: 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.my-progress,
.group-progress {
  display: flex;
  align-items: center;
}

.progress-label {
  font-size: 24rpx;
  color: #B2BEC3;
  margin-right: 12rpx;
}

.progress-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #5BBD72;
}

.group-progress .progress-label {
  color: #636E72;
  font-weight: 500;
}

.progress-bar-wrapper {
  height: 12rpx;
  background: #F0F4F2;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F4F2;
}

.deadline-info {
  display: flex;
  align-items: center;
}

.deadline-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.deadline-text {
  font-size: 24rpx;
  color: #F39C12;
  font-weight: 500;
}

.arrow {
  font-size: 32rpx;
  color: #B2BEC3;
}

.templates-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F4F2;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F7FAF8;
  border-radius: 50%;
  font-size: 28rpx;
  color: #636E72;
}

.modal-body {
  padding: 24rpx 32rpx 48rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.template-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.template-card {
  display: flex;
  align-items: center;
  background: #F7FAF8;
  border-radius: 20rpx;
  padding: 24rpx;
  transition: all 0.3s;
}

.template-card:active {
  background: #F0F4F2;
}

.template-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-size: 40rpx;
}

.template-info {
  flex: 1;
  min-width: 0;
}

.template-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.template-desc {
  font-size: 24rpx;
  color: #B2BEC3;
  margin-bottom: 12rpx;
}

.template-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 20rpx;
  color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.template-use {
  font-size: 26rpx;
  color: #5BBD72;
  font-weight: 500;
  padding: 12rpx 24rpx;
  background: rgba(91, 189, 114, 0.1);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
