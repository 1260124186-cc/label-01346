<view class="page-container">
  <view class="header-section">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="group-info">
        <view class="group-name">{{currentGroup ? currentGroup.name : '请先选择组'}}</view>
        <view class="group-desc">组作业管理中心</view>
      </view>
      <view class="create-btn" wx:if="{{isCurrentUserAdmin}}" bindtap="onCreateHomework">
        <text class="create-icon">+</text>
        <text class="create-text">创建作业</text>
      </view>
    </view>
  </view>

  <view class="status-filter-section">
    <scroll-view class="filter-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="filter-list">
        <view
          wx:for="{{statusOptions}}"
          wx:key="id"
          class="filter-item {{statusFilter === item.id ? 'active' : ''}}"
          bindtap="onFilterStatus"
          data-status="{{item.id}}"
        >
          <text class="filter-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
    <view class="template-btn" bindtap="onShowTemplates">
      <text class="template-icon">📑</text>
      <text class="template-text">模板库</text>
    </view>
  </view>

  <view wx:if="{{!currentGroup}}" class="empty-group">
    <view class="empty-icon">👥</view>
    <view class="empty-title">请先加入或创建一个组</view>
    <view class="empty-desc">组作业功能需要在组内使用</view>
  </view>

  <block wx:else>
    <view wx:if="{{filteredHomeworkList.length === 0}}" class="empty-homework">
      <view class="empty-icon">📋</view>
      <view class="empty-title">暂无组作业</view>
      <view class="empty-desc" wx:if="{{isCurrentUserAdmin}}">点击右上角创建新的组作业</view>
      <view class="empty-desc" wx:else>等待老师/家长发布组作业</view>
    </view>

    <view wx:else class="homework-list">
      <view
        wx:for="{{filteredHomeworkList}}"
        wx:key="id"
        class="homework-card"
        bindtap="onHomeworkTap"
        data-id="{{item.id}}"
      >
        <view class="card-header">
          <view class="card-icon" style="background: {{item.color}}20;">
            <text class="icon-text">{{item.icon}}</text>
          </view>
          <view class="card-info">
            <view class="card-title">{{item.title}}</view>
            <view class="card-desc">{{item.description}}</view>
          </view>
          <view class="status-badge" style="background: {{item.statusInfo.bgColor}}; color: {{item.statusInfo.color}};">
            {{item.statusInfo.name}}
          </view>
        </view>

        <view class="task-summary">
          <view
            wx:for="{{item.taskSummary}}"
            wx:for-item="task"
            wx:key="name"
            class="task-item"
          >
            <text class="task-icon">{{task.icon}}</text>
            <text class="task-name">{{task.name}}</text>
          </view>
        </view>

        <view class="progress-section">
          <view class="progress-header">
            <view class="my-progress">
              <text class="progress-label">我的进度</text>
              <text class="progress-value">{{item.myProgress.completionRate}}%</text>
            </view>
            <view class="group-progress">
              <text class="progress-label">{{item.completionText}}</text>
            </view>
          </view>
          <view class="progress-bar-wrapper">
            <view
              class="progress-bar-fill"
              style="width: {{item.myProgress.completionRate}}%; background: {{item.color}};"
            ></view>
          </view>
        </view>

        <view class="card-footer">
          <view class="deadline-info">
            <text class="deadline-icon">⏰</text>
            <text class="deadline-text">{{item.daysLeftText}}</text>
          </view>
          <view class="arrow">
            <text>›</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view class="safe-area-bottom"></view>

  <view wx:if="{{showTemplates}}" class="templates-modal" catchtap="stopPropagation">
    <view class="modal-mask" bindtap="onHideTemplates"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">作业模板库</text>
        <view class="modal-close" bindtap="onHideTemplates">
          <text>✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="template-list">
          <view
            class="template-card"
            bindtap="onUseTemplate"
            data-template-id="tpl_first_week"
          >
            <view class="template-icon" style="background: rgba(155, 89, 182, 0.1);">
              <text>🎒</text>
            </view>
            <view class="template-info">
              <view class="template-name">开学第一周</view>
              <view class="template-desc">新学期快速进入学习状态</view>
              <view class="template-tags">
                <text class="tag">2章节</text>
                <text class="tag">20题</text>
                <text class="tag">5天签到</text>
              </view>
            </view>
            <view class="template-use">使用</view>
          </view>

          <view
            class="template-card"
            bindtap="onUseTemplate"
            data-template-id="tpl_vacation"
          >
            <view class="template-icon" style="background: rgba(52, 152, 219, 0.1);">
              <text>🏖️</text>
            </view>
            <view class="template-info">
              <view class="template-name">假期专项</view>
              <view class="template-desc">寒暑假学习计划</view>
              <view class="template-tags">
                <text class="tag">4章节</text>
                <text class="tag">50题</text>
                <text class="tag">20天签到</text>
              </view>
            </view>
            <view class="template-use">使用</view>
          </view>

          <view
            class="template-card"
            bindtap="onUseTemplate"
            data-template-id="tpl_harmful"
          >
            <view class="template-icon" style="background: rgba(232, 93, 93, 0.1);">
              <text>☣️</text>
            </view>
            <view class="template-info">
              <view class="template-name">有害垃圾专题</view>
              <view class="template-desc">深入学习有害垃圾分类</view>
              <view class="template-tags">
                <text class="tag">1章节</text>
                <text class="tag">20题</text>
                <text class="tag">5天签到</text>
              </view>
            </view>
            <view class="template-use">使用</view>
          </view>

          <view
            class="template-card"
            bindtap="onUseTemplate"
            data-template-id="tpl_weekend"
          >
            <view class="template-icon" style="background: rgba(243, 156, 18, 0.1);">
              <text>📝</text>
            </view>
            <view class="template-info">
              <view class="template-name">周末巩固</view>
              <view class="template-desc">周末复习巩固本周内容</view>
              <view class="template-tags">
                <text class="tag">15题</text>
                <text class="tag">2天签到</text>
              </view>
            </view>
            <view class="template-use">使用</view>
          </view>

          <view
            class="template-card"
            bindtap="onUseTemplate"
            data-template-id="tpl_exam_prep"
          >
            <view class="template-icon" style="background: rgba(39, 174, 96, 0.1);">
              <text>🎯</text>
            </view>
            <view class="template-info">
              <view class="template-name">考前冲刺</view>
              <view class="template-desc">知识竞赛考前强化训练</view>
              <view class="template-tags">
                <text class="tag">1章节</text>
                <text class="tag">50题</text>
                <text class="tag">7天签到</text>
              </view>
            </view>
            <view class="template-use">使用</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
