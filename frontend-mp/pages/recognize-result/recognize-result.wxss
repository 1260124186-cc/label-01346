/**
 * 识别结果页面样式
 */

.page-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}

/* ========== 识别失败样式 ========== */
.fail-container {
  padding: 80rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.fail-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(245, 63, 63, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.fail-icon {
  font-size: 80rpx;
}

.fail-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 16rpx;
}

.fail-desc {
  font-size: 28rpx;
  color: #86909C;
  text-align: center;
  margin-bottom: 48rpx;
}

.fail-actions {
  display: flex;
  gap: 32rpx;
  margin-bottom: 60rpx;
}

.fail-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.15s ease;
}

.fail-action-btn:active {
  transform: scale(0.95);
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #4E5969;
  font-weight: 500;
}

.feedback-section {
  width: 100%;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 32rpx;
}

.feedback-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 24rpx;
}

.feedback-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.feedback-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #F7F8FA;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.feedback-item.active {
  background: rgba(91, 189, 114, 0.1);
  border-color: #5BBD72;
}

.feedback-emoji {
  font-size: 28rpx;
}

.feedback-name {
  font-size: 26rpx;
  color: #4E5969;
}

.feedback-item.active .feedback-name {
  color: #5BBD72;
  font-weight: 500;
}

.feedback-input-wrapper {
  margin-bottom: 20rpx;
}

.feedback-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1D2129;
  box-sizing: border-box;
}

.feedback-submit {
  width: 100%;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease;
}

.submit-btn:active {
  transform: scale(0.98);
}

.submit-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.fail-preview {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  opacity: 0.5;
}

/* ========== 识别成功样式 ========== */
.result-container {
  padding: 0 0 40rpx;
}

.image-section {
  width: 100%;
  height: 400rpx;
  background: #000;
}

.result-image {
  width: 100%;
  height: 100%;
}

.confidence-section {
  padding: 24rpx 32rpx 0;
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.confidence-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.confidence-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.confidence-label {
  font-size: 28rpx;
  color: #86909C;
  font-weight: 500;
}

.confidence-value {
  font-size: 48rpx;
  font-weight: 700;
}

.confidence-value.high {
  color: #00B42A;
}

.confidence-value.medium {
  color: #F39C12;
}

.confidence-value.low {
  color: #F53F3F;
}

.confidence-bar {
  width: 100%;
  height: 12rpx;
  background: #F0F2F5;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.confidence-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.confidence-fill.high {
  background: linear-gradient(90deg, #5BBD72 0%, #00B42A 100%);
}

.confidence-fill.medium {
  background: linear-gradient(90deg, #F39C12 0%, #E67E22 100%);
}

.confidence-fill.low {
  background: linear-gradient(90deg, #F53F3F 0%, #C0392B 100%);
}

.confidence-desc {
  font-size: 24rpx;
  color: #86909C;
}

.result-section {
  padding: 24rpx 32rpx;
}

.result-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border-left: 8rpx solid var(--type-color);
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: var(--type-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.result-emoji {
  font-size: 52rpx;
  line-height: 1;
}

.result-info {
  flex: 1;
  min-width: 0;
}

.result-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 8rpx;
  display: block;
}

.result-type {
  display: flex;
}

.type-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.type-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #ffffff;
}

.result-description {
  font-size: 26rpx;
  color: #4E5969;
  line-height: 1.6;
}

/* 通用区域标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
}

.section-title-icon {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #4AA862 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
}

.tips-section {
  margin-top: 8rpx;
}

.tips-card {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-bullet {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #F39C12;
  margin-right: 16rpx;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #4E5969;
  line-height: 1.6;
}

.wiki-section {
  margin-top: 32rpx;
}

.wiki-card {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  transition: transform 0.15s ease;
}

.wiki-card:active {
  transform: scale(0.98);
}

.wiki-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(155, 89, 182, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.wiki-icon {
  font-size: 36rpx;
}

.wiki-info {
  flex: 1;
  min-width: 0;
}

.wiki-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D2129;
  margin-bottom: 6rpx;
  display: block;
}

.wiki-desc {
  font-size: 24rpx;
  color: #86909C;
}

.wiki-arrow {
  font-size: 40rpx;
  color: #86909C;
  font-weight: 300;
  margin-left: 16rpx;
}

.related-section {
  margin-top: 32rpx;
}

.related-list {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.related-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F0F2F5;
  transition: background 0.15s ease;
}

.related-item:last-child {
  border-bottom: none;
}

.related-item:active {
  background: #F7F8FA;
}

.related-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.related-info {
  flex: 1;
  min-width: 0;
}

.related-name {
  font-size: 28rpx;
  color: #1D2129;
  margin-bottom: 4rpx;
  display: block;
}

.related-type {
  font-size: 22rpx;
  color: #86909C;
}

.related-arrow {
  font-size: 36rpx;
  color: #86909C;
  font-weight: 300;
  margin-left: 16rpx;
}

/* 确认区域 */
.confirm-section {
  padding: 48rpx 32rpx 24rpx;
}

.confirm-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D2129;
  text-align: center;
  margin-bottom: 24rpx;
}

.confirm-buttons {
  display: flex;
  gap: 24rpx;
}

.confirm-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: transform 0.15s ease;
}

.confirm-btn:active {
  transform: scale(0.98);
}

.correct-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.wrong-btn {
  background: rgba(245, 63, 63, 0.1);
  border: 2rpx solid rgba(245, 63, 63, 0.3);
}

.btn-icon {
  font-size: 32rpx;
}

.correct-btn .btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.wrong-btn .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #F53F3F;
}

/* 已确认状态 */
.confirmed-section {
  padding: 48rpx 32rpx 24rpx;
}

.confirmed-card {
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.1) 0%, rgba(76, 175, 80, 0.1) 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.confirmed-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.confirmed-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 12rpx;
}

.confirmed-points {
  font-size: 48rpx;
  font-weight: 700;
  color: #00B42A;
  margin-bottom: 8rpx;
}

.confirmed-desc {
  font-size: 26rpx;
  color: #86909C;
}

.confirmed-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn-secondary {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #E5E6EB;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease;
}

.action-btn-secondary:active {
  transform: scale(0.98);
}

.action-btn-secondary .action-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #4E5969;
}

.action-btn-primary {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease;
}

.action-btn-primary:active {
  transform: scale(0.98);
}

.action-btn-primary .action-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 反馈弹窗 */
.feedback-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.feedback-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.feedback-content {
  position: relative;
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.feedback-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
}

.feedback-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F7F8FA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #86909C;
}

.feedback-submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease;
}

.feedback-submit-btn:active {
  transform: scale(0.98);
}
