<!--
  识别结果页面
  功能：展示识别结果、置信度、投放提示、百科链接、确认操作、失败反馈
-->
<view class="page-container">
  <!-- 识别失败状态 -->
  <view wx:if="{{!recognizeSuccess}}" class="fail-container">
    <view class="fail-icon-wrapper">
      <text class="fail-icon">❌</text>
    </view>
    <view class="fail-title">识别失败</view>
    <view class="fail-desc">{{errorMessage || '无法识别该图片，请尝试其他方式'}}</view>
    
    <view class="fail-actions">
      <view class="fail-action-btn" bindtap="goToSearch">
        <text class="action-icon">🔍</text>
        <text class="action-text">手动搜索</text>
      </view>
      <view class="fail-action-btn" bindtap="retakePhoto">
        <text class="action-icon">📷</text>
        <text class="action-text">重新拍摄</text>
      </view>
    </view>

    <view class="feedback-section">
      <view class="feedback-title">遇到问题？</view>
      <view class="feedback-options">
        <view 
          wx:for="{{feedbackTypes}}" 
          wx:key="id"
          class="feedback-item {{selectedFeedback === item.id ? 'active' : ''}}"
          bindtap="selectFeedback"
          data-id="{{item.id}}"
        >
          <text class="feedback-emoji">{{item.emoji}}</text>
          <text class="feedback-name">{{item.name}}</text>
        </view>
      </view>
      <view wx:if="{{selectedFeedback}}" class="feedback-submit">
        <view class="feedback-input-wrapper">
          <input 
            class="feedback-input" 
            placeholder="请输入您的反馈意见（选填）" 
            value="{{feedbackContent}}"
            bindinput="onFeedbackInput"
            maxlength="200"
          />
        </view>
        <view class="submit-btn" bindtap="submitFeedback">
          <text class="submit-btn-text">提交反馈</text>
        </view>
      </view>
    </view>

    <image wx:if="{{capturedImage}}" class="fail-preview" src="{{capturedImage}}" mode="aspectFill" />
  </view>

  <!-- 识别成功状态 -->
  <view wx:if="{{recognizeSuccess && resultData}}" class="result-container">
    <!-- 图片预览 -->
    <view class="image-section">
      <image class="result-image" src="{{resultData.imagePath}}" mode="aspectFill" />
    </view>

    <!-- 置信度显示 -->
    <view class="confidence-section">
      <view class="confidence-card">
        <view class="confidence-header">
          <text class="confidence-label">识别置信度</text>
          <text class="confidence-value {{confidenceLevel}}">{{confidencePercent}}%</text>
        </view>
        <view class="confidence-bar">
          <view class="confidence-fill {{confidenceLevel}}" style="width: {{confidencePercent}}%"></view>
        </view>
        <view class="confidence-desc">{{confidenceText}}</view>
      </view>
    </view>

    <!-- 识别结果 -->
    <view class="result-section">
      <view class="result-card" style="--type-color: {{resultData.typeColor || '#5BBD72'}}; --type-bg: {{resultData.typeBgColor || 'rgba(91, 189, 114, 0.1)'}};">
        <view class="result-header">
          <view class="result-icon-wrapper">
            <text class="result-emoji">{{resultData.emoji}}</text>
          </view>
          <view class="result-info">
            <text class="result-name">{{resultData.name}}</text>
            <view class="result-type">
              <view class="type-badge" style="background: {{resultData.typeColor || '#5BBD72'}};">
                <text class="type-text">{{resultData.typeName}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="result-description">{{resultData.description}}</view>
      </view>
    </view>

    <!-- 投放提示 -->
    <view class="tips-section">
      <view class="section-header">
        <view class="section-title-wrapper">
          <view class="section-title-icon" style="background: linear-gradient(180deg, #F39C12 0%, #E67E22 100%);"></view>
          <text class="section-title">投放提示</text>
        </view>
      </view>
      <view class="tips-card">
        <view 
          wx:for="{{resultData.disposalTips}}" 
          wx:key="index"
          class="tip-item"
        >
          <view class="tip-bullet"></view>
          <text class="tip-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 相关百科链接 -->
    <view class="wiki-section" wx:if="{{resultData.wikiUrl}}">
      <view class="section-header">
        <view class="section-title-wrapper">
          <view class="section-title-icon" style="background: linear-gradient(180deg, #9B59B6 0%, #8E44AD 100%);"></view>
          <text class="section-title">相关百科</text>
        </view>
      </view>
      <view class="wiki-card" bindtap="openWiki">
        <view class="wiki-icon-wrapper">
          <text class="wiki-icon">📚</text>
        </view>
        <view class="wiki-info">
          <text class="wiki-title">{{resultData.name}} - 百度百科</text>
          <text class="wiki-desc">点击查看详细介绍</text>
        </view>
        <text class="wiki-arrow">›</text>
      </view>
    </view>

    <!-- 相关推荐 -->
    <view class="related-section" wx:if="{{relatedItems && relatedItems.length > 0}}">
      <view class="section-header">
        <view class="section-title-wrapper">
          <view class="section-title-icon" style="background: linear-gradient(180deg, #3498DB 0%, #2980B9 100%);"></view>
          <text class="section-title">相关推荐</text>
        </view>
      </view>
      <view class="related-list">
        <view 
          wx:for="{{relatedItems}}" 
          wx:key="id"
          class="related-item"
          bindtap="onRelatedItemTap"
          data-item="{{item}}"
        >
          <text class="related-emoji">{{item.emoji}}</text>
          <view class="related-info">
            <text class="related-name">{{item.name}}</text>
            <text class="related-type">{{item.typeName}}</text>
          </view>
          <text class="related-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 确认区域 -->
    <view class="confirm-section" wx:if="{{!confirmed}}">
      <view class="confirm-title">分类是否正确？</view>
      <view class="confirm-buttons">
        <view class="confirm-btn correct-btn" bindtap="confirmCorrect">
          <text class="btn-icon">✅</text>
          <text class="btn-text">分类正确 +10积分</text>
        </view>
        <view class="confirm-btn wrong-btn" bindtap="showFeedbackOptions">
          <text class="btn-icon">❌</text>
          <text class="btn-text">识别有误</text>
        </view>
      </view>
    </view>

    <!-- 已确认状态 -->
    <view class="confirmed-section" wx:if="{{confirmed}}">
      <view class="confirmed-card">
        <view class="confirmed-icon">🎉</view>
        <view class="confirmed-title">分类成功！</view>
        <view class="confirmed-points">+10 积分</view>
        <view class="confirmed-desc">已记录到您的分类历史</view>
      </view>
      <view class="confirmed-actions">
        <view class="action-btn-secondary" bindtap="goToRecords">
          <text class="action-btn-text">查看记录</text>
        </view>
        <view class="action-btn-primary" bindtap="continueRecognize">
          <text class="action-btn-text">继续识别</text>
        </view>
      </view>
    </view>

    <!-- 反馈选项（显示时） -->
    <view class="feedback-modal" wx:if="{{showFeedback}}">
      <view class="feedback-mask" bindtap="hideFeedback"></view>
      <view class="feedback-content">
        <view class="feedback-header">
          <text class="feedback-modal-title">反馈问题</text>
          <view class="feedback-close" bindtap="hideFeedback">✕</view>
        </view>
        <view class="feedback-options">
          <view 
            wx:for="{{feedbackTypes}}" 
            wx:key="id"
            class="feedback-item {{selectedFeedback === item.id ? 'active' : ''}}"
            bindtap="selectFeedback"
            data-id="{{item.id}}"
          >
            <text class="feedback-emoji">{{item.emoji}}</text>
            <text class="feedback-name">{{item.name}}</text>
          </view>
        </view>
        <view class="feedback-input-wrapper" wx:if="{{selectedFeedback}}">
          <input 
            class="feedback-input" 
            placeholder="请输入您的反馈意见（选填）" 
            value="{{feedbackContent}}"
            bindinput="onFeedbackInput"
            maxlength="200"
          />
        </view>
        <view class="feedback-submit-btn" wx:if="{{selectedFeedback}}" bindtap="submitFeedback">
          <text class="submit-btn-text">提交反馈</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-bottom"></view>
</view>
