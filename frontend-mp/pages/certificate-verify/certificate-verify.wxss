.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 40rpx;
}

.header-section {
  position: relative;
  padding: 60rpx 40rpx 80rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #5BBD72 0%, #3A9D5A 100%);
  opacity: 0.95;
}

.header-bg::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -80rpx;
  width: 300rpx;
  height: 300rpx;
  background: #FFFFFF;
  opacity: 0.08;
  border-radius: 50%;
}

.header-bg::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: #FFFFFF;
  opacity: 0.06;
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
}

.search-section {
  padding: 0 30rpx;
  margin-top: -50rpx;
}

.search-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.search-row {
  margin-bottom: 28rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #F5F7F6;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 96rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.search-input-wrapper:focus-within {
  background: #FFFFFF;
  border-color: #5BBD72;
}

.search-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #2D3436;
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #E8E8E8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.clear-icon {
  font-size: 22rpx;
  color: #999999;
  line-height: 1;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
  padding: 0;
  margin: 0;
  transition: all 0.2s;
}

.action-btn::after {
  border: none;
}

.action-btn.scan {
  background: #F5F7F6;
  color: #5BBD72;
  border: 2rpx solid #5BBD72;
}

.action-btn.scan:active {
  background: #E8F5EC;
}

.action-btn.verify {
  color: #FFFFFF;
}

.action-btn.verify.active {
  background: linear-gradient(135deg, #5BBD72 0%, #3A9D5A 100%);
  box-shadow: 0 6rpx 20rpx rgba(91, 189, 114, 0.35);
}

.action-btn.verify.active:active {
  transform: scale(0.98);
}

.action-btn.verify.disabled {
  background: #E0E0E0;
  color: #B2BEC3;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

.tip-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #F0F0F0;
}

.tip-icon {
  font-size: 24rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

.result-section {
  padding: 40rpx 30rpx 0;
}

.result-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border-top: 8rpx solid #999;
}

.result-card.success {
  border-top-color: #5BBD72;
}

.result-card.revoked {
  border-top-color: #E85D5D;
}

.result-card.expired {
  border-top-color: #F39C12;
}

.result-card.error {
  border-top-color: #8E8E93;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.result-status-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.result-card.success .result-status-icon {
  background: rgba(91, 189, 114, 0.12);
}

.result-card.revoked .result-status-icon {
  background: rgba(232, 93, 93, 0.12);
}

.result-card.expired .result-status-icon {
  background: rgba(243, 156, 18, 0.12);
}

.result-status-text {
  flex: 1;
}

.status-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D3436;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.result-card.success .status-title {
  color: #27AE60;
}

.result-card.revoked .status-title {
  color: #C0392B;
}

.result-card.expired .status-title {
  color: #D68910;
}

.status-subtitle {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.5;
}

.result-divider {
  height: 2rpx;
  background: #F0F0F0;
  margin: 32rpx 0;
}

.cert-info-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.cert-info-row {
  display: flex;
  gap: 24rpx;
}

.cert-info-item {
  flex: 1;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.cert-info-item.full {
  flex: 1 1 100%;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 600;
  line-height: 1.4;
  word-break: break-all;
}

.info-value.name {
  color: #5BBD72;
}

.info-value.course {
  font-size: 30rpx;
  color: #2D3436;
}

.info-value.cert-name {
  font-size: 32rpx;
}

.info-value.score {
  color: #F39C12;
}

.info-value.mono {
  font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
  font-size: 24rpx;
  color: #666666;
  letter-spacing: 0.5rpx;
}

.info-value.expired {
  color: #E85D5D;
  text-decoration: line-through;
}

.info-value.revoked {
  color: #E85D5D;
  font-weight: 700;
}

.info-value.issuer {
  font-size: 26rpx;
  color: #666666;
}

.verify-meta {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #E8E8E8;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.meta-icon {
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.meta-text {
  flex: 1;
  font-size: 22rpx;
  color: #AAAAAA;
  line-height: 1.5;
}

.notice-section {
  padding: 40rpx 30rpx 0;
}

.notice-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border-left: 8rpx solid #F39C12;
}

.notice-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.notice-icon {
  font-size: 32rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D3436;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.notice-dot {
  font-size: 24rpx;
  color: #F39C12;
  flex-shrink: 0;
  line-height: 1.5;
}

.notice-text {
  flex: 1;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
