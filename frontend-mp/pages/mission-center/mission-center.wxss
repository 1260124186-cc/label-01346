.mission-page {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 60rpx;
}

.mission-page.child-mode {
  background: linear-gradient(180deg, #FFF8E1 0%, #F7FAF8 30%);
}

.header-section {
  position: relative;
  background: linear-gradient(180deg, #5BBD72 0%, #4CAF50 60%, #F7FAF8 100%);
  padding: 32rpx 32rpx 48rpx;
}

.mission-page.child-mode .header-section {
  background: linear-gradient(180deg, #FF9A8B 0%, #FFCDA2 60%, #FFF8E1 100%);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: radial-gradient(circle at 20% 20%, rgba(255,255,255,0.15) 0%, transparent 50%),
              radial-gradient(circle at 80% 60%, rgba(255,255,255,0.1) 0%, transparent 50%);
  pointer-events: none;
}

.header-content {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.streak-card,
.points-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.streak-emoji,
.points-emoji {
  font-size: 52rpx;
}

.streak-num,
.points-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.streak-label,
.points-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.progress-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
}

.progress-count {
  font-size: 26rpx;
  font-weight: 700;
  color: #5BBD72;
}

.mission-page.child-mode .progress-count {
  color: #FF9A8B;
}

.progress-bar-bg {
  height: 16rpx;
  background: #EDF2F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72 0%, #81C784 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.mission-page.child-mode .progress-bar-fill {
  background: linear-gradient(90deg, #FF9A8B 0%, #FFCDA2 100%);
}

.treasure-section {
  margin-top: 8rpx;
}

.treasure-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.treasure-card.available {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border: 2rpx solid #FFD54F;
  animation: pulse 2s ease-in-out infinite;
}

.treasure-card.claimed {
  opacity: 0.7;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 4rpx 20rpx rgba(255, 213, 79, 0.3); }
  50% { box-shadow: 0 8rpx 36rpx rgba(255, 213, 79, 0.5); }
}

.treasure-icon-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFECB3 0%, #FFD54F 100%);
  border-radius: 24rpx;
}

.treasure-icon {
  font-size: 56rpx;
  position: relative;
  z-index: 2;
}

.treasure-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(255, 235, 59, 0.6) 0%, transparent 70%);
  animation: glow 2s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 1; transform: translate(-50%, -50%) scale(1.2); }
}

.treasure-info {
  flex: 1;
}

.treasure-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.treasure-desc {
  font-size: 24rpx;
  color: #636E72;
}

.treasure-points {
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 24rpx;
}

.treasure-points .points-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #F39C12;
}

.treasure-arrow .check-icon {
  font-size: 40rpx;
  color: #5BBD72;
  font-weight: 700;
}

.tabs-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.tabs-wrapper {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  position: relative;
  padding: 14rpx 28rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
}

.mission-page.child-mode .tab-item.active {
  background: linear-gradient(135deg, #FF9A8B 0%, #FFCDA2 100%);
}

.tab-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #636E72;
  transition: color 0.3s;
}

.tab-item.active .tab-text {
  color: #fff;
}

.week-range {
  display: block;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
  text-align: center;
}

.claim-all-btn {
  position: relative;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(243, 156, 18, 0.3);
}

.claim-all-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.claim-all-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #E74C3C;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.badge-num {
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
}

.content-section {
  padding: 8rpx 32rpx 0;
}

.mission-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mission-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.mission-card:active {
  transform: scale(0.99);
}

.mission-card.completed {
  border-color: rgba(91, 189, 114, 0.3);
}

.mission-page.child-mode .mission-card.completed {
  border-color: rgba(255, 154, 139, 0.4);
}

.mission-card.claimed {
  opacity: 0.7;
}

.mission-card.child-mission {
  padding: 24rpx 20rpx;
  border-radius: 28rpx;
}

.mission-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.mission-card.child-mission .mission-icon {
  width: 110rpx;
  height: 110rpx;
  border-radius: 28rpx;
}

.icon-emoji {
  font-size: 48rpx;
}

.mission-card.child-mission .icon-emoji {
  font-size: 56rpx;
}

.mission-content {
  flex: 1;
  min-width: 0;
}

.mission-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 6rpx;
  line-height: 1.3;
}

.mission-card.child-mission .mission-name {
  font-size: 32rpx;
  font-weight: 700;
}

.mission-desc {
  font-size: 22rpx;
  color: #636E72;
  margin-bottom: 12rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mission-progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.mission-progress-bg {
  flex: 1;
  height: 12rpx;
  background: #EDF2F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.mission-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72 0%, #81C784 100%);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

.mission-page.child-mode .mission-progress-fill {
  background: linear-gradient(90deg, #FF9A8B 0%, #FFCDA2 100%);
}

.mission-progress-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #636E72;
  flex-shrink: 0;
  min-width: 80rpx;
  text-align: right;
}

.mission-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.mission-points {
  padding: 4rpx 14rpx;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.1) 0%, rgba(91, 189, 114, 0.05) 100%);
  border-radius: 16rpx;
}

.points-val {
  font-size: 24rpx;
  font-weight: 700;
  color: #5BBD72;
}

.action-btn {
  min-width: 110rpx;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
  transition: all 0.3s;
}

.action-btn.go {
  background: #EDF2F0;
}

.action-btn.go .btn-text {
  color: #636E72;
  font-size: 24rpx;
  font-weight: 600;
}

.action-btn.can-claim {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  box-shadow: 0 4rpx 12rpx rgba(91, 189, 114, 0.3);
  animation: btnPulse 2s ease-in-out infinite;
}

.mission-page.child-mode .action-btn.can-claim {
  background: linear-gradient(135deg, #FF9A8B 0%, #FFCDA2 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 139, 0.3);
}

@keyframes btnPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.action-btn.can-claim .btn-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.action-btn.done {
  background: #EDF2F0;
}

.action-btn.done .btn-text {
  color: #B2BEC3;
  font-size: 24rpx;
  font-weight: 500;
}

.achievement-header-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.tip-emoji {
  font-size: 36rpx;
}

.tip-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #F39C12;
}

.achievement-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.achievement-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.achievement-card.unlocked {
  border-color: rgba(91, 189, 114, 0.3);
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.03) 0%, #fff 100%);
}

.achievement-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.achievement-emoji {
  font-size: 52rpx;
}

.achievement-content {
  flex: 1;
  min-width: 0;
}

.achievement-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.achievement-desc {
  font-size: 22rpx;
  color: #636E72;
  margin-bottom: 12rpx;
}

.achievement-progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.achievement-progress-bg {
  flex: 1;
  height: 10rpx;
  background: #EDF2F0;
  border-radius: 5rpx;
  overflow: hidden;
}

.achievement-progress-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.4s ease;
}

.achievement-progress-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #636E72;
  flex-shrink: 0;
  min-width: 80rpx;
  text-align: right;
}

.achievement-reward,
.achievement-time {
  font-size: 22rpx;
  color: #636E72;
  margin-top: 4rpx;
}

.reward-points {
  font-weight: 700;
  color: #5BBD72;
}

.time-val {
  color: #5BBD72;
}

.achievement-status {
  flex-shrink: 0;
}

.status-unlocked,
.status-locked {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.status-unlocked {
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.15) 0%, rgba(91, 189, 114, 0.08) 100%);
  color: #5BBD72;
}

.status-locked {
  background: #EDF2F0;
  color: #B2BEC3;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 60rpx;
}

.modal-content {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  animation: modalIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.9) translateY(20rpx); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.treasure-modal-emoji,
.claim-modal-emoji,
.achievement-modal-emoji {
  font-size: 120rpx;
  margin-bottom: 8rpx;
  display: block;
}

.treasure-modal-emoji {
  animation: bounce 1s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.treasure-modal-streak {
  font-size: 26rpx;
  color: #F39C12;
  font-weight: 600;
  margin-bottom: 28rpx;
}

.claim-mission-name {
  font-size: 28rpx;
  color: #636E72;
  margin-bottom: 28rpx;
  padding: 0 20rpx;
}

.treasure-modal-points,
.claim-modal-points {
  background: #F7FAF8;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
}

.points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.treasure-modal-points .points-label,
.claim-modal-points .points-label {
  font-size: 28rpx;
  color: #636E72;
}

.treasure-modal-points .points-value,
.claim-modal-points .points-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #5BBD72;
}

.modal-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.achievement-modal {
  max-width: 640rpx;
}

.achievement-unlock-list {
  margin: 24rpx 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.unlock-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #F7FAF8;
  border-radius: 20rpx;
  padding: 24rpx;
}

.unlock-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.unlock-emoji {
  font-size: 44rpx;
}

.unlock-info {
  flex: 1;
  text-align: left;
}

.unlock-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 4rpx;
}

.unlock-reward {
  font-size: 24rpx;
  color: #5BBD72;
  font-weight: 600;
}

.achievement-btn {
  background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
  box-shadow: 0 8rpx 24rpx rgba(243, 156, 18, 0.3);
}
