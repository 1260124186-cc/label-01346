.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F7FAF8 15%);
  padding-bottom: 160rpx;
}

.form-wrapper {
  padding: 24rpx;
}

.form-section {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.required {
  color: #E85D5D;
  margin-left: 6rpx;
  font-size: 28rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  width: calc(25% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.category-item.active {
  background: rgba(91, 189, 114, 0.08);
  border-color: #5BBD72;
}

.category-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.category-emoji {
  font-size: 40rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.category-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #5BBD72;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.quantity-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.stepper {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 12rpx;
  overflow: hidden;
}

.stepper-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  transition: all 0.2s ease;
}

.stepper-btn:active {
  background: #F0F0F0;
}

.stepper-btn.disabled {
  opacity: 0.4;
}

.stepper-icon {
  font-size: 36rpx;
  color: #5BBD72;
  font-weight: 500;
}

.stepper-input {
  width: 100rpx;
  height: 72rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  background: transparent;
}

.quantity-unit {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #666666;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.form-row:last-child {
  border-bottom: none;
}

.row-label {
  display: flex;
  align-items: center;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333333;
}

.row-value {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.value-text {
  font-size: 28rpx;
  color: #1A1A1A;
  margin-right: 8rpx;
}

.value-text.placeholder {
  color: #CCCCCC;
}

.value-text.link {
  color: #5BBD72;
}

.arrow {
  font-size: 24rpx;
  color: #CCCCCC;
}

.time-slots {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.time-slot-item {
  flex: 1;
  padding: 20rpx 12rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  text-align: center;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.time-slot-item.active {
  background: rgba(91, 189, 114, 0.1);
  border-color: #5BBD72;
}

.slot-text {
  font-size: 24rpx;
  color: #666666;
}

.time-slot-item.active .slot-text {
  color: #5BBD72;
  font-weight: 500;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.form-item:last-child {
  border-bottom: none;
}

.item-label {
  width: 160rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.item-label .label-text {
  font-size: 28rpx;
  color: #333333;
}

.item-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
}

.input-placeholder {
  color: #CCCCCC;
  font-size: 28rpx;
}

.remark-item {
  flex-direction: column;
  align-items: stretch;
  position: relative;
  padding-bottom: 50rpx;
}

.item-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.remark-count {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  font-size: 22rpx;
  color: #CCCCCC;
}

.points-section {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-top: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.points-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.points-value-wrapper {
  display: flex;
  align-items: baseline;
}

.points-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.points-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 6rpx;
}

.points-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.4);
  transition: all 0.3s ease;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(91, 189, 114, 0.3);
}

.submit-btn.disabled {
  background: #D0D0D0;
  box-shadow: none;
}

.submit-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}
