.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 180rpx;
}

.form-wrapper {
  padding: 20rpx;
}

.form-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
}

.required {
  color: #e74c3c;
  font-size: 28rpx;
  margin-left: 8rpx;
}

.optional {
  font-size: 24rpx;
  color: #95a5a6;
  margin-left: 10rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  width: 200rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.category-item.active {
  background: #e8f5e9;
  border-color: #27ae60;
}

.category-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.category-emoji {
  font-size: 48rpx;
}

.category-name {
  font-size: 26rpx;
  color: #2c3e50;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.category-points {
  font-size: 20rpx;
  color: #27ae60;
  font-weight: 500;
}

.category-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  background: #27ae60;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
}

.large-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: #e67e22;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tag-text {
  font-size: 20rpx;
  color: #fff;
}

.category-tip {
  display: flex;
  align-items: flex-start;
  background: #fff8e1;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #f39c12;
  flex: 1;
  line-height: 1.5;
}

.photo-hint {
  display: flex;
  align-items: center;
  background: #fff3e0;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.hint-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #e67e22;
  flex: 1;
}

.quantity-row {
  display: flex;
  align-items: center;
}

.stepper {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 40rpx;
  overflow: hidden;
}

.stepper-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stepper-btn.disabled {
  opacity: 0.4;
}

.stepper-icon {
  font-size: 36rpx;
  color: #2c3e50;
}

.stepper-input {
  width: 100rpx;
  height: 72rpx;
  text-align: center;
  font-size: 32rpx;
  color: #2c3e50;
  background: #fff;
}

.quantity-unit {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #7f8c8d;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-row:last-child {
  border-bottom: none;
}

.row-label {
  display: flex;
  align-items: center;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 28rpx;
  color: #34495e;
}

.row-value {
  display: flex;
  align-items: center;
}

.value-text {
  font-size: 28rpx;
  color: #2c3e50;
}

.value-text.placeholder {
  color: #bdc3c7;
}

.value-text.link {
  color: #3498db;
}

.arrow {
  color: #bdc3c7;
  font-size: 28rpx;
  margin-left: 10rpx;
}

.period-section,
.time-slots {
  margin-top: 24rpx;
}

.sub-label {
  font-size: 26rpx;
  color: #7f8c8d;
  margin-bottom: 20rpx;
  display: block;
}

.period-list {
  display: flex;
  gap: 20rpx;
}

.period-item {
  flex: 1;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid transparent;
}

.period-item.active {
  background: #e3f2fd;
  border-color: #3498db;
}

.period-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.period-name {
  font-size: 26rpx;
  color: #2c3e50;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.period-range {
  font-size: 20rpx;
  color: #95a5a6;
}

.slot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.time-slot-item {
  flex: 1;
  min-width: 180rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.time-slot-item.active {
  background: #e3f2fd;
  border-color: #3498db;
}

.slot-text {
  font-size: 26rpx;
  color: #2c3e50;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-bottom-left-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  color: #fff;
  font-size: 32rpx;
  line-height: 1;
}

.photo-add {
  width: 180rpx;
  height: 180rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx dashed #bdc3c7;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #bdc3c7;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 22rpx;
  color: #95a5a6;
}

.photo-tips {
  margin-top: 20rpx;
}

.tips-text {
  font-size: 22rpx;
  color: #95a5a6;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.item-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-input {
  font-size: 28rpx;
  color: #2c3e50;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
}

.input-placeholder {
  color: #bdc3c7;
}

.remark-item {
  position: relative;
}

.item-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #2c3e50;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.remark-count {
  position: absolute;
  right: 0;
  bottom: 24rpx;
  font-size: 22rpx;
  color: #bdc3c7;
}

.points-section {
  background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.points-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.points-value-wrapper {
  display: flex;
  align-items: baseline;
}

.points-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.points-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 8rpx;
}

.points-breakdown {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.breakdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.breakdown-left {
  display: flex;
  align-items: center;
}

.breakdown-emoji {
  font-size: 24rpx;
  margin-right: 10rpx;
}

.breakdown-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.breakdown-points {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.points-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  text-align: center;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
  border-radius: 48rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  opacity: 0.6;
}

.submit-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}
