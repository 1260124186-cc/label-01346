.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 180rpx;
}

.urgent-bar {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(230, 126, 34, 0.2);
}

.urgent-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.urgent-icon {
  font-size: 32rpx;
}

.urgent-text {
  font-size: 26rpx;
  color: #E65100;
  font-weight: 500;
}

.urgent-right {
  background: #E65100;
  border-radius: 32rpx;
  padding: 10rpx 24rpx;
}

.call-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.type-hint-card {
  background: #FFFFFF;
  margin: 24rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.hint-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hint-icon .icon-emoji {
  font-size: 36rpx;
}

.hint-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.hint-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D2129;
}

.hint-desc {
  font-size: 24rpx;
  color: #86909C;
}

.form-section {
  background: #FFFFFF;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.item-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 8rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D2129;
}

.required-mark {
  color: #F53F3F;
  font-size: 28rpx;
}

.label-hint {
  font-size: 24rpx;
  color: #86909C;
  margin-left: 8rpx;
}

.item-input-wrapper {
  display: flex;
  align-items: center;
  background: #F7FAF8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.item-input-wrapper:focus-within {
  border-color: #5BBD72;
  background: #FFFFFF;
}

.item-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #1D2129;
}

.input-placeholder {
  color: #C9CDD4;
}

.char-count {
  font-size: 22rpx;
  color: #86909C;
  flex-shrink: 0;
}

.item-textarea-wrapper {
  background: #F7FAF8;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.item-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #1D2129;
  line-height: 1.6;
}

.image-uploader {
  margin-top: 8rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  line-height: 1;
}

.upload-btn {
  width: 180rpx;
  height: 180rpx;
  background: #F7FAF8;
  border: 2rpx dashed #C9CDD4;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-btn:active {
  background: #EEF5F0;
  border-color: #5BBD72;
}

.upload-icon {
  font-size: 48rpx;
  color: #86909C;
  font-weight: 300;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: #86909C;
}

.notice-section {
  padding: 0 24rpx;
}

.notice-card {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 16rpx;
  border-left: 6rpx solid #5BBD72;
}

.notice-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2E7D32;
}

.notice-desc {
  font-size: 24rpx;
  color: #388E3C;
  line-height: 1.8;
  white-space: pre-line;
}

.bottom-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.submit-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.submit-btn:active {
  transform: scale(0.98);
}

.submit-btn.disabled {
  opacity: 0.7;
}

.submit-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.loading-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
