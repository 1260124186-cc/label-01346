/* 记忆配对游戏页面样式 */
.game-match-container {
  width: 100%;
  height: 100vh;
  overflow: hidden;
  position: relative;
}

/* ============ 准备阶段 ============ */
.ready-screen {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.ready-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #A78BFA 0%, #7C3AED 50%, #6D28D9 100%);
}

.ready-content {
  position: relative;
  text-align: center;
  padding: 48rpx 48rpx;
  max-width: 600rpx;
  width: 100%;
}

.ready-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.ready-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.ready-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.level-info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.level-info-item {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
}

.info-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.info-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.card-types-preview {
  margin-bottom: 48rpx;
}

.preview-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.preview-card {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.preview-card.item-card {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9F43 100%);
}

.preview-card.type-card {
  background: linear-gradient(135deg, #6BCB77 0%, #4A9F50 100%);
}

.preview-emoji {
  font-size: 48rpx;
  margin-bottom: 6rpx;
}

.preview-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.preview-arrow {
  font-size: 36rpx;
  color: #FFFFFF;
}

.start-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  color: #7C3AED;
  font-size: 34rpx;
  font-weight: 700;
  padding: 28rpx 100rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s ease;
}

.start-btn:active {
  transform: scale(0.96);
}

/* ============ 游戏中 ============ */
.playing-screen {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FBF8FF 0%, #FFFFFF 40%);
}

/* 顶部状态栏 */
.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
}

.header-left,
.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.header-left {
  justify-content: flex-start;
}

.header-right {
  justify-content: flex-end;
}

.header-center {
  flex: 0 0 auto;
}

.score-box {
  background: linear-gradient(135deg, #A78BFA 0%, #7C3AED 100%);
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.score-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.combo-box {
  background: linear-gradient(135deg, #FF9F43 0%, #FF6B35 100%);
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.combo-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.combo-fire {
  font-size: 22rpx;
}

.level-badge {
  background: rgba(167, 139, 250, 0.1);
  color: #7C3AED;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.time-box {
  background: rgba(255, 107, 107, 0.1);
  padding: 10rpx 16rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.time-box.urgent {
  background: rgba(255, 59, 48, 0.15);
  animation: pulse 0.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.time-emoji {
  font-size: 24rpx;
}

.time-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF3B30;
}

/* 道具栏 */
.powerup-bar {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
}

.powerup-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.powerup-btn.active {
  background: linear-gradient(135deg, #FF9F43 0%, #FF6B35 100%);
}

.powerup-btn:active {
  transform: scale(0.94);
}

.pu-emoji {
  font-size: 28rpx;
  margin-bottom: 2rpx;
}

.pu-label {
  font-size: 20rpx;
  color: #636E72;
}

.powerup-btn.active .pu-label {
  color: #FFFFFF;
}

/* 进度条 */
.progress-section {
  padding: 0 24rpx 16rpx;
}

.matched-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.matched-label {
  font-size: 24rpx;
  color: #86909C;
}

.matched-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #7C3AED;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #A78BFA 0%, #7C3AED 100%);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

/* 卡牌区域 */
.cards-area {
  flex: 1;
  padding: 8rpx 24rpx 32rpx;
  overflow: auto;
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  align-content: start;
}

.card-wrapper {
  aspect-ratio: 3 / 4;
  perspective: 1000rpx;
}

.card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  transition: transform 0.4s ease;
  transform-style: preserve-3d;
}

.card-inner.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* 卡片背面 */
.card-back {
  background: linear-gradient(135deg, #C4B5FD 0%, #8B5CF6 100%);
}

.card-back-emoji {
  font-size: 48rpx;
  opacity: 0.6;
}

/* 卡片正面 */
.card-front {
  transform: rotateY(180deg);
  background: linear-gradient(135deg, var(--card-color, #95A5A6) 0%, var(--card-color, #95A5A6) 100%);
  filter: brightness(1.1);
}

.card-front.matched {
  animation: matchedPulse 0.6s ease-out;
  filter: brightness(1.2);
}

.card-front.hinted {
  animation: hintGlow 0.6s ease-in-out infinite;
}

@keyframes matchedPulse {
  0% { transform: rotateY(180deg) scale(1); }
  50% { transform: rotateY(180deg) scale(1.1); }
  100% { transform: rotateY(180deg) scale(1); }
}

@keyframes hintGlow {
  0%, 100% { box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1), 0 0 0 0 rgba(243, 156, 18, 0.5); }
  50% { box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1), 0 0 0 10rpx rgba(243, 156, 18, 0); }
}

.card-type-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #FFFFFF;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.card-emoji {
  font-size: 44rpx;
  margin-bottom: 6rpx;
  line-height: 1;
}

.card-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
  text-align: center;
  line-height: 1.2;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 反馈动画 */
.feedback-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 50;
}

.feedback-popup {
  font-size: 56rpx;
  font-weight: 700;
  animation: feedbackPop 0.5s ease-out forwards;
}

.feedback-popup.correct {
  color: #5BBD72;
  text-shadow: 0 4rpx 12rpx rgba(91, 189, 114, 0.4);
}

.feedback-popup.wrong {
  color: #FF3B30;
  text-shadow: 0 4rpx 12rpx rgba(255, 59, 48, 0.4);
}

@keyframes feedbackPop {
  0% {
    opacity: 0;
    transform: scale(0.5);
  }
  50% {
    opacity: 1;
    transform: scale(1.3);
  }
  100% {
    opacity: 0;
    transform: scale(1);
  }
}

/* ============ 暂停遮罩 ============ */
.pause-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.pause-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  text-align: center;
  min-width: 480rpx;
}

.pause-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.pause-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 32rpx;
}

.pause-actions {
  display: flex;
  gap: 20rpx;
}

.pause-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}

.pause-btn.secondary {
  background: #F0F2F5;
  color: #636E72;
}

.pause-btn.primary {
  background: linear-gradient(135deg, #A78BFA 0%, #7C3AED 100%);
  color: #FFFFFF;
}

.pause-btn:active {
  transform: scale(0.96);
}

/* ============ 结果页 ============ */
.result-screen {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.result-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #A78BFA 0%, #7C3AED 100%);
}

.result-content {
  position: relative;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  max-width: 640rpx;
  width: 85%;
  text-align: center;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.2);
}

.result-emoji {
  font-size: 100rpx;
  margin-bottom: 12rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 32rpx;
}

.result-stats {
  background: #FAF5FF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.result-stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.result-stat-row:last-child {
  border-bottom: none;
}

.stat-label {
  font-size: 28rpx;
  color: #636E72;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.points-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #EDE9FE 0%, #DDD6FE 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.points-icon {
  font-size: 48rpx;
}

.points-info {
  flex: 1;
  text-align: left;
}

.points-title {
  font-size: 24rpx;
  color: #7C3AED;
  margin-bottom: 4rpx;
}

.points-total {
  font-size: 44rpx;
  font-weight: 700;
  color: #6D28D9;
  margin-bottom: 4rpx;
}

.points-detail {
  font-size: 22rpx;
  color: #7C3AED;
}

.result-actions {
  display: flex;
  gap: 16rpx;
}

.result-btn {
  flex: 1;
  padding: 24rpx 16rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}

.result-btn.secondary {
  background: #F0F2F5;
  color: #636E72;
}

.result-btn.primary {
  background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
  color: #FFFFFF;
}

.result-btn:active {
  transform: scale(0.96);
}
