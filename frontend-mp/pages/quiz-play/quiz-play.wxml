<view class="quiz-play-container" wx:if="{{!showResult}}">
  <view class="progress-section">
    <view class="progress-header">
      <text class="progress-text">第 {{currentIndex + 1}} / {{questions.length}} 题</text>
      <view class="score-info">
        <text class="correct-count">✓ {{correctCount}}</text>
        <text class="wrong-count">✗ {{wrongCount}}</text>
      </view>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
  </view>

  <view class="question-section">
    <view class="question-card">
      <view class="question-difficulty" wx:if="{{currentQuestion.difficulty}}">
        <text class="diff-tag diff-{{currentQuestion.difficulty}}">
          {{currentQuestion.difficulty === 'easy' ? '简单' : currentQuestion.difficulty === 'medium' ? '中等' : '困难'}}
        </text>
      </view>
      <view class="question-text">{{currentQuestion.question}}</view>
    </view>
  </view>

  <view class="options-section">
    <view class="options-list">
      <view
        class="option-item {{selectedIndex === index ? 'selected' : ''}} {{isAnswered && index === currentQuestion.correctIndex ? 'correct' : ''}} {{isAnswered && selectedIndex === index && !isCorrect ? 'wrong' : ''}}"
        wx:for="{{currentQuestion.optionsWithLabel}}"
        wx:key="index"
        data-index="{{index}}"
        bindtap="onSelectOption"
      >
        <view class="option-label">{{item.label}}</view>
        <view class="option-text">{{item.text}}</view>
        <view class="option-icon" wx:if="{{isAnswered}}">
          <text wx:if="{{index === currentQuestion.correctIndex}}" class="icon-correct">✓</text>
          <text wx:elif="{{selectedIndex === index && !isCorrect}}" class="icon-wrong">✗</text>
        </view>
      </view>
    </view>
  </view>

  <view class="explanation-section" wx:if="{{isAnswered}}">
    <view class="explanation-card">
      <view class="explanation-title">
        <text class="title-icon">💡</text>
        <text>答案解析</text>
      </view>
      <view class="explanation-text">{{currentQuestion.explanation}}</view>
    </view>
  </view>

  <view class="footer-section" wx:if="{{isAnswered}}">
    <view class="next-btn" bindtap="onNextQuestion">
      {{currentIndex + 1 >= questions.length ? '查看结果' : '下一题'}}
    </view>
  </view>
</view>

<view class="result-container" wx:if="{{showResult}}">
  <view class="result-header">
    <view class="result-emoji">{{resultData.emoji}}</view>
    <view class="result-title">{{resultData.title}}</view>
    <view class="result-subtitle">答题完成，获得 {{resultData.points}} 积分</view>
  </view>

  <view class="result-stats">
    <view class="stat-item">
      <view class="stat-value">{{resultData.total}}</view>
      <view class="stat-label">总题数</view>
    </view>
    <view class="stat-item correct">
      <view class="stat-value">{{resultData.correct}}</view>
      <view class="stat-label">答对</view>
    </view>
    <view class="stat-item wrong">
      <view class="stat-value">{{resultData.wrong}}</view>
      <view class="stat-label">答错</view>
    </view>
    <view class="stat-item accuracy">
      <view class="stat-value">{{resultData.accuracy}}%</view>
      <view class="stat-label">正确率</view>
    </view>
  </view>

  <view class="result-points-card">
    <view class="points-icon">🎁</view>
    <view class="points-info">
      <view class="points-title">获得积分</view>
      <view class="points-value">+{{resultData.points}}</view>
      <view class="points-breakdown">
        <text class="breakdown-item">答题: +{{resultData.basePoints}}</text>
        <text class="breakdown-divider">|</text>
        <text class="breakdown-item bonus">完成奖励: +{{resultData.bonusPoints}}</text>
      </view>
    </view>
  </view>

  <view class="result-actions">
    <view class="action-btn secondary" bindtap="onBackToHome">
      返回
    </view>
    <view class="action-btn primary" bindtap="onRestart">
      再练一次
    </view>
  </view>

  <view class="wrong-review-btn" wx:if="{{resultData.wrong > 0}}" bindtap="onGoToWrong">
    <text class="review-icon">📝</text>
    <text>去错题本复习 ({{resultData.wrong}}题)</text>
  </view>
</view>
