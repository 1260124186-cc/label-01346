<view class="quiz-play-container" wx:if="{{!showResult}}">
  <view class="progress-section">
    <view class="progress-header">
      <text class="progress-text">第 {{currentIndex + 1}} / {{questions.length}} 题</text>
      <view class="score-info">
        <text class="correct-count">✓ {{correctCount}}</text>
        <text class="wrong-count">✗ {{wrongCount}}</text>
        <text class="timeout-count" wx:if="{{isTimedMode}}">⏱ {{timeoutCount}}</text>
      </view>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
  </view>

  <view class="voice-quick-bar" wx:if="{{voiceModeEnabled}}">
    <view class="voice-btn-quick {{isSpeaking ? 'speaking' : ''}}" bindtap="onSpeakQuestion" aria-label="{{isSpeaking ? '停止播报' : '语音播报题目'}}" role="button">
      <text class="voice-icon">{{isSpeaking ? '🔊' : '🔈'}}</text>
      <text class="voice-btn-text">{{isSpeaking ? '停止播报' : '听题目'}}</text>
    </view>
    <view class="voice-btn-quick" bindtap="toggleVoicePanel" aria-label="语音答题" role="button">
      <text class="voice-icon">🎤</text>
      <text class="voice-btn-text">语音答题</text>
    </view>
    <view class="voice-btn-quick {{voiceQuizMode ? 'active' : ''}}" bindtap="toggleVoiceQuizMode" aria-label="{{voiceQuizMode ? '关闭语音模式' : '开启语音模式'}}" role="button">
      <text class="voice-icon">{{voiceQuizMode ? '✅' : '⚙️'}}</text>
      <text class="voice-btn-text">{{voiceQuizMode ? '语音模式' : '语音开关'}}</text>
    </view>
  </view>

  <view class="timer-section" wx:if="{{isTimedMode}}">
    <view class="timer-circle {{timeLeft <= 5 ? 'warning' : ''}}">
      <text class="timer-text">{{timeLeft}}</text>
    </view>
    <view class="timer-label">剩余时间(秒)</view>
  </view>

  <view class="boss-badge" wx:if="{{isBossMode}}">
    <text class="boss-icon">👹</text>
    <text class="boss-text">Boss关 · 综合挑战</text>
  </view>

  <view class="question-section">
    <view class="question-card">
      <view class="question-tags">
        <view class="tag type-tag type-{{currentQuestion.type}}">
          <text class="tag-icon">{{currentQuestion.type === 'image-single' ? '🖼️' : QUESTION_TYPE_MAP[currentQuestion.type].icon}}</text>
          <text>{{currentQuestion.type === 'image-single' ? '图片选择' : QUESTION_TYPE_MAP[currentQuestion.type].name}}</text>
        </view>
        <view class="diff-tag diff-{{currentQuestion.difficulty}}">
          {{currentQuestion.difficultyName}}
        </view>
        <view class="child-mode-tag" wx:if="{{useImageQuestions}}">
          👶 适龄
        </view>
        <view class="scene-tag" wx:for="{{currentQuestion.sceneLabels}}" wx:key="*this">
          {{item}}
        </view>
      </view>
      <view class="question-text">{{currentQuestion.question}}</view>
      <view class="question-image-wrap" wx:if="{{currentQuestion.questionImage}}">
        <image class="question-image" src="{{currentQuestion.questionImage}}" mode="widthFix" bindtap="onPreviewImage" data-url="{{currentQuestion.questionImage}}"></image>
      </view>
      <view class="question-media-list" wx:if="{{currentQuestion.media && currentQuestion.media.length > 0}}">
        <block wx:for="{{currentQuestion.media}}" wx:key="url">
          <image wx:if="{{item.type === 'image'}}" class="question-media-item" src="{{item.url}}" mode="widthFix" bindtap="onPreviewImage" data-url="{{item.url}}"></image>
        </block>
      </view>
      <view class="question-hint" wx:if="{{currentQuestion.normalizedType === 'multiple'}}">
        <text class="hint-icon">💡</text>
        <text>多选题，请选择所有正确选项</text>
      </view>
    </view>
  </view>

  <view class="options-section">
    <!-- 图片选择题（emoji大图标） -->
    <view class="image-options-grid" wx:if="{{currentQuestion.type === 'image-single'}}">
      <view
        class="image-option {{selectedIndex === index ? 'selected' : ''}} {{isAnswered && index === currentQuestion.correctIndex ? 'correct' : ''}} {{isAnswered && selectedIndex === index && !isCorrect ? 'wrong' : ''}}"
        wx:for="{{currentQuestion.optionsWithLabel}}"
        wx:key="index"
        data-index="{{index}}"
        bindtap="onSelectOption"
        aria-label="选项{{item.label}}：{{item.text}}{{index === currentQuestion.correctIndex && isAnswered ? '，正确答案' : ''}}{{selectedIndex === index && !isCorrect && isAnswered ? '，回答错误' : ''}}"
        role="button"
        tabindex="0"
      >
        <view class="image-emoji-wrap">
          <text class="image-emoji">{{item.emoji}}</text>
        </view>
        <view class="image-label">{{item.text}}</view>
        <view class="image-letter">{{item.label}}</view>
        <view class="option-icon big" wx:if="{{isAnswered}}">
          <text wx:if="{{index === currentQuestion.correctIndex}}" class="icon-correct">✓</text>
          <text wx:elif="{{selectedIndex === index && !isCorrect}}" class="icon-wrong">✗</text>
        </view>
      </view>
    </view>

    <!-- 普通选项 -->
    <view class="options-list {{currentQuestion.normalizedType === 'judge' ? 'judge-options' : ''}}" wx:else>
      <view
        class="option-item {{currentQuestion.normalizedType === 'judge' ? 'judge-item' : ''}} {{currentQuestion.normalizedType !== 'judge' && selectedIndexes.indexOf(index) > -1 ? 'selected' : ''}} {{selectedIndex === index && currentQuestion.normalizedType !== 'multiple' ? 'selected' : ''}} {{isAnswered && currentQuestion.normalizedType !== 'multiple' && index === currentQuestion.correctIndex ? 'correct' : ''}} {{isAnswered && currentQuestion.normalizedType === 'multiple' && currentQuestion.correctIndexes.indexOf(index) > -1 ? 'correct' : ''}} {{isAnswered && selectedIndex === index && !isCorrect && currentQuestion.normalizedType !== 'multiple' ? 'wrong' : ''}} {{isAnswered && currentQuestion.normalizedType === 'multiple' && selectedIndexes.indexOf(index) > -1 && currentQuestion.correctIndexes.indexOf(index) === -1 ? 'wrong' : ''}}"
        wx:for="{{currentQuestion.optionsWithLabel}}"
        wx:key="index"
        data-index="{{index}}"
        bindtap="onSelectOption"
        aria-label="选项{{item.label}}：{{item.text}}{{(currentQuestion.normalizedType !== 'multiple' && index === currentQuestion.correctIndex && isAnswered) || (currentQuestion.normalizedType === 'multiple' && currentQuestion.correctIndexes.indexOf(index) > -1 && isAnswered) ? '，正确答案' : ''}}{{(currentQuestion.normalizedType !== 'multiple' && selectedIndex === index && !isCorrect && isAnswered) || (currentQuestion.normalizedType === 'multiple' && selectedIndexes.indexOf(index) > -1 && currentQuestion.correctIndexes.indexOf(index) === -1 && isAnswered) ? '，回答错误' : ''}}"
        role="button"
        tabindex="0"
      >
        <view wx:if="{{currentQuestion.normalizedType === 'multiple'}}" class="option-checkbox {{selectedIndexes.indexOf(index) > -1 ? 'checked' : ''}} {{isAnswered && currentQuestion.correctIndexes.indexOf(index) > -1 ? 'correct' : ''}} {{isAnswered && selectedIndexes.indexOf(index) > -1 && currentQuestion.correctIndexes.indexOf(index) === -1 ? 'wrong' : ''}}">
          <text wx:if="{{selectedIndexes.indexOf(index) > -1}}" class="checkbox-mark">✓</text>
        </view>
        <view wx:elif="{{currentQuestion.normalizedType === 'judge'}}" class="option-judge-icon {{index === 0 ? 'icon-true' : 'icon-false'}}">
          <text>{{index === 0 ? '✓' : '✗'}}</text>
        </view>
        <view wx:else class="option-label">{{item.label}}</view>
        <view class="option-text">{{item.text}}</view>
        <view class="option-icon" wx:if="{{isAnswered}}">
          <text wx:if="{{(currentQuestion.normalizedType !== 'multiple' && index === currentQuestion.correctIndex) || (currentQuestion.normalizedType === 'multiple' && currentQuestion.correctIndexes.indexOf(index) > -1)}}" class="icon-correct">✓</text>
          <text wx:elif="{{(currentQuestion.normalizedType !== 'multiple' && selectedIndex === index && !isCorrect) || (currentQuestion.normalizedType === 'multiple' && selectedIndexes.indexOf(index) > -1 && currentQuestion.correctIndexes.indexOf(index) === -1)}}" class="icon-wrong">✗</text>
        </view>
      </view>
    </view>

    <view class="multiple-submit-section" wx:if="{{currentQuestion.normalizedType === 'multiple' && !isAnswered}}">
      <view class="selected-info" aria-label="已选择{{selectedIndexes.length}}项">已选择 {{selectedIndexes.length}} 项</view>
      <view class="submit-btn" bindtap="onSubmitMultiple" aria-label="提交答案" role="button" tabindex="0">提交答案</view>
    </view>
  </view>

  <view class="explanation-section" wx:if="{{isAnswered}}">
    <view class="answer-result-card {{isCorrect ? 'result-correct' : 'result-wrong'}}">
      <view class="result-icon">{{isCorrect ? '✅' : '❌'}}</view>
      <view class="result-info">
        <view class="result-title">{{isCorrect ? '回答正确' : '回答错误'}}</view>
        <view class="correct-answer" wx:if="{{!isCorrect}}">
          <text class="label">正确答案：</text>
          <text class="value">{{currentQuestion.correctAnswerLabel}}</text>
        </view>
      </view>
    </view>

    <view class="explanation-card" wx:if="{{currentQuestion.explanation}}">
      <view class="explanation-title">
        <text class="title-icon">💡</text>
        <text>答案解析</text>
      </view>
      <view class="explanation-text">{{currentQuestion.explanation}}</view>
      <view class="explanation-image-wrap" wx:if="{{currentQuestion.explanationImage}}">
        <image class="explanation-image" src="{{currentQuestion.explanationImage}}" mode="widthFix" bindtap="onPreviewImage" data-url="{{currentQuestion.explanationImage}}"></image>
      </view>
    </view>

    <view class="error-tip-card" wx:if="{{currentQuestion.errorTip}}">
      <view class="error-tip-title">
        <text class="title-icon">⚠️</text>
        <text>易错提示</text>
      </view>
      <view class="error-tip-text">{{currentQuestion.errorTip}}</view>
    </view>

    <view class="related-trash-card" wx:if="{{currentQuestion.relatedTrash && currentQuestion.relatedTrash.length > 0}}">
      <view class="related-title">
        <text class="title-icon">🔗</text>
        <text>关联垃圾条目</text>
      </view>
      <scroll-view class="related-scroll" scroll-x enable-flex>
        <view class="related-item" wx:for="{{currentQuestion.relatedTrash}}" wx:key="name">
          <view class="related-icon-wrap" style="background: {{TRASH_TYPE_MAP[item.typeId].bgColor}}">
            <text class="related-emoji">{{item.emoji}}</text>
          </view>
          <view class="related-name">{{item.name}}</view>
          <view class="related-type" style="color: {{TRASH_TYPE_MAP[item.typeId].color}}">
            {{TRASH_TYPE_MAP[item.typeId].name}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="encyclopedia-card" wx:if="{{encyclopediaEntry}}" bindtap="goToEncyclopedia">
      <view class="encyclopedia-icon-wrap">
        <text class="encyclopedia-icon">📖</text>
      </view>
      <view class="encyclopedia-info">
        <view class="encyclopedia-title">查看百科详解</view>
        <view class="encyclopedia-desc">{{encyclopediaEntry.label}} · 了解详细分类规则与常见误区</view>
      </view>
      <view class="encyclopedia-arrow">
        <text>›</text>
      </view>
    </view>

    <view class="similar-practice-card" wx:if="{{showSimilarPracticeBtn && !isCorrect}}" bindtap="practiceSimilarQuestions">
      <view class="similar-icon-wrap">
        <text class="similar-icon">🎯</text>
      </view>
      <view class="similar-info">
        <view class="similar-title">同类题强化练习</view>
        <view class="similar-desc">同场景同类型题目再练{{similarPracticeQuestions.length >= 5 ? 5 : similarPracticeQuestions.length}}题，巩固知识点</view>
      </view>
      <view class="similar-btn">
        <text>开始练习</text>
      </view>
    </view>
  </view>

  <view class="footer-section" wx:if="{{isAnswered}}">
    <view class="next-btn" bindtap="onNextQuestion" aria-label="{{currentIndex + 1 >= questions.length ? '查看结果' : '下一题'}}" role="button" tabindex="0">
      {{currentIndex + 1 >= questions.length ? '查看结果' : '下一题'}}
    </view>
  </view>
</view>

<view class="result-container" wx:if="{{showResult}}">
  <view class="result-header {{resultData.isTimedMode ? 'timed-mode' : ''}} {{resultData.isBossMode ? 'boss-mode' : ''}}">
    <view class="result-mode-badge" wx:if="{{resultData.isTimedMode}}">
      <text class="badge-icon">⏱</text>
      <text class="badge-text">限时挑战</text>
    </view>
    <view class="result-mode-badge boss" wx:if="{{resultData.isBossMode}}">
      <text class="badge-icon">👹</text>
      <text class="badge-text">Boss关</text>
    </view>
    <view class="result-emoji">{{resultData.emoji}}</view>
    <view class="result-title">{{resultData.title}}</view>
    <view class="result-subtitle">答题完成，获得 {{resultData.points}} 积分</view>
  </view>

  <view class="result-stats">
    <view class="stat-item">
      <view class="stat-value">{{resultData.total}}</view>
      <view class="stat-label">总题数</view>
    </view>
    <view class="stat-item correct">
      <view class="stat-value">{{resultData.correct}}</view>
      <view class="stat-label">答对</view>
    </view>
    <view class="stat-item wrong">
      <view class="stat-value">{{resultData.wrong}}</view>
      <view class="stat-label">答错</view>
    </view>
    <view class="stat-item timeout" wx:if="{{resultData.timeout > 0}}">
      <view class="stat-value">{{resultData.timeout}}</view>
      <view class="stat-label">超时</view>
    </view>
    <view class="stat-item accuracy">
      <view class="stat-value">{{resultData.accuracy}}%</view>
      <view class="stat-label">正确率</view>
    </view>
  </view>

  <view class="result-points-card">
    <view class="points-icon">🎁</view>
    <view class="points-info">
      <view class="points-title">获得积分</view>
      <view class="points-value">+{{resultData.points}}</view>
      <view class="points-breakdown">
        <text class="breakdown-item">答题: +{{resultData.basePoints}}</text>
        <text class="breakdown-divider">|</text>
        <text class="breakdown-item bonus">{{resultData.bonusTitle}}: +{{resultData.bonusPoints}}</text>
      </view>
    </view>
  </view>

  <view class="accuracy-bonus-card" wx:if="{{resultData.isTimedMode}}">
    <view class="bonus-title">
      <text class="bonus-icon">⭐</text>
      <text>正确率加成说明</text>
    </view>
    <view class="bonus-rules">
      <view class="bonus-rule">
        <text class="rule-name">完美(≥90%)</text>
        <text class="rule-points">+50分</text>
      </view>
      <view class="bonus-rule">
        <text class="rule-name">优秀(≥80%)</text>
        <text class="rule-points">+30分</text>
      </view>
      <view class="bonus-rule">
        <text class="rule-name">良好(≥60%)</text>
        <text class="rule-points">+15分</text>
      </view>
      <view class="bonus-rule">
        <text class="rule-name">加油(&lt;60%)</text>
        <text class="rule-points">+5分</text>
      </view>
    </view>
  </view>

  <view class="result-actions">
    <view class="action-btn secondary" bindtap="onBackToHome" aria-label="返回上一页" role="button" tabindex="0">
      返回
    </view>
    <view class="action-btn primary" bindtap="onRestart" aria-label="再练一次" role="button" tabindex="0">
      再练一次
    </view>
  </view>

  <view class="wrong-review-btn" wx:if="{{resultData.wrong > 0}}" bindtap="onGoToWrong" aria-label="去错题本复习，共{{resultData.wrong}}题" role="button" tabindex="0">
    <text class="review-icon">📝</text>
    <text>去错题本复习 ({{resultData.wrong}}题)</text>
  </view>
</view>

<view class="voice-overlay" wx:if="{{showVoicePanel}}" catchtouchmove="true">
  <view class="voice-overlay-mask" bindtap="closeVoicePanel"></view>
  <view class="voice-overlay-content" role="dialog" aria-label="语音答题面板">
    <view class="voice-overlay-header">
      <text class="voice-overlay-title">语音答题</text>
      <view class="voice-close-btn" bindtap="closeVoicePanel" aria-label="关闭语音面板" role="button">
        <text>✕</text>
      </view>
    </view>
    
    <view class="voice-wave-section">
      <view class="voice-wave-container {{isRecognizing ? 'active' : ''}}">
        <view class="wave-bar" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
      </view>
      <view class="voice-status-text">
        <text wx:if="{{isRecognizing}}">正在聆听...</text>
        <text wx:elif="{{isProcessing}}">正在识别...</text>
        <text wx:elif="{{recognizedText}}">{{recognizedText}}</text>
        <text wx:else>按住按钮说出答案</text>
      </view>
    </view>
    
    <view class="voice-record-btn-wrap">
      <view 
        class="voice-record-btn {{isRecognizing ? 'recording' : ''}} {{isChildMode ? 'child' : ''}}"
        bindtouchstart="onVoiceRecordToggle"
        bindtouchend="onVoiceRecordToggle"
        aria-label="{{isRecognizing ? '松开结束录音' : '按住开始录音'}}"
        role="button"
      >
        <text class="record-icon">{{isRecognizing ? '🔴' : '🎤'}}</text>
        <text class="record-text" wx:if="{{!isRecognizing}}">{{isChildMode ? '按住说话' : '按住 说话'}}</text>
        <text class="record-text" wx:else>松开 结束</text>
      </view>
    </view>
    
    <view class="voice-tips-section">
      <view class="voice-tip-title">语音指令：</view>
      <view class="voice-tip-list">
        <text class="voice-tip">A/B/C/D 选择答案</text>
        <text class="voice-tip">第一/第二个 选择答案</text>
        <text class="voice-tip">重复 重新听题</text>
        <text class="voice-tip">下一题 继续答题</text>
      </view>
    </view>
    
    <view class="voice-dialect-info">
      <text>识别方言：{{currentDialectName}}</text>
    </view>
  </view>
</view>

<view class="voice-speak-bar" wx:if="{{isSpeaking && !showVoicePanel}}" bindtap="onSpeakQuestion" aria-label="点击停止播报" role="button">
  <view class="speak-bar-icon">🔊</view>
  <view class="speak-bar-text">正在语音播报...</view>
  <view class="speak-bar-action">点击停止</view>
</view>
