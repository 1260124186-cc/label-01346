.quiz-play-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  display: flex;
  flex-direction: column;
}

.progress-section {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #636E72;
  font-weight: 500;
}

.score-info {
  display: flex;
  gap: 24rpx;
}

.correct-count {
  font-size: 28rpx;
  color: #5BBD72;
  font-weight: 600;
}

.wrong-count {
  font-size: 28rpx;
  color: #E85D5D;
  font-weight: 600;
}

.progress-bar {
  height: 12rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.question-section {
  padding: 32rpx;
  flex: 1;
}

.question-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.question-difficulty {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.diff-tag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}

.diff-easy {
  background: rgba(91, 189, 114, 0.15);
  color: #5BBD72;
}

.diff-medium {
  background: rgba(243, 156, 18, 0.15);
  color: #F39C12;
}

.diff-hard {
  background: rgba(232, 93, 93, 0.15);
  color: #E85D5D;
}

.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.6;
}

.options-section {
  padding: 0 32rpx 32rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.selected {
  border-color: #5BBD72;
  background: rgba(91, 189, 114, 0.05);
}

.option-item.correct {
  border-color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
}

.option-item.wrong {
  border-color: #E85D5D;
  background: rgba(232, 93, 93, 0.1);
}

.option-label {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(91, 189, 114, 0.1);
  color: #5BBD72;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.correct .option-label {
  background: #5BBD72;
  color: #fff;
}

.option-item.wrong .option-label {
  background: #E85D5D;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #2D3436;
  line-height: 1.5;
}

.option-icon {
  margin-left: 16rpx;
}

.icon-correct {
  font-size: 36rpx;
  color: #5BBD72;
  font-weight: 600;
}

.icon-wrong {
  font-size: 36rpx;
  color: #E85D5D;
  font-weight: 600;
}

.explanation-section {
  padding: 0 32rpx 32rpx;
}

.explanation-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border-left: 6rpx solid #5BBD72;
}

.explanation-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
}

.title-icon {
  font-size: 32rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.6;
}

.footer-section {
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.next-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.next-btn:active {
  transform: scale(0.98);
}

.result-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.result-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.result-subtitle {
  font-size: 28rpx;
  color: #636E72;
}

.result-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  width: 100%;
  margin-bottom: 40rpx;
}

.stat-item {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.stat-item.correct .stat-value {
  color: #5BBD72;
}

.stat-item.wrong .stat-value {
  color: #E85D5D;
}

.stat-item.accuracy .stat-value {
  color: #4A90D9;
}

.stat-label {
  font-size: 22rpx;
  color: #636E72;
}

.result-points-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  width: 100%;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.25);
}

.points-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.points-info {
  flex: 1;
}

.points-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.points-breakdown {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: nowrap;
}

.breakdown-item {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  white-space: nowrap;
}

.breakdown-item.bonus {
  color: #FFE082;
  font-weight: 500;
}

.breakdown-divider {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.result-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 32rpx;
}

.action-btn {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.9);
  color: #636E72;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
}

.wrong-review-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(232, 93, 93, 0.1);
  color: #E85D5D;
  font-size: 28rpx;
  font-weight: 500;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(232, 93, 93, 0.3);
}

.review-icon {
  font-size: 32rpx;
}
