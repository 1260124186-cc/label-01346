.quiz-play-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  display: flex;
  flex-direction: column;
}

.progress-section {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #636E72;
  font-weight: 500;
}

.score-info {
  display: flex;
  gap: 24rpx;
}

.correct-count {
  font-size: 28rpx;
  color: #5BBD72;
  font-weight: 600;
}

.wrong-count {
  font-size: 28rpx;
  color: #E85D5D;
  font-weight: 600;
}

.progress-bar {
  height: 12rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.question-section {
  padding: 32rpx;
  flex: 1;
}

.question-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.question-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  gap: 6rpx;
}

.tag-icon {
  font-size: 20rpx;
}

.type-tag {
  background: rgba(74, 144, 217, 0.15);
  color: #4A90D9;
}

.type-tag.type-multiple {
  background: rgba(155, 89, 182, 0.15);
  color: #9B59B6;
}

.type-tag.type-judge {
  background: rgba(243, 156, 18, 0.15);
  color: #F39C12;
}

.diff-tag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}

.diff-easy {
  background: rgba(91, 189, 114, 0.15);
  color: #5BBD72;
}

.diff-medium {
  background: rgba(243, 156, 18, 0.15);
  color: #F39C12;
}

.diff-hard {
  background: rgba(232, 93, 93, 0.15);
  color: #E85D5D;
}

.scene-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(142, 142, 147, 0.1);
  color: #8E8E93;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.child-mode-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(243, 156, 18, 0.15), rgba(91, 189, 114, 0.1));
  color: #E67E22;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
  border: 1rpx solid rgba(243, 156, 18, 0.3);
}

.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.6;
}

.question-hint {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(155, 89, 182, 0.08);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.hint-icon {
  font-size: 24rpx;
}

.question-hint text:last-child {
  font-size: 24rpx;
  color: #9B59B6;
  font-weight: 500;
}

/* 图片选择样式 */
.image-options-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 12rpx 0 0;
}

.image-option {
  position: relative;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 20rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  border: 4rpx solid transparent;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.image-option:active {
  transform: scale(0.96);
}

.image-option.selected {
  border-color: #5BBD72;
  background: rgba(91, 189, 114, 0.06);
  box-shadow: 0 6rpx 24rpx rgba(91, 189, 114, 0.2);
}

.image-option.correct {
  border-color: #5BBD72;
  background: rgba(91, 189, 114, 0.12);
  box-shadow: 0 6rpx 24rpx rgba(91, 189, 114, 0.25);
}

.image-option.wrong {
  border-color: #E74C3C;
  background: rgba(231, 76, 60, 0.08);
  box-shadow: 0 6rpx 24rpx rgba(231, 76, 60, 0.2);
}

.image-emoji-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(243, 156, 18, 0.08), rgba(91, 189, 114, 0.08));
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-option.selected .image-emoji-wrap {
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.18), rgba(91, 189, 114, 0.25));
}

.image-option.correct .image-emoji-wrap {
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.2), rgba(52, 199, 89, 0.28));
}

.image-option.wrong .image-emoji-wrap {
  background: linear-gradient(135deg, rgba(231, 76, 60, 0.15), rgba(231, 76, 60, 0.22));
}

.image-emoji {
  font-size: 80rpx;
  line-height: 1;
}

.image-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D3436;
  text-align: center;
}

.image-letter {
  position: absolute;
  top: 16rpx;
  left: 20rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(142, 142, 147, 0.1);
  color: #8E8E93;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-option.selected .image-letter {
  background: #5BBD72;
  color: #FFFFFF;
}

.image-option.correct .image-letter {
  background: #5BBD72;
  color: #FFFFFF;
}

.image-option.wrong .image-letter {
  background: #E74C3C;
  color: #FFFFFF;
}

.option-icon.big {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-icon.big .icon-correct {
  width: 100%;
  height: 100%;
  background: #5BBD72;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(91, 189, 114, 0.35);
}

.option-icon.big .icon-wrong {
  width: 100%;
  height: 100%;
  background: #E74C3C;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.35);
}

.options-section {
  padding: 0 32rpx 32rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.options-list.judge-options {
  flex-direction: row;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.judge-item {
  flex: 1;
  flex-direction: column;
  padding: 40rpx 24rpx;
  gap: 16rpx;
  justify-content: center;
}

.option-item.selected {
  border-color: #5BBD72;
  background: rgba(91, 189, 114, 0.05);
}

.option-item.correct {
  border-color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
}

.option-item.wrong {
  border-color: #E85D5D;
  background: rgba(232, 93, 93, 0.1);
}

.option-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  border: 3rpx solid #C8CCD1;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.option-checkbox.checked {
  border-color: #5BBD72;
  background: #5BBD72;
}

.option-checkbox.correct {
  border-color: #5BBD72;
  background: #5BBD72;
}

.option-checkbox.wrong {
  border-color: #E85D5D;
  background: #E85D5D;
}

.checkbox-mark {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

.option-judge-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0;
  flex-shrink: 0;
}

.option-judge-icon.icon-true {
  background: rgba(91, 189, 114, 0.15);
}

.option-judge-icon.icon-true text {
  color: #5BBD72;
  font-size: 40rpx;
  font-weight: 700;
}

.option-judge-icon.icon-false {
  background: rgba(232, 93, 93, 0.15);
}

.option-judge-icon.icon-false text {
  color: #E85D5D;
  font-size: 40rpx;
  font-weight: 700;
}

.option-judge-item.selected .option-judge-icon.icon-true,
.option-judge-item.correct .option-judge-icon.icon-true {
  background: #5BBD72;
}

.option-judge-item.selected .option-judge-icon.icon-true text,
.option-judge-item.correct .option-judge-icon.icon-true text {
  color: #fff;
}

.option-judge-item.selected .option-judge-icon.icon-false,
.option-judge-item.correct .option-judge-icon.icon-false {
  background: #E85D5D;
}

.option-judge-item.selected .option-judge-icon.icon-false text,
.option-judge-item.correct .option-judge-icon.icon-false text {
  color: #fff;
}

.option-label {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(91, 189, 114, 0.1);
  color: #5BBD72;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.correct .option-label {
  background: #5BBD72;
  color: #fff;
}

.option-item.wrong .option-label {
  background: #E85D5D;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #2D3436;
  line-height: 1.5;
}

.option-icon {
  margin-left: 16rpx;
}

.icon-correct {
  font-size: 36rpx;
  color: #5BBD72;
  font-weight: 600;
}

.icon-wrong {
  font-size: 36rpx;
  color: #E85D5D;
  font-weight: 600;
}

.multiple-submit-section {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(155, 89, 182, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.selected-info {
  font-size: 26rpx;
  color: #9B59B6;
  font-weight: 500;
}

.submit-btn {
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 36rpx;
  border-radius: 12rpx;
  box-shadow: 0 6rpx 18rpx rgba(155, 89, 182, 0.25);
}

.submit-btn:active {
  transform: scale(0.97);
}

.explanation-section {
  padding: 0 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.answer-result-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border-left: 6rpx solid #5BBD72;
}

.answer-result-card.result-wrong {
  border-left-color: #E85D5D;
}

.result-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.result-info {
  flex: 1;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.correct-answer {
  font-size: 26rpx;
  color: #636E72;
  display: flex;
  align-items: center;
}

.correct-answer .label {
  color: #636E72;
}

.correct-answer .value {
  color: #5BBD72;
  font-weight: 600;
  margin-left: 6rpx;
}

.explanation-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border-left: 6rpx solid #5BBD72;
}

.explanation-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
}

.title-icon {
  font-size: 32rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.6;
}

.explanation-image-wrap {
  margin-top: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.explanation-image {
  width: 100%;
  display: block;
  border-radius: 12rpx;
}

.error-tip-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(243, 156, 18, 0.08);
  border-left: 6rpx solid #F39C12;
}

.error-tip-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #F39C12;
}

.error-tip-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.6;
}

.related-trash-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.08);
  border-left: 6rpx solid #4A90D9;
}

.related-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #4A90D9;
}

.related-scroll {
  white-space: nowrap;
  width: 100%;
}

.related-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  margin-right: 16rpx;
  background: rgba(74, 144, 217, 0.04);
  border-radius: 16rpx;
  min-width: 160rpx;
}

.related-item:last-child {
  margin-right: 0;
}

.related-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.related-emoji {
  font-size: 40rpx;
}

.related-name {
  font-size: 24rpx;
  color: #2D3436;
  font-weight: 500;
  margin-bottom: 4rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 140rpx;
}

.related-type {
  font-size: 20rpx;
  font-weight: 500;
  text-align: center;
}

.footer-section {
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.next-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.next-btn:active {
  transform: scale(0.98);
}

.result-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.result-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.result-subtitle {
  font-size: 28rpx;
  color: #636E72;
}

.result-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  width: 100%;
  margin-bottom: 40rpx;
}

.stat-item {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.stat-item.correct .stat-value {
  color: #5BBD72;
}

.stat-item.wrong .stat-value {
  color: #E85D5D;
}

.stat-item.accuracy .stat-value {
  color: #4A90D9;
}

.stat-label {
  font-size: 22rpx;
  color: #636E72;
}

.result-points-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  width: 100%;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.25);
}

.points-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.points-info {
  flex: 1;
}

.points-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.points-breakdown {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: nowrap;
}

.breakdown-item {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  white-space: nowrap;
}

.breakdown-item.bonus {
  color: #FFE082;
  font-weight: 500;
}

.breakdown-divider {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.result-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 32rpx;
}

.action-btn {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.9);
  color: #636E72;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
}

.wrong-review-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(232, 93, 93, 0.1);
  color: #E85D5D;
  font-size: 28rpx;
  font-weight: 500;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(232, 93, 93, 0.3);
}

.review-icon {
  font-size: 32rpx;
}

.timeout-count {
  font-size: 28rpx;
  color: #F39C12;
  font-weight: 600;
}

.timer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx 0;
}

.timer-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
  transition: all 0.3s ease;
}

.timer-circle.warning {
  background: linear-gradient(135deg, #E85D5D 0%, #C0392B 100%);
  box-shadow: 0 8rpx 24rpx rgba(232, 93, 93, 0.4);
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.timer-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.timer-label {
  font-size: 22rpx;
  color: #636E72;
  margin-top: 12rpx;
}

.boss-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #E74C3C 0%, #C0392B 100%);
  margin: 20rpx 32rpx 0;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(231, 76, 60, 0.25);
}

.boss-icon {
  font-size: 36rpx;
}

.boss-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.result-header.timed-mode {
  background: linear-gradient(135deg, rgba(243, 156, 18, 0.1) 0%, rgba(230, 126, 34, 0.1) 100%);
  padding: 32rpx;
  border-radius: 24rpx;
  margin: -40rpx -32rpx 32rpx;
}

.result-header.boss-mode {
  background: linear-gradient(135deg, rgba(231, 76, 60, 0.1) 0%, rgba(192, 57, 43, 0.1) 100%);
  padding: 32rpx;
  border-radius: 24rpx;
  margin: -40rpx -32rpx 32rpx;
}

.result-mode-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.result-mode-badge.boss {
  background: linear-gradient(135deg, #E74C3C 0%, #C0392B 100%);
}

.badge-icon {
  font-size: 24rpx;
}

.badge-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.stat-item.timeout .stat-value {
  color: #F39C12;
}

.result-stats.has-timeout {
  grid-template-columns: repeat(5, 1fr);
}

.accuracy-bonus-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(243, 156, 18, 0.08);
  border-left: 6rpx solid #F39C12;
}

.bonus-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #F39C12;
}

.bonus-icon {
  font-size: 32rpx;
}

.bonus-rules {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.bonus-rule {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(243, 156, 18, 0.06);
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.rule-name {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 500;
}

.rule-points {
  font-size: 24rpx;
  color: #F39C12;
  font-weight: 600;
}

.question-image-wrap {
  margin-top: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F8F9FA;
}

.question-image {
  width: 100%;
  display: block;
  border-radius: 16rpx;
}

.question-media-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.question-media-item {
  width: 100%;
  border-radius: 12rpx;
  display: block;
}

.encyclopedia-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.08);
  border-left: 6rpx solid #2E7D32;
}

.encyclopedia-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.encyclopedia-icon {
  font-size: 36rpx;
}

.encyclopedia-info {
  flex: 1;
  min-width: 0;
}

.encyclopedia-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1B5E20;
  margin-bottom: 6rpx;
}

.encyclopedia-desc {
  font-size: 24rpx;
  color: #388E3C;
  opacity: 0.85;
  line-height: 1.4;
}

.encyclopedia-arrow {
  font-size: 40rpx;
  color: #2E7D32;
  opacity: 0.7;
  flex-shrink: 0;
  padding-right: 4rpx;
}

.similar-practice-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(230, 81, 0, 0.08);
  border-left: 6rpx solid #E65100;
}

.similar-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.similar-icon {
  font-size: 36rpx;
}

.similar-info {
  flex: 1;
  min-width: 0;
}

.similar-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #BF360C;
  margin-bottom: 6rpx;
}

.similar-desc {
  font-size: 24rpx;
  color: #E65100;
  opacity: 0.85;
  line-height: 1.4;
}

.similar-btn {
  background: #E65100;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.similar-btn text {
  color: #fff;
}

.voice-quick-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.05);
}

.voice-btn-quick {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 12rpx;
  background: linear-gradient(135deg, #F0F9FF 0%, #E0F2FE 100%);
  border-radius: 16rpx;
  border: 2rpx solid rgba(91, 189, 114, 0.2);
}

.voice-btn-quick.speaking {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-color: #4CAF50;
}

.voice-btn-quick.speaking .voice-icon,
.voice-btn-quick.speaking .voice-btn-text {
  color: #fff;
}

.voice-btn-quick.active {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-color: #4CAF50;
}

.voice-btn-quick.active .voice-icon,
.voice-btn-quick.active .voice-btn-text {
  color: #fff;
}

.voice-btn-quick .voice-icon {
  font-size: 36rpx;
}

.voice-btn-quick .voice-btn-text {
  font-size: 22rpx;
  color: #2D3436;
  font-weight: 500;
}

.voice-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.voice-overlay-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.voice-overlay-content {
  position: relative;
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: 60rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.voice-overlay-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.voice-overlay-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
}

.voice-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0F0F0;
  border-radius: 50%;
  font-size: 28rpx;
  color: #636E72;
}

.voice-wave-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.voice-wave-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.voice-wave-container .wave-bar {
  width: 8rpx;
  height: 40rpx;
  background: #5BBD72;
  border-radius: 4rpx;
  opacity: 0.3;
}

.voice-wave-container.active .wave-bar {
  animation: waveAnimation 1s ease-in-out infinite;
  opacity: 1;
}

.voice-wave-container.active .wave-bar:nth-child(1) { animation-delay: 0s; }
.voice-wave-container.active .wave-bar:nth-child(2) { animation-delay: 0.1s; }
.voice-wave-container.active .wave-bar:nth-child(3) { animation-delay: 0.2s; }
.voice-wave-container.active .wave-bar:nth-child(4) { animation-delay: 0.3s; }
.voice-wave-container.active .wave-bar:nth-child(5) { animation-delay: 0.4s; }

@keyframes waveAnimation {
  0%, 100% { height: 20rpx; }
  50% { height: 100rpx; }
}

.voice-status-text {
  font-size: 28rpx;
  color: #636E72;
  text-align: center;
  min-height: 40rpx;
}

.voice-record-btn-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.voice-record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.4);
  transition: all 0.2s ease;
}

.voice-record-btn.recording {
  background: linear-gradient(135deg, #E85D5D 0%, #E53935 100%);
  box-shadow: 0 8rpx 32rpx rgba(232, 93, 93, 0.4);
  animation: pulse 1.5s ease-in-out infinite;
}

.voice-record-btn.child {
  width: 240rpx;
  height: 240rpx;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 8rpx 32rpx rgba(232, 93, 93, 0.4);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 12rpx 48rpx rgba(232, 93, 93, 0.6);
  }
}

.voice-record-btn .record-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.voice-record-btn .record-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.voice-tips-section {
  margin-bottom: 32rpx;
}

.voice-tip-title {
  font-size: 26rpx;
  color: #636E72;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.voice-tip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.voice-tip {
  font-size: 24rpx;
  color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.voice-dialect-info {
  text-align: center;
  font-size: 24rpx;
  color: #B2BEC3;
}

.voice-speak-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 900;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.speak-bar-icon {
  font-size: 36rpx;
  animation: speakIcon 1s ease-in-out infinite;
}

@keyframes speakIcon {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.speak-bar-text {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.speak-bar-action {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

.page-large-font .voice-btn-quick .voice-btn-text {
  font-size: 28rpx;
}

.page-large-font .voice-overlay-title {
  font-size: 40rpx;
}

.page-large-font .voice-status-text {
  font-size: 32rpx;
}

.page-large-font .voice-record-btn {
  width: 240rpx;
  height: 240rpx;
}

.page-large-font .voice-record-btn.child {
  width: 280rpx;
  height: 280rpx;
}

.page-large-font .voice-tip {
  font-size: 28rpx;
  padding: 12rpx 20rpx;
}
