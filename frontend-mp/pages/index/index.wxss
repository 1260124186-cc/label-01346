/**
 * 首页样式
 * 设计风格：轻透清新风
 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding: 0 0 120rpx 0;
  box-sizing: border-box;
}

/* ==================== 轮播图区域 ==================== */
.banner-section {
  position: relative;
  padding: 24rpx 32rpx;
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
}

.banner-image-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #5BBD72 0%, #3D9A54 100%);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 100%);
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 自定义指示器 */
.banner-indicators {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 16rpx;
  gap: 12rpx;
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: rgba(91, 189, 114, 0.3);
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 32rpx;
  background: var(--color-primary);
}

/* ==================== 每日签到入口 ==================== */
.signin-entry-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.signin-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.25);
}

.signin-entry-card:active {
  transform: scale(0.98);
}

.signin-entry-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.signin-entry-emoji {
  font-size: 56rpx;
}

.signin-entry-text {
  flex: 1;
}

.signin-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
}

.signin-entry-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.signin-entry-btn {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 28rpx;
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
}

.signin-entry-btn.done {
  background: rgba(255, 255, 255, 0.15);
}

/* ==================== 快捷功能区域 ==================== */
.quick-actions-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.quick-actions-grid {
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  transition: transform 0.2s ease;
}

.quick-action-item:active {
  transform: scale(0.95);
}

.quick-action-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-action-icon {
  width: 48rpx;
  height: 48rpx;
}

.quick-action-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.quick-action-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ==================== 区域标题 ==================== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
}

.section-title-icon {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #4AA862 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-subtitle-wrapper {
  display: flex;
  align-items: center;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.section-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-left: 4rpx;
}

/* ==================== 垃圾分类卡片区域 ==================== */
.trash-types-section {
  padding: 0 32rpx;
}

.trash-types-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.trash-type-card {
  position: relative;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  overflow: hidden;
  transition: all 0.3s ease;
}

.trash-type-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 30rpx rgba(91, 189, 114, 0.15);
}

/* 卡片背景装饰 */
.card-decoration {
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--card-bg);
  opacity: 0.6;
}

/* 垃圾桶图标容器 */
.trash-icon-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: var(--card-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.trash-icon {
  width: 64rpx;
  height: 64rpx;
}

.trash-icon-emoji {
  font-size: 56rpx;
  line-height: 1;
}

/* 分类信息 */
.trash-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.trash-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.trash-english {
  font-size: 24rpx;
  color: var(--card-color);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* 箭头指示 */
.card-arrow {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--card-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 40rpx;
  color: var(--card-color);
  font-weight: 300;
  line-height: 1;
}

/* ==================== 底部提示 ==================== */
.footer-tips {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
}

.tips-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
}

/* ==================== 动画效果 ==================== */
@keyframes cardFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.trash-type-card {
  animation: cardFadeIn 0.4s ease forwards;
}

.trash-type-card:nth-child(1) { animation-delay: 0.1s; }
.trash-type-card:nth-child(2) { animation-delay: 0.2s; }
.trash-type-card:nth-child(3) { animation-delay: 0.3s; }
.trash-type-card:nth-child(4) { animation-delay: 0.4s; }
