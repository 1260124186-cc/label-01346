/**
 * 首页样式
 * 设计风格：轻透清新风
 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding: 0 0 120rpx 0;
  box-sizing: border-box;
}

/* ==================== 搜索框入口 ==================== */
.search-section {
  padding: 24rpx 32rpx 16rpx;
}

.search-entry {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 48rpx;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.2s ease;
}

.search-entry:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(91, 189, 114, 0.08);
}

.search-entry-icon {
  font-size: 32rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.search-entry-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ==================== 轮播图区域 ==================== */
.banner-section {
  position: relative;
  padding: 24rpx 32rpx;
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
}

.banner-image-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #5BBD72 0%, #3D9A54 100%);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 100%);
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.banner-link-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* 自定义指示器 */
.banner-indicators {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 16rpx;
  gap: 12rpx;
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: rgba(91, 189, 114, 0.3);
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 32rpx;
  background: var(--color-primary);
}

/* ==================== 每日签到入口 ==================== */
.signin-entry-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.signin-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.25);
}

.signin-entry-card:active {
  transform: scale(0.98);
}

.signin-entry-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.signin-entry-emoji {
  font-size: 56rpx;
}

.signin-entry-text {
  flex: 1;
}

.signin-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
}

.signin-entry-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.signin-entry-btn {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 28rpx;
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
}

.signin-entry-btn.done {
  background: rgba(255, 255, 255, 0.15);
}

/* ==================== 垃圾分类小游戏入口 ==================== */
.game-entry-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.game-entry-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(255, 107, 107, 0.2);
}

.game-entry-card:active {
  transform: scale(0.98);
}

.game-entry-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 50%, #C44569 100%);
}

.game-entry-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
}

.game-entry-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.game-entry-emoji {
  font-size: 56rpx;
}

.game-entry-text {
  flex: 1;
}

.game-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
}

.game-entry-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.game-entry-right {
  flex-shrink: 0;
}

.game-entry-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 24rpx;
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
}

.game-arrow {
  font-size: 28rpx;
  font-weight: 300;
  line-height: 1;
}

.recycle-entry-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(91, 189, 114, 0.25);
}

.recycle-entry-card:active {
  transform: scale(0.98);
}

.recycle-entry-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 50%, #3D9140 100%);
}

.learning-entry-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(155, 89, 182, 0.25);
}

.learning-entry-card:active {
  transform: scale(0.98);
}

.learning-entry-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #9B59B6 0%, #7D66C8 40%, #5BBD72 100%);
}

.learning-entry-bg::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.learning-entry-bg::before {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.learning-entry-tag {
  position: absolute;
  top: 20rpx;
  right: -42rpx;
  transform: rotate(45deg);
  background: linear-gradient(90deg, #FF6B6B, #EE5A5A);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 60rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 12rpx rgba(238, 90, 90, 0.4);
}

.learning-path-entry-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(255, 152, 0, 0.25);
}

.learning-path-entry-card:active {
  transform: scale(0.98);
}

.learning-path-entry-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF9800 0%, #FFB74D 40%, #5BBD72 100%);
}

.learning-path-entry-bg::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.learning-path-entry-bg::before {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.verify-entry-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(91, 189, 114, 0.25);
}

.verify-entry-card:active {
  transform: scale(0.98);
}

.verify-entry-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #5BBD72 0%, #3A9D5A 50%, #27AE60 100%);
}

.verify-entry-bg::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.verify-entry-bg::before {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

/* ==================== 快捷功能区域 ==================== */
.quick-actions-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.quick-actions-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.quick-actions-title-wrapper {
  display: flex;
  align-items: center;
}

.quick-actions-title-icon {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #4AA862 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.quick-actions-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.quick-actions-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.quick-actions-grid {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 36rpx 24rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.quick-actions-grid.six-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 36rpx 16rpx;
}

.quick-actions-grid.six-grid .quick-action-item {
  flex: none;
}

.quick-actions-grid.seven-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 36rpx 16rpx;
}

.quick-actions-grid.seven-grid .quick-action-item {
  flex: none;
}

.quick-actions-grid.eight-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40rpx 12rpx;
}

.quick-actions-grid.eight-grid .quick-action-item {
  flex: none;
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  transition: transform 0.2s ease;
}

.quick-action-item:active {
  transform: scale(0.92);
}

.quick-action-icon-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.quick-action-icon-ring {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  right: -4rpx;
  bottom: -4rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(91, 189, 114, 0.15);
  pointer-events: none;
}

.quick-action-icon {
  width: 48rpx;
  height: 48rpx;
}

.quick-action-emoji {
  font-size: 48rpx;
  line-height: 1;
  position: relative;
  z-index: 2;
}

.quick-action-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
}

/* ==================== 区域标题 ==================== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
}

.section-title-icon {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #4AA862 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-subtitle-wrapper {
  display: flex;
  align-items: center;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.section-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-left: 4rpx;
}

/* ==================== 垃圾分类卡片区域 ==================== */
.trash-types-section {
  padding: 0 32rpx;
}

.trash-types-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.trash-type-card {
  position: relative;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  overflow: hidden;
  transition: all 0.3s ease;
}

.trash-type-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 30rpx rgba(91, 189, 114, 0.15);
}

/* 卡片背景装饰 */
.card-decoration {
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--card-bg);
  opacity: 0.6;
}

/* 练一练按钮 */
.practice-btn {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 18rpx;
  background: var(--btn-color);
  color: #fff;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  z-index: 10;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.practice-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.practice-btn-icon {
  font-size: 22rpx;
}

.practice-btn-text {
  font-size: 22rpx;
}

/* 垃圾桶图标容器 */
.trash-icon-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: var(--card-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.trash-icon {
  width: 64rpx;
  height: 64rpx;
}

.trash-icon-emoji {
  font-size: 56rpx;
  line-height: 1;
}

/* 分类信息 */
.trash-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.trash-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.trash-english {
  font-size: 24rpx;
  color: var(--card-color);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* 箭头指示 */
.card-arrow {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--card-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 40rpx;
  color: var(--card-color);
  font-weight: 300;
  line-height: 1;
}

/* ==================== 今日环保小贴士 ==================== */
.eco-tips-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.eco-tip-card {
  display: flex;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 248, 230, 0.9) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(243, 156, 18, 0.1);
  border: 1rpx solid rgba(243, 156, 18, 0.1);
}

.eco-tip-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(243, 156, 18, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.eco-tip-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.eco-tip-content {
  flex: 1;
  min-width: 0;
}

.eco-tip-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.eco-tip-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.eco-tip-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.eco-tip-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.eco-tip-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 16rpx;
  gap: 10rpx;
}

.eco-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: rgba(243, 156, 18, 0.25);
  transition: all 0.3s ease;
}

.eco-dot.active {
  width: 28rpx;
  background: #F39C12;
}

/* ==================== 本周热点动态 ==================== */
.hot-news-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.hot-news-item {
  display: flex;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.2s ease;
}

.hot-news-item:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 30rpx rgba(91, 189, 114, 0.15);
}

.hot-news-item:last-child {
  margin-bottom: 0;
}

.hot-news-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #E85D5D 0%, #C0392B 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hot-news-item:nth-child(n+4) .hot-news-index {
  background: linear-gradient(135deg, #B2BEC3 0%, #95A5A6 100%);
}

.hot-news-content {
  flex: 1;
  min-width: 0;
}

.hot-news-header {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.hot-news-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.hot-news-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.4;
  flex: 1;
}

.hot-news-footer {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hot-news-source {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.hot-news-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ==================== 底部提示 ==================== */
.footer-tips {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
}

.tips-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
}

/* ==================== 动画效果 ==================== */
@keyframes cardFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.trash-type-card {
  animation: cardFadeIn 0.4s ease forwards;
}

.trash-type-card:nth-child(1) { animation-delay: 0.1s; }
.trash-type-card:nth-child(2) { animation-delay: 0.2s; }
.trash-type-card:nth-child(3) { animation-delay: 0.3s; }
.trash-type-card:nth-child(4) { animation-delay: 0.4s; }

/* ==================== 拍一拍识垃圾悬浮按钮 ==================== */
.photo-recognize-float {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  z-index: 999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.photo-float-ring {
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(91, 189, 114, 0.3);
  animation: floatPulse 2s ease-in-out infinite;
  z-index: -1;
}

@keyframes floatPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.15);
    opacity: 0.3;
  }
}

.photo-float-btn {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.4);
  transition: transform 0.2s ease;
}

.photo-float-btn:active {
  transform: scale(0.92);
}

.photo-float-icon {
  font-size: 48rpx;
  line-height: 1;
}

.photo-float-text {
  font-size: 20rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}
