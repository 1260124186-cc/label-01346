<!--
  首页
  功能：展示轮播图、快捷功能、四种垃圾分类卡片
  考核点：swiper组件、wx:for、bindtap事件、view/image标签
-->
<view class="page-container">
  <!-- 搜索框入口 -->
  <view class="search-section">
    <view class="search-entry" bindtap="goToSearch">
      <text class="search-entry-icon">🔍</text>
      <text class="search-entry-placeholder">搜索垃圾名称，如：塑料瓶、废电池</text>
    </view>
  </view>

  <!-- 顶部轮播图区域 -->
  <view class="banner-section">
    <swiper
      class="banner-swiper"
      indicator-dots="{{false}}"
      autoplay="{{true}}"
      interval="{{4000}}"
      duration="{{500}}"
      circular="{{true}}"
      bindchange="onBannerChange"
    >
      <swiper-item
        wx:for="{{bannerList}}"
        wx:key="id"
        class="banner-item"
      >
        <view
          class="banner-image-wrapper"
          bindtap="onBannerTap"
          data-item="{{item}}"
        >
          <image
            class="banner-image"
            src="{{item.image}}"
            mode="aspectFill"
          />
          <view class="banner-overlay">
            <text class="banner-title">{{item.title}}</text>
            <text class="banner-link-hint" wx:if="{{item.linkType}}">点击了解更多 ›</text>
          </view>
        </view>
      </swiper-item>
    </swiper>

    <!-- 自定义指示器 -->
    <view class="banner-indicators">
      <view
        wx:for="{{bannerList}}"
        wx:key="id"
        class="indicator-dot {{currentBannerIndex === index ? 'active' : ''}}"
      />
    </view>
  </view>

  <!-- 每日签到入口 -->
  <view class="signin-entry-section" bindtap="goToSignIn">
    <view class="signin-entry-card">
      <view class="signin-entry-left">
        <view class="signin-entry-emoji">{{isSignedToday ? '✅' : '📅'}}</view>
        <view class="signin-entry-text">
          <view class="signin-entry-title">{{isSignedToday ? '今日已签到' : '每日签到'}}</view>
          <view class="signin-entry-subtitle">
            连续打卡 {{streakDays}} 天 · 每日+5积分，连续7天+50积分
          </view>
        </view>
      </view>
      <view class="signin-entry-btn {{isSignedToday ? 'done' : ''}}">
        {{isSignedToday ? '已完成' : '去签到'}}
      </view>
    </view>
  </view>

  <!-- 积分即将过期弱提示 badge -->
  <view wx:if="{{expiringBadge && expiringBadge.points > 0}}" class="expiring-badge-section" bindtap="goToPoints">
    <view class="expiring-badge-card">
      <view class="expiring-badge-icon">⏰</view>
      <view class="expiring-badge-text">
        <text class="badge-points">¥{{expiringBadge.points}}</text>
        <text class="badge-label">积分将于 {{expiringBadge.dateLabel}} 过期</text>
      </view>
      <view class="expiring-badge-arrow">›</view>
    </view>
  </view>

  <!-- 我的学习路径入口 -->
  <view class="game-entry-section" bindtap="goToLearningPath">
    <view class="learning-path-entry-card">
      <view class="learning-path-entry-bg"></view>
      <view class="game-entry-content">
        <view class="game-entry-left">
          <view class="game-entry-emoji">🗺️</view>
          <view class="game-entry-text">
            <view class="game-entry-title">我的学习路径</view>
            <view class="game-entry-subtitle">
              阅读常识 · 分类练习 · 章节闯关 · 课程学习 · 游戏通关
            </view>
          </view>
        </view>
        <view class="game-entry-right">
          <view class="game-entry-btn" style="background: linear-gradient(135deg, #FF9800 0%, #5BBD72 100%);">
            <text>去学习</text>
            <text class="game-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 证书验真入口 -->
  <view class="game-entry-section" bindtap="goToVerify">
    <view class="verify-entry-card">
      <view class="verify-entry-bg"></view>
      <view class="game-entry-content">
        <view class="game-entry-left">
          <view class="game-entry-emoji">🔐</view>
          <view class="game-entry-text">
            <view class="game-entry-title">证书公开验真</view>
            <view class="game-entry-subtitle">
              扫码或输入证书编号 · 快速验证结业证书真伪 · 适用于学校企业HR
            </view>
          </view>
        </view>
        <view class="game-entry-right">
          <view class="game-entry-btn" style="background: linear-gradient(135deg, #5BBD72 0%, #27AE60 100%);">
            <text>去验真</text>
            <text class="game-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 垃圾分类小游戏入口 -->
  <view class="game-entry-section" bindtap="goToGameHall">
    <view class="game-entry-card">
      <view class="game-entry-bg"></view>
      <view class="game-entry-content">
        <view class="game-entry-left">
          <view class="game-entry-emoji">🎮</view>
          <view class="game-entry-text">
            <view class="game-entry-title">垃圾分类小游戏</view>
            <view class="game-entry-subtitle">
              接垃圾 · 分拣流水线 · 记忆配对 · 通关赢积分
            </view>
          </view>
        </view>
        <view class="game-entry-right">
          <view class="game-entry-btn">
            <text>去挑战</text>
            <text class="game-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 上门回收入口 -->
  <view class="game-entry-section" bindtap="goToRecycleBook">
    <view class="recycle-entry-card">
      <view class="recycle-entry-bg"></view>
      <view class="game-entry-content">
        <view class="game-entry-left">
          <view class="game-entry-emoji">🚛</view>
          <view class="game-entry-text">
            <view class="game-entry-title">预约上门回收</view>
            <view class="game-entry-subtitle">
              家电 · 家具 · 过期药品 · 废旧电池 · 完成得高额积分
            </view>
          </view>
        </view>
        <view class="game-entry-right">
          <view class="game-entry-btn" style="background: #5BBD72;">
            <text>去预约</text>
            <text class="game-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 学习中心入口 -->
  <view class="game-entry-section" bindtap="goToLearningCenter">
    <view class="learning-entry-card">
      <view class="learning-entry-bg"></view>
      <view class="game-entry-content">
        <view class="game-entry-left">
          <view class="game-entry-emoji">📚</view>
          <view class="game-entry-text">
            <view class="game-entry-title">环保学习中心</view>
            <view class="game-entry-subtitle">
              结构化课程 · 视频/图文讲解 · 课后测验 · 结业拿电子证书
            </view>
          </view>
        </view>
        <view class="game-entry-right">
          <view class="game-entry-btn" style="background: linear-gradient(135deg, #9B59B6 0%, #5BBD72 100%);">
            <text>去学习</text>
            <text class="game-arrow">›</text>
          </view>
        </view>
      </view>
      <view class="learning-entry-tag">NEW</view>
    </view>
  </view>

  <!-- 快捷功能区域 -->
  <view class="quick-actions-section">
    <view class="quick-actions-header">
      <view class="quick-actions-title-wrapper">
        <view class="quick-actions-title-icon"></view>
        <text class="quick-actions-title">快捷功能</text>
      </view>
      <text class="quick-actions-desc">常用功能一键直达</text>
    </view>
    <view class="quick-actions-grid eight-grid">
      <view
        wx:for="{{quickActions}}"
        wx:key="key"
        class="quick-action-cell"
      >
        <view
          class="quick-action-item"
          bindtap="onQuickActionTap"
          data-action="{{item.action}}"
        >
          <view
            class="quick-action-icon-wrapper"
            style="background: {{item.bgGradient}};"
          >
            <view
              class="quick-action-icon-ring"
              style="border-color: {{item.ringColor}};"
            ></view>
            <text class="quick-action-emoji">{{item.emoji}}</text>
          </view>
          <text class="quick-action-name">{{item.name}}</text>
          <view wx:if="{{item.tag}}" class="quick-action-tag">{{item.tag}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 垃圾分类标题 -->
  <view class="section-header">
    <view class="section-title-wrapper">
      <view class="section-title-icon"></view>
      <text class="section-title">垃圾分类</text>
    </view>
    <view class="section-subtitle-wrapper" bindtap="goToFirstClassify">
      <text class="section-subtitle">点击了解分类详情</text>
      <text class="section-arrow">›</text>
    </view>
  </view>

  <!-- 今日环保小贴士 -->
  <view class="section-header">
    <view class="section-title-wrapper">
      <view class="section-title-icon" style="background: linear-gradient(180deg, #F39C12 0%, #E67E22 100%);"></view>
      <text class="section-title">今日环保小贴士</text>
    </view>
  </view>
  <view class="eco-tips-section">
    <view class="eco-tip-card">
      <view class="eco-tip-icon-wrapper">
        <text class="eco-tip-emoji">{{currentTip.icon}}</text>
      </view>
      <view class="eco-tip-content">
        <view class="eco-tip-header">
          <text class="eco-tip-title">{{currentTip.title}}</text>
          <text class="eco-tip-tag" style="background: rgba(243, 156, 18, 0.1); color: #F39C12;">{{currentTip.tag}}</text>
        </view>
        <text class="eco-tip-desc">{{currentTip.content}}</text>
      </view>
    </view>
    <view class="eco-tip-dots">
      <view
        wx:for="{{ecoTips}}"
        wx:key="id"
        class="eco-dot {{currentTipIndex === index ? 'active' : ''}}"
        bindtap="onTipDotTap"
        data-index="{{index}}"
      />
    </view>
  </view>

  <!-- 本周热点垃圾动态 -->
  <view class="section-header">
    <view class="section-title-wrapper">
      <view class="section-title-icon" style="background: linear-gradient(180deg, #E85D5D 0%, #C0392B 100%);"></view>
      <text class="section-title">本周热点动态</text>
    </view>
  </view>
  <view class="hot-news-section">
    <view
      wx:for="{{hotNews}}"
      wx:key="id"
      class="hot-news-item"
      bindtap="onHotNewsTap"
      data-item="{{item}}"
    >
      <view class="hot-news-index">{{index + 1}}</view>
      <view class="hot-news-content">
        <view class="hot-news-header">
          <text class="hot-news-tag" style="background: {{item.tagColor}}20; color: {{item.tagColor}};">{{item.tag}}</text>
          <text class="hot-news-title">{{item.title}}</text>
        </view>
        <view class="hot-news-footer">
          <text class="hot-news-source">{{item.source}}</text>
          <text class="hot-news-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 四种垃圾分类卡片 - 使用 wx:for 循环渲染 -->
  <view class="trash-types-section">
    <view class="trash-types-grid">
      <view
        wx:for="{{trashTypes}}"
        wx:key="id"
        class="trash-type-card"
        bindtap="goToClassify"
        bindlongpress="onTrashCardLongPress"
        data-item="{{item}}"
        style="--card-color: {{item.color}}; --card-bg: {{item.bgColor}};"
      >
        <!-- 卡片背景装饰 -->
        <view class="card-decoration"></view>

        <!-- 垃圾桶图标 -->
        <view class="trash-icon-wrapper">
          <text class="trash-icon-emoji">{{item.emoji}}</text>
        </view>

        <!-- 分类信息 -->
        <view class="trash-info">
          <text class="trash-name">{{item.name}}</text>
          <text class="trash-english">{{item.englishName}}</text>
        </view>

        <!-- 练一练按钮 -->
        <view class="practice-btn" catchtap="startSortPractice" data-item="{{item}}" style="--btn-color: {{item.color}};">
          <text class="practice-btn-icon">✏️</text>
          <text class="practice-btn-text">练一练</text>
        </view>

        <!-- 箭头指示 -->
        <view class="card-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tips">
    <text class="tips-text">垃圾分类，从我做起，保护环境，人人有责</text>
  </view>

  <!-- 拍一拍识垃圾悬浮入口 -->
  <view class="photo-recognize-float" bindtap="goToPhotoRecognize">
    <view class="photo-float-ring"></view>
    <view class="photo-float-btn">
      <text class="photo-float-icon">📷</text>
    </view>
    <text class="photo-float-text">拍一拍识垃圾</text>
  </view>

  <!-- 新用户引导蒙层 -->
  <guide-mask
    wx:if="{{showGuideMask}}"
    visible="{{showGuideMask}}"
    bind:close="onGuideClose"
  />
</view>
