.record-page {
  min-height: 100vh;
  background: #F7FAF8;
}

.dark-mode.record-page {
  background: #1A1A1A;
}

.tabs-bar {
  display: flex;
  background: #FFFFFF;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.dark-mode .tabs-bar {
  background: #2A2A2A;
  border-bottom-color: #3A3A3A;
}

.tab-item {
  flex: 1;
  padding: 28rpx 0;
  text-align: center;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.dark-mode .tab-text {
  color: #AAAAAA;
}

.tab-item.active .tab-text {
  color: #16A085;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #16A085;
  border-radius: 3rpx;
}

.form-card {
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  margin: 20rpx 0 20rpx;
}

.dark-mode .section-title {
  color: #E0E0E0;
}

.category-tabs {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.category-tab {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 2rpx solid #E8E8E8;
}

.dark-mode .category-tab {
  background: #2A2A2A;
  border-color: #3A3A3A;
  color: #CCCCCC;
}

.category-tab.active {
  border-color: transparent;
}

.cat-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.cat-name {
  font-size: 26rpx;
  font-weight: 500;
}

.activity-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.activity-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid #E8E8E8;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}

.dark-mode .activity-item {
  background: #2A2A2A;
  border-color: #3A3A3A;
}

.activity-item.active {
  border-color: #16A085;
  background: rgba(22, 160, 133, 0.06);
}

.activity-emoji {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.activity-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.dark-mode .activity-name {
  color: #E0E0E0;
}

.activity-factor {
  font-size: 22rpx;
  color: #999999;
}

.quantity-input-row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx;
  border: 2rpx solid #E8E8E8;
}

.dark-mode .quantity-input-row {
  background: #2A2A2A;
  border-color: #3A3A3A;
}

.qty-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 40rpx;
  font-weight: 600;
}

.qty-btn.minus {
  background: #F5F5F5;
  color: #666666;
}

.dark-mode .qty-btn.minus {
  background: #3A3A3A;
  color: #CCCCCC;
}

.qty-btn.plus {
  background: #16A085;
  color: #FFFFFF;
}

.qty-input {
  flex: 1;
  height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.dark-mode .qty-input {
  color: #E0E0E0;
}

.quick-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.quick-btn {
  padding: 14rpx 28rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #16A085;
  border: 2rpx solid rgba(22, 160, 133, 0.3);
}

.dark-mode .quick-btn {
  background: #2A2A2A;
}

.note-input {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
  border: 2rpx solid #E8E8E8;
}

.dark-mode .note-input {
  background: #2A2A2A;
  border-color: #3A3A3A;
  color: #E0E0E0;
}

.preview-card {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #16A085 0%, #27AE60 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
}

.preview-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 12rpx;
}

.preview-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 12rpx;
}

.preview-number {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.preview-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 12rpx;
}

.preview-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.5;
}

.submit-btn {
  margin-top: 40rpx;
  background: #16A085;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  overflow-x: auto;
  white-space: nowrap;
  border-bottom: 1rpx solid #F0F0F0;
}

.dark-mode .filter-bar {
  background: #2A2A2A;
  border-bottom-color: #3A3A3A;
}

.filter-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  background: #F5F5F5;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666666;
  flex-shrink: 0;
}

.dark-mode .filter-item {
  background: #3A3A3A;
  color: #AAAAAA;
}

.filter-item.active {
  color: #FFFFFF;
}

.records-list {
  padding: 24rpx;
}

.record-item {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.dark-mode .record-item {
  background: #2A2A2A;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(22, 160, 133, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-content {
  flex: 1;
  min-width: 0;
}

.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.dark-mode .record-name {
  color: #E0E0E0;
}

.record-co2e {
  font-size: 28rpx;
  color: #16A085;
  font-weight: 600;
}

.record-bottom {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.record-qty,
.record-time,
.record-source {
  font-size: 22rpx;
  color: #999999;
}

.record-source {
  padding: 4rpx 12rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  color: #666666;
}

.dark-mode .record-source {
  background: #3A3A3A;
  color: #AAAAAA;
}

.record-note {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #F8FBF9;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.dark-mode .record-note {
  background: #333333;
  color: #AAAAAA;
}

.record-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  margin-top: 8rpx;
  color: #CCCCCC;
  font-size: 40rpx;
  flex-shrink: 0;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
