/**
 * 分类记录页面样式
 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F7FAF8 20%);
  padding-bottom: 48rpx;
}

/* 统计概览 */
.summary-section {
  padding: 24rpx 32rpx;
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.3);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.summary-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 分类统计 */
.category-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

.category-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.category-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  backdrop-filter: blur(10rpx);
}

.category-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.category-count {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--item-color);
}

/* 记录列表 */
.records-section {
  padding: 0 32rpx;
}

.records-list {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  overflow: hidden;
  backdrop-filter: blur(10rpx);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-emoji {
  font-size: 36rpx;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 4rpx;
}

.record-type {
  font-size: 24rpx;
  color: #999999;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.record-points {
  font-size: 28rpx;
  font-weight: 600;
  color: #5BBD72;
  margin-bottom: 4rpx;
}

.record-time {
  font-size: 22rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}
