.page-container {
  min-height: 100vh;
  padding: var(--spacing-xl);
  padding-bottom: calc(var(--spacing-xl) + 160rpx);
  box-sizing: border-box;
}

/* ==================== 无组状态 ==================== */
.empty-group-section {
  padding: var(--spacing-xxl) 0;
}

.empty-group-card {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xxl) var(--spacing-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
}

.empty-group-icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-lg);
  line-height: 1;
}

.empty-group-title {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.empty-group-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-bottom: var(--spacing-xxl);
}

.empty-buttons {
  display: flex;
  gap: var(--spacing-md);
  width: 100%;
}

.empty-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg) var(--spacing-md);
  border-radius: var(--radius-lg);
  transition: all var(--transition-fast) ease;
}

.empty-btn:active {
  transform: scale(0.96);
}

.empty-btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  box-shadow: 0 6rpx 20rpx rgba(91, 189, 114, 0.3);
}

.empty-btn-outline {
  background: var(--bg-card-solid);
  border: 2rpx solid var(--color-primary);
}

.empty-btn-icon {
  font-size: 48rpx;
  margin-bottom: var(--spacing-xs);
  line-height: 1;
}

.empty-btn-text {
  font-size: var(--font-md);
  font-weight: 600;
}

.empty-btn-primary .empty-btn-text {
  color: var(--text-white);
}

.empty-btn-outline .empty-btn-text {
  color: var(--color-primary);
}

/* ==================== 组切换栏 ==================== */
.group-switch-section {
  margin-bottom: var(--spacing-lg);
}

.group-switch-scroll {
  white-space: nowrap;
}

.group-switch-item {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  margin-right: var(--spacing-sm);
  box-shadow: var(--shadow-light);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast) ease;
}

.group-switch-item-active {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.3);
}

.group-switch-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  line-height: 1;
}

.group-switch-name {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-secondary);
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-switch-item-active .group-switch-name {
  color: var(--text-white);
}

/* ==================== 组信息卡片 ==================== */
.group-info-card {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-medium);
}

.group-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--color-primary) 0%, #3DA35D 100%);
  opacity: 0.95;
}

.group-card-content {
  position: relative;
  padding: var(--spacing-xl);
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-xl);
}

.group-type-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-lg);
  flex-shrink: 0;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.group-type-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.group-header-info {
  flex: 1;
  min-width: 0;
}

.group-name-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-xs);
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.group-name {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--text-white);
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-type-tag {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-xs);
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.type-tag-text {
  font-size: var(--font-xs);
  color: var(--text-white);
  font-weight: 500;
}

.group-creator {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.85);
}

.group-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg) 0;
}

.group-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.group-stat-value {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-white);
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.group-stat-label {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.8);
}

.group-stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ==================== 卡片通用样式 ==================== */
.card {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
}

.section-header-left {
  display: flex;
  align-items: center;
}

.section-header-icon {
  font-size: 36rpx;
  margin-right: var(--spacing-sm);
  line-height: 1;
}

.section-header-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

/* ==================== 邀请成员区域 ==================== */
.invite-btn {
  padding: var(--spacing-xs) var(--spacing-md);
  background: var(--color-primary-light);
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast) ease;
}

.invite-btn:active {
  transform: scale(0.96);
}

.invite-btn-shown {
  background: rgba(142, 142, 147, 0.1);
}

.invite-btn-text {
  font-size: var(--font-xs);
  color: var(--color-primary);
  font-weight: 500;
}

.invite-btn-shown .invite-btn-text {
  color: var(--text-secondary);
}

.invite-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-code-area {
  width: 280rpx;
  height: 280rpx;
  background: linear-gradient(135deg, #F0FFF0 0%, #E8F5E9 100%);
  border: 4rpx dashed var(--color-primary);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-lg);
}

.qr-code-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-code-icon {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: var(--spacing-sm);
}

.qr-code-text {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.invite-code-row {
  display: flex;
  align-items: center;
  background: var(--bg-page);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-sm);
  width: 100%;
  box-sizing: border-box;
}

.invite-code-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.invite-code-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--bg-card-solid);
  border-radius: var(--radius-sm);
  margin-right: var(--spacing-sm);
  border: 2rpx solid var(--color-primary-light);
}

.invite-code-text {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 8rpx;
}

.copy-btn {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-primary);
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast) ease;
  flex-shrink: 0;
}

.copy-btn:active {
  transform: scale(0.96);
}

.copy-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
  line-height: 1;
}

.copy-text {
  font-size: var(--font-xs);
  color: var(--text-white);
  font-weight: 500;
}

/* ==================== 组积分池 ==================== */
.points-pool-content {
  display: flex;
  gap: var(--spacing-md);
}

.points-pool-item {
  flex: 1;
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.points-pool-total {
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.1) 0%, rgba(91, 189, 114, 0.05) 100%);
  border: 1rpx solid var(--color-primary-light);
}

.points-pool-week {
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.1) 0%, rgba(255, 193, 7, 0.05) 100%);
  border: 1rpx solid rgba(255, 193, 7, 0.2);
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.points-pool-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
}

.points-pool-total .points-pool-label {
  margin-bottom: var(--spacing-sm);
}

.points-pool-value {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.week-added-badge {
  padding: 6rpx 20rpx;
  background: linear-gradient(135deg, #FFC107 0%, #FF9800 100%);
  border-radius: var(--radius-xl);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.25);
}

.week-added-value {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-white);
}

/* ==================== 组作业入口 ==================== */
.homework-section {
  margin-top: var(--spacing-md);
  transition: all var(--transition-fast) ease;
}

.homework-section:active {
  transform: scale(0.98);
}

.homework-entry {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.entry-label {
  font-size: var(--font-sm);
  color: var(--color-primary);
  font-weight: 500;
}

.entry-arrow {
  font-size: 28rpx;
  color: var(--color-primary);
}

.homework-stats {
  display: flex;
  justify-content: space-around;
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--border-light);
}

.homework-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}

.homework-stat-value {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.homework-stat-label {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

/* ==================== 组徽章 ==================== */
.badge-section {
  margin-top: var(--spacing-md);
}

.badge-count {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.badge-scroll {
  width: 100%;
  white-space: nowrap;
}

.badge-list {
  display: inline-flex;
  gap: var(--spacing-md);
  padding: var(--spacing-sm) 0;
}

.badge-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 120rpx;
}

.badge-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-emoji {
  font-size: 44rpx;
}

.badge-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  white-space: nowrap;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ==================== 成员列表 ==================== */
.member-count {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.member-list {
  margin: 0 calc(-1 * var(--spacing-lg));
}

.member-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-top: 1rpx solid var(--border-light);
  transition: background var(--transition-fast) ease;
}

.member-item:first-child {
  border-top: none;
}

.member-item:active {
  background: var(--bg-page);
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.member-avatar-emoji {
  font-size: 40rpx;
  line-height: 1;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
}

.member-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-role-tag {
  padding: 2rpx 12rpx;
  border-radius: var(--radius-xs);
}

.role-tag-text {
  font-size: 20rpx;
  font-weight: 500;
}

.role-owner {
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.15) 0%, rgba(255, 152, 0, 0.1) 100%);
}

.role-owner .role-tag-text {
  color: #FF9800;
}

.role-admin {
  background: rgba(91, 189, 114, 0.1);
}

.role-admin .role-tag-text {
  color: var(--color-primary);
}

.role-member {
  background: rgba(142, 142, 147, 0.1);
}

.role-member .role-tag-text {
  color: var(--text-tertiary);
}

.member-join-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.member-actions {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-left: var(--spacing-sm);
}

.member-action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast) ease;
}

.member-action-btn:active {
  transform: scale(0.9);
}

.action-role {
  background: rgba(91, 189, 114, 0.1);
}

.action-remove {
  background: rgba(255, 59, 48, 0.1);
}

.action-icon {
  font-size: 26rpx;
  line-height: 1;
}

/* ==================== 底部操作区 ==================== */
.footer-actions {
  display: flex;
  gap: var(--spacing-md);
  margin-top: var(--spacing-lg);
}

.footer-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-lg);
  transition: all var(--transition-fast) ease;
}

.footer-btn:active {
  transform: scale(0.96);
}

.footer-btn-join {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 2rpx solid var(--color-primary);
  box-shadow: var(--shadow-light);
}

.footer-btn-join .footer-btn-icon,
.footer-btn-join .footer-btn-text {
  color: var(--color-primary);
}

.footer-btn-leave {
  background: linear-gradient(135deg, #FF9500 0%, #FF6B00 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 0, 0.25);
}

.footer-btn-dismiss {
  background: linear-gradient(135deg, #FF3B30 0%, #D32F2F 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 59, 48, 0.25);
}

.footer-btn-icon {
  font-size: 32rpx;
  margin-right: var(--spacing-sm);
  line-height: 1;
}

.footer-btn-text {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-white);
}

/* ==================== 弹窗通用样式 ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn var(--transition-normal) ease;
}

.modal-content {
  width: 600rpx;
  background: var(--bg-card-solid);
  border-radius: var(--radius-xl);
  overflow: hidden;
  animation: modalIn var(--transition-normal) ease;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg) var(--spacing-xl);
  border-bottom: 1rpx solid var(--border-light);
}

.modal-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-round);
  transition: background var(--transition-fast) ease;
}

.modal-close:active {
  background: var(--bg-page);
}

.close-icon {
  font-size: 28rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.modal-body {
  padding: var(--spacing-xl);
}

.modal-footer {
  display: flex;
  gap: var(--spacing-md);
  padding: var(--spacing-lg) var(--spacing-xl) var(--spacing-xl);
}

.modal-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-md) 0;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast) ease;
}

.modal-btn:active {
  transform: scale(0.96);
}

.modal-btn-cancel {
  background: var(--bg-page);
}

.modal-btn-text {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--text-secondary);
}

.modal-btn-confirm {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.3);
}

.modal-btn-text-white {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-white);
}

/* ==================== 表单样式 ==================== */
.form-item {
  margin-bottom: var(--spacing-lg);
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
}

.type-selector {
  display: flex;
  gap: var(--spacing-md);
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg) var(--spacing-md);
  background: var(--bg-page);
  border: 3rpx solid transparent;
  border-radius: var(--radius-lg);
  transition: all var(--transition-fast) ease;
}

.type-option:active {
  transform: scale(0.96);
}

.type-option-active {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.type-option-family.type-option-active {
  border-color: var(--color-primary);
  background: rgba(91, 189, 114, 0.1);
}

.type-option-class.type-option-active {
  border-color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
}

.type-option-icon {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: var(--spacing-sm);
}

.type-option-name {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-secondary);
}

.type-option-active .type-option-name {
  color: var(--color-primary);
  font-weight: 600;
}

.type-option-class.type-option-active .type-option-name {
  color: #4A90D9;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--spacing-lg);
  background: var(--bg-page);
  border: 2rpx solid var(--border-light);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  color: var(--text-primary);
  box-sizing: border-box;
  transition: all var(--transition-fast) ease;
}

.form-input:focus {
  border-color: var(--color-primary);
  background: var(--bg-card-solid);
}

.form-input-code {
  text-align: center;
  font-size: var(--font-xl);
  font-weight: 600;
  letter-spacing: 16rpx;
  color: var(--color-primary);
}

.input-placeholder {
  color: var(--text-tertiary);
  font-size: var(--font-sm);
  letter-spacing: 0;
  text-align: left;
  font-weight: 400;
}

.join-hint {
  display: block;
  margin-top: var(--spacing-sm);
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  text-align: center;
}

/* ==================== 角色选择弹窗 ==================== */
.role-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  background: var(--bg-page);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-md);
  transition: all var(--transition-fast) ease;
  border: 2rpx solid transparent;
}

.role-option:last-child {
  margin-bottom: 0;
}

.role-option:active {
  transform: scale(0.98);
}

.role-option-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.role-option-icon {
  font-size: 48rpx;
  line-height: 1;
  margin-right: var(--spacing-md);
}

.role-option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.role-option-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.role-option-desc {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.role-option-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-round);
  border: 3rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all var(--transition-fast) ease;
}

.role-option-check.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.check-icon {
  font-size: 26rpx;
  color: var(--text-white);
  font-weight: 700;
  line-height: 1;
}
