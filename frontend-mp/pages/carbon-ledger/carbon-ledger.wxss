.carbon-page {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 40rpx;
}

.dark-mode.carbon-page {
  background: #1A1A1A;
}

.header-card {
  position: relative;
  margin: 0;
  padding: 60rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #16A085 0%, #27AE60 50%, #2ECC71 100%);
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
}

.total-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.total-value {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.total-number {
  font-size: 88rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
  letter-spacing: -2rpx;
}

.total-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 12rpx;
  font-weight: 500;
}

.carbon-points {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.18);
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
}

.points-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.points-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.analogy-grid {
  display: flex;
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  padding: 28rpx 0;
  position: relative;
  z-index: 1;
}

.analogy-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.15);
}

.analogy-item:last-child {
  border-right: none;
}

.analogy-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.analogy-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.analogy-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 6rpx;
}

.action-row {
  display: flex;
  margin: -30rpx 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(22, 160, 133, 0.12);
  position: relative;
  z-index: 2;
}

.dark-mode .action-row {
  background: #2A2A2A;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.dark-mode .action-text {
  color: #E0E0E0;
}

.milestone-card {
  display: flex;
  align-items: center;
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.dark-mode .milestone-card {
  background: #2A2A2A;
}

.milestone-left {
  flex: 1;
  display: flex;
  align-items: center;
}

.milestone-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.milestone-icon {
  font-size: 48rpx;
}

.milestone-info {
  flex: 1;
}

.milestone-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.dark-mode .milestone-title {
  color: #E0E0E0;
}

.milestone-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
}

.milestone-progress-bar {
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.dark-mode .milestone-progress-bar {
  background: #3A3A3A;
}

.milestone-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.milestone-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
}

.chart-card {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.dark-mode .chart-card {
  background: #2A2A2A;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.chart-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.dark-mode .chart-title {
  color: #E0E0E0;
}

.chart-tabs {
  display: flex;
  background: #F5F5F5;
  border-radius: 20rpx;
  padding: 4rpx;
}

.dark-mode .chart-tabs {
  background: #3A3A3A;
}

.chart-tab {
  padding: 10rpx 32rpx;
  font-size: 24rpx;
  color: #999999;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.chart-tab.active {
  background: #16A085;
  color: #FFFFFF;
  font-weight: 500;
}

.chart-body {
  margin-bottom: 32rpx;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 220rpx;
  padding: 0 8rpx;
}

.chart-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.chart-bar-wrapper {
  flex: 1;
  width: 36rpx;
  display: flex;
  flex-direction: column-reverse;
  align-items: center;
  position: relative;
}

.chart-bar {
  width: 100%;
  background: linear-gradient(180deg, #2ECC71 0%, #16A085 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 6rpx;
  transition: height 0.3s;
}

.chart-bar-value {
  position: absolute;
  top: -36rpx;
  font-size: 20rpx;
  color: #666666;
  white-space: nowrap;
}

.dark-mode .chart-bar-value {
  color: #AAAAAA;
}

.chart-bar-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 12rpx;
}

.compare-row {
  display: flex;
  align-items: center;
  background: #F8FBF9;
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.dark-mode .compare-row {
  background: #333333;
}

.compare-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.compare-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.compare-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.dark-mode .compare-value {
  color: #E0E0E0;
}

.compare-value.my {
  color: #16A085;
}

.compare-divider {
  width: 1rpx;
  height: 48rpx;
  background: #E5E5E5;
}

.dark-mode .compare-divider {
  background: #444444;
}

.category-card,
.recent-card {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.dark-mode .category-card,
.dark-mode .recent-card {
  background: #2A2A2A;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.dark-mode .card-title {
  color: #E0E0E0;
}

.card-more {
  font-size: 24rpx;
  color: #16A085;
}

.category-list {
  display: flex;
  flex-direction: column;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.dark-mode .category-item {
  border-bottom-color: #3A3A3A;
}

.category-item:last-child {
  border-bottom: none;
}

.category-left {
  flex: 1;
  display: flex;
  align-items: center;
}

.category-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.category-info {
  display: flex;
  flex-direction: column;
}

.category-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.dark-mode .category-name {
  color: #E0E0E0;
}

.category-count {
  font-size: 22rpx;
  color: #999999;
}

.category-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 160rpx;
}

.category-co2e {
  font-size: 28rpx;
  color: #16A085;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.category-bar {
  width: 120rpx;
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.dark-mode .category-bar {
  background: #3A3A3A;
}

.category-bar-fill {
  height: 100%;
  border-radius: 4rpx;
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.dark-mode .recent-item {
  border-bottom-color: #3A3A3A;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.recent-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recent-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.dark-mode .recent-name {
  color: #E0E0E0;
}

.recent-time {
  font-size: 22rpx;
  color: #999999;
}

.recent-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.recent-quantity {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.dark-mode .recent-quantity {
  color: #AAAAAA;
}

.recent-co2e {
  font-size: 26rpx;
  color: #16A085;
  font-weight: 600;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
