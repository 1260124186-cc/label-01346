/**
 * 学习中心页面样式
 * 设计风格：轻透清新风，沿用项目主色 #5BBD72
 */

.learning-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  padding-bottom: 40rpx;
}

/* ==================== 顶部区域 ==================== */
.header-card {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  margin: 0;
  padding: 60rpx 32rpx 32rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.2);
}

.header-content {
  color: #fff;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.stats-card {
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.25);
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ==================== 分类Tab ==================== */
.category-scroll {
  white-space: nowrap;
  padding: 24rpx 0 8rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.08);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.category-item.active {
  background: var(--cat-color);
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.25);
}

.category-icon {
  font-size: 28rpx;
}

.category-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #2D3436;
}

.category-item.active .category-name {
  color: #FFFFFF;
  font-weight: 600;
}

/* ==================== 课程列表区域 ==================== */
.course-section {
  padding: 24rpx 32rpx 0;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.course-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  transition: all 0.3s ease;
}

.course-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(91, 189, 114, 0.12);
}

/* 课程封面 */
.course-cover {
  position: relative;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.course-cover-icon {
  font-size: 88rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.15));
}

.course-tags {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.course-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #2D3436;
  font-size: 20rpx;
  font-weight: 500;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 课程信息 */
.course-info {
  padding: 24rpx 24rpx 20rpx;
}

.course-title-row {
  margin-bottom: 8rpx;
}

.course-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-subtitle {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.meta-difficulty {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.meta-info {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #636E72;
}

/* 进度条 */
.course-progress-row {
  margin-bottom: 16rpx;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar-bg {
  flex: 1;
  height: 10rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  font-weight: 600;
  min-width: 64rpx;
  text-align: right;
}

/* 底部信息 */
.course-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.footer-left,
.footer-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.footer-icon {
  font-size: 22rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #636E72;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #B2BEC3;
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  height: 48rpx;
}
