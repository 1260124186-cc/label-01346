.detail-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  padding-bottom: 40rpx;
}

.header-card {
  margin: 0;
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.2);
}

.header-content {
  text-align: center;
  color: #fff;
  margin-bottom: 32rpx;
}

.type-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.type-name {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.chapter-name {
  font-size: 36rpx;
  font-weight: 700;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  margin-bottom: 24rpx;
}

.stats-row .stat-item {
  text-align: center;
  min-width: 100rpx;
  padding: 0 12rpx;
}

.stats-row .stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.stats-row .stat-value.accuracy-excellent {
  color: #A8E6CF;
}

.stats-row .stat-value.accuracy-good {
  color: #B3E5FC;
}

.stats-row .stat-value.accuracy-normal {
  color: #FFE0B2;
}

.stats-row .stat-value.accuracy-poor {
  color: #FFCCBC;
}

.stats-row .stat-value.points {
  color: #FFD700;
}

.stats-row .stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.3);
}

.record-time {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.actions-section {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.98);
}

.review-btn {
  background: linear-gradient(135deg, #4A90D9 0%, #3498DB 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.25);
}

.delete-btn {
  background: rgba(232, 93, 93, 0.1);
  color: #E85D5D;
  border: 2rpx solid rgba(232, 93, 93, 0.3);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 28rpx;
}

.questions-section {
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 24rpx;
}

.questions-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.question-item {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.question-item.correct {
  border-color: rgba(91, 189, 114, 0.3);
}

.question-item.wrong {
  border-color: rgba(232, 93, 93, 0.3);
}

.question-item.expanded {
  border-width: 3rpx;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.question-number {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.number-text {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
}

.type-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 500;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(74, 144, 217, 0.15);
  color: #4A90D9;
}

.type-tag .tag-icon {
  font-size: 18rpx;
}

.type-tag.type-multiple {
  background: rgba(155, 89, 182, 0.15);
  color: #9B59B6;
}

.type-tag.type-judge {
  background: rgba(243, 156, 18, 0.15);
  color: #F39C12;
}

.diff-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.diff-easy {
  background: rgba(91, 189, 114, 0.15);
  color: #5BBD72;
}

.diff-medium {
  background: rgba(243, 156, 18, 0.15);
  color: #F39C12;
}

.diff-hard {
  background: rgba(232, 93, 93, 0.15);
  color: #E85D5D;
}

.question-status {
  flex-shrink: 0;
}

.status-icon {
  font-size: 36rpx;
}

.question-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #2D3436;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.answer-section {
  background: rgba(0, 0, 0, 0.02);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.answer-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.answer-row:last-child {
  margin-bottom: 16rpx;
}

.answer-label {
  font-size: 24rpx;
  color: #636E72;
  flex-shrink: 0;
}

.answer-value {
  font-size: 28rpx;
  font-weight: 600;
}

.answer-value.user-answer.correct {
  color: #5BBD72;
}

.answer-value.user-answer.wrong {
  color: #E85D5D;
}

.answer-value.correct-answer {
  color: #5BBD72;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item.correct {
  background: rgba(91, 189, 114, 0.08);
  border-color: rgba(91, 189, 114, 0.3);
}

.option-item.wrong {
  background: rgba(232, 93, 93, 0.08);
  border-color: rgba(232, 93, 93, 0.3);
}

.option-label {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-right: 12rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.option-text {
  flex: 1;
  font-size: 26rpx;
  color: #2D3436;
  line-height: 1.5;
}

.option-indicator {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #5BBD72;
  font-weight: 600;
  flex-shrink: 0;
}

.option-indicator.wrong {
  color: #E85D5D;
}

.explanation {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(243, 156, 18, 0.08);
  border-radius: 12rpx;
  border-left: 4rpx solid #F39C12;
}

.explanation-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #E67E22;
  margin-bottom: 8rpx;
}

.explanation-text {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.6;
}

.expand-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding-top: 8rpx;
  font-size: 22rpx;
  color: #B2BEC3;
}

.expand-hint .arrow {
  font-size: 20rpx;
}
