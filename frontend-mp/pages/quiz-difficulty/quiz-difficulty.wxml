<view class="difficulty-container">
  <view class="header-card">
    <view class="header-content">
      <view class="header-icon">⭐</view>
      <view class="header-title">难度分层</view>
      <view class="header-subtitle">选择适合你的难度，挑战自我</view>
    </view>

    <view class="points-info">
      <text class="points-label">当前积分</text>
      <text class="points-value">{{userPoints}}</text>
    </view>
  </view>

  <view class="difficulties-section">
    <view class="section-title">选择难度</view>
    <view class="difficulties-list">
      <view
        class="difficulty-item"
        wx:for="{{difficulties}}"
        wx:key="id"
        data-difficulty="{{item}}"
        bindtap="onDifficultyTap"
        style="--diff-color: {{item.color}}"
      >
        <view class="difficulty-header">
          <view class="difficulty-icon" style="background: {{item.color}}20; color: {{item.color}}">
            {{item.icon}}
          </view>
          <view class="difficulty-info">
            <view class="difficulty-name">{{item.name}}</view>
            <view class="difficulty-desc">{{item.description}}</view>
          </view>
          <view class="difficulty-arrow">›</view>
        </view>

        <view class="difficulty-stats">
          <view class="stat-item">
            <text class="stat-icon">📝</text>
            <text class="stat-text">{{item.questionCount}} 题</text>
          </view>
          <view class="stat-item">
            <text class="stat-icon">🎁</text>
            <text class="stat-text">每题 +{{item.pointsPerQuestion}} 积分</text>
          </view>
        </view>

        <view class="difficulty-record" wx:if="{{item.totalAttempts > 0}}">
          <view class="record-item">
            <text class="record-label">挑战次数</text>
            <text class="record-value">{{item.totalAttempts}} 次</text>
          </view>
          <view class="record-item">
            <text class="record-label">最高正确率</text>
            <text class="record-value" style="color: {{item.color}}">{{item.bestScore}}%</text>
          </view>
        </view>

        <view class="difficulty-tag" style="background: {{item.color}}; color: #fff">
          {{item.tagText}}
        </view>
      </view>
    </view>
  </view>

  <view class="tips-section">
    <view class="tips-card">
      <view class="tips-title">💡 难度说明</view>
      <view class="tips-list">
        <view class="tips-item">
          <text class="tips-level easy">简单</text>
          <text class="tips-desc">基础题目，适合初学者，每题 +5 积分</text>
        </view>
        <view class="tips-item">
          <text class="tips-level medium">中等</text>
          <text class="tips-desc">有一定难度，需要思考，每题 +10 积分</text>
        </view>
        <view class="tips-item">
          <text class="tips-level hard">困难</text>
          <text class="tips-desc">高难度题目，挑战极限，每题 +20 积分</text>
        </view>
      </view>
    </view>
  </view>
</view>
