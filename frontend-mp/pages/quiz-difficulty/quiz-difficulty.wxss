.difficulty-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  padding-bottom: 40rpx;
}

.header-card {
  background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
  margin: 0;
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(243, 156, 18, 0.2);
}

.header-content {
  text-align: center;
  color: #fff;
  margin-bottom: 32rpx;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.points-info {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx;
}

.points-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.points-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.difficulties-section {
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 24rpx;
}

.difficulties-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.difficulty-item {
  position: relative;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border-left: 8rpx solid var(--diff-color);
  transition: all 0.3s ease;
  overflow: hidden;
}

.difficulty-item:active {
  transform: scale(0.99);
}

.difficulty-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.difficulty-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.difficulty-info {
  flex: 1;
  min-width: 0;
}

.difficulty-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.difficulty-desc {
  font-size: 24rpx;
  color: #636E72;
}

.difficulty-arrow {
  font-size: 40rpx;
  color: #B2BEC3;
  margin-left: 16rpx;
}

.difficulty-stats {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 24rpx;
}

.stat-text {
  font-size: 24rpx;
  color: #636E72;
}

.difficulty-record {
  display: flex;
  gap: 32rpx;
  padding: 16rpx 20rpx;
  background: rgba(0, 0, 0, 0.02);
  border-radius: 12rpx;
}

.record-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-label {
  font-size: 20rpx;
  color: #B2BEC3;
}

.record-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D3436;
}

.difficulty-tag {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 20rpx;
  font-weight: 500;
  padding: 8rpx 20rpx;
  border-radius: 0 24rpx 0 24rpx;
}

.tips-section {
  padding: 0 32rpx;
  margin-top: 16rpx;
}

.tips-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tips-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tips-level {
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.tips-level.easy {
  background: rgba(91, 189, 114, 0.15);
  color: #5BBD72;
}

.tips-level.medium {
  background: rgba(243, 156, 18, 0.15);
  color: #F39C12;
}

.tips-level.hard {
  background: rgba(232, 93, 93, 0.15);
  color: #E85D5D;
}

.tips-desc {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.5;
}
