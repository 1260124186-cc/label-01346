.records-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  padding-bottom: 40rpx;
}

.header-card {
  background: linear-gradient(135deg, #4A90D9 0%, #3498DB 100%);
  margin: 0;
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.2);
}

.header-content {
  text-align: center;
  color: #fff;
  margin-bottom: 40rpx;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
}

.stats-grid .stat-item {
  text-align: center;
}

.stats-grid .stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.stats-grid .stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
}

.filter-section {
  padding: 24rpx 0 0;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-tabs {
  display: inline-flex;
  gap: 12rpx;
  padding: 0 32rpx;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #636E72;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.filter-tab.active {
  background: #4A90D9;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.25);
}

.filter-icon {
  font-size: 22rpx;
}

.filter-name {
  font-size: 24rpx;
}

.empty-section {
  padding: 120rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.empty-subtitle {
  font-size: 28rpx;
  color: #B2BEC3;
}

.records-section {
  padding: 24rpx 32rpx;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  transition: all 0.3s ease;
}

.record-item:active {
  transform: scale(0.99);
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-content {
  flex: 1;
  min-width: 0;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.record-points {
  font-size: 28rpx;
  font-weight: 700;
  color: #F39C12;
}

.record-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #636E72;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.accuracy-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  margin-right: 16rpx;
}

.accuracy-label {
  font-size: 22rpx;
  color: #B2BEC3;
  flex-shrink: 0;
}

.accuracy-track {
  flex: 1;
  height: 8rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 4rpx;
  overflow: hidden;
}

.accuracy-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.accuracy-fill.accuracy-excellent {
  background: linear-gradient(90deg, #5BBD72 0%, #4CAF50 100%);
}

.accuracy-fill.accuracy-good {
  background: linear-gradient(90deg, #4A90D9 0%, #3498DB 100%);
}

.accuracy-fill.accuracy-normal {
  background: linear-gradient(90deg, #F39C12 0%, #E67E22 100%);
}

.accuracy-fill.accuracy-poor {
  background: linear-gradient(90deg, #E85D5D 0%, #C0392B 100%);
}

.accuracy-value {
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  min-width: 70rpx;
}

.accuracy-value.accuracy-excellent {
  color: #5BBD72;
}

.accuracy-value.accuracy-good {
  color: #4A90D9;
}

.accuracy-value.accuracy-normal {
  color: #F39C12;
}

.accuracy-value.accuracy-poor {
  color: #E85D5D;
}

.record-time {
  font-size: 22rpx;
  color: #B2BEC3;
  flex-shrink: 0;
}

.record-arrow {
  font-size: 40rpx;
  color: #B2BEC3;
  margin-left: 16rpx;
  flex-shrink: 0;
}
