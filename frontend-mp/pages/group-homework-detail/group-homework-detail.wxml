<view class="page-container">
  <view wx:if="{{homework}}" class="detail-container">
    <view class="header-section">
      <view class="header-bg" style="background: {{homework.color}};"></view>
      <view class="header-content">
        <view class="homework-icon">
          <text>{{homework.icon}}</text>
        </view>
        <view class="homework-info">
          <view class="homework-title">{{homework.title}}</view>
          <view class="homework-desc" wx:if="{{homework.description}}">{{homework.description}}</view>
          <view class="homework-meta">
            <view class="status-badge" style="background: {{statusInfo.bgColor}}; color: {{statusInfo.color}};">
              {{statusInfo.name}}
            </view>
            <view class="deadline-info">
              <text class="deadline-icon">⏰</text>
              <text class="deadline-text">{{homework.daysLeftText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="progress-card">
      <view class="progress-header">
        <view class="progress-title">整体进度</view>
        <view class="progress-value">{{homework.completionText}}</view>
      </view>
      <view class="progress-bar-wrapper">
        <view
          class="progress-bar-fill"
          style="width: {{homework.overallProgress}}%; background: {{homework.color}};"
        ></view>
      </view>
      <view class="progress-stats">
        <view class="stat-item">
          <text class="stat-value">{{homework.completedCount}}</text>
          <text class="stat-label">已完成</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{homework.totalMembers - homework.completedCount}}</text>
          <text class="stat-label">未完成</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{homework.deadlineText}}</text>
          <text class="stat-label">截止日期</text>
        </view>
      </view>
    </view>

    <view wx:if="{{homework.reward}}" class="reward-card">
      <view class="reward-icon">{{homework.reward.type === 'points_pool' ? '💰' : '🏅'}}</view>
      <view class="reward-info">
        <view class="reward-title">
          {{homework.reward.type === 'points_pool' ? '组积分池奖励' : '组限定勋章'}}
        </view>
        <view class="reward-desc">
          {{homework.reward.type === 'points_pool' ? homework.reward.points + ' 积分' : homework.reward.badgeName}}
        </view>
      </view>
      <view class="reward-badge">
        <text>完成后发放</text>
      </view>
    </view>

    <view class="tabs-section">
      <view class="tabs">
        <view
          wx:for="{{tabs}}"
          wx:key="id"
          class="tab-item {{activeTab === item.id ? 'active' : ''}}"
          bindtap="onTabChange"
          data-id="{{item.id}}"
        >
          <text class="tab-name">{{item.name}}</text>
          <view class="tab-underline" wx:if="{{activeTab === item.id}}"></view>
        </view>
      </view>

      <view wx:if="{{activeTab === 'tasks'}}" class="tab-content">
        <view wx:if="{{homework.tasks.length === 0}}" class="empty-content">
          <view class="empty-icon">📋</view>
          <view class="empty-text">暂无任务</view>
        </view>

        <view wx:else class="task-list">
          <view
            wx:for="{{homework.tasks}}"
            wx:key="index"
            class="task-item"
            bindtap="onGoToTask"
            data-task="{{item}}"
          >
            <view class="task-icon" style="background: {{homework.color}}20;">
              <text>{{item.typeInfo.icon}}</text>
            </view>
            <view class="task-info">
              <view class="task-header">
                <text class="task-name">{{item.name}}</text>
                <view class="task-required" wx:if="{{item.required}}">必做</view>
                <view class="task-required optional" wx:else>选做</view>
              </view>
              <view class="task-detail">
                {{item.typeInfo.name}} · {{item.detail}}
              </view>
              <view class="task-progress">
                <view class="task-progress-bar">
                  <view
                    class="task-progress-fill {{item.statusClass}}"
                    style="width: {{myProgress.tasks[index]?.progress || 0}}%;"
                  ></view>
                </view>
                <text class="task-progress-text {{item.statusClass}}">
                  {{item.statusText}}
                </text>
              </view>
            </view>
            <view class="task-arrow">›</view>
          </view>
        </view>
      </view>

      <view wx:if="{{activeTab === 'members'}}" class="tab-content">
        <view wx:if="{{isCurrentUserAdmin}}" class="ranking-tip">
          <text class="tip-icon">📊</text>
          <text class="tip-text">查看完整排行榜</text>
          <view class="view-report-btn" bindtap="onViewReport">
            <text>去学习报告</text>
            <text class="btn-arrow">›</text>
          </view>
        </view>

        <view class="member-list">
          <view
            wx:for="{{memberProgressList}}"
            wx:key="member.id"
            class="member-item"
          >
            <view class="member-avatar">
              <text>{{item.member.name[0]}}</text>
            </view>
            <view class="member-info">
              <view class="member-header">
                <text class="member-name">{{item.member.name}}</text>
                <text class="member-status {{item.progress.completed ? 'completed' : ''}}">
                  {{item.statusText}}
                </text>
              </view>
              <view class="member-progress">
                <view class="progress-bar-small">
                  <view
                    class="progress-fill-small"
                    style="width: {{item.progress.completionRate}}%; background: {{homework.color}};"
                  ></view>
                </view>
                <text class="progress-text-small">{{item.completionText}}</text>
              </view>
            </view>
            <view
              wx:if="{{isCurrentUserAdmin && !item.progress.completed && homework.status !== 'expired'}}"
              class="remind-btn"
              bindtap="onRemindMember"
              data-member-id="{{item.member.id}}"
            >
              <text>提醒</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="my-progress-card">
      <view class="my-progress-header">
        <text class="my-progress-title">我的进度</text>
        <text class="my-progress-value {{myProgress.completed ? 'completed' : ''}}">
          {{myProgress.completed ? '🎉 已完成' : myProgress.completionRate + '%'}}
        </text>
      </view>
      <view class="my-progress-bar">
        <view
          class="my-progress-fill"
          style="width: {{myProgress.completionRate}}%; background: {{homework.color}};"
        ></view>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
