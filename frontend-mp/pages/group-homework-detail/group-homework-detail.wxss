.page-container {
  min-height: 100vh;
  background: #F7FAF8;
}

.detail-container {
  padding-bottom: 48rpx;
}

.header-section {
  position: relative;
  padding: 60rpx 32rpx 80rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.9;
}

.header-content {
  position: relative;
  display: flex;
  align-items: flex-start;
}

.homework-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.homework-info {
  flex: 1;
  min-width: 0;
}

.homework-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.homework-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.homework-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
}

.deadline-info {
  display: flex;
  align-items: center;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
}

.deadline-icon {
  margin-right: 8rpx;
}

.progress-card {
  background: #FFFFFF;
  margin: -40rpx 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.progress-value {
  font-size: 28rpx;
  color: #5BBD72;
  font-weight: 500;
}

.progress-bar-wrapper {
  height: 16rpx;
  background: #F0F4F2;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #B2BEC3;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #F0F4F2;
}

.reward-card {
  background: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.reward-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.reward-info {
  flex: 1;
}

.reward-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.reward-desc {
  font-size: 24rpx;
  color: #B2BEC3;
}

.reward-badge {
  font-size: 22rpx;
  color: #F39C12;
  background: rgba(243, 156, 18, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.tabs-section {
  background: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.tabs {
  display: flex;
  border-bottom: 1rpx solid #F0F4F2;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  position: relative;
}

.tab-name {
  font-size: 28rpx;
  color: #636E72;
  font-weight: 500;
}

.tab-item.active .tab-name {
  color: #5BBD72;
  font-weight: 600;
}

.tab-underline {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #5BBD72;
  border-radius: 3rpx;
}

.tab-content {
  padding: 24rpx 32rpx;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B2BEC3;
}

.ranking-tip {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.1) 0%, rgba(155, 89, 182, 0.1) 100%);
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
}

.view-report-btn {
  display: flex;
  align-items: center;
  color: #5BBD72;
  font-size: 24rpx;
  font-weight: 500;
}

.btn-arrow {
  font-size: 28rpx;
  margin-left: 4rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  align-items: center;
  background: #F7FAF8;
  border-radius: 20rpx;
  padding: 24rpx;
  transition: all 0.3s;
}

.task-item:active {
  background: #F0F4F2;
}

.task-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-info {
  flex: 1;
  min-width: 0;
}

.task-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.task-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  margin-right: 12rpx;
}

.task-required {
  font-size: 20rpx;
  color: #E85D5D;
  background: rgba(232, 93, 93, 0.1);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.task-required.optional {
  color: #B2BEC3;
  background: rgba(178, 190, 195, 0.15);
}

.task-detail {
  font-size: 24rpx;
  color: #B2BEC3;
  margin-bottom: 12rpx;
}

.task-progress {
  display: flex;
  align-items: center;
}

.task-progress-bar {
  flex: 1;
  height: 8rpx;
  background: #E8E8E8;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.task-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
  background: #F39C12;
}

.task-progress-fill.in_progress {
  background: #F39C12;
}

.task-progress-fill.completed {
  background: #5BBD72;
}

.task-progress-text {
  font-size: 22rpx;
  color: #B2BEC3;
  min-width: 60rpx;
  text-align: right;
}

.task-progress-text.in_progress {
  color: #F39C12;
}

.task-progress-text.completed {
  color: #5BBD72;
  font-weight: 500;
}

.task-arrow {
  font-size: 32rpx;
  color: #B2BEC3;
  margin-left: 12rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F4F2;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #5BBD72;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.member-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
  margin-right: 12rpx;
}

.member-status {
  font-size: 22rpx;
  color: #B2BEC3;
  background: rgba(178, 190, 195, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.member-status.completed {
  color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
}

.member-progress {
  display: flex;
  align-items: center;
}

.progress-bar-small {
  flex: 1;
  height: 8rpx;
  background: #F0F4F2;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill-small {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text-small {
  font-size: 22rpx;
  color: #636E72;
  min-width: 80rpx;
  text-align: right;
}

.remind-btn {
  font-size: 24rpx;
  color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  margin-left: 16rpx;
  font-weight: 500;
}

.my-progress-card {
  background: #FFFFFF;
  margin: 0 32rpx;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.my-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.my-progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
}

.my-progress-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #F39C12;
}

.my-progress-value.completed {
  color: #5BBD72;
}

.my-progress-bar {
  height: 12rpx;
  background: #F0F4F2;
  border-radius: 6rpx;
  overflow: hidden;
}

.my-progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
