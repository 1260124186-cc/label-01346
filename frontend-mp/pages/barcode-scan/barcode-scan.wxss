.barcode-scan-page {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 140rpx;
}

/* ========== 扫码主界面 ========== */
.scan-main-section {
  padding: 0 32rpx;
}

.scan-hero {
  position: relative;
  margin-top: 32rpx 0 0;
  padding: 48rpx 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.scan-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  opacity: 0.12;
  border-radius: 24rpx;
}

.scan-hero-content {
  position: relative;
  z-index: 1;
}

.scan-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.scan-hero-emoji {
  font-size: 56rpx;
  margin-right: 16rpx;
}

.scan-hero-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1D2129;
}

.scan-hero-subtitle {
  font-size: 28rpx;
  color: #4E5969;
  line-height: 1.6;
}

/* 扫码按钮区 */
.scan-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0 48rpx;
}

.big-scan-btn {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-btn-ring {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  border: 4rpx solid rgba(91, 189, 114, 0.2);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.4;
  }
  50% {
    transform: scale(1.08);
    opacity: 0.8;
  }
}

.scan-btn-inner {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.3);
}

.scan-btn-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.scan-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.scan-hint {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #86909C;
}

/* 快捷功能入口 */
.quick-entries {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 8rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.quick-entry-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  transition: background 0.2s;
}

.quick-entry-item:active {
  background: rgba(91, 189, 114, 0.06);
}

.entry-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.entry-icon {
  font-size: 36rpx;
}

.entry-info {
  flex: 1;
}

.entry-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1D2129;
  display: block;
}

.entry-desc {
  font-size: 24rpx;
  color: #86909C;
  margin-top: 4rpx;
  display: block;
}

.entry-arrow {
  font-size: 36rpx;
  color: #C9CDD4;
}

/* 合规说明 */
.compliance-notice {
  display: flex;
  padding: 24rpx;
  background: rgba(91, 189, 114, 0.08);
  border-radius: 16rpx;
  margin-top: 16rpx;
}

.compliance-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.compliance-text {
  flex: 1;
}

.compliance-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #1D2129;
  display: block;
}

.compliance-desc {
  font-size: 22rpx;
  color: #4E5969;
  line-height: 1.5;
  margin-top: 4rpx;
  display: block;
}

/* ========== 扫描历史页 ========== */
.history-section {
  padding: 32rpx;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.history-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1D2129;
}

.clear-history-btn {
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  background: rgba(232, 93, 93, 0.1);
}

.clear-text {
  font-size: 24rpx;
  color: #E85D5D;
}

.history-empty,
.favorites-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1D2129;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #86909C;
  margin-bottom: 48rpx;
}

.empty-action-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 48rpx;
}

.empty-btn-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.history-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.history-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  transition: background 0.2s;
  border-bottom: 1rpx solid #F2F3F5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: rgba(91, 189, 114, 0.04);
}

.history-emoji-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(91, 189, 114, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.history-emoji {
  font-size: 44rpx;
}

.history-info {
  flex: 1;
}

.history-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1D2129;
  display: block;
}

.history-barcode {
  font-size: 22rpx;
  color: #86909C;
  margin-top: 6rpx;
  display: block;
}

.history-time {
  font-size: 22rpx;
  color: #C9CDD4;
  margin-top: 4rpx;
  display: block;
}

.history-favorite {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 193, 7, 0.1);
  margin-left: 16rpx;
}

.history-favorite.active {
  background: rgba(255, 193, 7, 0.15);
}

.favorite-icon {
  font-size: 32rpx;
}

/* ========== 收藏商品页 ========== */
.favorites-section {
  padding: 32rpx;
}

.favorites-header {
  margin-bottom: 24rpx;
}

.favorites-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1D2129;
}

.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.favorite-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.favorite-card-header {
  display: flex;
  align-items: center;
}

.favorite-emoji-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: rgba(91, 189, 114, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.favorite-emoji {
  font-size: 48rpx;
}

.favorite-info {
  flex: 1;
}

.favorite-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
  display: block;
}

.favorite-brand {
  font-size: 24rpx;
  color: #86909C;
  margin-top: 6rpx;
  display: block;
}

.favorite-materials {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx 0;
}

.material-chip {
  padding: 8rpx 20rpx;
  background: rgba(91, 189, 114, 0.1);
  border-radius: 24rpx;
}

.material-text {
  font-size: 22rpx;
  color: #5BBD72;
}

.favorite-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F2F3F5;
}

.footer-action {
  display: flex;
  align-items: center;
}

.action-text {
  font-size: 26rpx;
  color: #5BBD72;
}

.action-arrow {
  font-size: 28rpx;
  color: #5BBD72;
  margin-left: 4rpx;
}

.footer-favorite {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 193, 7, 0.1);
}

.footer-favorite.active {
  background: rgba(255, 193, 7, 0.15);
}

/* ========== 底部Tab栏 ========== */
.bottom-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  transition: all 0.2s;
}

.tab-item.active {
  color: #5BBD72;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.tab-label {
  font-size: 22rpx;
  color: #86909C;
}

.tab-item.active .tab-label {
  color: #5BBD72;
  font-weight: 500;
}
