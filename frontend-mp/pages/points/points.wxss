/**
 * 积分明细页面样式
 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F7FAF8 20%);
  padding-bottom: 48rpx;
}

/* 积分概览 */
.points-section {
  padding: 24rpx 32rpx;
}

.points-card {
  position: relative;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.3);
}

.points-bg {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.points-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 12rpx;
}

.points-value {
  font-size: 80rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
  margin-bottom: 32rpx;
}

.points-detail {
  display: flex;
  align-items: center;
  width: 100%;
  justify-content: center;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

.detail-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.detail-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.detail-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 筛选标签 */
.filter-section {
  display: flex;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.filter-tab {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 32rpx;
  transition: all 0.3s ease;
}

.filter-tab.active {
  background: #5BBD72;
}

.filter-text {
  font-size: 26rpx;
  color: #666666;
}

.filter-tab.active .filter-text {
  color: #FFFFFF;
  font-weight: 500;
}

/* 记录列表 */
.records-section {
  padding: 0 32rpx;
}

.records-list {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  overflow: hidden;
  backdrop-filter: blur(10rpx);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-emoji {
  font-size: 36rpx;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 4rpx;
}

.record-desc {
  font-size: 24rpx;
  color: #999999;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.record-points {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.record-points.earn {
  color: #5BBD72;
}

.record-points.spend {
  color: #E85D5D;
}

.record-time {
  font-size: 22rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
}
