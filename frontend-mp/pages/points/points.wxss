.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 40rpx;
}

.points-section {
  padding: 20rpx;
}

.points-card {
  position: relative;
  background: linear-gradient(135deg, #5BBD72, #4CAF50);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.points-bg {
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.points-content {
  position: relative;
  z-index: 1;
  color: #fff;
}

.points-label {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: bold;
  line-height: 1;
  display: block;
  margin-bottom: 24rpx;
}

.points-detail {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.detail-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-value {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.detail-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.detail-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.3);
}

.expiring-tip {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.expiring-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.expiring-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.5;
}

.expiring-arrow {
  font-size: 24rpx;
  opacity: 0.8;
  margin-left: 10rpx;
}

.validity-link {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.link-text {
  font-size: 24rpx;
  opacity: 0.8;
}

.link-arrow {
  font-size: 22rpx;
  opacity: 0.8;
  margin-left: 4rpx;
}

.signin-entry-section {
  padding: 0 20rpx 20rpx;
}

.signin-entry-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.signin-entry-card.done {
  background: #F0FFF0;
}

.signin-entry-left {
  display: flex;
  align-items: center;
}

.signin-entry-emoji {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.signin-entry-text {
  display: flex;
  flex-direction: column;
}

.signin-entry-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}

.signin-entry-subtitle {
  font-size: 24rpx;
  color: #999;
}

.signin-entry-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #5BBD72, #4CAF50);
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
}

.quick-section {
  padding: 20rpx;
}

.quick-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.quick-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.quick-emoji {
  font-size: 40rpx;
}

.quick-title-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.quick-desc {
  font-size: 22rpx;
  color: #999;
}

.filter-section {
  padding: 20rpx;
  padding-bottom: 0;
}

.filter-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.filter-tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.filter-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.filter-tab.active {
  background: linear-gradient(135deg, #5BBD72, #4CAF50);
}

.filter-text {
  font-size: 26rpx;
  color: #666;
}

.filter-tab.active .filter-text {
  color: #fff;
  font-weight: 500;
}

.records-section {
  padding: 20rpx;
}

.records-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-emoji {
  font-size: 36rpx;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.record-title {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.record-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-expired {
  margin-top: 6rpx;
}

.expired-text {
  font-size: 20rpx;
  color: #E85D5D;
  background: #FFF0F0;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.record-points {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.record-points.earn {
  color: #5BBD72;
}

.record-points.spend {
  color: #E85D5D;
}

.record-time {
  font-size: 22rpx;
  color: #ccc;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  background: #fff;
  border-radius: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.validity-modal {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.validity-modal.show {
  opacity: 1;
  visibility: visible;
}

.validity-content {
  width: 600rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s;
}

.validity-modal.show .validity-content {
  transform: scale(1);
}

.validity-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.validity-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.validity-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.validity-body {
  max-height: 60vh;
  padding: 30rpx;
}

.validity-section {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx dashed #eee;
}

.validity-section:last-of-type {
  border-bottom: none;
}

.section-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.section-info {
  flex: 1;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.tip-section {
  display: block;
  background: #FFF9E6;
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 20rpx 0;
  border-bottom: none;
}

.tip-text {
  font-size: 24rpx;
  color: #E67E22;
  line-height: 1.7;
}

.validity-footer {
  text-align: center;
  padding-top: 20rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #ccc;
}
