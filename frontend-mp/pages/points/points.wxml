<!--
  积分明细页面
  功能：展示用户积分的获取与消费记录，包含即将过期积分提醒
-->
<view class="page-container">
  <!-- 积分概览 -->
  <view class="points-section">
    <view class="points-card">
      <view class="points-bg"></view>
      <view class="points-content">
        <text class="points-label">当前积分</text>
        <text class="points-value">{{currentPoints}}</text>
        <view class="points-detail">
          <view class="detail-item">
            <text class="detail-value">+{{totalEarned}}</text>
            <text class="detail-label">累计获得</text>
          </view>
          <view class="detail-divider"></view>
          <view class="detail-item">
            <text class="detail-value">-{{totalSpent}}</text>
            <text class="detail-label">累计消费</text>
          </view>
        </view>
        
        <!-- 即将过期提醒 - 分级展示 -->
        <block wx:if="{{expiringTiered && (expiringTiered.within1Day.points > 0 || expiringTiered.within7Days.points > 0 || expiringTiered.within30Days.points > 0)}}">
          <view class="expiring-tip-group" bindtap="showValidityRules">
            <view class="expiring-tip danger" wx:if="{{expiringTiered.within1Day.points > 0}}">
              <text class="expiring-icon">⚠️</text>
              <text class="expiring-text">{{expiringTiered.within1Day.points}} 积分今日即将过期</text>
              <text class="expiring-arrow">></text>
            </view>
            <view class="expiring-tip warning" wx:if="{{expiringTiered.within7Days.points > 0 && expiringTiered.within1Day.points === 0}}">
              <text class="expiring-icon">⏰</text>
              <text class="expiring-text">{{expiringTiered.within7Days.points}} 积分7天内即将过期</text>
              <text class="expiring-arrow">></text>
            </view>
            <view class="expiring-tip info" wx:if="{{expiringTiered.within30Days.points > 0 && expiringTiered.within1Day.points === 0 && expiringTiered.within7Days.points === 0}}">
              <text class="expiring-icon">🔔</text>
              <text class="expiring-text">{{expiringTiered.within30Days.points}} 积分30天内即将过期</text>
              <text class="expiring-arrow">></text>
            </view>
          </view>
        </block>
        
        <view class="validity-link" bindtap="showValidityRules">
          <text class="link-text">积分有效期说明</text>
          <text class="link-arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 签到入口 -->
  <view class="signin-entry-section" bindtap="onQuickAction" data-id="signin">
    <view class="signin-entry-card {{isSignedToday ? 'done' : ''}}">
      <view class="signin-entry-left">
        <text class="signin-entry-emoji">{{isSignedToday ? '✅' : '📅'}}</text>
        <view class="signin-entry-text">
          <text class="signin-entry-title">{{isSignedToday ? '今日已签到' : '每日签到'}}</text>
          <text class="signin-entry-subtitle">
            {{isSignedToday ? '连续打卡' + streakDays + '天，明天继续' : '连续打卡' + streakDays + '天，点击签到+5积分'}}
          </text>
        </view>
      </view>
      <view class="signin-entry-btn">{{isSignedToday ? '已完成' : '去签到'}}</view>
    </view>
  </view>

  <!-- 快捷功能入口 -->
  <view class="quick-section">
    <view class="quick-title">赚取积分</view>
    <view class="quick-grid">
      <view 
        wx:for="{{quickActions}}" 
        wx:key="id"
        class="quick-item"
        bindtap="onQuickAction"
        data-id="{{item.id}}"
      >
        <view class="quick-icon" style="background: {{item.color}}1A;">
          <text class="quick-emoji">{{item.emoji}}</text>
        </view>
        <text class="quick-title-text">{{item.title}}</text>
        <text class="quick-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-section">
    <view class="filter-title">积分明细</view>
    <view class="filter-tabs">
      <view 
        wx:for="{{filterTabs}}" 
        wx:key="id"
        class="filter-tab {{currentFilter === item.id ? 'active' : ''}}"
        bindtap="onFilterChange"
        data-id="{{item.id}}"
      >
        <text class="filter-text">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 积分记录列表 -->
  <view class="records-section">
    <view class="records-list">
      <block wx:for="{{pointsList}}" wx:key="index">
        <!-- 即将过期的分组头 -->
        <view wx:if="{{item.isSectionHeader}}" class="expire-section-header" style="border-left-color: {{item.tierColor}};">
          <text class="section-label" style="color: {{item.tierColor}};">{{item.tierLabel}}</text>
          <text class="section-points">共 {{item.tierPoints}} 积分</text>
        </view>
        <!-- 普通记录 -->
        <view wx:else class="record-item">
          <view class="record-icon" style="background: {{item.type === 'earn' ? 'rgba(91, 189, 114, 0.1)' : 'rgba(232, 93, 93, 0.1)'}};">
            <text class="record-emoji">{{item.emoji}}</text>
          </view>
          <view class="record-info">
            <text class="record-title">{{item.title}}</text>
            <text class="record-desc">{{item.desc}}</text>
            <view class="record-meta">
              <view wx:if="{{item.expireAt && !item.expired}}" class="record-expire-tag" style="color: {{item.tierColor || '#999'}};">
                {{item.expireAt}} 过期
              </view>
              <view wx:if="{{item.expired}}" class="record-expired">
                <text class="expired-text">已过期</text>
              </view>
              <view wx:if="{{item.remainingPoints != null && item.remainingPoints !== item.points}}" class="record-remaining">
                剩余 {{item.remainingPoints}}/{{item.points}}
              </view>
            </view>
          </view>
          <view class="record-right">
            <text class="record-points {{item.type === 'earn' ? 'earn' : 'spend'}}">
              {{item.type === 'earn' ? '+' : '-'}}{{item.points}}
            </text>
            <text class="record-time">{{item.time}}</text>
          </view>
        </view>
      </block>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{pointsList.length === 0}}">
      <text class="empty-emoji">{{currentFilter === 'expiring' ? '✅' : '💰'}}</text>
      <text class="empty-text">{{currentFilter === 'expiring' ? '暂无即将过期积分' : '暂无积分记录'}}</text>
      <view wx:if="{{currentFilter === 'expiring'}}" class="empty-sub">您的积分状态良好</view>
    </view>
  </view>
  
  <!-- 积分有效期弹窗 - 动态展示用户真实过期计划 -->
  <view class="validity-modal {{showValidityModal ? 'show' : ''}}" bindtap="hideValidityRules">
    <view class="validity-content" catchtap="preventClose">
      <view class="validity-header">
        <text class="validity-title">积分有效期说明</text>
        <view class="validity-close" bindtap="hideValidityRules">
          <text class="close-icon">×</text>
        </view>
      </view>
      
      <scroll-view class="validity-body" scroll-y="{{true}}">
        <view class="validity-section">
          <view class="section-icon">📅</view>
          <view class="section-info">
            <text class="section-title">有效期规则</text>
            <text class="section-desc">积分自获取之日起，有效期为1年（365天）</text>
          </view>
        </view>
        
        <!-- 用户真实过期计划 -->
        <view class="validity-section user-plan" wx:if="{{expiryPlan && expiryPlan.length > 0}}">
          <view class="section-icon">📊</view>
          <view class="section-info">
            <text class="section-title">我的过期计划</text>
            <text class="section-desc user-plan-desc">以下是您的积分真实过期情况</text>
            <view class="plan-list">
              <view wx:for="{{expiryPlan}}" wx:key="expireAt" class="plan-item">
                <view class="plan-date">{{item.month}}月{{item.day}}日</view>
                <view class="plan-right">
                  <text class="plan-points">{{item.totalPoints}} 积分</text>
                  <text class="plan-days">{{item.daysLeft <= 0 ? '今日到期' : '剩' + item.daysLeft + '天'}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        
        <view class="validity-section tip-section" wx:if="{{!expiryPlan || expiryPlan.length === 0}}">
          <text class="tip-text">🎉 当前暂无即将过期的积分，请继续保持！</text>
        </view>
        
        <view class="validity-section">
          <view class="section-icon">⏰</view>
          <view class="section-info">
            <text class="section-title">过期提醒</text>
            <text class="section-desc">系统会在积分到期前30/7/1天分级提醒，请及时使用</text>
          </view>
        </view>
        
        <view class="validity-section">
          <view class="section-icon">🔄</view>
          <view class="section-info">
            <text class="section-title">扣减规则</text>
            <text class="section-desc">消费采用先过期先扣（FIFO），到期后自动清零无法恢复</text>
          </view>
        </view>
        
        <view class="validity-section">
          <view class="section-icon">🎁</view>
          <view class="section-info">
            <text class="section-title">使用范围</text>
            <text class="section-desc">积分可用于积分商城兑换各类环保商品</text>
          </view>
        </view>
        
        <view class="validity-footer-btn" bindtap="goToExchange">
          <text class="footer-btn-text">立即去兑换 →</text>
        </view>
        
        <view class="validity-footer">
          <text class="footer-text">最终解释权归垃圾分类助手所有</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
