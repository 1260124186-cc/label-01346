<view class="wrong-container">
  <view class="header-card">
    <view class="header-content">
      <view class="header-icon">📝</view>
      <view class="header-title">错题本</view>
      <view class="header-subtitle">复习做错的题目，巩固知识点</view>
    </view>

    <view class="stats-row">
      <view class="stat-item">
        <view class="stat-value">{{wrongQuestions.length}}</view>
        <view class="stat-label">待复习</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{selectedQuestions.length}}</view>
        <view class="stat-label">已选择</view>
      </view>
    </view>
  </view>

  <view class="empty-section" wx:if="{{wrongQuestions.length === 0}}">
    <view class="empty-icon">🎉</view>
    <view class="empty-title">太棒了！</view>
    <view class="empty-subtitle">暂无错题，继续保持</view>
    <view class="empty-tip">做错的题目会自动加入错题本</view>
  </view>

  <view class="questions-section" wx:else>
    <view class="section-header">
      <view class="section-title">
        <text>错题列表</text>
        <text class="title-count">({{wrongQuestions.length}}题)</text>
      </view>
      <view class="section-actions">
        <view class="action-btn" wx:if="{{!isSelectMode}}" bindtap="onQuestionLongPress">
          选择
        </view>
        <view class="action-btn" wx:else bindtap="onCancelSelect">
          取消
        </view>
      </view>
    </view>

    <view class="questions-list">
      <view
        class="question-item {{selectedQuestions.indexOf(index) > -1 ? 'selected' : ''}}"
        wx:for="{{wrongQuestions}}"
        wx:key="id"
        data-question="{{item}}"
        data-index="{{index}}"
        bindtap="onQuestionTap"
        bindlongpress="onQuestionLongPress"
      >
        <view class="question-checkbox" wx:if="{{isSelectMode}}">
          <view class="checkbox-inner {{selectedQuestions.indexOf(index) > -1 ? 'checked' : ''}}">
            <text wx:if="{{selectedQuestions.indexOf(index) > -1}}">✓</text>
          </view>
        </view>

        <view class="question-content">
          <view class="question-header">
            <view class="question-number">第 {{index + 1}} 题</view>
            <view class="question-diff diff-{{item.difficulty}}">
              {{item.difficulty === 'easy' ? '简单' : item.difficulty === 'medium' ? '中等' : '困难'}}
            </view>
          </view>

          <view class="question-text">{{item.question}}</view>

          <view class="question-options">
            <view class="option-preview" wx:for="{{item.optionsWithLabel}}" wx:key="index" wx:for-item="opt">
              <text class="option-label">{{opt.label}}.</text>
              <text class="option-text">{{opt.text}}</text>
            </view>
          </view>

          <view class="question-answer">
            <text class="answer-label">正确答案：</text>
            <text class="answer-value">{{item.correctAnswerLabel}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="footer-section" wx:if="{{wrongQuestions.length > 0}}">
    <view class="footer-actions" wx:if="{{isSelectMode}}">
      <view class="action-btn secondary" bindtap="onSelectAll">
        {{selectedQuestions.length === wrongQuestions.length ? '取消全选' : '全选'}}
      </view>
      <view class="action-btn danger" bindtap="onDeleteSelected">
        删除
      </view>
    </view>

    <view class="start-btn" bindtap="onStartReview">
      {{isSelectMode && selectedQuestions.length > 0 ? '复习选中 (' + selectedQuestions.length + ')' : '开始复习'}}
    </view>
  </view>
</view>
