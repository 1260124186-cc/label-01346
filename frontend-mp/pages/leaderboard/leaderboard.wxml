<view class="page-container">
  <view class="season-banner" wx:if="{{seasonInfo}}">
    <view class="season-banner-bg"></view>
    <view class="season-banner-content">
      <view class="season-info-row">
        <text class="season-icon">🏆</text>
        <text class="season-name">{{seasonInfo.seasonName}}</text>
        <view class="season-days-badge">
          <text class="season-days-text">剩余 {{seasonInfo.daysRemaining}} 天</text>
        </view>
      </view>
      <text class="season-date">{{seasonInfo.startDate}} ~ {{seasonInfo.endDate}}</text>
      <view class="season-medals-row">
        <view class="season-medal-item">
          <text class="season-medal-icon">🎖️</text>
          <text class="season-medal-label">本赛季徽章</text>
          <text class="season-medal-count">{{seasonInfo.medals.length || 0}}</text>
        </view>
        <view class="season-medal-divider"></view>
        <view class="season-medal-item">
          <text class="season-medal-icon">🏅</text>
          <text class="season-medal-label">历史徽章</text>
          <text class="season-medal-count">{{historyMedals.length}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="tab-section">
    <view class="period-tabs">
      <view
        class="period-tab {{currentPeriod === item.id ? 'period-tab-active' : ''}}"
        wx:for="{{periods}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onPeriodTap"
      >
        <text class="period-tab-icon">{{item.icon}}</text>
        <text class="period-tab-name">{{item.name}}</text>
      </view>
    </view>
    <view class="dimension-tabs">
      <view
        class="dimension-tab {{currentDimension === item.id ? 'dimension-tab-active' : ''}}"
        wx:for="{{dimensions}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onDimensionTap"
      >
        <text class="dimension-tab-icon">{{item.icon}}</text>
        <text class="dimension-tab-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="month-reset-tip" wx:if="{{currentPeriod === 'month'}}">
    <text class="month-reset-tip-text">💡 每月赛季结束自动清零，徽章永久保留</text>
  </view>

  <view class="honor-hall-section">
    <view class="honor-hall-header">
      <text class="honor-hall-icon">🏅</text>
      <text class="honor-hall-title">荣誉殿堂</text>
    </view>
    <scroll-view wx:if="{{historyMedals.length > 0}}" class="medals-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
      <view class="medals-scroll-inner">
        <view
          class="medal-card"
          wx:for="{{historyMedals}}"
          wx:key="id"
          data-medal="{{item}}"
          bindtap="onMedalTap"
        >
          <view class="medal-card-icon-wrap">
            <text class="medal-card-icon">{{item.icon}}</text>
          </view>
          <text class="medal-card-name">{{item.name}}</text>
          <view class="medal-card-rank">
            <text wx:if="{{item.rank === 1}}">🥇</text>
            <text wx:elif="{{item.rank === 2}}">🥈</text>
            <text wx:elif="{{item.rank === 3}}">🥉</text>
            <text wx:else>第{{item.rank}}名</text>
          </view>
          <text class="medal-card-season">S{{item.seasonId}}</text>
          <text class="medal-card-time">{{item.time}}</text>
        </view>
      </view>
    </scroll-view>
    <view wx:else class="medals-empty">
      <text class="medals-empty-icon">🎯</text>
      <text class="medals-empty-text">参与赛季排行榜赢取专属徽章</text>
    </view>
  </view>

  <view class="podium-section" wx:if="{{leaderboardList.length >= 3}}">
    <view class="podium-container">
      <view class="podium-item podium-silver">
        <view class="podium-avatar-wrap podium-avatar-silver">
          <text class="podium-avatar-emoji">{{leaderboardList[1].avatarEmoji || '😎'}}</text>
        </view>
        <text class="podium-name">{{leaderboardList[1].nickName}}</text>
        <text class="podium-value">{{leaderboardList[1].displayValue}}</text>
        <view class="podium-bar podium-bar-silver">
          <text class="podium-rank-text">2</text>
        </view>
      </view>
      <view class="podium-item podium-gold">
        <view class="podium-crown">👑</view>
        <view class="podium-avatar-wrap podium-avatar-gold">
          <text class="podium-avatar-emoji">{{leaderboardList[0].avatarEmoji || '🥇'}}</text>
        </view>
        <text class="podium-name">{{leaderboardList[0].nickName}}</text>
        <text class="podium-value">{{leaderboardList[0].displayValue}}</text>
        <view class="podium-bar podium-bar-gold">
          <text class="podium-rank-text">1</text>
        </view>
      </view>
      <view class="podium-item podium-bronze">
        <view class="podium-avatar-wrap podium-avatar-bronze">
          <text class="podium-avatar-emoji">{{leaderboardList[2].avatarEmoji || '😊'}}</text>
        </view>
        <text class="podium-name">{{leaderboardList[2].nickName}}</text>
        <text class="podium-value">{{leaderboardList[2].displayValue}}</text>
        <view class="podium-bar podium-bar-bronze">
          <text class="podium-rank-text">3</text>
        </view>
      </view>
    </view>
  </view>

  <view class="rank-list">
    <view
      class="rank-item {{item.isCurrentUser ? 'rank-item-self' : ''}}"
      wx:for="{{leaderboardList}}"
      wx:key="id"
      wx:if="{{index >= 3}}"
    >
      <view class="rank-number-wrap">
        <text class="rank-number">{{item.rank}}</text>
      </view>
      <view class="rank-avatar-wrap">
        <text class="rank-avatar-emoji">{{item.avatarEmoji || '🌱'}}</text>
      </view>
      <view class="rank-info">
        <text class="rank-name">{{item.nickName}}</text>
        <text class="rank-value">{{item.displayValue}}</text>
      </view>
      <view class="rank-self-badge" wx:if="{{item.isCurrentUser}}">
        <text class="rank-self-badge-text">我</text>
      </view>
    </view>
  </view>

  <view class="my-rank-card" wx:if="{{myData}}">
    <view class="my-rank-left">
      <view class="my-rank-badge">
        <text class="my-rank-number">{{myRank}}</text>
      </view>
      <view class="my-rank-avatar">
        <text class="my-rank-avatar-emoji">{{myData.avatarEmoji || '🌱'}}</text>
      </view>
      <view class="my-rank-info">
        <text class="my-rank-name">{{myData.nickName}}</text>
        <text class="my-rank-value">{{myData.displayValue}}</text>
      </view>
    </view>
    <view class="my-rank-tag">
      <text class="my-rank-tag-text">我的排名</text>
    </view>
  </view>

  <view class="pk-entry" bindtap="onPKTap">
    <view class="pk-entry-bg"></view>
    <view class="pk-entry-content">
      <text class="pk-entry-icon">⚔️</text>
      <view class="pk-entry-text-wrap">
        <text class="pk-entry-title">PK挑战</text>
        <text class="pk-entry-desc">与好友对战赢积分</text>
      </view>
      <text class="pk-entry-arrow">›</text>
    </view>
  </view>

  <view wx:if="{{showMedalModal && selectedMedal}}" class="medal-modal" catchtap="onCloseMedalModal">
    <view class="medal-modal-mask"></view>
    <view class="medal-modal-card" catchtap="">
      <view class="medal-modal-close" bindtap="onCloseMedalModal">
        <text class="medal-modal-close-icon">✕</text>
      </view>
      <view class="medal-modal-icon-wrap">
        <text class="medal-modal-icon">{{selectedMedal.icon}}</text>
      </view>
      <text class="medal-modal-name">{{selectedMedal.name}}</text>
      <view class="medal-modal-info">
        <view class="medal-modal-info-row">
          <text class="medal-modal-info-label">赛季</text>
          <text class="medal-modal-info-value">S{{selectedMedal.seasonId}}</text>
        </view>
        <view class="medal-modal-info-row">
          <text class="medal-modal-info-label">排名</text>
          <view class="medal-modal-info-value">
            <text wx:if="{{selectedMedal.rank === 1}}">🥇 第1名</text>
            <text wx:elif="{{selectedMedal.rank === 2}}">🥈 第2名</text>
            <text wx:elif="{{selectedMedal.rank === 3}}">🥉 第3名</text>
            <text wx:else>第{{selectedMedal.rank}}名</text>
          </view>
        </view>
        <view class="medal-modal-info-row">
          <text class="medal-modal-info-label">获得时间</text>
          <text class="medal-modal-info-value">{{selectedMedal.time}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
