.season-banner {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: var(--spacing-lg);
}

.season-banner-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #5BBD72 0%, #3DA35D 100%);
  opacity: 0.9;
}

.season-banner-content {
  position: relative;
  padding: var(--spacing-lg) var(--spacing-xl);
}

.season-info-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}

.season-icon {
  font-size: 40rpx;
  margin-right: var(--spacing-sm);
}

.season-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: #FFFFFF;
  margin-right: var(--spacing-md);
}

.season-days-badge {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-xl);
  padding: 4rpx 16rpx;
}

.season-days-text {
  font-size: var(--font-xs);
  color: #FFFFFF;
  font-weight: 500;
}

.season-date {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.8);
}

.tab-section {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.period-tabs {
  display: flex;
  background: var(--bg-page);
  border-radius: var(--radius-md);
  padding: 4rpx;
  margin-bottom: var(--spacing-md);
}

.period-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) 0;
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast) ease;
}

.period-tab-active {
  background: var(--bg-card-solid);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.period-tab-icon {
  font-size: var(--font-sm);
  margin-right: 6rpx;
}

.period-tab-name {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.period-tab-active .period-tab-name {
  color: var(--color-primary);
  font-weight: 600;
}

.dimension-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.dimension-tab {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-xl);
  background: var(--bg-page);
  transition: all var(--transition-fast) ease;
}

.dimension-tab-active {
  background: var(--color-primary-light);
}

.dimension-tab-icon {
  font-size: var(--font-xs);
  margin-right: 4rpx;
}

.dimension-tab-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

.dimension-tab-active .dimension-tab-name {
  color: var(--color-primary);
  font-weight: 600;
}

.podium-section {
  margin-bottom: var(--spacing-lg);
}

.podium-container {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: var(--spacing-xl) var(--spacing-md) 0;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 210rpx;
}

.podium-gold {
  order: 2;
  margin: 0 16rpx;
}

.podium-silver {
  order: 1;
}

.podium-bronze {
  order: 3;
  margin: 0 0 0 16rpx;
}

.podium-crown {
  font-size: 44rpx;
  margin-bottom: 4rpx;
  animation: crownFloat 2s ease-in-out infinite;
}

@keyframes crownFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-6rpx);
  }
}

.podium-avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-xs);
  border: 4rpx solid transparent;
}

.podium-avatar-gold {
  width: 112rpx;
  height: 112rpx;
  border-color: #FFD700;
  box-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.35);
  background: rgba(255, 215, 0, 0.1);
}

.podium-avatar-silver {
  border-color: #C0C0C0;
  box-shadow: 0 4rpx 16rpx rgba(192, 192, 192, 0.3);
  background: rgba(192, 192, 192, 0.1);
}

.podium-avatar-bronze {
  border-color: #CD7F32;
  box-shadow: 0 4rpx 16rpx rgba(205, 127, 50, 0.3);
  background: rgba(205, 127, 50, 0.1);
}

.podium-avatar-emoji {
  font-size: 48rpx;
}

.podium-gold .podium-avatar-emoji {
  font-size: 56rpx;
}

.podium-name {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 600;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.podium-value {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2rpx;
  margin-bottom: var(--spacing-sm);
}

.podium-gold .podium-value {
  color: #D4A017;
  font-weight: 600;
}

.podium-silver .podium-value {
  color: #A0A0A0;
  font-weight: 600;
}

.podium-bronze .podium-value {
  color: #CD7F32;
  font-weight: 600;
}

.podium-bar {
  width: 100%;
  border-radius: var(--radius-md) var(--radius-md) 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) 0;
}

.podium-bar-gold {
  height: 160rpx;
  background: linear-gradient(180deg, #FFD700 0%, #F0C060 100%);
}

.podium-bar-silver {
  height: 120rpx;
  background: linear-gradient(180deg, #C0C0C0 0%, #A8A8A8 100%);
}

.podium-bar-bronze {
  height: 90rpx;
  background: linear-gradient(180deg, #CD7F32 0%, #B87333 100%);
}

.podium-rank-text {
  font-size: var(--font-xl);
  font-weight: 700;
  color: #FFFFFF;
}

.rank-list {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  overflow: hidden;
  margin-bottom: var(--spacing-lg);
}

.rank-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 1rpx solid var(--border-light);
  transition: background var(--transition-fast) ease;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-item-self {
  background: var(--color-primary-light);
}

.rank-number-wrap {
  width: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-number {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-tertiary);
}

.rank-item:nth-child(4) .rank-number {
  color: #CD7F32;
}

.rank-item:nth-child(5) .rank-number {
  color: #A0A0A0;
}

.rank-avatar-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-round);
  background: var(--bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 var(--spacing-md);
}

.rank-avatar-emoji {
  font-size: 36rpx;
}

.rank-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rank-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.rank-value {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 600;
}

.rank-self-badge {
  background: var(--color-primary);
  border-radius: var(--radius-xs);
  padding: 2rpx 12rpx;
  margin-left: var(--spacing-sm);
}

.rank-self-badge-text {
  font-size: var(--font-xs);
  color: #FFFFFF;
  font-weight: 600;
}

.my-rank-card {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-medium);
  border: 2rpx solid var(--color-primary);
  padding: var(--spacing-md) var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
}

.my-rank-left {
  display: flex;
  align-items: center;
}

.my-rank-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
}

.my-rank-number {
  font-size: var(--font-md);
  font-weight: 700;
  color: #FFFFFF;
}

.my-rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-round);
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
}

.my-rank-avatar-emoji {
  font-size: 36rpx;
}

.my-rank-info {
  display: flex;
  flex-direction: column;
}

.my-rank-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 600;
}

.my-rank-value {
  font-size: var(--font-sm);
  color: var(--color-primary);
  font-weight: 600;
}

.my-rank-tag {
  background: var(--color-primary-light);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xs) var(--spacing-md);
}

.my-rank-tag-text {
  font-size: var(--font-xs);
  color: var(--color-primary);
  font-weight: 600;
}

.pk-entry {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.pk-entry-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #5BBD72 0%, #3DA35D 100%);
  opacity: 0.08;
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-lg);
}

.pk-entry-content {
  position: relative;
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-xl);
}

.pk-entry-icon {
  font-size: 52rpx;
  margin-right: var(--spacing-md);
}

.pk-entry-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.pk-entry-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.pk-entry-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 2rpx;
}

.pk-entry-arrow {
  font-size: 44rpx;
  color: var(--color-primary);
  font-weight: 300;
}

.season-medals-row {
  display: flex;
  align-items: center;
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.season-medal-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.season-medal-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.season-medal-label {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.85);
  margin-right: 6rpx;
}

.season-medal-count {
  font-size: var(--font-sm);
  color: #FFFFFF;
  font-weight: 700;
}

.season-medal-divider {
  width: 1rpx;
  height: 32rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 var(--spacing-md);
}

.month-reset-tip {
  margin-bottom: var(--spacing-md);
  padding-left: var(--spacing-xs);
}

.month-reset-tip-text {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.honor-hall-section {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.honor-hall-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.honor-hall-icon {
  font-size: 32rpx;
  margin-right: var(--spacing-xs);
}

.honor-hall-title {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 600;
}

.medals-scroll {
  width: 100%;
  white-space: nowrap;
}

.medals-scroll-inner {
  display: inline-flex;
  gap: var(--spacing-md);
  padding-right: var(--spacing-xs);
}

.medal-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
  padding: var(--spacing-md) var(--spacing-sm);
  background: linear-gradient(180deg, #FFFBEB 0%, #FEF3C7 100%);
  border-radius: var(--radius-md);
  border: 2rpx solid #F59E0B;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.15);
  flex-shrink: 0;
  transition: transform var(--transition-fast) ease;
}

.medal-card:active {
  transform: scale(0.96);
}

.medal-card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-round);
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-xs);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.medal-card-icon {
  font-size: 44rpx;
}

.medal-card-name {
  font-size: var(--font-xs);
  color: var(--text-primary);
  font-weight: 600;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.medal-card-rank {
  font-size: 24rpx;
  color: #B45309;
  font-weight: 600;
  margin-bottom: 2rpx;
}

.medal-card-season {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 2rpx;
}

.medal-card-time {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.medals-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-lg);
}

.medals-empty-icon {
  font-size: 56rpx;
  margin-bottom: var(--spacing-sm);
  opacity: 0.6;
}

.medals-empty-text {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.medal-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.medal-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
}

.medal-modal-card {
  position: relative;
  width: 560rpx;
  background: var(--bg-card-solid);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl) var(--spacing-xl) var(--spacing-lg);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: medalModalIn 0.25s ease-out;
}

@keyframes medalModalIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.medal-modal-close {
  position: absolute;
  top: var(--spacing-md);
  right: var(--spacing-md);
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-round);
  background: var(--bg-page);
  transition: background var(--transition-fast) ease;
}

.medal-modal-close:active {
  background: var(--border-light);
}

.medal-modal-close-icon {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.medal-modal-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
  border: 4rpx solid #F59E0B;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-md);
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.2);
}

.medal-modal-icon {
  font-size: 88rpx;
}

.medal-modal-name {
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: var(--spacing-lg);
}

.medal-modal-info {
  width: 100%;
  background: var(--bg-page);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
}

.medal-modal-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-xs) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.medal-modal-info-row:last-child {
  border-bottom: none;
}

.medal-modal-info-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.medal-modal-info-value {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 600;
}
