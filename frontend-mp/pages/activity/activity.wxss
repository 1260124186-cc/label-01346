.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 120rpx;
}

.activity-banner {
  padding: 60rpx 30rpx 80rpx;
  color: #fff;
  position: relative;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.banner-time {
  margin-top: 20rpx;
}

.time-text {
  font-size: 22rpx;
  opacity: 0.8;
}

.countdown-section {
  background: #fff;
  margin: -40rpx 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.countdown-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.countdown-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.countdown-timer {
  display: flex;
  align-items: center;
}

.time-block {
  width: 56rpx;
  height: 56rpx;
  background: #E85D5D;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.time-num {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  font-family: monospace;
}

.time-colon {
  font-size: 28rpx;
  color: #E85D5D;
  font-weight: bold;
  margin: 0 8rpx;
}

.discount-badge {
  background: #fff;
  margin: -40rpx 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.badge-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.badge-label {
  font-size: 26rpx;
  color: #999;
}

.badge-level {
  font-size: 28rpx;
  color: #5BBD72;
  font-weight: 500;
}

.badge-discount {
  font-size: 26rpx;
  color: #E85D5D;
  font-weight: 500;
}

.section-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.section-content {
  padding: 24rpx 30rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.goods-list {
  padding: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx;
  background: #F7FAF8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.goods-item:last-child {
  margin-bottom: 0;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.4;
}

.goods-price {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.sale-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #E85D5D;
}

.price-unit {
  font-size: 22rpx;
  color: #E85D5D;
  margin-left: 4rpx;
}

.original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.goods-tag {
  display: inline-block;
  padding: 2rpx 10rpx;
  background: #FFEAEA;
  border-radius: 4rpx;
  align-self: flex-start;
  margin-top: 6rpx;
}

.tag-text {
  font-size: 20rpx;
  color: #E85D5D;
}

.goods-progress {
  margin-top: 8rpx;
}

.progress-bar {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #F39C12, #E74C3C);
  border-radius: 6rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #999;
}

.rules-list {
  padding: 24rpx 30rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-index {
  width: 36rpx;
  height: 36rpx;
  background: #5BBD72;
  color: #fff;
  font-size: 22rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.rule-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

.bottom-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.bar-left {
  display: flex;
  align-items: baseline;
}

.points-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 10rpx;
}

.points-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #E85D5D;
}

.bar-btn {
  min-width: 200rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #5BBD72, #4CAF50);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}
