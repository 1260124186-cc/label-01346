/**
 * 设置页面样式
 */

.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 120rpx;
}

.section {
  padding: 32rpx 32rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  padding: 0 8rpx 16rpx;
}

.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 16rpx;
}

.section-header-row .section-title {
  padding: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.title-icon {
  font-size: 30rpx;
}

.child-lock-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  background: rgba(243, 156, 18, 0.12);
  border-radius: 20rpx;
}

.lock-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #F39C12;
}

.lock-text {
  font-size: 22rpx;
  color: #F39C12;
  font-weight: 500;
}

.child-main-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 2rpx solid rgba(243, 156, 18, 0.12);
}

.child-toggle-row {
  padding: 36rpx 32rpx;
}

.setting-icon.big-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  margin-right: 24rpx;
}

.setting-icon.big-icon .setting-emoji {
  font-size: 40rpx;
}

.setting-title.big-title {
  font-size: 32rpx;
  font-weight: 600;
}

.pin-tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  margin-left: 12rpx;
  padding: 4rpx 12rpx;
  background: rgba(91, 189, 114, 0.1);
  border-radius: 12rpx;
}

.pin-icon {
  font-size: 20rpx;
}

.pin-text {
  font-size: 20rpx;
  color: #5BBD72;
  font-weight: 500;
}

.child-config-area {
  padding: 0 32rpx 32rpx;
}

.today-stats-card {
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.06), rgba(52, 152, 219, 0.06));
  border-radius: 20rpx;
  padding: 24rpx 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.stats-header {
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.usage-progress-wrap {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.progress-info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.progress-info-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.progress-info-item.right {
  align-items: flex-end;
}

.info-label {
  font-size: 22rpx;
  color: #8E8E93;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
}

.info-value.used {
  color: #5BBD72;
}

.info-value.remain {
  color: #3498DB;
}

.usage-bar {
  height: 14rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 7rpx;
  overflow: hidden;
}

.usage-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72, #4A9D5E);
  border-radius: 7rpx;
  transition: width 0.5s ease;
}

.usage-fill.warn {
  background: linear-gradient(90deg, #F39C12, #E74C3C);
}

.sub-settings-list {
  background: rgba(0, 0, 0, 0.02);
  border-radius: 18rpx;
  overflow: hidden;
}

.sub-setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  position: relative;
  transition: background 0.15s;
}

.sub-setting-item:active {
  background: rgba(91, 189, 114, 0.05);
}

.sub-setting-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 72rpx;
  right: 24rpx;
  bottom: 0;
  height: 1rpx;
  background: rgba(0, 0, 0, 0.05);
}

.sub-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.sub-icon {
  font-size: 30rpx;
  width: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.sub-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.sub-desc {
  font-size: 22rpx;
  color: #8E8E93;
}

.sub-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.sub-value {
  font-size: 26rpx;
  color: #8E8E93;
}

.sub-value.highlight {
  color: #5BBD72;
  font-weight: 600;
}

.new-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #E74C3C 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 12rpx;
  line-height: 1.2;
}

/* 弹窗 */
.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.picker-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F0F0F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #8E8E93;
}

.picker-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  background: #F7F7FA;
  border-radius: 20rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.picker-option.selected {
  background: rgba(91, 189, 114, 0.06);
  border-color: #5BBD72;
}

.option-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.age-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.option-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.age-tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 12rpx;
  background: rgba(155, 89, 182, 0.12);
  border-radius: 12rpx;
}

.tag-icon {
  font-size: 20rpx;
}

.tag-text {
  font-size: 20rpx;
  color: #9B59B6;
  font-weight: 500;
}

.option-desc {
  font-size: 24rpx;
  color: #8E8E93;
}

.option-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #5BBD72;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  position: relative;
  transition: background 0.2s ease;
}

.setting-item:active {
  background: rgba(91, 189, 114, 0.05);
}

.setting-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: rgba(0, 0, 0, 0.06);
}

.setting-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.setting-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.setting-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.setting-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.setting-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.setting-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #2D3436;
}

.setting-lock-icon {
  font-size: 26rpx;
  margin-left: 8rpx;
  line-height: 1;
}

.setting-desc {
  font-size: 24rpx;
  color: #B2BEC3;
}

.setting-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.setting-value {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-right: 8rpx;
}

.setting-arrow {
  font-size: 36rpx;
  color: #B2BEC3;
  font-weight: 300;
  line-height: 1;
}

/* 版本信息 */
.version-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx 32rpx;
}

.version-text {
  font-size: 24rpx;
  color: #B2BEC3;
  margin-bottom: 8rpx;
}

.copyright-text {
  font-size: 22rpx;
  color: #B2BEC3;
  opacity: 0.7;
}

.safe-area-bottom {
  height: 48rpx;
}

.badge-new {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #E74C3C 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-right: 8rpx;
  line-height: 1.2;
}
