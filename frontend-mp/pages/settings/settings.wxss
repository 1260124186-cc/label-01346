/**
 * 设置页面样式
 */

.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 120rpx;
}

.section {
  padding: 32rpx 32rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  padding: 0 8rpx 16rpx;
}

.settings-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  position: relative;
  transition: background 0.2s ease;
}

.setting-item:active {
  background: rgba(91, 189, 114, 0.05);
}

.setting-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: rgba(0, 0, 0, 0.06);
}

.setting-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.setting-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.setting-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.setting-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.setting-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.setting-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #2D3436;
}

.setting-lock-icon {
  font-size: 26rpx;
  margin-left: 8rpx;
  line-height: 1;
}

.setting-desc {
  font-size: 24rpx;
  color: #B2BEC3;
}

.setting-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.setting-value {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-right: 8rpx;
}

.setting-arrow {
  font-size: 36rpx;
  color: #B2BEC3;
  font-weight: 300;
  line-height: 1;
}

/* 版本信息 */
.version-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx 32rpx;
}

.version-text {
  font-size: 24rpx;
  color: #B2BEC3;
  margin-bottom: 8rpx;
}

.copyright-text {
  font-size: 22rpx;
  color: #B2BEC3;
  opacity: 0.7;
}

.safe-area-bottom {
  height: 48rpx;
}

.badge-new {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #E74C3C 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-right: 8rpx;
  line-height: 1.2;
}
