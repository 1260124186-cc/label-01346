<!--
  设置页面
  功能：消息通知开关、儿童模式管控、清除缓存、隐私政策、用户协议、意见反馈
-->
<view class="page-container {{experienceClasses}}">

  <!-- 儿童模式管控区 -->
  <view class="section child-section">
    <view class="section-header-row">
      <view class="section-title">
        <text class="title-icon">🧒</text>
        <text>儿童模式管控</text>
      </view>
      <view class="child-lock-status" wx:if="{{isChildLocked}}">
        <text class="lock-dot"></text>
        <text class="lock-text">已锁定</text>
      </view>
    </view>

    <view class="child-main-card">
      <view class="setting-item child-toggle-row">
        <view class="setting-left">
          <view class="setting-icon big-icon" style="background: rgba(243, 156, 18, 0.12);">
            <text class="setting-emoji">🧸</text>
          </view>
          <view class="setting-info">
            <view class="setting-title-row">
              <text class="setting-title big-title">儿童模式</text>
              <view class="pin-tag" wx:if="{{hasChildPIN}}">
                <text class="pin-icon">🔒</text>
                <text class="pin-text">PIN已设</text>
              </view>
            </view>
            <text class="setting-desc">家长管控 · 适龄内容 · 时长限制</text>
          </view>
        </view>
        <view class="setting-right">
          <switch
            checked="{{childModeEnabled}}"
            bindchange="onChildModeChange"
            color="#5BBD72"
            aria-label="儿童模式开关"
          />
        </view>
      </view>

      <!-- 儿童模式开启后才显示的配置 -->
      <view class="child-config-area" wx:if="{{childModeEnabled || hasChildPIN}}">

        <view class="today-stats-card">
          <view class="stats-header">
            <text class="stats-title">📊 今日使用情况</text>
          </view>
          <view class="usage-progress-wrap">
            <view class="progress-info-row">
              <view class="progress-info-item">
                <text class="info-label">已使用</text>
                <text class="info-value used">{{usageTimeText}}</text>
              </view>
              <view class="progress-info-item right">
                <text class="info-label">剩余</text>
                <text class="info-value remain">{{usageRemainingText}}</text>
              </view>
            </view>
            <view class="usage-bar">
              <view class="usage-fill {{usagePercent >= 90 ? 'warn' : ''}}" style="width: {{usagePercent}}%;"></view>
            </view>
          </view>
        </view>

        <view class="sub-settings-list">
          <view class="sub-setting-item" bindtap="onSelectTimeLimit">
            <view class="sub-left">
              <text class="sub-icon">⏱️</text>
              <view class="sub-info">
                <text class="sub-title">每日时长上限</text>
                <text class="sub-desc">超时自动锁定，仅保留学习</text>
              </view>
            </view>
            <view class="sub-right">
              <text class="sub-value highlight">{{childTimeLimit}}分钟</text>
              <text class="setting-arrow">›</text>
            </view>
          </view>

          <view class="sub-setting-item" bindtap="onSelectAgeGroup">
            <view class="sub-left">
              <text class="sub-icon">🎂</text>
              <view class="sub-info">
                <text class="sub-title">年龄分级</text>
                <text class="sub-desc">自动适配适龄内容和题目</text>
              </view>
            </view>
            <view class="sub-right">
              <text class="sub-value">{{childAgeGroupText}}</text>
              <text class="setting-arrow">›</text>
            </view>
          </view>

          <view class="sub-setting-item" bindtap="onChangePIN">
            <view class="sub-left">
              <text class="sub-icon">🔐</text>
              <view class="sub-info">
                <text class="sub-title">{{hasChildPIN ? '修改家长PIN' : '设置家长PIN'}}</text>
                <text class="sub-desc">4-6位数字验证开启/关闭</text>
              </view>
            </view>
            <view class="sub-right">
              <text class="setting-arrow">›</text>
            </view>
          </view>

          <view class="sub-setting-item" bindtap="onGoDashboard">
            <view class="sub-left">
              <text class="sub-icon">📈</text>
              <view class="sub-info">
                <text class="sub-title">家长监控看板</text>
                <text class="sub-desc">查看学习数据 · 远程管控</text>
              </view>
            </view>
            <view class="sub-right">
              <view class="new-tag">NEW</view>
              <text class="setting-arrow">›</text>
            </view>
          </view>
        </view>

      </view>
    </view>
  </view>

  <!-- 通用设置 -->
  <view class="section">
    <view class="section-title">通用设置</view>
    <view class="settings-card">
      <view class="setting-item">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(91, 189, 114, 0.1);">
            <text class="setting-emoji">🔔</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">消息通知</text>
            <text class="setting-desc">接收活动和签到提醒</text>
          </view>
        </view>
        <view class="setting-right">
          <switch
            checked="{{notifyEnabled}}"
            bindchange="onNotifyChange"
            color="#5BBD72"
            aria-label="消息通知开关"
          />
        </view>
      </view>

      <view class="setting-item" bindtap="onRoleSelect">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(155, 89, 182, 0.1);">
            <text class="setting-emoji">{{roleEmojiMap[userRole] || '👤'}}</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">我的角色</text>
            <text class="setting-desc">选择您在家庭中的角色</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-value">{{currentRoleDisplay}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>

      <view class="setting-item" bindtap="onCitySelect">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(74, 144, 217, 0.1);">
            <text class="setting-emoji">{{currentCityInfo.emoji || '📍'}}</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">所在城市</text>
            <text class="setting-desc">选择城市，使用当地分类标准</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-value">{{currentCityInfo.name || '上海'}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>

      <view class="setting-item" bindtap="onUpcomingStandard" wx:if="{{hasUpcomingStandard}}">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(243, 156, 18, 0.1);">
            <text class="setting-emoji">📢</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">新标准预告</text>
            <text class="setting-desc">查看即将实施的新分类标准</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="badge-new">NEW</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>

      <view class="setting-item" bindtap="onClearCache">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(243, 156, 18, 0.1);">
            <text class="setting-emoji">🧹</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">清除缓存</text>
            <text class="setting-desc">清除本地缓存数据</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-value">{{cacheSize}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 体验设置 -->
  <view class="section">
    <view class="section-title">体验设置</view>
    <view class="settings-card">
      <view class="setting-item">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(74, 144, 217, 0.1);">
            <text class="setting-emoji">🌙</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">深色模式</text>
            <text class="setting-desc">护眼舒适 · 减少屏幕刺眼</text>
          </view>
        </view>
        <view class="setting-right">
          <switch
            checked="{{darkMode}}"
            bindchange="onDarkModeChange"
            color="#5BBD72"
            aria-label="深色模式开关"
          />
        </view>
      </view>

      <view class="setting-item" bindtap="onDarkModeSourceSelect">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(155, 89, 182, 0.1);">
            <text class="setting-emoji">🔄</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">深色模式来源</text>
            <text class="setting-desc">跟随系统或手动切换</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-value">{{darkModeSource === 'system' ? '跟随系统' : darkModeSource === 'dark' ? '始终深色' : '始终浅色'}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>

      <view class="setting-item">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(243, 156, 18, 0.1);">
            <text class="setting-emoji">🔤</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">大字号模式</text>
            <text class="setting-desc">放大文字 · 阅读更轻松</text>
          </view>
        </view>
        <view class="setting-right">
          <switch
            checked="{{largeFont}}"
            bindchange="onLargeFontChange"
            color="#5BBD72"
            aria-label="大字号模式开关"
          />
        </view>
      </view>
    </view>
  </view>

  <!-- 语音设置 -->
  <view class="section">
    <view class="section-title">语音设置</view>
    <view class="settings-card">
      <view class="setting-item">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(91, 189, 114, 0.1);">
            <text class="setting-emoji">🎤</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">语音模式</text>
            <text class="setting-desc">语音搜索 · 语音答题 · 语音播报</text>
          </view>
        </view>
        <view class="setting-right">
          <switch
            checked="{{voiceModeEnabled}}"
            bindchange="onVoiceModeChange"
            color="#5BBD72"
            aria-label="语音模式开关"
          />
        </view>
      </view>

      <view class="setting-item" bindtap="onDialectSelect">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(155, 89, 182, 0.1);">
            <text class="setting-emoji">🗣️</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">识别方言</text>
            <text class="setting-desc">选择语音识别的方言类型</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-value {{voiceModeEnabled ? '' : 'disabled'}}">{{currentDialectName}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 关于与协议 -->
  <view class="section">
    <view class="section-title">关于与协议</view>
    <view class="settings-card">
      <view class="setting-item" bindtap="onPrivacyPolicy">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(74, 144, 217, 0.1);">
            <text class="setting-emoji">🛡️</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">隐私政策</text>
            <text class="setting-desc">了解我们如何保护您的隐私</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-arrow">›</text>
        </view>
      </view>

      <view class="setting-item" bindtap="onUserAgreement">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(155, 89, 182, 0.1);">
            <text class="setting-emoji">📄</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">用户协议</text>
            <text class="setting-desc">使用条款与服务协议</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-arrow">›</text>
        </view>
      </view>

      <view class="setting-item" bindtap="onFeedback">
        <view class="setting-left">
          <view class="setting-icon" style="background: rgba(231, 76, 60, 0.1);">
            <text class="setting-emoji">💬</text>
          </view>
          <view class="setting-info">
            <text class="setting-title">意见反馈</text>
            <text class="setting-desc">告诉我们您的想法和建议</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-section">
    <text class="version-text">垃圾分类助手 v{{version}}</text>
    <text class="copyright-text">让垃圾分类更简单</text>
  </view>

  <view class="safe-area-bottom"></view>
</view>

<!-- 时长选择弹窗 -->
<view class="picker-mask" wx:if="{{showTimePicker}}" bindtap="onCloseTimePicker">
  <view class="picker-panel" catchtap="preventMaskClose">
    <view class="picker-header">
      <text class="picker-title">设置每日使用时长</text>
      <view class="picker-close" bindtap="onCloseTimePicker">✕</view>
    </view>
    <view class="picker-options">
      <view wx:for="{{childTimeLimitOptions}}" wx:key="id"
            class="picker-option {{childTimeLimit === item.id ? 'selected' : ''}}"
            bindtap="onConfirmTimeLimit" data-minutes="{{item.id}}">
        <view class="option-main">
          <text class="option-name">{{item.name}}</text>
          <text class="option-desc">{{item.desc}}</text>
        </view>
        <view class="option-check" wx:if="{{childTimeLimit === item.id}}">✓</view>
      </view>
    </view>
  </view>
</view>

<!-- 年龄选择弹窗 -->
<view class="picker-mask" wx:if="{{showAgePicker}}" bindtap="onCloseAgePicker">
  <view class="picker-panel" catchtap="preventMaskClose">
    <view class="picker-header">
      <text class="picker-title">选择年龄分级</text>
      <view class="picker-close" bindtap="onCloseAgePicker">✕</view>
    </view>
    <view class="picker-options">
      <view wx:for="{{childAgeGroups}}" wx:key="id"
            class="picker-option {{childAgeGroup === item.id ? 'selected' : ''}}"
            bindtap="onConfirmAgeGroup" data-age-id="{{item.id}}">
        <view class="option-main">
          <view class="age-row">
            <text class="option-name">{{item.name}}</text>
            <view class="age-tag" wx:if="{{item.useImageQuestions}}">
              <text class="tag-icon">🖼️</text>
              <text class="tag-text">图片题</text>
            </view>
          </view>
          <text class="option-desc">{{item.desc}}</text>
        </view>
        <view class="option-check" wx:if="{{childAgeGroup === item.id}}">✓</view>
      </view>
    </view>
  </view>
</view>

<!-- 方言选择弹窗 -->
<view class="picker-mask" wx:if="{{showDialectPicker}}" bindtap="onCloseDialectPicker">
  <view class="picker-panel" catchtap="preventMaskClose">
    <view class="picker-header">
      <text class="picker-title">选择识别方言</text>
      <view class="picker-close" bindtap="onCloseDialectPicker">✕</view>
    </view>
    <view class="picker-options">
      <view wx:for="{{dialectOptions}}" wx:key="id"
            class="picker-option {{currentDialect === item.id ? 'selected' : ''}}"
            bindtap="onConfirmDialect" data-dialect-id="{{item.id}}">
        <view class="option-main">
          <text class="option-name">{{item.name}}</text>
          <text class="option-desc">{{item.desc}}</text>
        </view>
        <view class="option-check" wx:if="{{currentDialect === item.id}}">✓</view>
      </view>
    </view>
  </view>
</view>
