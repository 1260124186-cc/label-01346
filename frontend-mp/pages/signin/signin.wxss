.signin-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  padding-bottom: 40rpx;
}

.header-card {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  margin: 0;
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.2);
  display: flex;
  justify-content: space-around;
}

.streak-info,
.points-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.streak-emoji,
.points-emoji {
  font-size: 56rpx;
}

.streak-content,
.points-content {
  text-align: center;
}

.streak-days,
.points-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.streak-label,
.points-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.calendar-card {
  margin: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(91, 189, 114, 0.1);
  border-radius: 50%;
}

.nav-btn:active {
  background: rgba(91, 189, 114, 0.2);
}

.nav-icon {
  font-size: 40rpx;
  color: #5BBD72;
  font-weight: 600;
}

.month-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 16rpx;
}

.week-item {
  text-align: center;
  font-size: 24rpx;
  color: #636E72;
  padding: 12rpx 0;
  font-weight: 500;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.day-cell.empty {
  background: transparent;
}

.day-cell.future {
  background: rgba(142, 142, 147, 0.06);
}

.day-cell.today {
  background: rgba(91, 189, 114, 0.08);
  border: 2rpx solid #5BBD72;
}

.day-cell.signed {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
}

.day-cell:not(.empty):not(.future):not(.signed):active {
  background: rgba(91, 189, 114, 0.15);
}

.day-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.day-number {
  font-size: 26rpx;
  color: #2D3436;
  font-weight: 500;
}

.day-cell.today .day-number {
  color: #5BBD72;
  font-weight: 700;
}

.day-cell.signed .day-number {
  color: #fff;
}

.day-cell.future .day-number {
  color: #B2BEC3;
}

.day-check {
  font-size: 20rpx;
  color: #fff;
  margin-top: 2rpx;
}

.day-tip {
  font-size: 18rpx;
  color: #5BBD72;
  font-weight: 600;
  margin-top: 2rpx;
}

.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
}

.legend-dot.signed {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
}

.legend-dot.today {
  background: rgba(91, 189, 114, 0.08);
  border: 2rpx solid #5BBD72;
}

.legend-dot.future {
  background: rgba(142, 142, 147, 0.2);
}

.legend-text {
  font-size: 22rpx;
  color: #636E72;
}

.action-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.signin-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.signin-btn.disabled {
  background: #B2BEC3;
  box-shadow: none;
}

.signin-btn:active {
  transform: scale(0.98);
}

.signin-tip {
  text-align: center;
  font-size: 24rpx;
  color: #636E72;
  margin-top: 16rpx;
}

.reward-section {
  padding: 0 32rpx;
}

.reward-section .section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 24rpx;
}

.reward-list {
  display: flex;
  gap: 24rpx;
}

.reward-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.reward-item.highlight {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.reward-day {
  font-size: 26rpx;
  color: #636E72;
  margin-bottom: 12rpx;
}

.reward-item.highlight .reward-day {
  color: #F39C12;
  font-weight: 600;
}

.reward-points {
  font-size: 36rpx;
  font-weight: 700;
  color: #5BBD72;
}

.reward-item.highlight .reward-points {
  color: #F39C12;
}

.signin-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  text-align: center;
}

.modal-emoji {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.modal-streak {
  font-size: 26rpx;
  color: #636E72;
  margin-bottom: 32rpx;
}

.modal-points {
  background: #F7FAF8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.points-label {
  font-size: 26rpx;
  color: #636E72;
}

.points-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #5BBD72;
}

.points-value.bonus {
  color: #F39C12;
}

.modal-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 16rpx;
}

.modal-btn:active {
  transform: scale(0.98);
}
