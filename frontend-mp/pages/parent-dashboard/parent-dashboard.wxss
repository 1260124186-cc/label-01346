.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 60rpx;
}

.header-section {
  background: linear-gradient(180deg, #5BBD72 0%, #4A9D5E 100%);
  padding: 24rpx 32rpx 48rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
}

.back-btn, .refresh-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.refresh-icon {
  font-size: 32rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.member-scroll {
  white-space: nowrap;
  margin: 24rpx 0;
}

.member-tabs {
  display: inline-flex;
  gap: 16rpx;
}

.member-tab {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 32rpx;
  transition: all 0.25s;
}

.member-tab.active {
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.tab-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.tab-avatar-placeholder {
  font-size: 28rpx;
}

.tab-name {
  font-size: 24rpx;
  color: #FFFFFF;
}

.member-tab.active .tab-name {
  color: #5BBD72;
  font-weight: 500;
}

.profile-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.profile-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(91, 189, 114, 0.18);
}

.member-avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #A8E6CF, #5BBD72);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.member-info-text {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.member-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #5BBD72;
  animation: pulse 2s ease-in-out infinite;
}

.status-dot.locked {
  background: #F39C12;
  animation: none;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.status-text {
  font-size: 24rpx;
  color: #8E8E93;
}

.quick-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: rgba(91, 189, 114, 0.08);
  border-radius: 24rpx;
}

.settings-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 24rpx;
  color: #5BBD72;
  font-weight: 500;
}

.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(247, 250, 248, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  z-index: 999;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid rgba(91, 189, 114, 0.2);
  border-top-color: #5BBD72;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #8E8E93;
}

.content-section {
  padding: -24rpx 32rpx 0;
  margin-top: -16rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.time-limit-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: rgba(91, 189, 114, 0.08);
  border-radius: 20rpx;
}

.limit-text {
  font-size: 24rpx;
  color: #5BBD72;
  font-weight: 500;
}

.chevron {
  font-size: 22rpx;
  color: #5BBD72;
}

.time-progress-section {
  display: flex;
  align-items: center;
  gap: 40rpx;
  margin-bottom: 28rpx;
}

.progress-ring {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.ring-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 14rpx solid #F0F0F5;
}

.ring-progress {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 14rpx solid transparent;
  border-top-color: #5BBD72;
  border-right-color: #5BBD72;
  transform: rotate(calc(var(--percent) / 100 * 360deg - 90deg));
  transition: transform 0.5s ease;
}

.ring-center {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.percent-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #5BBD72;
  line-height: 1.1;
}

.percent-label {
  font-size: 20rpx;
  color: #8E8E93;
  margin-top: 4rpx;
}

.time-stats {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.time-stat-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 600;
}

.stat-value.primary { color: #1A1A1A; }
.stat-value.success { color: #5BBD72; }
.stat-value.warn { color: #E74C3C; }

.stat-label {
  font-size: 22rpx;
  color: #8E8E93;
}

.progress-bar {
  height: 12rpx;
  background: #F0F0F5;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72, #4A9D5E);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-fill.full {
  background: linear-gradient(90deg, #F39C12, #E74C3C);
}

.time-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 80rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.action-btn:active {
  transform: scale(0.97);
}

.extend-btn {
  background: rgba(91, 189, 114, 0.1);
  border: 2rpx solid rgba(91, 189, 114, 0.3);
}

.extend-btn .action-icon,
.extend-btn .action-label {
  color: #5BBD72;
}

.lock-btn {
  background: rgba(243, 156, 18, 0.1);
  border: 2rpx solid rgba(243, 156, 18, 0.3);
}

.lock-btn .action-label {
  color: #F39C12;
}

.lock-btn.unlock {
  background: rgba(91, 189, 114, 0.1);
  border: 2rpx solid rgba(91, 189, 114, 0.3);
}

.lock-btn.unlock .action-label {
  color: #5BBD72;
}

.action-icon {
  font-size: 28rpx;
}

.action-label {
  font-size: 26rpx;
  font-weight: 500;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.stat-icon-wrap {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.stat-icon-wrap.blue { background: rgba(52, 152, 219, 0.12); }
.stat-icon-wrap.green { background: rgba(91, 189, 114, 0.12); }
.stat-icon-wrap.orange { background: rgba(243, 156, 18, 0.12); }
.stat-icon-wrap.purple { background: rgba(155, 89, 182, 0.12); }
.stat-icon-wrap.teal { background: rgba(26, 188, 156, 0.12); }
.stat-icon-wrap.yellow { background: rgba(241, 196, 15, 0.12); }

.stat-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.1;
}

.stat-desc {
  font-size: 20rpx;
  color: #8E8E93;
}

.chart-container {
  padding-top: 16rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 260rpx;
  padding: 0 8rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 220rpx;
  width: 100%;
  position: relative;
}

.bar-value-label {
  position: absolute;
  top: 0;
  font-size: 18rpx;
  color: #5BBD72;
  font-weight: 500;
  white-space: nowrap;
}

.bar-column {
  width: 36rpx;
  background: linear-gradient(180deg, rgba(91, 189, 114, 0.4), rgba(91, 189, 114, 0.8));
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  transition: height 0.4s ease;
}

.bar-column.today {
  background: linear-gradient(180deg, rgba(91, 189, 114, 0.7), #5BBD72);
  box-shadow: 0 0 12rpx rgba(91, 189, 114, 0.4);
}

.bar-label {
  font-size: 20rpx;
  color: #8E8E93;
  margin-top: 12rpx;
}

.tips-card {
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.06), rgba(52, 152, 219, 0.06));
  border-radius: 20rpx;
  padding: 28rpx;
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tips-icon {
  font-size: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.tip-bullet {
  font-size: 24rpx;
  color: #5BBD72;
  line-height: 1.5;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.picker-panel, .extend-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F0F0F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #8E8E93;
}

.picker-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  background: #F7F7FA;
  border-radius: 20rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.picker-option.selected {
  background: rgba(91, 189, 114, 0.06);
  border-color: #5BBD72;
}

.option-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.option-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.option-desc {
  font-size: 24rpx;
  color: #8E8E93;
}

.option-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #5BBD72;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.extend-panel {
  margin: auto 32rpx 32rpx;
  border-radius: 28rpx;
  max-width: 600rpx;
}

.extend-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 40rpx;
}

.extend-icon {
  font-size: 40rpx;
}

.extend-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.extend-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 28rpx;
}

.extend-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F0F0F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 300;
  color: #5BBD72;
  transition: all 0.15s;
}

.extend-btn:active {
  background: #E0E0E8;
  transform: scale(0.92);
}

.extend-btn.plus {
  font-weight: 400;
}

.extend-value-box {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.extend-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #5BBD72;
  line-height: 1;
}

.extend-unit {
  font-size: 28rpx;
  color: #8E8E93;
}

.extend-tip {
  text-align: center;
  margin-bottom: 36rpx;
}

.extend-tip .tip-text {
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.5;
}

.extend-actions {
  display: flex;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.15s;
}

.dialog-btn.cancel {
  background: #F0F0F5;
  color: #666;
}

.dialog-btn.confirm {
  background: linear-gradient(135deg, #5BBD72, #4A9D5E);
  color: #FFFFFF;
}

.dialog-btn:active {
  transform: scale(0.97);
}
