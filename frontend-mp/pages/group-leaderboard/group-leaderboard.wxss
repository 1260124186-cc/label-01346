}

.history-item-points {
  font-size: var(--font-lg);
  font-weight: 700;
}

.game-week-range {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.08) 0%, rgba(91, 189, 114, 0.04) 100%);
