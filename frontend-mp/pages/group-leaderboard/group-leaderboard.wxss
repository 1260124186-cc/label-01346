.main-tabs {
  display: flex;
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  padding: 6rpx;
  margin-bottom: var(--spacing-lg);
}

.main-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) 0;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast) ease;
}

.main-tab-active {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.3);
}

.main-tab-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.main-tab-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

.main-tab-active .main-tab-name {
  color: #FFFFFF;
  font-weight: 600;
}

.tab-section {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.period-tabs {
  display: flex;
  background: var(--bg-page);
  border-radius: var(--radius-md);
  padding: 4rpx;
  margin-bottom: var(--spacing-md);
}

.period-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) 0;
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast) ease;
}

.period-tab-active {
  background: var(--bg-card-solid);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.period-tab-icon {
  font-size: var(--font-sm);
  margin-right: 6rpx;
}

.period-tab-name {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.period-tab-active .period-tab-name {
  color: var(--color-primary);
  font-weight: 600;
}

.dimension-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.dimension-tab {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-xl);
  background: var(--bg-page);
  transition: all var(--transition-fast) ease;
}

.dimension-tab-active {
  background: var(--color-primary-light);
}

.dimension-tab-icon {
  font-size: var(--font-xs);
  margin-right: 4rpx;
}

.dimension-tab-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

.dimension-tab-active .dimension-tab-name {
  color: var(--color-primary);
  font-weight: 600;
}

.podium-section {
  margin-bottom: var(--spacing-lg);
}

.podium-container {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: var(--spacing-xl) var(--spacing-md) 0;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 210rpx;
}

.podium-gold {
  order: 2;
  margin: 0 16rpx;
}

.podium-silver {
  order: 1;
}

.podium-bronze {
  order: 3;
  margin: 0 0 0 16rpx;
}

.podium-crown {
  font-size: 44rpx;
  margin-bottom: 4rpx;
  animation: crownFloat 2s ease-in-out infinite;
}

@keyframes crownFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-6rpx);
  }
}

.podium-avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-xs);
  border: 4rpx solid transparent;
}

.podium-avatar-gold {
  width: 112rpx;
  height: 112rpx;
  border-color: #FFD700;
  box-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.35);
  background: rgba(255, 215, 0, 0.1);
}

.podium-avatar-silver {
  border-color: #C0C0C0;
  box-shadow: 0 4rpx 16rpx rgba(192, 192, 192, 0.3);
  background: rgba(192, 192, 192, 0.1);
}

.podium-avatar-bronze {
  border-color: #CD7F32;
  box-shadow: 0 4rpx 16rpx rgba(205, 127, 50, 0.3);
  background: rgba(205, 127, 50, 0.1);
}

.podium-avatar-emoji {
  font-size: 48rpx;
}

.podium-gold .podium-avatar-emoji {
  font-size: 56rpx;
}

.podium-name {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 600;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.podium-value {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2rpx;
  margin-bottom: var(--spacing-sm);
}

.podium-gold .podium-value {
  color: #D4A017;
  font-weight: 600;
}

.podium-silver .podium-value {
  color: #A0A0A0;
  font-weight: 600;
}

.podium-bronze .podium-value {
  color: #CD7F32;
  font-weight: 600;
}

.podium-bar {
  width: 100%;
  border-radius: var(--radius-md) var(--radius-md) 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) 0;
}

.podium-bar-gold {
  height: 160rpx;
  background: linear-gradient(180deg, #FFD700 0%, #F0C060 100%);
}

.podium-bar-silver {
  height: 120rpx;
  background: linear-gradient(180deg, #C0C0C0 0%, #A8A8A8 100%);
}

.podium-bar-bronze {
  height: 90rpx;
  background: linear-gradient(180deg, #CD7F32 0%, #B87333 100%);
}

.podium-rank-text {
  font-size: var(--font-xl);
  font-weight: 700;
  color: #FFFFFF;
}

.rank-list {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  overflow: hidden;
  margin-bottom: var(--spacing-lg);
}

.rank-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 1rpx solid var(--border-light);
  transition: background var(--transition-fast) ease;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-number-wrap {
  width: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-number {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-tertiary);
}

.rank-avatar-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-round);
  background: var(--bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 var(--spacing-md);
}

.rank-avatar-emoji {
  font-size: 36rpx;
}

.rank-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rank-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.rank-value {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 600;
}

.my-rank-card {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-medium);
  border: 2rpx solid var(--color-primary);
  padding: var(--spacing-md) var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
}

.my-rank-left {
  display: flex;
  align-items: center;
}

.my-rank-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
}

.my-rank-number {
  font-size: var(--font-md);
  font-weight: 700;
  color: #FFFFFF;
}

.my-rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-round);
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
}

.my-rank-avatar-emoji {
  font-size: 36rpx;
}

.my-rank-info {
  display: flex;
  flex-direction: column;
}

.my-rank-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 600;
}

.my-rank-value {
  font-size: var(--font-sm);
  color: var(--color-primary);
  font-weight: 600;
}

.my-rank-tag {
  background: var(--color-primary-light);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xs) var(--spacing-md);
}

.my-rank-tag-text {
  font-size: var(--font-xs);
  color: var(--color-primary);
  font-weight: 600;
}

.task-card {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.task-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.task-title-wrap {
  display: flex;
  align-items: center;
}

.task-icon {
  font-size: 40rpx;
  margin-right: var(--spacing-sm);
}

.task-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.task-status {
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-xl);
}

.task-status-progress {
  background: rgba(91, 189, 114, 0.1);
}

.task-status-completed {
  background: linear-gradient(135deg, #5BBD72 0%, #3DA35D 100%);
}

.task-status-text {
  font-size: var(--font-xs);
  font-weight: 600;
}

.task-status-progress .task-status-text {
  color: var(--color-primary);
}

.task-status-completed .task-status-text {
  color: #FFFFFF;
}

.task-goal-text {
  background: var(--bg-page);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.task-goal-label {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.task-goal-value {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.progress-section {
  margin-bottom: var(--spacing-lg);
}

.progress-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.progress-text {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 600;
}

.progress-current {
  font-size: var(--font-lg);
  color: var(--color-primary);
  font-weight: 700;
}

.progress-divider {
  font-size: var(--font-md);
  color: var(--text-tertiary);
  margin: 0 4rpx;
}

.progress-total {
  font-size: var(--font-md);
  color: var(--text-secondary);
  font-weight: 500;
}

.progress-percent {
  font-size: var(--font-sm);
  color: var(--color-primary);
  font-weight: 600;
}

.progress-bar-wrap {
  height: 20rpx;
  background: var(--bg-page);
  border-radius: var(--radius-round);
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72 0%, #7BD992 50%, #5BBD72 100%);
  border-radius: var(--radius-round);
  transition: width var(--transition-normal) ease;
}

.reward-section {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.08) 0%, rgba(255, 193, 7, 0.06) 100%);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
  border: 1rpx solid rgba(255, 215, 0, 0.2);
}

.reward-title-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.reward-title-icon {
  font-size: 28rpx;
  margin-right: var(--spacing-xs);
}

.reward-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: #B8860B;
}

.reward-items {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.reward-item {
  display: flex;
  align-items: center;
}

.reward-item-icon {
  font-size: 28rpx;
  margin-right: var(--spacing-xs);
}

.reward-item-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.reward-distributed {
  display: flex;
  align-items: center;
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx dashed rgba(255, 215, 0, 0.2);
}

.reward-distributed-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: var(--radius-round);
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-xs);
}

.reward-distributed-text {
  font-size: var(--font-xs);
  color: var(--color-primary);
  font-weight: 600;
}

.contribution-section {
  border-top: 1rpx solid var(--border-light);
  padding-top: var(--spacing-md);
}

.contribution-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.contribution-header-icon {
  font-size: 28rpx;
  margin-right: var(--spacing-xs);
}

.contribution-header-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.contribution-list {
  background: var(--bg-page);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.contribution-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  border-bottom: 1rpx solid var(--border-light);
}

.contribution-item:last-child {
  border-bottom: none;
}

.contribution-rank-wrap {
  width: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contribution-rank-badge {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contribution-rank-emoji {
  font-size: 32rpx;
}

.contribution-rank-number {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--text-tertiary);
}

.contribution-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-round);
  background: var(--bg-card-solid);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 var(--spacing-sm);
}

.contribution-avatar-emoji {
  font-size: 28rpx;
}

.contribution-name {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200rpx;
}

.contribution-count {
  font-size: var(--font-sm);
  color: var(--color-primary);
  font-weight: 600;
}

.pool-card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-medium);
}

.pool-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #5BBD72 0%, #3DA35D 100%);
}

.pool-card-content {
  position: relative;
  padding: var(--spacing-xl) var(--spacing-lg);
}

.pool-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.pool-icon {
  font-size: 40rpx;
  margin-right: var(--spacing-sm);
}

.pool-title {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.85);
