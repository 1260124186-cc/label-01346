.page {
  min-height: 100vh;
  background: #F7FAF8;
  padding: 24rpx 30rpx 180rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.item-card {
  display: flex;
  align-items: center;
}

.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #F0F2F5;
}

.item-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 16rpx;
}

.seller-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.seller-avatar {
  font-size: 36rpx;
}

.seller-name {
  font-size: 26rpx;
  color: #5B6470;
  flex: 1;
}

.seller-rating {
  font-size: 24rpx;
  color: #F39C12;
  font-weight: 500;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 24rpx;
}

.section-hint {
  font-size: 24rpx;
  color: #84919A;
  font-weight: 400;
}

.rating-card {
  text-align: center;
}

.rating-card .section-title {
  justify-content: center;
}

.stars-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 0;
}

.star-item {
  padding: 10rpx;
}

.star {
  font-size: 64rpx;
  color: #E0E4E8;
  transition: color 0.15s ease;
}

.star.active {
  color: #F39C12;
}

.rating-text {
  font-size: 28rpx;
  color: #F39C12;
  font-weight: 500;
  margin-left: 16rpx;
}

.tags-group {
  margin-bottom: 24rpx;
}

.tags-group:last-child {
  margin-bottom: 0;
}

.tags-label {
  font-size: 26rpx;
  color: #84919A;
  margin-bottom: 16rpx;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 14rpx 28rpx;
  background: #F0F2F5;
  color: #5B6470;
  border-radius: 32rpx;
  font-size: 26rpx;
  transition: all 0.2s ease;
}

.tag-item.active.positive {
  background: rgba(91, 189, 114, 0.12);
  color: #5BBD72;
  font-weight: 500;
}

.tag-item.active.negative {
  background: rgba(231, 76, 60, 0.1);
  color: #E74C3C;
  font-weight: 500;
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  background: #F7FAF8;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.6;
  box-sizing: border-box;
}

.content-placeholder {
  color: #B2BEC3;
}

.anonymous-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.anonymous-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.anonymous-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.anonymous-text {
  display: flex;
  flex-direction: column;
}

.anonymous-title {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.anonymous-desc {
  font-size: 24rpx;
  color: #84919A;
}

.anonymous-switch {
  transform: scale(0.9);
}

.reward-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.1) 0%, rgba(243, 156, 18, 0.1) 100%);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin: 8rpx 0 24rpx;
}

.reward-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.reward-text {
  font-size: 26rpx;
  color: #5BBD72;
  font-weight: 500;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #7ECF91 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}
