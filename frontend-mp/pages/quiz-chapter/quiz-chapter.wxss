.chapter-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  padding-bottom: 40rpx;
}

.header-card {
  background: linear-gradient(135deg, #4A90D9 0%, #3498DB 100%);
  margin: 0;
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.2);
}

.header-content {
  text-align: center;
  color: #fff;
  margin-bottom: 40rpx;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.progress-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
}

.summary-item {
  text-align: center;
}

.summary-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.summary-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.chapters-section {
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 24rpx;
}

.chapters-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chapter-item {
  display: flex;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.chapter-item:active {
  transform: scale(0.99);
}

.chapter-item.locked {
  opacity: 0.6;
}

.chapter-item.completed {
  border-color: #5BBD72;
}

.chapter-number {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.chapter-info {
  flex: 1;
  min-width: 0;
}

.chapter-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.chapter-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chapter-icon {
  font-size: 32rpx;
}

.chapter-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.chapter-status {
  flex-shrink: 0;
}

.status-completed {
  font-size: 24rpx;
  color: #5BBD72;
  font-weight: 500;
  background: rgba(91, 189, 114, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.status-locked {
  font-size: 24rpx;
  color: #B2BEC3;
}

.status-progress {
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 600;
}

.chapter-desc {
  font-size: 24rpx;
  color: #636E72;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.chapter-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #B2BEC3;
}

.chapter-progress-bar {
  width: 100%;
}

.progress-track {
  height: 8rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.chapter-arrow {
  font-size: 40rpx;
  color: #B2BEC3;
  margin-left: 16rpx;
  align-self: center;
}

.tips-section {
  padding: 0 32rpx;
  margin-top: 16rpx;
}

.tips-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.6;
}
