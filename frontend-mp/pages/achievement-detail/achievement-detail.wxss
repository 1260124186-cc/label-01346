.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F7F2 0%, #E8F5E9 30%, #F7FAF8 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.unlock-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.unlock-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  animation: unlockFadeIn 0.5s ease;
}

.unlock-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: unlockBounce 0.8s ease;
}

.unlock-badge {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 60rpx rgba(255, 215, 0, 0.6), 0 0 120rpx rgba(255, 165, 0, 0.3);
  margin-bottom: 40rpx;
  animation: unlockGlow 1.5s ease-in-out infinite;
}

.unlock-emoji {
  font-size: 100rpx;
}

.unlock-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.unlock-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.unlock-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.unlock-particles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.particle {
  position: absolute;
  bottom: -60rpx;
  font-size: 40rpx;
  animation: particleRise linear forwards;
}

@keyframes unlockFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes unlockBounce {
  0% { opacity: 0; transform: scale(0.3) translateY(100rpx); }
  50% { opacity: 1; transform: scale(1.1) translateY(-20rpx); }
  70% { transform: scale(0.95) translateY(10rpx); }
  100% { transform: scale(1) translateY(0); }
}

@keyframes unlockGlow {
  0%, 100% { box-shadow: 0 0 60rpx rgba(255, 215, 0, 0.6), 0 0 120rpx rgba(255, 165, 0, 0.3); }
  50% { box-shadow: 0 0 80rpx rgba(255, 215, 0, 0.8), 0 0 160rpx rgba(255, 165, 0, 0.5); }
}

@keyframes particleRise {
  0% { opacity: 1; transform: translateY(0) rotate(0deg); }
  100% { opacity: 0; transform: translateY(-1200rpx) rotate(720deg); }
}

.achievement-hero {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.hero-glow {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 40rpx 48rpx;
}

.badge-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.badge-wrapper.unlocked .badge-inner {
  animation: badgePulse 2s ease-in-out infinite;
}

.badge-inner {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.badge-emoji {
  font-size: 80rpx;
}

.badge-ring {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  border: 4rpx solid;
  pointer-events: none;
}

.badge-ring.outer {
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-style: dashed;
}

@keyframes badgePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.hero-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.hero-desc {
  font-size: 28rpx;
  color: #636E72;
  margin-bottom: 24rpx;
}

.hero-status {
  margin-top: 8rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.status-icon {
  font-size: 24rpx;
}

.hero-locked {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.locked-text {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-bottom: 16rpx;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 80%;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #636E72;
  white-space: nowrap;
}

.info-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.info-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.info-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.info-card-icon {
  font-size: 32rpx;
}

.info-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.condition-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.condition-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.condition-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.condition-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
}

.condition-detail {
  font-size: 24rpx;
  color: #636E72;
}

.condition-status {
  flex-shrink: 0;
}

.status-value {
  font-size: 28rpx;
  font-weight: 600;
}

.unlock-time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.unlock-time-value {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
}

.unlock-time-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.records-section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon {
  font-size: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.section-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  background: rgba(91, 189, 114, 0.08);
  border-radius: 20rpx;
}

.link-text {
  font-size: 24rpx;
  color: #5BBD72;
}

.link-arrow {
  font-size: 28rpx;
  color: #5BBD72;
}

.records-list {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.record-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: background 0.2s ease;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item:active {
  background: rgba(91, 189, 114, 0.04);
}

.record-emoji {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
}

.record-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.record-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-subtitle {
  font-size: 24rpx;
  color: #636E72;
}

.record-time {
  font-size: 22rpx;
  color: #B2BEC3;
  flex-shrink: 0;
}

.slogan-section {
  margin-bottom: 24rpx;
}

.slogan-card {
  position: relative;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.slogan-quote {
  position: absolute;
  font-size: 80rpx;
  font-family: Georgia, serif;
  opacity: 0.15;
  line-height: 1;
}

.slogan-quote.end {
  right: 32rpx;
  bottom: 20rpx;
}

.slogan-text {
  position: relative;
  z-index: 1;
  font-size: 34rpx;
  font-weight: 600;
  font-family: 'STKaiti', 'KaiTi', serif;
  letter-spacing: 4rpx;
}

.action-section {
  padding: 16rpx 0 24rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  position: relative;
  overflow: hidden;
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

.action-btn.poster-btn {
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(155, 89, 182, 0.3);
}

.action-btn.share-btn {
  background: linear-gradient(135deg, #5DA3E8 0%, #4A90D9 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.25);
}

.action-btn.timeline-btn {
  background: linear-gradient(135deg, #F06E6E 0%, #E85D5D 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(232, 93, 93, 0.25);
}

.action-btn.back-btn {
  background: #fff;
  color: #666;
  border: 2rpx solid #e8e8e8;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.poster-modal-content {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  position: relative;
}

.poster-preview {
  width: 100%;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  background: #f5f5f5;
}

.poster-image {
  width: 100%;
  height: auto;
  display: block;
}

.poster-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 600rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.poster-actions {
  display: flex;
  gap: 20rpx;
}

.poster-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.poster-action-btn::after {
  border: none;
}

.poster-action-btn.generate {
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #fff;
}

.poster-action-btn.save {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  color: #fff;
}

.poster-action-btn[disabled] {
  opacity: 0.6;
}

.action-icon {
  font-size: 28rpx;
}

.action-label {
  font-size: 26rpx;
}

.poster-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 50%;
}

.close-icon {
  font-size: 28rpx;
  color: #999;
}

.canvas-container {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  opacity: 0;
  pointer-events: none;
  z-index: -1;
}

.poster-canvas {
  display: block;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}