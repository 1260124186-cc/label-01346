.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F7F2 0%, #E8F5E9 50%, #F7FAF8 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.revoke-banner {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE8E8 100%);
  border: 2rpx solid #F8C8C8;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.revoke-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.revoke-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.revoke-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #C0392B;
  line-height: 1.3;
}

.revoke-subtitle {
  font-size: 24rpx;
  color: #E74C3C;
  line-height: 1.5;
}

.verify-info-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #F0FFF4 0%, #E8F8EC 100%);
  border: 2rpx solid #B8E6C4;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.verify-info-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.verify-info-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.verify-info-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.verify-info-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #27AE60;
  line-height: 1.3;
}

.verify-info-subtitle {
  font-size: 22rpx;
  color: #5BBD72;
  line-height: 1.4;
}

.verify-info-badge {
  flex-shrink: 0;
  background: linear-gradient(135deg, #5BBD72 0%, #3A9D5A 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(91, 189, 114, 0.3);
}

.cert-section {
  padding: 8rpx 0 8rpx;
}

.cert-wrapper {
  padding: 0 8rpx;
}

.cert-card {
  position: relative;
  background: linear-gradient(135deg, #FFFDF5 0%, #FFFBEC 50%, #FFFDF5 100%;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  box-shadow:
    0 20rpx 60rpx rgba(0, 0, 0, 0.08),
    0 4rpx 20rpx rgba(91, 189, 114, 0.06);
  overflow: hidden;
}

.cert-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(ellipse at top left, var(--gradient-start, transparent 50%),
    radial-gradient(ellipse at bottom right, var(--gradient-end),
    transparent 60%;
  opacity: 0.05;
  pointer-events: none;
}

.cert-border-outer {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  border: 4rpx solid var(--primary);
  border-radius: 16rpx;
  pointer-events: none;
  z-index: 1;
}

.cert-border-mid {
  position: absolute;
  top: 44rpx;
  left: 44rpx;
  right: 44rpx;
  bottom: 44rpx;
  border: 1rpx dashed var(--accent);
  pointer-events: none;
  z-index: 1;
}

.cert-border-inner {
  position: absolute;
  top: 58rpx;
  left: 58rpx;
  right: 58rpx;
  bottom: 58rpx;
  border: 1rpx solid var(--primary);
  opacity: 0.5;
  pointer-events: none;
  z-index: 1;
}

.corner {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  z-index: 2;
}

.corner.top-left {
  top: 28rpx;
  left: 28rpx;
}

.corner.top-right {
  top: 28rpx;
  right: 28rpx;
  transform: rotate(90deg);
}

.corner.bottom-left {
  bottom: 28rpx;
  left: 28rpx;
  transform: rotate(-90deg);
}

.corner.bottom-right {
  bottom: 28rpx;
  right: 28rpx;
  transform: rotate(180deg);
}

.corner-deco {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.corner-deco::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 6rpx;
  background: var(--primary);
  border-radius: 3rpx;
}

.corner-deco::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 50%;
  background: var(--primary);
  border-radius: 3rpx;
}

.corner-star {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 28rpx;
  color: var(--primary);
  opacity: 0.4;
}

.cert-header {
  position: relative;
  z-index: 3;
  text-align: center;
  padding: 20rpx 0 48rpx;
}

.header-stars {
  font-size: 36rpx;
  color: var(--primary);
  letter-spacing: 12rpx;
  opacity: 0.7;
  margin-bottom: 12rpx;
}

.header-en {
  font-size: 22rpx;
  color: #999;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.header-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.divider-line {
  width: 120rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--primary), transparent 100%);
  opacity: 0.4;
}

.divider-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
}

.cert-title-section {
  position: relative;
  z-index: 3;
  text-align: center;
  padding: 24rpx 0 48rpx;
}

.cert-title {
  font-family: 'STKaiti', 'KaiTi', serif;
  font-size: 72rpx;
  font-weight: bold;
  color: var(--primary);
  text-shadow: 0 4rpx 12rpx var(--accent);
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
}

.cert-title-en {
  font-size: 24rpx;
  color: #888;
  letter-spacing: 4rpx;
}

.cert-body {
  position: relative;
  z-index: 3;
  padding: 12rpx 24rpx 48rpx;
}

.cert-intro-line {
  text-align: left;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 28rpx;
}

.intro-label {
  color: #888;
}

.intro-name {
  font-family: 'STKaiti', 'KaiTi', serif;
  font-size: 40rpx;
  font-weight: bold;
  margin: 0 8rpx;
}

.intro-suffix {
  color: #888;
}

.cert-course-title {
  font-family: 'STKaiti', 'KaiTi', serif;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 28rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, var(--gradient-start, 0.05), var(--gradient-end, 0.05) 100%);
  border-radius: 12rpx;
}

.cert-completion-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.8;
  margin-bottom: 48rpx;
}

.cert-info-grid {
  background: #FAFAF8;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 36rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999;
}

.info-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.cert-no-row {
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
}

.cert-no-label {
  color: #999;
}

.cert-no-value {
  color: #888;
  font-family: monospace;
  letter-spacing: 2rpx;
}

.cert-footer {
  position: relative;
  z-index: 3;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 24rpx 16rpx 24rpx;
}

.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.qr-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: #fff;
  border: 2rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 8rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.qr-pattern {
  width: 100%;
  height: 100%;
  position: relative;
  background:
    repeating-linear-gradient(
      45deg,
      var(--primary) 0rpx,
      var(--primary) 4rpx,
      transparent 4rpx,
      transparent 10rpx
    ),
    repeating-linear-gradient(
      -45deg,
      var(--primary) 0rpx,
      var(--primary) 4rpx,
      transparent 4rpx,
      transparent 10rpx
    );
  background-size: 12rpx 12rpx;
  opacity: 0.25;
  border-radius: 4rpx;
}

.qr-dots {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border: 6rpx solid;
  border-radius: 4rpx;
  background:
    radial-gradient(circle, var(--primary) 2rpx, transparent 2rpx);
  background-size: 8rpx 8rpx;
  opacity: 0.5;
}

.qr-corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary);
  background: #fff;
  border-radius: 2rpx;
}

.qr-corner.tl {
  top: 0;
  left: 0;
  border-top: 8rpx solid var(--primary);
  border-left: 8rpx solid var(--primary);
}

.qr-corner.tr {
  top: 0;
  right: 0;
  border-top: 8rpx solid var(--primary);
  border-right: 8rpx solid var(--primary);
}

.qr-corner.bl {
  bottom: 0;
  left: 0;
  border-bottom: 8rpx solid var(--primary);
  border-left: 8rpx solid var(--primary);
}

.qr-label {
  font-size: 22rpx;
  color: #999;
}

.qr-sub-label {
  font-size: 20rpx;
  color: #888;
  font-family: monospace;
  letter-spacing: 1rpx;
  opacity: 0.8;
}

.seal-section {
  position: relative;
}

.seal-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid;
  opacity: 0.85;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transform: rotate(-8deg);
  box-shadow: inset 0 0 20rpx currentColor;
}

.seal-inner-ring {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  border-radius: 50%;
  border: 2rpx solid;
  opacity: 0.5;
}

.seal-text-arc {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  opacity: 0.9;
  width: 140rpx;
  text-align: center;
  font-family: 'STKaiti', 'KaiTi', serif;
}

.seal-star {
  font-size: 36rpx;
  opacity: 0.85;
  margin-top: -8rpx;
}

.seal-text {
  font-size: 18rpx;
  font-weight: bold;
  opacity: 0.85;
  font-family: 'STKaiti', 'KaiTi', serif;
  margin-top: 4rpx;
}

.seal-en {
  font-size: 14rpx;
  opacity: 0.6;
  letter-spacing: 1rpx;
  margin-top: 2rpx;
}

.cert-watermark {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.watermark-text {
  position: absolute;
  font-size: 36rpx;
  opacity: 0.04;
  font-family: 'STKaiti', 'KaiTi', serif;
  white-space: nowrap;
  transform: rotate(-30deg);
  pointer-events: none;
}

.watermark-text:nth-child(1) { top: 15%; left: -10%; }
.watermark-text:nth-child(2) { top: 30%; left: 40%; }
.watermark-text:nth-child(3) { top: 50%; left: -20%; }
.watermark-text:nth-child(4) { top: 65%; left: 30%; }
.watermark-text:nth-child(5) { top: 80%; left: 10%; }
.watermark-text:nth-child(6) { top: 20%; left: 60%; }

.action-section {
  padding: 32rpx 16rpx 24rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  position: relative;
  overflow: hidden;
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--gradient-start, #5BBD72) 0%, var(--gradient-end, #3A9D5A) 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.action-btn.share-friend {
  background: linear-gradient(135deg, #5DA3E8 0%, #4A90D9 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.25);
}

.action-btn.share-timeline {
  background: linear-gradient(135deg, #F06E6E 0%, #E85D5D 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(232, 93, 93, 0.25);
}

.action-btn.verify-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #3A9D5A 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.action-btn.copy-link {
  background: linear-gradient(135deg, #F5A623 0%, #E8971E 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(245, 166, 35, 0.25);
}

.action-btn.copy-code {
  background: linear-gradient(135deg, #9013FE 0%, #8227D9 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(144, 19, 254, 0.25);
}

.action-btn.revoke {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF8F8 100%);
  color: #E74C3C;
  border: 2rpx solid #F8C8C8;
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.08);
}

.action-btn.back {
  background: #fff;
  color: #666;
  border: 2rpx solid #e8e8e8;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.action-btn[disabled] {
  opacity: 0.6;
}

.canvas-container {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  opacity: 0;
  pointer-events: none;
  z-index: -1;
}

.cert-canvas {
  display: block;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
