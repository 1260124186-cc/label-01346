.detail-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F9FF 0%, #F8FFF8 100%);
  padding-bottom: 180rpx;
}

.header-card {
  margin: 0;
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.course-info {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.course-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.course-meta {
  flex: 1;
  min-width: 0;
}

.course-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.chapter-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.chapter-progress text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.completed-badge {
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.chapter-type-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.type-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.type-tag .type-icon {
  font-size: 28rpx;
}

.video-tag {
  color: #E74C3C;
}

.article-tag {
  color: #4A90D9;
}

.duration-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
}

.duration-icon {
  font-size: 24rpx;
}

.content-wrapper {
  padding: 32rpx 32rpx 0;
}

.video-section {
  margin-bottom: 28rpx;
}

.video-wrapper {
  position: relative;
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: #1a1a1a;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.video-player {
  width: 100%;
  height: 420rpx;
  display: block;
}

.video-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
}

.placeholder-play {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.play-icon {
  font-size: 48rpx;
  color: #fff;
  margin-left: 8rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.summary-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border-left: 6rpx solid #F39C12;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.7;
}

.sections-section {
  margin-bottom: 28rpx;
}

.section-title-wrap {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.sections-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-item {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.05);
}

.section-number {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.section-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.4;
}

.section-content {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.section-content:last-child {
  margin-bottom: 0;
}

.bullets-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.bullet-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.bullet-text {
  flex: 1;
  font-size: 26rpx;
  color: #2D3436;
  line-height: 1.7;
}

.tips-section {
  margin-bottom: 28rpx;
}

.tips-card {
  background: linear-gradient(135deg, rgba(243, 156, 18, 0.08) 0%, rgba(230, 126, 34, 0.08) 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(243, 156, 18, 0.2);
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid rgba(243, 156, 18, 0.15);
}

.tips-icon {
  font-size: 36rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #E67E22;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.tip-number {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(243, 156, 18, 0.2);
  color: #E67E22;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #2D3436;
  line-height: 1.7;
}

.bottom-spacer {
  height: 40rpx;
}

.bottom-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.btn-prev {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 44rpx;
  background: rgba(0, 0, 0, 0.05);
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.btn-prev.disabled {
  opacity: 0.5;
}

.btn-prev .btn-icon {
  font-size: 28rpx;
  color: #2D3436;
}

.btn-prev .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
}

.btn-next {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #5BBD72;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.35);
  transition: all 0.3s ease;
}

.btn-next:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-next.completed {
  box-shadow: 0 8rpx 24rpx rgba(178, 190, 195, 0.35);
}

.btn-next .btn-icon {
  font-size: 30rpx;
  color: #fff;
}

.btn-next .btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}
