.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 160rpx;
}

/* ==================== 顶部区域 ==================== */
.header-section {
  position: relative;
  padding-bottom: 24rpx;
}

.header-bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 50%, #66BB6A 100%);
  z-index: 0;
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 24rpx 32rpx 0;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.title-area {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
}

.action-btn:active {
  opacity: 0.8;
}

.action-icon {
  font-size: 26rpx;
}

.action-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.points-card {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.points-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.points-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 搜索框 ==================== */
.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 80rpx;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-bar.focused {
  background: #FFFFFF;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.12);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2D3436;
  height: 80rpx;
}

.search-placeholder {
  color: #B2BEC3;
  font-size: 28rpx;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  background: #DFE6E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-icon {
  font-size: 28rpx;
  color: #636E72;
  line-height: 1;
}

/* ==================== 交易方式筛选 ==================== */
.trade-filter-section {
  background: #FFFFFF;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.trade-scroll {
  padding: 0 24rpx;
  white-space: nowrap;
}

.trade-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  background: #F5F5F5;
  margin-right: 16rpx;
  transition: all 0.2s ease;
}

.trade-item:last-child {
  margin-right: 0;
}

.trade-item.active {
  background: color-mix(in srgb, var(--trade-color) 15%, transparent);
}

.trade-icon {
  font-size: 26rpx;
}

.trade-name {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
}

.trade-item.active .trade-name {
  color: var(--trade-color);
  font-weight: 600;
}

/* ==================== 分类筛选 ==================== */
.category-section {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.category-item.active {
  background: color-mix(in srgb, var(--cat-color) 12%, transparent);
}

.category-icon {
  font-size: 40rpx;
}

.category-name {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 500;
}

.category-item.active .category-name {
  color: var(--cat-color);
  font-weight: 600;
}

/* ==================== 物品列表 ==================== */
.items-section {
  padding: 24rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
}

.section-count {
  font-size: 24rpx;
  color: #B2BEC3;
}

.items-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.item-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.item-card:active {
  transform: scale(0.97);
}

.item-image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
}

.item-image {
  width: 100%;
  height: 100%;
}

.item-trade-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
}

.trade-badge-icon {
  font-size: 20rpx;
}

.trade-badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.item-condition-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.55);
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
}

.condition-badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.item-info {
  padding: 20rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.item-desc {
  font-size: 22rpx;
  color: #8E8E93;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-icon {
  font-size: 22rpx;
}

.price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #E67E22;
}

.price-unit {
  font-size: 20rpx;
  color: #E67E22;
  font-weight: 500;
}

.item-location {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.location-icon {
  font-size: 18rpx;
}

.location-text {
  font-size: 20rpx;
  color: #B2BEC3;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-seller {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.seller-avatar {
  font-size: 28rpx;
}

.seller-name {
  flex: 1;
  font-size: 22rpx;
  color: #636E72;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seller-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-star {
  font-size: 18rpx;
}

.rating-value {
  font-size: 20rpx;
  color: #E67E22;
  font-weight: 600;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  padding: 20rpx 64rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.35);
}

.empty-btn:active {
  transform: scale(0.96);
}

.empty-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ==================== 底部安全区域 ==================== */
.bottom-safe {
  height: 40rpx;
}

/* ==================== 浮动发布按钮 ==================== */
.fab-publish {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  box-shadow: 0 12rpx 32rpx rgba(91, 189, 114, 0.45);
  z-index: 100;
  transition: all 0.2s ease;
}

.fab-publish:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

.fab-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}
