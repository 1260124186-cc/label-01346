.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F7F2 0%, #F7FAF8 30%, #FFFFFF 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.stats-section {
  padding: 8rpx 0 16rpx;
}

.stats-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #5BBD72 0%, #3A9D5A 100%);
  box-shadow: 0 12rpx 32rpx rgba(91, 189, 114, 0.25);
}

.stats-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 20% 0%, rgba(255,255,255,0.2) 0%, transparent 50%),
    radial-gradient(circle at 100% 100%, rgba(255,255,255,0.15) 0%, transparent 50%);
  pointer-events: none;
}

.stats-content {
  position: relative;
  padding: 40rpx 32rpx;
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1.2;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stats-divider {
  width: 2rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.25);
}

.content-section {
  padding-top: 24rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 8rpx 8rpx 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.section-subtitle {
  font-size: 26rpx;
  color: #8E8E93;
}

.cert-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.cert-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.cert-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.cert-cover {
  position: relative;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.cert-cover-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    repeating-linear-gradient(
      45deg,
      transparent 0rpx,
      transparent 20rpx,
      rgba(255,255,255,0.08) 20rpx,
      rgba(255,255,255,0.08) 40rpx
    );
  pointer-events: none;
}

.cert-category-icon {
  font-size: 72rpx;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.15));
}

.cert-ribbon {
  position: absolute;
  top: 16rpx;
  right: -30rpx;
  width: 100rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.25);
  transform: rotate(45deg);
}

.cert-body {
  padding: 20rpx 20rpx 24rpx;
}

.cert-name-row {
  margin-bottom: 12rpx;
}

.cert-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cert-level-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.cert-course-title {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 66rpx;
}

.cert-footer-row {
  display: flex;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0F0F0;
}

.cert-date {
  font-size: 22rpx;
  color: #999999;
}

.empty-section {
  padding: 80rpx 40rpx;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-illustration {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.1) 0%, rgba(74, 144, 217, 0.1) 100%);
  border-radius: 50%;
}

.empty-icon-big {
  font-size: 120rpx;
  position: relative;
  z-index: 1;
}

.empty-sparkles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.sparkle {
  position: absolute;
  font-size: 36rpx;
  opacity: 0.6;
}

.sparkle.s1 {
  top: 20rpx;
  left: 30rpx;
  animation: twinkle 2s ease-in-out infinite;
}

.sparkle.s2 {
  top: 10rpx;
  right: 40rpx;
  font-size: 32rpx;
  animation: twinkle 2s ease-in-out infinite 0.5s;
}

.sparkle.s3 {
  bottom: 30rpx;
  left: 50rpx;
  font-size: 28rpx;
  animation: twinkle 2s ease-in-out infinite 1s;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 0.8; transform: scale(1.1); }
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8E8E93;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 48rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #3A9D5A 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
  transition: transform 0.2s ease;
}

.empty-btn:active {
  transform: scale(0.96);
}

.empty-btn .btn-icon {
  font-size: 32rpx;
}

.empty-btn .btn-text {
  font-size: 30rpx;
  font-weight: 600;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
