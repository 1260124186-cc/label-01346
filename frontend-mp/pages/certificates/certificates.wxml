<view class="page-container">
  <view class="stats-section">
    <view class="stats-card">
      <view class="stats-bg"></view>
      <view class="stats-content">
        <view class="stats-grid">
          <view class="stats-item">
            <text class="stats-icon">🏆</text>
            <text class="stats-value">{{stats.certificates}}</text>
            <text class="stats-label">证书总数</text>
          </view>
          <view class="stats-divider"></view>
          <view class="stats-item">
            <text class="stats-icon">📖</text>
            <text class="stats-value">{{stats.completedCourses}}</text>
            <text class="stats-label">已学课程</text>
          </view>
          <view class="stats-divider"></view>
          <view class="stats-item">
            <text class="stats-icon">⏱️</text>
            <text class="stats-value">{{stats.totalMinutes}}</text>
            <text class="stats-label">累计时长</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="content-section" wx:if="{{certificates.length > 0}}">
    <view class="section-header">
      <text class="section-title">我的证书</text>
      <text class="section-subtitle">共 {{certificates.length}} 张</text>
    </view>
    <view class="cert-grid">
      <view
        wx:for="{{certificates}}"
        wx:key="id"
        class="cert-card"
        bindtap="onCertificateTap"
        data-cert-id="{{item.id}}"
      >
        <view
          class="cert-cover"
          style="background: linear-gradient(135deg, {{item.categoryColor}} 0%, {{item.categoryColor}}CC 100%);"
        >
          <view class="cert-cover-pattern"></view>
          <text class="cert-category-icon">{{item.categoryIcon}}</text>
          <view class="cert-ribbon"></view>
        </view>
        <view class="cert-body">
          <view class="cert-name-row">
            <text class="cert-name">{{item.certificateName}}</text>
          </view>
          <view
            class="cert-level-tag"
            style="background: {{levelColors[item.certificateLevel]}}15; color: {{levelColors[item.certificateLevel]}};"
          >
            {{item.certificateLevel}}
          </view>
          <view class="cert-course-title">{{item.courseTitle}}</view>
          <view class="cert-footer-row">
            <text class="cert-date">📅 {{item.issueDate}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-section" wx:else>
    <view class="empty-content">
      <view class="empty-illustration">
        <text class="empty-icon-big">🎓</text>
        <view class="empty-sparkles">
          <text class="sparkle s1">✨</text>
          <text class="sparkle s2">⭐</text>
          <text class="sparkle s3">✨</text>
        </view>
      </view>
      <text class="empty-title">暂无证书</text>
      <text class="empty-desc">完成课程学习并通过考核即可获得证书</text>
      <view class="empty-btn" bindtap="goToLearningCenter">
        <text class="btn-icon">📚</text>
        <text class="btn-text">去学习中心赢取第一张证书</text>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
