<view class="learning-path-container">
  <view class="header-card">
    <view class="header-content">
      <view class="header-title">我的学习路径</view>
      <view class="header-subtitle">循序渐进，成为垃圾分类达人</view>
    </view>

    <view class="progress-overview">
      <view class="overview-progress-wrap">
        <view class="overview-progress-ring">
          <view class="ring-bg"></view>
          <view class="ring-progress" style="background: conic-gradient(#FFD93D 0% {{overallProgress}}%, rgba(255,255,255,0.15) {{overallProgress}}% 100%);"></view>
          <view class="ring-inner">
            <text class="ring-value">{{overallProgress}}%</text>
            <text class="ring-label">总进度</text>
          </view>
        </view>
      </view>
      <view class="overview-stats">
        <view class="overview-stat-item">
          <text class="stat-icon">✅</text>
          <view class="stat-text-wrap">
            <text class="stat-value">{{completedCount}}</text>
            <text class="stat-label">已完成</text>
          </view>
        </view>
        <view class="overview-stat-item">
          <text class="stat-icon">🎯</text>
          <view class="stat-text-wrap">
            <text class="stat-value">{{totalCount}}</text>
            <text class="stat-label">总节点</text>
          </view>
        </view>
        <view class="overview-stat-item">
          <text class="stat-icon">💎</text>
          <view class="stat-text-wrap">
            <text class="stat-value">{{earnedPoints}}</text>
            <text class="stat-label">已获积分</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="path-section">
    <view class="path-timeline">
      <view
        class="path-node {{item.status}}"
        wx:for="{{pathNodes}}"
        wx:key="id"
        data-item="{{item}}"
        bindtap="onNodeTap"
      >
        <view class="node-connector" wx:if="{{index > 0}}">
          <view class="connector-line {{pathNodes[index - 1].status === 'completed' ? 'active' : ''}}"></view>
        </view>

        <view class="node-icon-wrap" style="--node-color: {{item.color}};">
          <view class="node-icon-bg"></view>
          <text class="node-icon">{{item.emoji}}</text>
          <view class="node-check" wx:if="{{item.status === 'completed'}}">
            <text class="check-icon">✓</text>
          </view>
          <view class="node-pulse" wx:if="{{item.status === 'in-progress'}}"></view>
        </view>

        <view class="node-content">
          <view class="node-header">
            <view class="node-title-wrap">
              <text class="node-step">第{{index + 1}}步</text>
              <text class="node-title">{{item.title}}</text>
            </view>
            <view class="node-status-tag" style="background: {{item.statusBg}}; color: {{item.statusColor}};">
              <text wx:if="{{item.status === 'completed'}}">已完成</text>
              <text wx:elif="{{item.status === 'in-progress'}}">进行中</text>
              <text wx:else>未开始</text>
            </view>
          </view>

          <text class="node-desc">{{item.description}}</text>

          <view class="node-progress-row" wx:if="{{item.status !== 'locked' && item.total > 0}}">
            <view class="node-progress-bar">
              <view class="node-progress-fill" style="width: {{item.progressPercent}}%; background: {{item.color}};"></view>
            </view>
            <text class="node-progress-text" style="color: {{item.color}};">{{item.progressPercent}}%</text>
          </view>

          <view class="node-meta">
            <view class="meta-item">
              <text class="meta-icon">📖</text>
              <text class="meta-text">{{item.current}}/{{item.total}} {{item.unit}}</text>
            </view>
            <view class="meta-item" wx:if="{{item.reward > 0}}">
              <text class="meta-icon">💎</text>
              <text class="meta-text">+{{item.reward}}积分</text>
            </view>
          </view>

          <view class="node-action">
            <view
              class="action-btn"
              style="background: {{item.status === 'locked' ? '#E8E8E8' : 'linear-gradient(135deg, ' + item.color + ' 0%, ' + item.colorDark + ' 100%)'}};"
            >
              <text wx:if="{{item.status === 'completed'}}">再次学习</text>
              <text wx:elif="{{item.status === 'in-progress'}}">继续学习</text>
              <text wx:elif="{{item.status === 'locked'}}">未解锁</text>
              <text wx:else>开始学习</text>
              <text class="action-arrow">›</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="tips-section">
    <view class="tips-card">
      <view class="tips-icon-wrap">
        <text class="tips-icon">💡</text>
      </view>
      <view class="tips-content">
        <text class="tips-title">学习小贴士</text>
        <text class="tips-text">按顺序完成每个学习节点，循序渐进效果更佳。完成所有节点即可解锁"垃圾分类达人"成就勋章！</text>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
