<view class="learning-path-container">
  <view class="header-card">
    <view class="header-content">
      <view class="header-title">我的学习路径</view>
      <view class="header-subtitle">循序渐进，成为垃圾分类达人</view>
    </view>

    <view class="progress-overview">
      <view class="overview-progress-wrap">
        <view class="overview-progress-ring">
          <view class="ring-bg"></view>
          <view class="ring-progress" style="background: conic-gradient(#FFD93D 0% {{overallProgress}}%, rgba(255,255,255,0.15) {{overallProgress}}% 100%);"></view>
          <view class="ring-inner">
            <text class="ring-value">{{overallProgress}}%</text>
            <text class="ring-label">总进度</text>
          </view>
        </view>
      </view>
      <view class="overview-stats">
        <view class="overview-stat-item">
          <text class="stat-icon">✅</text>
          <view class="stat-text-wrap">
            <text class="stat-value">{{completedCount}}</text>
            <text class="stat-label">已完成</text>
          </view>
        </view>
        <view class="overview-stat-item">
          <text class="stat-icon">💎</text>
          <view class="stat-text-wrap">
            <text class="stat-value">{{earnedPoints}}</text>
            <text class="stat-label">已获积分</text>
          </view>
        </view>
        <view class="overview-stat-item">
          <text class="stat-icon">🏅</text>
          <view class="stat-text-wrap">
            <text class="stat-value">{{earnedBadges.length}}</text>
            <text class="stat-label">虚拟徽章</text>
          </view>
        </view>
      </view>
    </view>

    <view class="earned-badges-row" wx:if="{{earnedBadges.length > 0}}">
      <view class="badge-chip" wx:for="{{earnedBadges}}" wx:key="name" style="--badge-color: {{item.color}};">
        <text class="badge-chip-emoji">{{item.badge}}</text>
        <text class="badge-chip-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="recommended-section" wx:if="{{recommendedAction}}" bindtap="onRecommendedTap">
    <view class="recommended-card">
      <view class="recommended-left">
        <text class="recommended-emoji">{{recommendedAction.emoji}}</text>
      </view>
      <view class="recommended-content">
        <text class="recommended-title">{{recommendedAction.title}}</text>
        <text class="recommended-message">{{recommendedAction.message}}</text>
      </view>
      <view class="recommended-arrow">
        <text class="arrow-icon">›</text>
      </view>
    </view>
  </view>

  <view class="weak-section" wx:if="{{weakAreas.length > 0}}">
    <view class="weak-header">
      <text class="weak-header-icon">⚠️</text>
      <text class="weak-header-title">薄弱环节</text>
      <text class="weak-header-count">{{weakAreas.length}}项待加强</text>
    </view>
    <view class="weak-list">
      <view
        class="weak-item"
        wx:for="{{weakAreas}}"
        wx:key="name"
        data-item="{{item}}"
        bindtap="onWeakAreaTap"
        style="--weak-color: {{item.color}};"
      >
        <view class="weak-dot"></view>
        <text class="weak-name">{{item.name}}</text>
        <text class="weak-message">{{item.message}}</text>
        <text class="weak-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="path-section">
    <view class="path-timeline">
      <view
        class="path-node {{item.status}}"
        wx:for="{{pathNodes}}"
        wx:key="id"
        data-item="{{item}}"
        bindtap="onNodeTap"
      >
        <view class="node-connector" wx:if="{{index > 0}}">
          <view class="connector-line {{pathNodes[index - 1].status === 'completed' ? 'active' : ''}}"></view>
        </view>

        <view class="node-icon-wrap" style="--node-color: {{item.color}};">
          <view class="node-icon-bg"></view>
          <text class="node-icon">{{item.emoji}}</text>
          <view class="node-check" wx:if="{{item.status === 'completed'}}">
            <text class="check-icon">✓</text>
          </view>
          <view class="node-pulse" wx:if="{{item.status === 'in-progress'}}"></view>
        </view>

        <view class="node-content">
          <view class="node-header">
            <view class="node-title-wrap">
              <text class="node-step">第{{index + 1}}步</text>
              <text class="node-title">{{item.title}}</text>
            </view>
            <view class="node-status-tag" style="background: {{item.statusBg}}; color: {{item.statusColor}};">
              <text wx:if="{{item.status === 'completed'}}">已完成</text>
              <text wx:elif="{{item.status === 'in-progress'}}">进行中</text>
              <text wx:elif="{{item.status === 'locked'}}">未解锁</text>
              <text wx:else>未开始</text>
            </view>
          </view>

          <text class="node-desc">{{item.description}}</text>

          <view class="node-unlock-row" wx:if="{{item.status === 'locked' && item.unlockLabel}}">
            <text class="unlock-icon">🔒</text>
            <text class="unlock-text">解锁条件：{{item.unlockLabel}}</text>
          </view>

          <view class="node-progress-row" wx:if="{{item.status !== 'locked' && item.total > 0}}">
            <view class="node-progress-bar">
              <view class="node-progress-fill" style="width: {{item.progressPercent}}%; background: {{item.color}};"></view>
            </view>
            <text class="node-progress-text" style="color: {{item.color}};">{{item.progressPercent}}%</text>
          </view>

          <view class="node-meta">
            <view class="meta-item" wx:if="{{item.total > 0}}">
              <text class="meta-icon">📖</text>
              <text class="meta-text">{{item.current}}/{{item.total}} {{item.unit}}</text>
            </view>
            <view class="meta-item">
              <text class="meta-icon">💎</text>
              <text class="meta-text">+{{item.reward.points}}积分</text>
            </view>
            <view class="meta-item">
              <text class="meta-icon">🏅</text>
              <text class="meta-text">{{item.reward.badgeName}}</text>
            </view>
          </view>

          <view class="node-reward-badges" wx:if="{{item.status === 'completed'}}">
            <view class="reward-badge earned" style="--badge-color: {{item.color}};">
              <text class="reward-badge-emoji">{{item.reward.badge}}</text>
              <text class="reward-badge-label">已获得</text>
            </view>
          </view>
          <view class="node-reward-badges" wx:elif="{{item.status !== 'locked'}}">
            <view class="reward-badge locked-badge">
              <text class="reward-badge-emoji">{{item.reward.badge}}</text>
              <text class="reward-badge-label">待解锁</text>
            </view>
          </view>

          <view class="node-action">
            <view
              class="action-btn"
              style="background: {{item.status === 'locked' ? '#E8E8E8' : 'linear-gradient(135deg, ' + item.color + ' 0%, ' + item.colorDark + ' 100%)'}};"
            >
              <text wx:if="{{item.status === 'completed'}}">再次学习</text>
              <text wx:elif="{{item.status === 'in-progress'}}">继续学习</text>
              <text wx:elif="{{item.status === 'locked'}}">未解锁</text>
              <text wx:else>开始学习</text>
              <text class="action-arrow">›</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="tips-section">
    <view class="tips-card">
      <view class="tips-icon-wrap">
        <text class="tips-icon">💡</text>
      </view>
      <view class="tips-content">
        <text class="tips-title">学习小贴士</text>
        <text class="tips-text">每个节点需满足解锁条件才可开始，前序正确率≥80%才能进入下一步。薄弱环节已标红提醒，优先攻克弱项效率更高！</text>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
