.learning-path-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E1 0%, #E8F5E9 30%, #F0F9FF 100%);
  padding-bottom: 40rpx;
}

.header-card {
  background: linear-gradient(135deg, #FFB74D 0%, #FF9800 50%, #5BBD72 100%);
  margin: 0;
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 152, 0, 0.2);
}

.header-content {
  color: #fff;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.92;
}

.progress-overview {
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.overview-progress-wrap {
  flex-shrink: 0;
}

.overview-progress-ring {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.ring-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.ring-progress {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  mask: radial-gradient(transparent 55%, #000 56%);
  -webkit-mask: radial-gradient(transparent 55%, #000 56%);
}

.ring-inner {
  position: absolute;
  inset: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ring-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.1;
}

.ring-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 2rpx;
}

.overview-stats {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.overview-stat-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-icon {
  font-size: 32rpx;
}

.stat-text-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.path-section {
  padding: 32rpx 24rpx 0;
}

.path-timeline {
  position: relative;
  padding-left: 20rpx;
}

.path-node {
  position: relative;
  padding-bottom: 32rpx;
}

.path-node:last-child {
  padding-bottom: 0;
}

.node-connector {
  position: absolute;
  left: 54rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  z-index: 0;
}

.connector-line {
  width: 100%;
  height: 100%;
  background: #E0E0E0;
  border-radius: 2rpx;
}

.connector-line.active {
  background: linear-gradient(180deg, #5BBD72 0%, #4CAF50 100%);
}

.node-icon-wrap {
  position: relative;
  width: 108rpx;
  height: 108rpx;
  flex-shrink: 0;
  z-index: 1;
}

.node-icon-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: var(--node-color);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
}

.path-node.locked .node-icon-bg {
  background: #E0E0E0;
}

.node-icon {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  z-index: 2;
}

.path-node.locked .node-icon {
  opacity: 0.5;
  filter: grayscale(100%);
}

.node-check {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #5BBD72;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
  z-index: 3;
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.node-pulse {
  position: absolute;
  inset: -8rpx;
  border-radius: 50%;
  border: 4rpx solid var(--node-color);
  opacity: 0.6;
  animation: nodePulse 2s ease-in-out infinite;
}

@keyframes nodePulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.15);
    opacity: 0;
  }
}

.node-content {
  margin-top: 16rpx;
  margin-left: 8rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.path-node.locked .node-content {
  opacity: 0.7;
}

.path-node.completed .node-content {
  border-left: 6rpx solid #5BBD72;
}

.path-node.in-progress .node-content {
  border-left: 6rpx solid #FF9800;
}

.node-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.node-title-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.node-step {
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 500;
}

.node-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.3;
}

.node-status-tag {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.node-desc {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.node-progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.node-progress-bar {
  flex: 1;
  height: 10rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 5rpx;
  overflow: hidden;
}

.node-progress-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.node-progress-text {
  font-size: 22rpx;
  font-weight: 600;
  min-width: 64rpx;
  text-align: right;
}

.node-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #636E72;
}

.node-action {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-arrow {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.tips-section {
  padding: 24rpx 24rpx 0;
}

.tips-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: rgba(255, 193, 7, 0.1);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.2);
}

.tips-icon-wrap {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 193, 7, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tips-icon {
  font-size: 30rpx;
}

.tips-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #F57C00;
}

.tips-text {
  font-size: 24rpx;
  color: #795548;
  line-height: 1.6;
}

.safe-area-bottom {
  height: 48rpx;
}
