.page {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 120rpx;
}

.header {
  position: relative;
  padding: 30rpx 30rpx 80rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #7ECF91 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.stats-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.15);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3436;
  line-height: 1.2;
}

.stats-label {
  font-size: 24rpx;
  color: #84919A;
  margin-top: 8rpx;
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E8ECF0;
}

.tabs {
  display: flex;
  background: #FFFFFF;
  margin: 0 30rpx;
  border-radius: 20rpx;
  padding: 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #84919A;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #5BBD72 0%, #7ECF91 100%);
  color: #FFFFFF;
  font-weight: 600;
}

.tab-count {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  padding: 0 10rpx;
  border-radius: 18rpx;
  background: rgba(0, 0, 0, 0.08);
  font-size: 22rpx;
  margin-left: 8rpx;
}

.tab-item.active .tab-count {
  background: rgba(255, 255, 255, 0.25);
}

.content {
  padding: 24rpx 30rpx;
}

.item-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #F0F2F5;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  margin-right: 12rpx;
}

.item-status-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-available {
  background: rgba(91, 189, 114, 0.12);
  color: #5BBD72;
}

.status-sold {
  background: rgba(243, 156, 18, 0.12);
  color: #F39C12;
}

.status-offshelf {
  background: rgba(132, 145, 154, 0.12);
  color: #84919A;
}

.item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.meta-tag {
  padding: 6rpx 14rpx;
  background: #F0F7F2;
  color: #5BBD72;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.item-price-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.price-label {
  font-size: 24rpx;
  color: #84919A;
  margin-right: 12rpx;
}

.price-label.barter {
  color: #9B59B6;
}

.price-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #F39C12;
}

.barter-wish {
  font-size: 24rpx;
  color: #2D3436;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.item-stats {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.stat-text {
  font-size: 22rpx;
  color: #84919A;
}

.item-actions {
  display: flex;
  gap: 16rpx;
  margin-top: auto;
}

.action-btn {
  flex: 1;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  border-radius: 28rpx;
  padding: 0;
  border: none;
  font-weight: 500;
}

.action-btn::after {
  border: none;
}

.action-sold {
  background: linear-gradient(135deg, #5BBD72 0%, #7ECF91 100%);
  color: #FFFFFF;
}

.action-offshelf {
  background: #F0F2F5;
  color: #84919A;
}

.action-review {
  background: linear-gradient(135deg, #F39C12 0%, #F7B731 100%);
  color: #FFFFFF;
}

.action-relist {
  background: linear-gradient(135deg, #4A90D9 0%, #6BA3E0 100%);
  color: #FFFFFF;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 14rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #84919A;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #7ECF91 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 20rpx 80rpx;
  border-radius: 48rpx;
  border: none;
}

.empty-btn::after {
  border: none;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #7ECF91 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  line-height: 1;
}

.fab-text {
  font-size: 22rpx;
  color: #FFFFFF;
  margin-top: 4rpx;
}
