.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 200rpx;
}

/* ==================== 审核提示 ==================== */
.review-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 32rpx;
  background: #FFF8E1;
  margin: 0 32rpx 20rpx;
  border-radius: 16rpx;
}

.review-icon {
  font-size: 28rpx;
}

.review-text {
  font-size: 24rpx;
  color: #E67E22;
  flex: 1;
}

/* ==================== 帖子卡片 ==================== */
.post-card {
  background: rgba(255, 255, 255, 0.95);
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  position: relative;
}

.post-official-badge {
  position: absolute;
  top: 0;
  right: 28rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #E67E22 0%, #D35400 100%);
  padding: 8rpx 20rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.badge-icon {
  font-size: 22rpx;
}

.badge-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.2) 0%, rgba(74, 144, 217, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-emoji {
  font-size: 40rpx;
}

.post-user-info {
  flex: 1;
}

.post-user-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.post-nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.official-badge {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.official-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.post-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.more-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-icon {
  font-size: 40rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.post-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.post-content {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
}

.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.post-image {
  width: 100%;
  height: 210rpx;
  border-radius: 12rpx;
}

.post-image.single {
  grid-column: span 3;
  height: 480rpx;
  border-radius: 16rpx;
}

.post-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.post-topic {
  font-size: 24rpx;
  color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
  padding: 8rpx 18rpx;
  border-radius: 14rpx;
}

.post-stats {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.stats-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ==================== 评论区域 ==================== */
.comments-header {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.comments-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.comments-section {
  padding: 0 32rpx;
}

.comment-item {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.15) 0%, rgba(74, 144, 217, 0.15) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-avatar-emoji {
  font-size: 32rpx;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-nickname {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.comment-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.comment-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.comment-actions {
  display: flex;
  align-items: center;
}

.comment-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.comment-like.liked .like-count {
  color: #E85D5D;
}

.like-icon {
  font-size: 26rpx;
}

.like-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.comments-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 48rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.empty-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.bottom-space {
  height: 40rpx;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.comment-input-wrapper {
  flex: 1;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
}

.comment-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  height: 72rpx;
}

.input-placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.action-btns {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 10rpx;
  background: none;
  border: none;
  line-height: 1.2;
}

.action-btn.liked .btn-count {
  color: #E85D5D;
}

.share-btn {
  margin: 0;
  padding: 6rpx 10rpx;
  background: none;
  font-size: inherit;
  line-height: 1.2;
}

.share-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  line-height: 1;
}

.btn-count {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 2rpx;
}

.report-btn {
  opacity: 0.7;
}

/* ==================== 举报弹窗 ==================== */
.report-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.report-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.report-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.report-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
}

.close-icon {
  font-size: 36rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.report-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.report-reasons {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.report-reason {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #F9FAFB;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.report-reason.selected {
  background: rgba(91, 189, 114, 0.08);
  border-color: rgba(91, 189, 114, 0.3);
}

.reason-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.report-reason.selected .reason-name {
  color: #5BBD72;
  font-weight: 600;
}

.reason-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #5BBD72;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.report-desc {
  width: 100%;
  min-height: 120rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.desc-placeholder {
  color: var(--text-tertiary);
}

.report-tips {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #F0FDF4;
  border-radius: 12rpx;
  margin-bottom: 28rpx;
}

.tips-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: #5BBD72;
  flex: 1;
  line-height: 1.5;
}

.submit-report-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.submit-report-btn:active {
  opacity: 0.9;
}
