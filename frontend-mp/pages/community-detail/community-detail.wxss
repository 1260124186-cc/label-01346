.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 200rpx;
}

/* ==================== 审核提示 ==================== */
.review-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 32rpx;
  background: #FFF8E1;
  margin: 0 32rpx 20rpx;
  border-radius: 16rpx;
}

.review-icon {
  font-size: 28rpx;
}

.review-text {
  font-size: 24rpx;
  color: #E67E22;
  flex: 1;
}

/* ==================== 隐藏提示 ==================== */
.hidden-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 32rpx;
  background: #FDECEA;
  margin: 32rpx;
  border-radius: 16rpx;
}

.hidden-icon {
  font-size: 32rpx;
}

.hidden-text {
  font-size: 26rpx;
  color: #E74C3C;
  flex: 1;
  font-weight: 500;
}

/* ==================== 帖子卡片 ==================== */
.post-card {
  background: rgba(255, 255, 255, 0.95);
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  position: relative;
}

.post-card.featured {
  background: linear-gradient(135deg, #FFFBEB 0%, #FFFFFF 50%, #F0FDF4 100%);
  border: 2rpx solid rgba(234, 179, 8, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(234, 179, 8, 0.12);
}

.post-featured-badge {
  position: absolute;
  top: 0;
  left: 28rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #EAB308 0%, #F59E0B 100%);
  padding: 8rpx 20rpx;
  border-radius: 0 0 16rpx 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(234, 179, 8, 0.3);
}

.featured-icon {
  font-size: 22rpx;
}

.featured-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.post-official-badge {
  position: absolute;
  top: 0;
  right: 28rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #E67E22 0%, #D35400 100%);
  padding: 8rpx 20rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.badge-icon {
  font-size: 22rpx;
}

.badge-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  margin-top: 24rpx;
}

.avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.2) 0%, rgba(74, 144, 217, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-emoji {
  font-size: 40rpx;
}

.post-user-info {
  flex: 1;
  min-width: 0;
}

.post-user-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 4rpx;
}

.post-nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.official-badge {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.official-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.creator-badge {
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.creator-badge-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.post-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.post-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.post-level {
  font-size: 22rpx;
  color: #E67E22;
  font-weight: 500;
}

.more-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-icon {
  font-size: 40rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.post-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.post-content {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
}

.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.post-image {
  width: 100%;
  height: 210rpx;
  border-radius: 12rpx;
}

.post-image.single {
  grid-column: span 3;
  height: 480rpx;
  border-radius: 16rpx;
}

.post-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.post-topic {
  font-size: 24rpx;
  color: #5BBD72;
  background: rgba(91, 189, 114, 0.1);
  padding: 8rpx 18rpx;
  border-radius: 14rpx;
}

/* ==================== 知识卡片区域 ==================== */
.post-knowledge-cards {
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
}

.kc-section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.kc-section-icon {
  font-size: 26rpx;
}

.kc-section-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.kc-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid;
  margin-bottom: 12rpx;
}

.kc-card:last-child {
  margin-bottom: 0;
}

.kc-card:active {
  opacity: 0.8;
}

.kc-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.kc-emoji {
  font-size: 40rpx;
}

.kc-content {
  flex: 1;
  min-width: 0;
}

.kc-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.kc-type-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.kc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.kc-summary {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.kc-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex-wrap: wrap;
}

.kc-meta-item {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.kc-link {
  font-size: 22rpx;
  color: #5BBD72;
  font-weight: 500;
}

/* ==================== 帖子统计 ==================== */
.post-stats {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.stats-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.stats-report {
  font-size: 22rpx;
  color: #E74C3C;
}

/* ==================== 楼主操作提示 ==================== */
.owner-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  margin: 0 32rpx 20rpx;
  background: linear-gradient(135deg, #FFF4E6 0%, #FFE8CC 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(230, 126, 34, 0.2);
}

.owner-icon {
  font-size: 28rpx;
}

.owner-text {
  font-size: 24rpx;
  color: #E67E22;
  font-weight: 500;
}

/* ==================== 评论区域 ==================== */
.comments-header {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.comments-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.comments-section {
  padding: 0 32rpx;
}

.comment-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.comment-item.pinned {
  background: linear-gradient(135deg, #FFF4E6 0%, #FFFFFF 100%);
  border: 2rpx solid rgba(230, 126, 34, 0.15);
}

.comment-item.reported {
  opacity: 0.85;
}

.comment-pinned-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  margin: -24rpx -24rpx 16rpx;
  background: linear-gradient(135deg, #E67E22 0%, #D35400 100%);
}

.pin-icon {
  font-size: 22rpx;
}

.pin-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.comment-main {
  display: flex;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.15) 0%, rgba(74, 144, 217, 0.15) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-avatar-emoji {
  font-size: 32rpx;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-user-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.comment-nickname {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.comment-lz {
  font-size: 20rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #E67E22 0%, #D35400 100%);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.comment-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.comment-content-wrapper {
  margin-bottom: 12rpx;
}

.comment-reply-to {
  display: inline-flex;
  align-items: center;
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.reply-to-text {
  color: var(--text-tertiary);
  font-size: 26rpx;
}

.reply-to-name {
  color: #4A90D9;
  font-size: 26rpx;
  font-weight: 500;
  margin: 0 4rpx;
}

.reply-to-colon {
  color: var(--text-secondary);
  font-size: 26rpx;
}

.comment-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.mention-highlight {
  color: #4A90D9;
  font-weight: 500;
}

.comment-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.comment-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.comment-like.liked {
  background: rgba(232, 93, 93, 0.08);
}

.comment-like.liked .like-count {
  color: #E85D5D;
}

.like-icon {
  font-size: 26rpx;
}

.like-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.comment-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.comment-action:active {
  background: rgba(0, 0, 0, 0.04);
}

.action-icon {
  font-size: 26rpx;
}

.action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.pin-action {
  background: rgba(230, 126, 34, 0.08);
}

.pin-action .action-text {
  color: #E67E22;
}

.pin-action.pinned {
  background: rgba(230, 126, 34, 0.15);
}

.report-action {
  background: rgba(231, 76, 60, 0.08);
}

.report-action .action-text {
  color: #E74C3C;
}

/* 评论举报提示 */
.comment-reported {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #FEF3C7;
  border-radius: 10rpx;
}

.reported-text {
  font-size: 22rpx;
  color: #92400E;
}

/* ==================== 楼中楼子回复 ==================== */
.reply-list {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 14rpx;
}

.reply-item {
  display: flex;
  margin-bottom: 16rpx;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.12) 0%, rgba(74, 144, 217, 0.12) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.reply-avatar-emoji {
  font-size: 24rpx;
}

.reply-body {
  flex: 1;
  min-width: 0;
}

.reply-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
  flex-wrap: wrap;
}

.reply-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.reply-lz {
  font-size: 18rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #E67E22 0%, #D35400 100%);
  padding: 2rpx 8rpx;
  border-radius: 5rpx;
  font-weight: 500;
}

.reply-reply-to {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.reply-to-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.reply-to-user {
  font-size: 22rpx;
  color: #4A90D9;
  font-weight: 500;
}

.reply-content {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.reply-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.reply-time {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.reply-like {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.reply-like.liked .like-count {
  color: #E85D5D;
}

.reply-action {
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
}

.reply-action:active {
  background: rgba(0, 0, 0, 0.04);
}

/* ==================== 空评论 ==================== */
.comments-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 48rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.empty-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.bottom-space {
  height: 40rpx;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  padding: 12rpx 24rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.replying-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 16rpx;
  margin-bottom: 8rpx;
  background: linear-gradient(135deg, #EBF5FF 0%, #D6E9FF 100%);
  border-radius: 10rpx;
}

.replying-text {
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 500;
}

.replying-cancel {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(74, 144, 217, 0.15);
  border-radius: 50%;
}

.replying-cancel .cancel-icon {
  font-size: 28rpx;
  color: #4A90D9;
  line-height: 1;
}

.bottom-bar > .comment-input-wrapper,
.bottom-bar > .action-btns {
  display: flex;
  align-items: center;
}

.bottom-bar > .comment-input-wrapper {
  flex: 1;
  gap: 16rpx;
}

.comment-input-wrapper {
  flex: 1;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
}

.comment-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  height: 72rpx;
}

.input-placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.action-btns {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: 16rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 10rpx;
  background: none;
  border: none;
  line-height: 1.2;
}

.action-btn.liked .btn-count {
  color: #E85D5D;
}

.share-btn {
  margin: 0;
  padding: 6rpx 10rpx;
  background: none;
  font-size: inherit;
  line-height: 1.2;
}

.share-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  line-height: 1;
}

.btn-count {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 2rpx;
}

.report-btn {
  opacity: 0.7;
}

/* ==================== 举报弹窗 ==================== */
.report-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.report-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.report-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.report-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
}

.close-icon {
  font-size: 36rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.report-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.report-reasons {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.report-reason {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #F9FAFB;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.report-reason.selected {
  background: rgba(91, 189, 114, 0.08);
  border-color: rgba(91, 189, 114, 0.3);
}

.reason-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.report-reason.selected .reason-name {
  color: #5BBD72;
  font-weight: 600;
}

.reason-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #5BBD72;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.report-desc {
  width: 100%;
  min-height: 120rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.desc-placeholder {
  color: var(--text-tertiary);
}

.report-tips {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #F0FDF4;
  border-radius: 12rpx;
  margin-bottom: 28rpx;
}

.tips-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: #5BBD72;
  flex: 1;
  line-height: 1.5;
}

.submit-report-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
