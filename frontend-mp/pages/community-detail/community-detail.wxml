<view class="page-container" wx:if="{{post}}">

  <!-- 内容审核提示 -->
  <view class="review-tip" wx:if="{{isReviewing}}">
    <text class="review-icon">⚠️</text>
    <text class="review-text">该内容正在审核中，暂时仅部分用户可见</text>
  </view>

  <!-- 内容隐藏提示 -->
  <view class="hidden-tip" wx:if="{{post.status === 'hidden'}}">
    <text class="hidden-icon">🚫</text>
    <text class="hidden-text">该内容因多次举报已被隐藏，如有疑问请联系客服</text>
  </view>

  <!-- 帖子主体 -->
  <view class="post-card {{post.isFeatured ? 'featured' : ''}}" wx:if="{{post.status !== 'hidden'}}">
    <!-- 官方精选徽章 -->
    <view class="post-featured-badge" wx:if="{{post.isFeatured}}">
      <text class="featured-icon">⭐</text>
      <text class="featured-text">官方精选</text>
    </view>

    <!-- 官方标识 -->
    <view class="post-official-badge" wx:if="{{post.isOfficial}}">
      <text class="badge-icon">🌿</text>
      <text class="badge-text">{{post.category || '官方'}}</text>
    </view>

    <!-- 用户信息 -->
    <view class="post-header">
      <view class="avatar-wrapper">
        <text class="avatar-emoji">{{post.userAvatarEmoji}}</text>
      </view>
      <view class="post-user-info">
        <view class="post-user-row">
          <text class="post-nickname">{{post.userNickName}}</text>
          <view class="official-badge" wx:if="{{post.isOfficial}}">
            <text class="official-text">官方</text>
          </view>
          <view
            wx:if="{{post.creatorBadge && post.creatorLevel >= 3}}"
            class="creator-badge"
            style="background: {{post.creatorBadge.color}}; box-shadow: 0 4rpx 12rpx {{post.creatorBadge.color}}50;"
          >
            <text class="creator-badge-text">{{post.creatorBadge.name}}</text>
          </view>
        </view>
        <view class="post-meta-row">
          <text class="post-time">{{post.createTime}}</text>
          <text class="post-level" wx:if="{{post.creatorLevel > 1}}">Lv.{{post.creatorLevel}} · {{post.creatorBadge.name}}</text>
        </view>
      </view>
      <view class="more-btn" bindtap="onMoreTap">
        <text class="more-icon">⋯</text>
      </view>
    </view>

    <!-- 标题 -->
    <text class="post-title" wx:if="{{post.title}}">{{post.title}}</text>

    <!-- 内容 -->
    <text class="post-content">{{post.content}}</text>

    <!-- 图片 -->
    <view class="post-images" wx:if="{{post.images && post.images.length > 0}}">
      <image
        wx:for="{{post.images}}"
        wx:for-item="img"
        wx:key="*this"
        src="{{img}}"
        mode="aspectFill"
        class="post-image {{post.images.length === 1 ? 'single' : ''}}"
        bindtap="onPreviewImage"
        data-index="{{index}}"
      />
    </view>

    <!-- 话题 -->
    <view class="post-topics" wx:if="{{post.topicNames && post.topicNames.length > 0}}">
      <text
        wx:for="{{post.topicNames}}"
        wx:key="*this"
        wx:for-item="topicName"
        class="post-topic"
      >#{{topicName}}</text>
    </view>

    <!-- 知识卡片 -->
    <view class="post-knowledge-cards" wx:if="{{post.knowledgeCards && post.knowledgeCards.length > 0}}">
      <view class="kc-section-title">
        <text class="kc-section-icon">📚</text>
        <text class="kc-section-text">关联知识卡片</text>
      </view>
      <view
        wx:for="{{post.knowledgeCards}}"
        wx:key="id"
        class="kc-card"
        style="border-color: {{item.color}}40; background: linear-gradient(135deg, {{item.color}}10 0%, #FFFFFF 100%);"
        bindtap="onKnowledgeCardTap"
        data-card="{{item}}"
      >
        <view class="kc-icon-wrapper" style="background: {{item.color}}20;">
          <text class="kc-emoji">{{item.emoji}}</text>
        </view>
        <view class="kc-content">
          <view class="kc-header">
            <text class="kc-type-tag" style="background: {{item.color}}20; color: {{item.color}};">
              {{item.type === 'course' ? '课程' : '百科'}}
            </text>
            <text class="kc-title">{{item.title}}</text>
          </view>
          <text class="kc-summary">{{item.summary}}</text>
          <view class="kc-meta">
            <text class="kc-meta-item" wx:if="{{item.relatedTrashCount}}">📚 关联{{item.relatedTrashCount}}种分类</text>
            <text class="kc-meta-item" wx:if="{{item.chaptersCount}}">🎓 {{item.chaptersCount}}节课</text>
            <text class="kc-link">点击查看 →</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 统计 -->
    <view class="post-stats">
      <text class="stats-text">{{post.likes}} 赞 · {{post.comments}} 评论 · {{post.shares}} 转发</text>
      <text class="stats-report" wx:if="{{post.reportCount > 0}}">（{{post.reportCount}}人举报）</text>
    </view>
  </view>

  <!-- 楼主操作提示 -->
  <view class="owner-tip" wx:if="{{isPostOwner}}">
    <text class="owner-icon">👑</text>
    <text class="owner-text">你是楼主，可以置顶优质评论哦～</text>
  </view>

  <!-- 评论区域标题 -->
  <view class="comments-header">
    <text class="comments-title">全部评论（{{comments.length}}）</text>
  </view>

  <!-- 评论列表 -->
  <view class="comments-section">
    <!-- 楼中楼渲染 - 父评论 -->
    <view
      wx:for="{{comments}}"
      wx:key="id"
      class="comment-item {{item.isPinned ? 'pinned' : ''}} {{item.reportCount >= 3 ? 'reported' : ''}}"
    >
      <!-- 置顶徽章 -->
      <view class="comment-pinned-badge" wx:if="{{item.isPinned}}">
        <text class="pin-icon">📌</text>
        <text class="pin-text">楼主置顶</text>
      </view>

      <view class="comment-main">
        <view class="comment-avatar">
          <text class="comment-avatar-emoji">{{item.userAvatarEmoji}}</text>
        </view>
        <view class="comment-body">
          <view class="comment-header">
            <view class="comment-user-row">
              <text class="comment-nickname">{{item.userNickName}}</text>
              <text class="comment-lz" wx:if="{{item.userId === post.userId}}">楼主</text>
            </view>
            <text class="comment-time">{{item.createTime}}</text>
          </view>

          <!-- 评论内容：含 @用户高亮 + replyTo 引用 -->
          <view class="comment-content-wrapper">
            <view class="comment-reply-to" wx:if="{{item.replyTo}}">
              <text class="reply-to-text">回复</text>
              <text class="reply-to-name">@{{item.replyTo.userNickName}}</text>
              <text class="reply-to-colon">：</text>
            </view>
            <text class="comment-content">
              <block wx:for="{{item.displayContent}}" wx:for-item="seg" wx:key="index">
                <text wx:if="{{seg.type === 'mention'}}" class="mention-highlight">@{{seg.text}}</text>
                <text wx:else>{{seg.text}}</text>
              </block>
              <text wx:if="{{!item.displayContent}}">{{item.content}}</text>
            </text>
          </view>

          <view class="comment-actions">
            <view class="comment-like {{item.liked ? 'liked' : ''}}" bindtap="onCommentLikeTap" data-id="{{item.id}}">
              <text class="like-icon">{{item.liked ? '❤️' : '🤍'}}</text>
              <text class="like-count">{{item.likes}}</text>
            </view>
            <view class="comment-action" bindtap="onReplyTap" data-comment="{{item}}">
              <text class="action-icon">💬</text>
              <text class="action-text">回复</text>
            </view>
            <view
              wx:if="{{isPostOwner && !item.isPinned}}"
              class="comment-action pin-action"
              bindtap="onPinComment"
              data-id="{{item.id}}"
            >
              <text class="action-icon">📌</text>
              <text class="action-text">置顶</text>
            </view>
            <view
              wx:if="{{item.isPinned}}"
              class="comment-action pin-action pinned"
              bindtap="onPinComment"
              data-id="{{item.id}}"
            >
              <text class="action-icon">📌</text>
              <text class="action-text">取消置顶</text>
            </view>
            <view class="comment-action report-action" bindtap="onCommentReportTap" data-id="{{item.id}}">
              <text class="action-icon">🚩</text>
              <text class="action-text">举报</text>
            </view>
          </view>

          <!-- 举报提示 -->
          <view class="comment-reported" wx:if="{{item.reportCount >= 3 && item.reportCount < 5}}">
            <text class="reported-text">⚠️ 该评论已被{{item.reportCount}}人举报，正在审核</text>
          </view>

          <!-- 楼中楼 - 子回复列表 -->
          <view class="reply-list" wx:if="{{item.replies && item.replies.length > 0}}">
            <view
              wx:for="{{item.replies}}"
              wx:for-item="reply"
              wx:key="id"
              class="reply-item"
            >
              <view class="reply-avatar">
                <text class="reply-avatar-emoji">{{reply.userAvatarEmoji}}</text>
              </view>
              <view class="reply-body">
                <view class="reply-header">
                  <text class="reply-nickname">{{reply.userNickName}}</text>
                  <text class="reply-lz" wx:if="{{reply.userId === post.userId}}">楼主</text>
                  <view class="reply-reply-to" wx:if="{{reply.replyTo}}">
                    <text class="reply-to-label">回复</text>
                    <text class="reply-to-user">@{{reply.replyTo.userNickName}}</text>
                  </view>
                </view>
                <text class="reply-content">
                  <block wx:for="{{reply.displayContent}}" wx:for-item="seg" wx:key="idx">
                    <text wx:if="{{seg.type === 'mention'}}" class="mention-highlight">@{{seg.text}}</text>
                    <text wx:else>{{seg.text}}</text>
                  </block>
                  <text wx:if="{{!reply.displayContent}}">{{reply.content}}</text>
                </text>
                <view class="reply-actions">
                  <text class="reply-time">{{reply.createTime}}</text>
                  <view class="reply-like {{reply.liked ? 'liked' : ''}}" bindtap="onCommentLikeTap" data-id="{{reply.id}}">
                    <text class="like-icon">{{reply.liked ? '❤️' : '🤍'}}</text>
                    <text class="like-count">{{reply.likes}}</text>
                  </view>
                  <view class="reply-action" bindtap="onReplyTap" data-comment="{{reply}}">
                    <text class="action-text">回复</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="comments-empty" wx:if="{{comments.length === 0}}">
      <text class="empty-emoji">💬</text>
      <text class="empty-text">还没有评论，快来抢沙发～</text>
    </view>
  </view>

  <view class="bottom-space"></view>

  <!-- 底部输入和操作栏 -->
  <view class="bottom-bar">
    <!-- 回复状态提示 -->
    <view class="replying-tip" wx:if="{{replyingTo}}">
      <text class="replying-text">回复 @{{replyingTo.userNickName}}</text>
      <view class="replying-cancel" bindtap="onReplyCancel">
        <text class="cancel-icon">×</text>
      </view>
    </view>

    <view class="comment-input-wrapper">
      <input
        class="comment-input"
        placeholder="{{commentPlaceholder}}"
        placeholder-class="input-placeholder"
        value="{{commentContent}}"
        bindinput="onCommentInput"
        confirm-type="send"
        bindconfirm="onSubmitComment"
        maxlength="200"
        focus="{{!!replyingTo}}"
      />
    </view>
    <view class="action-btns">
      <view class="action-btn {{post.liked ? 'liked' : ''}}" bindtap="onLikeTap">
        <text class="btn-icon">{{post.liked ? '❤️' : '🤍'}}</text>
        <text class="btn-count">{{post.likes}}</text>
      </view>
      <view class="action-btn">
        <text class="btn-icon">💬</text>
        <text class="btn-count">{{post.comments}}</text>
      </view>
      <button class="action-btn share-btn" open-type="share" bindtap="onShareTap">
        <text class="btn-icon">📤</text>
        <text class="btn-count">{{post.shares}}</text>
      </button>
      <view class="action-btn report-btn" bindtap="onReportTap">
        <text class="btn-icon">🚩</text>
      </view>
    </view>
  </view>

  <!-- 举报弹窗 -->
  <view class="report-modal" wx:if="{{showReport}}" catchtap="onReportClose">
    <view class="report-content" catchtap="">
      <view class="report-header">
        <text class="report-title">举报{{reportTargetType === 'post' ? '帖子' : '评论'}}</text>
        <view class="report-close" bindtap="onReportClose">
          <text class="close-icon">×</text>
        </view>
      </view>

      <text class="report-section-title">请选择举报理由</text>
      <view class="report-reasons">
        <view
          wx:for="{{reportReasons}}"
          wx:key="id"
          class="report-reason {{selectedReasonId === item.id ? 'selected' : ''}}"
          bindtap="onReportReasonTap"
          data-id="{{item.id}}"
        >
          <text class="reason-name">{{item.name}}</text>
          <text class="reason-check" wx:if="{{selectedReasonId === item.id}}">✓</text>
        </view>
      </view>

      <text class="report-section-title">补充说明（选填）</text>
      <textarea
        class="report-desc"
        placeholder="请详细描述问题，有助于我们更快处理"
        placeholder-class="desc-placeholder"
        value="{{reportDescription}}"
        bindinput="onReportDescInput"
        maxlength="200"
        auto-height
      />

      <view class="report-tips">
        <text class="tips-icon">📋</text>
        <text class="tips-text">我们会在24小时内审核处理。累计5次举报自动隐藏。恶意举报将被限制功能。</text>
      </view>

      <button class="submit-report-btn" bindtap="onReportSubmit">提交举报</button>
    </view>
  </view>
</view>
