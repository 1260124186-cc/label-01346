/* 接垃圾游戏页面样式 */
.game-catch-container {
  width: 100%;
  height: 100vh;
  overflow: hidden;
  position: relative;
}

/* ============ 准备阶段 ============ */
.ready-screen {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.ready-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 50%, #D94A5F 100%);
}

.ready-content {
  position: relative;
  text-align: center;
  padding: 48rpx 48rpx;
  max-width: 600rpx;
  width: 100%;
}

.ready-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.ready-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.ready-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.level-info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.level-info-item {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
}

.info-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.info-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.trash-preview {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 48rpx;
}

.trash-type-preview {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  padding: 16rpx 8rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.trash-preview-emoji {
  display: block;
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.trash-preview-name {
  font-size: 20rpx;
  color: #FFFFFF;
}

.start-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  color: #EE5A6F;
  font-size: 34rpx;
  font-weight: 700;
  padding: 28rpx 100rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s ease;
}

.start-btn:active {
  transform: scale(0.96);
}

/* ============ 游戏中 ============ */
.playing-screen {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 40%);
}

/* 顶部状态栏 */
.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
}

.header-left,
.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.header-left {
  justify-content: flex-start;
}

.header-right {
  justify-content: flex-end;
}

.header-center {
  flex: 0 0 auto;
}

.score-box {
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 100%);
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.score-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.combo-box {
  background: linear-gradient(135deg, #FF9F43 0%, #FF6B35 100%);
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.combo-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.combo-fire {
  font-size: 22rpx;
}

.level-badge {
  background: rgba(91, 189, 114, 0.1);
  color: #5BBD72;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.time-box {
  background: rgba(255, 107, 107, 0.1);
  padding: 10rpx 16rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.time-box.urgent {
  background: rgba(255, 59, 48, 0.15);
  animation: pulse 0.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.time-emoji {
  font-size: 24rpx;
}

.time-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF3B30;
}

/* 道具栏 */
.powerup-bar {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
}

.powerup-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.powerup-btn.active {
  background: linear-gradient(135deg, #FF9F43 0%, #FF6B35 100%);
}

.powerup-btn:active {
  transform: scale(0.94);
}

.pu-emoji {
  font-size: 28rpx;
  margin-bottom: 2rpx;
}

.pu-label {
  font-size: 20rpx;
  color: #636E72;
}

.powerup-btn.active .pu-label {
  color: #FFFFFF;
}

/* 进度条 */
.progress-section {
  display: flex;
  align-items: center;
  padding: 0 24rpx 12rpx;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B 0%, #5BBD72 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #86909C;
  min-width: 80rpx;
  text-align: right;
}

/* 游戏区域 */
.game-area {
  flex: 1;
  position: relative;
  overflow: hidden;
  background: 
    linear-gradient(180deg, rgba(255, 107, 107, 0.03) 0%, transparent 30%),
    radial-gradient(ellipse at 50% 0%, rgba(255, 107, 107, 0.08) 0%, transparent 60%);
}

.falling-item {
  position: absolute;
  width: 80px;
  text-align: center;
  transition: none;
}

.falling-item.hinted {
  animation: hintGlow 0.6s ease-in-out infinite;
}

@keyframes hintGlow {
  0%, 100% { filter: drop-shadow(0 0 8rpx #F39C12); }
  50% { filter: drop-shadow(0 0 20rpx #F39C12); }
}

.item-emoji {
  display: block;
  font-size: 48px;
  line-height: 1;
}

.item-name {
  display: block;
  font-size: 20rpx;
  color: #2D3436;
  background: rgba(255, 255, 255, 0.9);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

.hint-arrow {
  position: absolute;
  top: -30px;
  left: 50%;
  transform: translateX(-50%);
  background: #F39C12;
  color: #FFFFFF;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.feedback-popup {
  position: absolute;
  font-size: 36rpx;
  font-weight: 700;
  pointer-events: none;
  animation: feedbackFloat 0.6s ease-out forwards;
}

.feedback-popup.correct {
  color: #5BBD72;
}

.feedback-popup.wrong {
  color: #FF3B30;
}

@keyframes feedbackFloat {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-60rpx) scale(1.2);
  }
}

/* 垃圾桶区域 */
.trash-bins-area {
  position: relative;
  height: 220rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.03) 100%);
  padding: 16rpx 8rpx;
  display: flex;
  align-items: flex-end;
}

.trash-bin {
  flex: 1;
  text-align: center;
  padding: 12rpx 4rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  position: relative;
  z-index: 1;
}

.trash-bin.active {
  background: rgba(255, 255, 255, 0.9);
  transform: scale(1.05);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.bin-emoji {
  display: block;
  font-size: 48rpx;
  margin-bottom: 4rpx;
}

.bin-name {
  display: block;
  font-size: 20rpx;
  color: var(--bin-color, #636E72);
  font-weight: 500;
}

.catching-basket {
  position: absolute;
  top: 0;
  transition: left 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 2;
  pointer-events: none;
}

.basket-top {
  height: 12rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border-radius: 8rpx 8rpx 0 0;
}

.basket-body {
  height: 80rpx;
  background: linear-gradient(180deg, rgba(139, 69, 19, 0.15) 0%, rgba(139, 69, 19, 0.3) 100%);
  border: 4rpx solid #8B4513;
  border-top: none;
  border-radius: 0 0 16rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.basket-emoji {
  font-size: 40rpx;
}

/* ============ 暂停遮罩 ============ */
.pause-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.pause-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  text-align: center;
  min-width: 480rpx;
}

.pause-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.pause-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 32rpx;
}

.pause-actions {
  display: flex;
  gap: 20rpx;
}

.pause-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}

.pause-btn.secondary {
  background: #F0F2F5;
  color: #636E72;
}

.pause-btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 100%);
  color: #FFFFFF;
}

.pause-btn:active {
  transform: scale(0.96);
}

/* ============ 结果页 ============ */
.result-screen {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.result-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A6F 100%);
}

.result-content {
  position: relative;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  max-width: 640rpx;
  width: 85%;
  text-align: center;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.2);
}

.result-emoji {
  font-size: 100rpx;
  margin-bottom: 12rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 32rpx;
}

.result-stats {
  background: #F7FAF8;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.result-stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.result-stat-row:last-child {
  border-bottom: none;
}

.stat-label {
  font-size: 28rpx;
  color: #636E72;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.stat-value .correct {
  color: #5BBD72;
}

.stat-value .wrong {
  color: #FF3B30;
}

.points-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #FFF7E6 0%, #FFEFD1 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.points-icon {
  font-size: 48rpx;
}

.points-info {
  flex: 1;
  text-align: left;
}

.points-title {
  font-size: 24rpx;
  color: #B7791F;
  margin-bottom: 4rpx;
}

.points-total {
  font-size: 44rpx;
  font-weight: 700;
  color: #D48806;
  margin-bottom: 4rpx;
}

.points-detail {
  font-size: 22rpx;
  color: #B7791F;
}

.result-actions {
  display: flex;
  gap: 16rpx;
}

.result-btn {
  flex: 1;
  padding: 24rpx 16rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}

.result-btn.secondary {
  background: #F0F2F5;
  color: #636E72;
}

.result-btn.primary {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  color: #FFFFFF;
}

.result-btn:active {
  transform: scale(0.96);
}
