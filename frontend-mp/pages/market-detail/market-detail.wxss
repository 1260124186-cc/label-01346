.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 160rpx;
}

/* ==================== 图片区域 ==================== */
.image-section {
  position: relative;
  width: 100%;
  height: 600rpx;
  background: #E8E8E8;
}

.image-swiper {
  width: 100%;
  height: 100%;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.image-indicator {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.55);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  color: #FFFFFF;
  font-size: 24rpx;
}

.status-badge {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
}

.status-badge.status-sold {
  background: linear-gradient(135deg, #E85D5D 0%, #F39C12 100%);
}

.status-badge.status-offline {
  background: linear-gradient(135deg, #8E8E93 0%, #636E72 100%);
}

.status-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* ==================== 基本信息 ==================== */
.info-section {
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.price-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-icon {
  font-size: 28rpx;
}

.price-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #E67E22;
  line-height: 1;
}

.price-unit {
  font-size: 26rpx;
  color: #E67E22;
  font-weight: 500;
}

.trade-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
}

.badge-icon {
  font-size: 22rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.favorite-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  background: #F7F9FA;
  transition: all 0.2s ease;
}

.favorite-btn.active {
  background: rgba(232, 93, 93, 0.1);
}

.favorite-icon {
  font-size: 32rpx;
}

.favorite-count {
  font-size: 24rpx;
  color: #636E72;
}

.item-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #8E8E93;
}

/* ==================== 卖家信息 ==================== */
.seller-section {
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.seller-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.seller-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.2) 0%, rgba(74, 144, 217, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 40rpx;
}

.seller-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.seller-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.seller-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-icon {
  font-size: 20rpx;
}

.stat-text {
  font-size: 22rpx;
  color: #8E8E93;
}

.contact-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
}

.contact-btn:active {
  opacity: 0.9;
}

.contact-icon {
  font-size: 26rpx;
}

.contact-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ==================== 详细描述 ==================== */
.desc-section {
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.section-count {
  font-size: 24rpx;
  color: #B2BEC3;
  margin-left: 8rpx;
}

.review-btn {
  margin-left: auto;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
}

.review-btn-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.desc-text {
  font-size: 28rpx;
  color: #4E5969;
  line-height: 1.8;
}

.barter-wish {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.08) 0%, rgba(91, 189, 114, 0.08) 100%);
  border-radius: 16rpx;
}

.barter-icon {
  font-size: 28rpx;
}

.barter-content {
  flex: 1;
}

.barter-label {
  font-size: 24rpx;
  color: #9B59B6;
  font-weight: 500;
  margin-right: 8rpx;
}

.barter-text {
  font-size: 26rpx;
  color: #4E5969;
  line-height: 1.6;
}

.location-row,
.time-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.location-icon,
.time-icon {
  font-size: 22rpx;
}

.location-text,
.time-text {
  font-size: 24rpx;
  color: #8E8E93;
}

/* ==================== 环保小贴士 ==================== */
.eco-tip-section {
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.1) 0%, rgba(74, 144, 217, 0.1) 100%);
  margin: 0 32rpx 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(91, 189, 114, 0.2);
}

.eco-tip-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.eco-icon {
  font-size: 28rpx;
}

.eco-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #5BBD72;
}

.eco-content {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.6;
}

/* ==================== 评价区 ==================== */
.review-section {
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.review-item {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.review-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.review-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.review-avatar {
  font-size: 36rpx;
}

.review-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.review-user-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #2D3436;
}

.review-rating {
  display: flex;
  gap: 4rpx;
}

.review-star {
  font-size: 22rpx;
  color: #DFE6E9;
}

.review-star.active {
  color: #F39C12;
}

.review-time {
  font-size: 22rpx;
  color: #B2BEC3;
}

.review-content {
  font-size: 26rpx;
  color: #4E5969;
  line-height: 1.7;
  padding-left: 52rpx;
}

.review-empty {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text {
  font-size: 26rpx;
  color: #B2BEC3;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 16rpx 32rpx 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bottom-bar.owner .owner-actions {
  display: flex;
  gap: 24rpx;
}

.owner-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.owner-btn.secondary {
  background: #F7F9FA;
  color: #636E72;
}

.owner-btn.primary {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.35);
}

.bottom-bar.buyer {
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex: 1;
  padding: 8rpx 0;
}

.action-item.report .action-icon {
  color: #E85D5D;
}

.action-item.barter {
  border-left: 1rpx solid rgba(0, 0, 0, 0.05);
  border-right: 1rpx solid rgba(0, 0, 0, 0.05);
}

.action-icon {
  font-size: 36rpx;
}

.action-text {
  font-size: 22rpx;
  color: #636E72;
  font-weight: 500;
}

.action-item.negotiate {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 16rpx;
  margin-left: 16rpx;
}

.action-item.negotiate .action-text {
  color: #FFFFFF;
  font-weight: 600;
}

/* ==================== 底部安全区域 ==================== */
.bottom-safe {
  height: 40rpx;
}

/* ==================== 通用弹窗 ==================== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.25s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 640rpx;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 40rpx;
  color: #B2BEC3;
  line-height: 1;
}

.modal-body {
  padding: 28rpx 32rpx;
  flex: 1;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  padding: 20rpx 32rpx 32rpx;
  gap: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #F7F9FA;
  color: #636E72;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #FFFFFF;
}

.modal-btn.confirm.danger {
  background: linear-gradient(135deg, #E85D5D 0%, #C0392B 100%);
}

.modal-btn.single {
  flex: none;
  width: 100%;
}

/* ==================== 议价弹窗 ==================== */
.negotiate-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.negotiate-label {
  font-size: 26rpx;
  color: #8E8E93;
}

.negotiate-value {
  font-size: 26rpx;
  color: #2D3436;
  font-weight: 500;
}

.negotiate-value.price {
  color: #E67E22;
  font-weight: 600;
  font-size: 30rpx;
}

.negotiate-input-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.negotiate-input-wrapper {
  display: flex;
  align-items: center;
  background: #F7F9FA;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.negotiate-input {
  width: 240rpx;
  height: 72rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #E67E22;
  text-align: right;
}

.input-unit {
  font-size: 24rpx;
  color: #E67E22;
  font-weight: 500;
  margin-left: 8rpx;
}

.negotiate-tip {
  display: block;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #B2BEC3;
  line-height: 1.6;
}

.input-placeholder {
  color: #B2BEC3;
}

/* ==================== 以物易物弹窗 ==================== */
.barter-item-info {
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.08) 0%, rgba(91, 189, 114, 0.08) 100%);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.barter-item-label {
  display: block;
  font-size: 22rpx;
  color: #9B59B6;
  margin-bottom: 8rpx;
}

.barter-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
}

.input-section {
  margin-bottom: 24rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: #4E5969;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.barter-input {
  width: 100%;
  height: 80rpx;
  background: #F7F9FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2D3436;
  box-sizing: border-box;
}

.barter-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F7F9FA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.6;
  box-sizing: border-box;
}

/* ==================== 联系卖家弹窗 ==================== */
.contact-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.contact-label {
  font-size: 26rpx;
  color: #8E8E93;
}

.contact-value-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.contact-value {
  font-size: 26rpx;
  color: #2D3436;
  font-weight: 500;
}

.copy-btn {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 16rpx;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 500;
}

.contact-notice {
  margin-top: 24rpx;
  padding: 20rpx;
  background: rgba(243, 156, 18, 0.08);
  border-radius: 12rpx;
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.notice-icon {
  font-size: 26rpx;
}

.notice-text {
  flex: 1;
  font-size: 24rpx;
  color: #8B6914;
  line-height: 1.7;
}

/* ==================== 举报弹窗 ==================== */
.report-subtitle {
  display: block;
  font-size: 26rpx;
  color: #4E5969;
  margin-bottom: 20rpx;
}

.report-reasons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.report-reason {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F7F9FA;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.report-reason.active {
  background: rgba(232, 93, 93, 0.08);
  border-color: rgba(232, 93, 93, 0.4);
}

.reason-name {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
}

.report-reason.active .reason-name {
  color: #E85D5D;
  font-weight: 600;
}

.reason-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #E85D5D;
  color: #FFFFFF;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
