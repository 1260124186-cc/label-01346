.milestone-page {
  min-height: 100vh;
  background: #F7FAF8;
}

.dark-mode.milestone-page {
  background: #1A1A1A;
}

.header-card {
  position: relative;
  padding: 60rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #9B59B6 0%, #3498DB 50%, #16A085 100%);
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.honor-badge {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.badge-icon {
  font-size: 64rpx;
}

.current-title {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.stats-row {
  display: flex;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  padding: 28rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.2);
}

.next-card {
  margin: -20rpx 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(22, 160, 133, 0.1);
  position: relative;
  z-index: 2;
}

.dark-mode .next-card {
  background: #2A2A2A;
}

.next-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.next-info {
  display: flex;
  align-items: center;
}

.next-emoji {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.next-detail {
  flex: 1;
}

.next-name {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.dark-mode .next-name {
  color: #E0E0E0;
}

.next-progress-bar {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.dark-mode .next-progress-bar {
  background: #3A3A3A;
}

.next-progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.next-desc {
  font-size: 24rpx;
  color: #16A085;
  font-weight: 500;
}

.milestones-section {
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.dark-mode .section-title {
  color: #E0E0E0;
}

.milestones-timeline {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx 16rpx;
}

.dark-mode .milestones-timeline {
  background: #2A2A2A;
}

.milestone-item {
  display: flex;
  padding: 20rpx 8rpx;
}

.timeline-left {
  width: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 32rpx;
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  background: #E8E8E8;
  margin: 8rpx 0;
  min-height: 60rpx;
}

.dark-mode .timeline-line {
  background: #3A3A3A;
}

.milestone-item.locked .timeline-line {
  background: #E8E8E8;
}

.milestone-content {
  flex: 1;
  display: flex;
  align-items: flex-start;
  padding-left: 16rpx;
}

.milestone-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.milestone-icon {
  font-size: 44rpx;
}

.milestone-info {
  flex: 1;
  min-width: 0;
}

.milestone-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.milestone-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.dark-mode .milestone-name {
  color: #E0E0E0;
}

.milestone-item.locked .milestone-name {
  color: #999999;
}

.dark-mode .milestone-item.locked .milestone-name {
  color: #777777;
}

.milestone-target {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

.dark-mode .milestone-target {
  color: #AAAAAA;
}

.milestone-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
}

.dark-mode .milestone-desc {
  color: #AAAAAA;
}

.milestone-item.locked .milestone-desc {
  color: #999999;
}

.milestone-reward {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.reward-label {
  font-size: 22rpx;
  color: #999999;
}

.reward-value {
  font-size: 24rpx;
  color: #F39C12;
  font-weight: 600;
}

.milestone-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.progress-wrapper {
  flex: 1;
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.dark-mode .progress-wrapper {
  background: #3A3A3A;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #999999;
  width: 80rpx;
  text-align: right;
}

.milestone-unlock-time {
  display: block;
  font-size: 22rpx;
  color: #16A085;
  margin-top: 6rpx;
  font-weight: 500;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.unlock-modal {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.dark-mode .unlock-modal {
  background: #2A2A2A;
}

.modal-glow {
  position: absolute;
  top: -100rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(22, 160, 133, 0.3) 0%, transparent 70%);
}

.modal-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.modal-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.modal-emoji {
  font-size: 72rpx;
}

.modal-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.dark-mode .modal-title {
  color: #E0E0E0;
}

.modal-name {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.dark-mode .modal-desc {
  color: #AAAAAA;
}

.modal-reward {
  background: rgba(243, 156, 18, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 32rpx;
}

.reward-text {
  font-size: 28rpx;
  color: #F39C12;
  font-weight: 600;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.share {
  background: #F0F0F0;
  color: #333333;
}

.dark-mode .modal-btn.share {
  background: #3A3A3A;
  color: #E0E0E0;
}

.modal-btn.confirm {
  background: #16A085;
  color: #FFFFFF;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
