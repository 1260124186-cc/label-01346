.lottery-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F8EC 0%, #F7FAF8 30%);
  padding-bottom: 60rpx;
}

.lottery-page.dark-mode {
  background: linear-gradient(180deg, #1A3A22 0%, #1C2321 30%);
}

.header-section {
  padding: 32rpx;
  padding-bottom: 16rpx;
}

.user-info-card {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA860 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.3);
}

.dark-mode .user-info-card {
  background: linear-gradient(135deg, #3D8B50 0%, #2D6B3E 100%);
}

.points-display {
  text-align: center;
  margin-bottom: 32rpx;
}

.points-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.stat-value.highlight {
  color: #FFE58A;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.85;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
}

.guarantee-bar {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.dark-mode .guarantee-bar {
  background: #2A3A30;
}

.guarantee-text {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #4E5969;
  margin-bottom: 12rpx;
  gap: 8rpx;
}

.dark-mode .guarantee-text {
  color: #C9CDD4;
}

.guarantee-icon {
  font-size: 28rpx;
}

.guarantee-soon {
  color: #E85D5D;
  font-weight: 600;
  margin-left: auto;
}

.guarantee-progress {
  height: 8rpx;
  background: #F0F5F2;
  border-radius: 4rpx;
  overflow: hidden;
}

.dark-mode .guarantee-progress {
  background: #3A4A40;
}

.guarantee-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72, #9B59B6);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.wheel-section {
  padding: 0 32rpx;
}

.wheel-title {
  padding: 32rpx 0 24rpx;
}

.title-main {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 8rpx;
}

.dark-mode .title-main {
  color: #F2F3F5;
}

.title-sub {
  display: block;
  font-size: 24rpx;
  color: #86909C;
}

.dark-mode .title-sub {
  color: #86909C;
}

.wheel-container {
  position: relative;
  width: 560rpx;
  height: 560rpx;
  margin: 0 auto 40rpx;
}

.wheel-wrapper {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  transition: transform 4s cubic-bezier(0.17, 0.67, 0.12, 0.99);
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.2);
  background: #fff;
}

.dark-mode .wheel-wrapper {
  background: #2A3A30;
}

.wheel-wrapper.spinning {
  transition: transform 5s cubic-bezier(0.17, 0.67, 0.12, 0.99);
}

.wheel-sectors {
  position: relative;
  width: 100%;
  height: 100%;
}

.sector {
  position: absolute;
  width: 50%;
  height: 50%;
  top: 0;
  left: 50%;
  transform-origin: 0% 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 40rpx;
  box-sizing: border-box;
  clip-path: polygon(0 100%, 50% 0, 100% 100%);
}

.sector-1 { transform: rotate(0deg) skewY(-45deg); background: #FFF5E6; }
.sector-2 { transform: rotate(45deg) skewY(-45deg); background: #E8F8EC; }
.sector-3 { transform: rotate(90deg) skewY(-45deg); background: #FFF5E6; }
.sector-4 { transform: rotate(135deg) skewY(-45deg); background: #E8F8EC; }
.sector-5 { transform: rotate(180deg) skewY(-45deg); background: #FFF5E6; }
.sector-6 { transform: rotate(225deg) skewY(-45deg); background: #E8F8EC; }
.sector-7 { transform: rotate(270deg) skewY(-45deg); background: #FFF5E6; }
.sector-8 { transform: rotate(315deg) skewY(-45deg); background: #E8F8EC; }

.sector-emoji {
  display: block;
  font-size: 36rpx;
  transform: skewY(45deg);
  margin-bottom: 4rpx;
}

.sector-text {
  font-size: 18rpx;
  color: #1D2129;
  font-weight: 500;
  transform: skewY(45deg);
}

.wheel-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(243, 156, 18, 0.4);
  z-index: 10;
  transition: all 0.2s ease;
}

.wheel-center:active {
  transform: translate(-50%, -50%) scale(0.95);
}

.wheel-center.spinning {
  background: linear-gradient(135deg, #95A5A6 0%, #7F8C8D 100%);
}

.center-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.center-cost {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 2rpx;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.wheel-pointer {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 24rpx solid transparent;
  border-right: 24rpx solid transparent;
  border-top: 48rpx solid #E85D5D;
  filter: drop-shadow(0 4rpx 8rpx rgba(232, 93, 93, 0.3));
  z-index: 20;
}

.wheel-pointer::after {
  content: '';
  position: absolute;
  top: -56rpx;
  left: -12rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #E85D5D;
}

.draw-buttons {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.draw-btn {
  flex: 1;
  border-radius: 48rpx;
  padding: 28rpx 24rpx;
  text-align: center;
  position: relative;
  transition: all 0.2s ease;
}

.draw-btn:active {
  transform: scale(0.97);
}

.draw-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.single-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA860 100%);
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.3);
}

.ten-btn {
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  box-shadow: 0 4rpx 16rpx rgba(155, 89, 182, 0.3);
}

.btn-text {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4rpx;
}

.btn-cost {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.btn-badge {
  position: absolute;
  top: -12rpx;
  right: 24rpx;
  background: #E85D5D;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.quick-links {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.link-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  transition: all 0.2s ease;
}

.dark-mode .link-card {
  background: #2A3A30;
}

.link-card:active {
  transform: scale(0.98);
}

.link-emoji {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.link-info {
  flex: 1;
}

.link-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 4rpx;
}

.dark-mode .link-title {
  color: #F2F3F5;
}

.link-desc {
  display: block;
  font-size: 22rpx;
  color: #86909C;
}

.link-arrow {
  font-size: 36rpx;
  color: #C9CDD4;
}

.festival-tag {
  position: absolute;
  top: 16rpx;
  right: 24rpx;
  background: linear-gradient(135deg, #E85D5D, #F39C12);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.probability-section,
.rules-section {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.dark-mode .probability-section,
.dark-mode .rules-section {
  background: #2A3A30;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F2F3F5;
}

.dark-mode .section-header {
  border-bottom-color: #3A4A40;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D2129;
}

.dark-mode .section-title {
  color: #F2F3F5;
}

.toggle-icon {
  font-size: 24rpx;
  color: #86909C;
  transition: transform 0.2s ease;
}

.toggle-icon.open {
  transform: rotate(180deg);
}

.probability-content,
.rules-content {
  padding: 24rpx;
}

.rarity-group {
  margin-bottom: 24rpx;
}

.rarity-group:last-child {
  margin-bottom: 0;
}

.rarity-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0 12rpx 16rpx;
  border-left: 6rpx solid #5BBD72;
  margin-bottom: 12rpx;
}

.rarity-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1D2129;
}

.dark-mode .rarity-name {
  color: #F2F3F5;
}

.rarity-prob {
  font-size: 22rpx;
  color: #86909C;
}

.prize-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.prize-row {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #F7FAF8;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.dark-mode .prize-row {
  background: #3A4A40;
}

.prize-emoji {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.prize-name {
  flex: 1;
  color: #4E5969;
}

.dark-mode .prize-name {
  color: #C9CDD4;
}

.prize-prob {
  color: #5BBD72;
  font-weight: 500;
}

.guarantee-note {
  margin-top: 24rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.1), rgba(91, 189, 114, 0.1));
  border-radius: 12rpx;
}

.note-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #9B59B6;
  margin-bottom: 12rpx;
}

.note-text {
  display: block;
  font-size: 22rpx;
  color: #4E5969;
  line-height: 1.8;
}

.dark-mode .note-text {
  color: #C9CDD4;
}

.rule-item {
  font-size: 24rpx;
  color: #4E5969;
  line-height: 2;
  padding-left: 8rpx;
}

.dark-mode .rule-item {
  color: #C9CDD4;
}

.prize-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.prize-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.prize-modal-content {
  position: relative;
  width: 620rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx 32rpx;
  overflow-y: auto;
  animation: modalIn 0.3s ease;
}

.dark-mode .prize-modal-content {
  background: #2A3A30;
}

@keyframes modalIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 36rpx;
  color: #86909C;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  color: #1D2129;
  margin-bottom: 32rpx;
}

.dark-mode .modal-title {
  color: #F2F3F5;
}

.prize-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  justify-content: center;
}

.prize-grid-item {
  width: calc(25% - 12rpx);
  aspect-ratio: 1;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  position: relative;
  border: 2rpx solid transparent;
}

.prize-grid-item.rare {
  border-color: #5BBD72;
  box-shadow: 0 0 16rpx rgba(91, 189, 114, 0.3);
}

.prize-grid-item.epic {
  border-color: #F39C12;
  box-shadow: 0 0 20rpx rgba(243, 156, 18, 0.4);
  background: linear-gradient(135deg, rgba(243, 156, 18, 0.1) 0%, transparent 100%);
}

.grid-emoji {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.grid-name {
  font-size: 18rpx;
  color: #1D2129;
  text-align: center;
  line-height: 1.2;
}

.dark-mode .grid-name {
  color: #F2F3F5;
}

.grid-rarity-tag {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #5BBD72;
  color: #fff;
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-radius: 12rpx;
}

.prize-single {
  text-align: center;
  padding: 48rpx 32rpx;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}

.single-emoji {
  display: block;
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.single-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1D2129;
  margin-bottom: 12rpx;
}

.dark-mode .single-name {
  color: #F2F3F5;
}

.single-desc {
  display: block;
  font-size: 24rpx;
  color: #4E5969;
}

.dark-mode .single-desc {
  color: #C9CDD4;
}

.summary-row {
  text-align: center;
  font-size: 26rpx;
  color: #9B59B6;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  border-radius: 48rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.modal-btn:active {
  transform: scale(0.97);
}

.modal-btn.secondary {
  background: #F2F3F5;
  color: #4E5969;
}

.dark-mode .modal-btn.secondary {
  background: #3A4A40;
  color: #C9CDD4;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA860 100%);
  color: #fff;
}

.pin-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pin-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.pin-modal-content {
  position: relative;
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  animation: modalIn 0.3s ease;
}

.dark-mode .pin-modal-content {
  background: #2A3A30;
}

.pin-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  color: #1D2129;
  margin-bottom: 20rpx;
}

.dark-mode .pin-title {
  color: #F2F3F5;
}

.pin-desc {
  font-size: 26rpx;
  color: #4E5969;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.dark-mode .pin-desc {
  color: #C9CDD4;
}

.pin-buttons {
  display: flex;
  gap: 20rpx;
}

.pin-btn {
  flex: 1;
  border-radius: 48rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.pin-btn.secondary {
  background: #F2F3F5;
  color: #4E5969;
}

.dark-mode .pin-btn.secondary {
  background: #3A4A40;
  color: #C9CDD4;
}

.pin-btn.primary {
  background: linear-gradient(135deg, #5BBD72 0%, #4AA860 100%);
  color: #fff;
}
