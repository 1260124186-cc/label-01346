@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    opacity: 1;
    transform: scale(1.1);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.pk-result-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F0F9FF 100%);
  padding: 0 32rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.pk-result-container.show {
  opacity: 1;
}

.result-banner {
  width: calc(100% + 64rpx);
  margin-left: -32rpx;
  padding: 60rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 0 0 40rpx 40rpx;
}

.result-emoji-wrap {
  animation: bounceIn 0.8s ease-out;
}

.result-emoji {
  font-size: 140rpx;
  line-height: 1;
}

.result-title-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.result-points-badge {
  margin-top: 16rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  padding: 10rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.vs-section {
  width: 100%;
  margin-top: 32rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  animation: slideUp 0.5s ease-out 0.2s both;
}

.vs-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.player-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(91, 189, 114, 0.25);
}

.player-avatar.opponent {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 217, 0.25);
}

.avatar-emoji {
  font-size: 48rpx;
}

.player-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D3436;
  margin-top: 12rpx;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vs-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.vs-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #636E72;
  letter-spacing: 2rpx;
}

.stats-comparison {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.stat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.stat-row:not(:last-child) {
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stat-value {
  width: 140rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #636E72;
}

.stat-value.winner {
  color: #5BBD72;
}

.stat-value.my {
  text-align: right;
  padding-right: 24rpx;
}

.stat-value.opponent {
  text-align: left;
  padding-left: 24rpx;
}

.stat-label-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-label-text {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
  padding: 6rpx 20rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 20rpx;
}

.points-card {
  width: 100%;
  margin-top: 32rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  animation: slideUp 0.5s ease-out 0.4s both;
}

.points-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.points-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.points-label {
  font-size: 24rpx;
  color: #636E72;
  margin-bottom: 4rpx;
}

.points-amount {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.points-detail {
  margin-left: auto;
}

.detail-text {
  font-size: 22rpx;
  color: #B2BEC3;
  font-weight: 500;
}

.action-section {
  width: 100%;
  margin-top: 48rpx;
  display: flex;
  gap: 24rpx;
  animation: slideUp 0.5s ease-out 0.6s both;
}

.action-btn {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.action-btn.primary {
  color: #fff;
}

.action-btn.primary:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.action-btn.outline {
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid;
}

.action-btn.outline:active {
  transform: scale(0.96);
  background: rgba(0, 0, 0, 0.02);
}
