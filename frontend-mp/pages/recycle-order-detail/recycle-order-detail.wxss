.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 120rpx;
}

.status-section {
  padding: 60rpx 30rpx;
  display: flex;
  align-items: center;
  color: #fff;
}

.status-pending {
  background: linear-gradient(135deg, #F39C12, #E67E22);
}

.status-appointed {
  background: linear-gradient(135deg, #3498DB, #2980B9);
}

.status-visiting {
  background: linear-gradient(135deg, #9B59B6, #8E44AD);
}

.status-completed {
  background: linear-gradient(135deg, #5BBD72, #4CAF50);
}

.status-cancelled {
  background: linear-gradient(135deg, #95A5A6, #7F8C8D);
}

.status-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.icon-emoji {
  font-size: 48rpx;
}

.status-info {
  flex: 1;
}

.status-title {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.progress-section {
  background: #fff;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.progress-steps {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  position: relative;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
  z-index: 2;
}

.step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ddd;
  margin-bottom: 12rpx;
}

.step-item.done .step-dot {
  background: #5BBD72;
}

.step-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.step-item.done .step-text {
  color: #333;
  font-weight: 500;
}

.step-time {
  font-size: 20rpx;
  color: #ccc;
}

.step-item.done .step-time {
  color: #999;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #eee;
  margin-top: 10rpx;
  position: relative;
  z-index: 1;
}

.step-line.done {
  background: #5BBD72;
}

.goods-card,
.appointment-card,
.address-card,
.remark-card,
.order-info-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.goods-item {
  display: flex;
  padding: 24rpx 30rpx;
  align-items: center;
}

.goods-icon {
  width: 100rpx;
  height: 100rpx;
  background: #F0F9F2;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.goods-icon .icon-emoji {
  font-size: 48rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.4;
}

.goods-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.goods-bottom {
  margin-top: 12rpx;
}

.goods-points {
  font-size: 26rpx;
  color: #5BBD72;
  font-weight: 500;
}

.actual-points-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #F0F9F2;
  margin: 0 20rpx 20rpx;
  border-radius: 12rpx;
}

.points-label {
  font-size: 26rpx;
  color: #666;
}

.points-value {
  font-size: 32rpx;
  color: #5BBD72;
  font-weight: 600;
}

.info-list {
  padding: 16rpx 30rpx 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  max-width: 400rpx;
  text-align: right;
  word-break: break-all;
}

.info-value.status-text {
  color: #5BBD72;
}

.order-no-wrapper {
  display: flex;
  align-items: center;
}

.copy-btn {
  font-size: 22rpx;
  color: #5BBD72;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  border: 1rpx solid #5BBD72;
  border-radius: 8rpx;
}

.address-info {
  padding: 24rpx 30rpx;
}

.address-top {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail .detail-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.remark-content {
  padding: 24rpx 30rpx;
}

.remark-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.bottom-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  gap: 20rpx;
}

.bar-btn {
  min-width: 180rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bar-btn.secondary {
  border: 1rpx solid #ddd;
  background: #fff;
}

.bar-btn.secondary .btn-text {
  color: #666;
  font-size: 26rpx;
}

.bar-btn.primary {
  background: linear-gradient(135deg, #5BBD72, #4CAF50);
}

.bar-btn.primary .btn-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.bar-btn.primary.disabled {
  background: #ccc;
}

.bar-btn.danger {
  background: linear-gradient(135deg, #E85D5D, #C0392B);
}

.bar-btn.danger .btn-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}
