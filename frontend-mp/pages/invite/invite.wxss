.page-container {
  min-height: 100vh;
  background: #F7FAF8;
  padding-bottom: 40rpx;
}

.stats-section {
  padding: 30rpx 30rpx 0;
}

.stats-card {
  position: relative;
  background: linear-gradient(135deg, #5BBD72 0%, #4A9D5F 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(91, 189, 114, 0.3);
}

.stats-bg-decoration {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.stats-bg-circle {
  position: absolute;
  bottom: -40rpx;
  left: 50%;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  transform: translateX(-50%);
}

.stats-header {
  margin-bottom: 30rpx;
}

.stats-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stats-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.share-tip-section {
  padding: 20rpx 30rpx 0;
}

.share-tip-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.share-tip-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.share-tip-text {
  flex: 1;
}

.share-tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.share-tip-desc {
  display: block;
  font-size: 24rpx;
  color: #636E72;
}

.action-section {
  padding: 30rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: none;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4A9D5F 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.3);
}

.primary-btn .btn-icon {
  font-size: 32rpx;
}

.secondary-btn {
  background: #FFFFFF;
  color: #5BBD72;
  border: 2rpx solid #5BBD72 !important;
  box-shadow: 0 2rpx 8rpx rgba(91, 189, 114, 0.1);
}

.secondary-btn .btn-icon {
  font-size: 32rpx;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 30rpx;
}

.rules-section {
  padding: 0 30rpx 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2D3436;
}

.section-count {
  font-size: 24rpx;
  color: #B2BEC3;
}

.rules-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.rule-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rule-emoji {
  font-size: 36rpx;
}

.rule-content {
  flex: 1;
}

.rule-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.rule-desc {
  display: block;
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.4;
}

.rule-points {
  text-align: right;
  flex-shrink: 0;
}

.points-text {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #5BBD72;
}

.reward-label {
  font-size: 20rpx;
  color: #B2BEC3;
}

.rule-divider {
  height: 2rpx;
  background: #F0F0F0;
  margin: 0;
}

.records-section {
  padding: 0 30rpx 30rpx;
}

.records-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BBD72 0%, #4A9D5F 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-emoji {
  font-size: 32rpx;
}

.record-info {
  flex: 1;
  overflow: hidden;
}

.record-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 6rpx;
}

.record-time {
  display: block;
  font-size: 22rpx;
  color: #B2BEC3;
}

.record-reward {
  text-align: right;
  flex-shrink: 0;
}

.reward-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #5BBD72;
}

.empty-state {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 80rpx 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.empty-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #2D3436;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: #B2BEC3;
}

.simulate-section {
  padding: 0 30rpx;
}

.simulate-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: #F0F0F0;
  color: #999;
  font-size: 24rpx;
  border-radius: 36rpx;
  border: none;
}

.simulate-btn::after {
  border: none;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.poster-content {
  width: 100%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.poster-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 2rpx solid #F0F0F0;
}

.poster-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2D3436;
}

.poster-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F5F5;
}

.close-icon {
  font-size: 24rpx;
  color: #999;
}

.poster-image-wrapper {
  padding: 30rpx;
  display: flex;
  justify-content: center;
}

.poster-image {
  width: 100%;
  max-height: 700rpx;
  border-radius: 16rpx;
}

.poster-placeholder {
  width: 100%;
  height: 400rpx;
  background: #F7FAF8;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #2D3436;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.placeholder-desc {
  font-size: 24rpx;
  color: #B2BEC3;
}

.poster-actions {
  padding: 0 30rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.poster-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: none;
  padding: 0;
}

.poster-btn::after {
  border: none;
}

.save-btn {
  background: linear-gradient(135deg, #5BBD72 0%, #4A9D5F 100%);
  color: #FFFFFF;
}

.share-btn {
  background: #F5F5F5;
  color: #2D3436;
}

.hidden-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 300px;
  height: 500px;
  pointer-events: none;
  opacity: 0;
}
