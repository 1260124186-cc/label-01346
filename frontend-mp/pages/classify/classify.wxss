/**
 * 垃圾分类常识页面样式
 * 设计风格：轻透清新风
 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: 48rpx;
  box-sizing: border-box;
}

/* ==================== 分类切换器 ==================== */
.type-switcher {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.type-switcher::-webkit-scrollbar {
  display: none;
}

.type-tab {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
}

.type-tab.active {
  background: var(--tab-bg);
  border-color: var(--tab-color);
}

.tab-name {
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.type-tab.active .tab-name {
  color: var(--tab-color);
  font-weight: 600;
}

/* ==================== 分类头部 ==================== */
.classify-header {
  position: relative;
  margin: 0 32rpx 32rpx;
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, var(--header-bg) 0%, rgba(255, 255, 255, 0.9) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.header-bg-decoration {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: var(--header-color);
  opacity: 0.1;
}

.header-content {
  position: relative;
  display: flex;
  align-items: center;
}

.classify-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.classify-icon {
  width: 80rpx;
  height: 80rpx;
}

.classify-icon-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.classify-title-section {
  flex: 1;
}

.classify-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--header-color);
  margin-bottom: 8rpx;
}

.classify-english {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* ==================== 通用卡片样式 ==================== */
.section-card {
  margin: 0 32rpx 24rpx;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 0;
}

.card-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.icon-text {
  font-size: 28rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.practice-entry-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: var(--btn-color);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.practice-entry-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.practice-icon {
  font-size: 24rpx;
}

.practice-text {
  font-size: 24rpx;
}

.card-content {
  padding: 24rpx 28rpx 28rpx;
}

/* ==================== 分类说明卡片 ==================== */
.description-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* ==================== 常见垃圾列表 ==================== */
.examples-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.example-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--item-bg);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.example-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.example-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.example-icon {
  font-size: 28rpx;
}

.example-info {
  flex: 1;
  min-width: 0;
}

.example-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.example-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.example-arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.example-arrow .arrow {
  font-size: 32rpx;
  color: var(--item-color);
  opacity: 0.6;
}

/* ==================== 投放提示 ==================== */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
}

.tip-number {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: var(--tip-color);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  padding-top: 6rpx;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(91, 189, 114, 0.2);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  height: 48rpx;
}
