<!--
  垃圾分类常识页面
  功能：展示各类垃圾的详细分类知识
  考核点：正确接收页面传递参数、view/image标签使用、基本样式
-->
<view class="page-container" wx:if="{{!isLoading && classifyData}}">
  <!-- 顶部分类切换 -->
  <view class="type-switcher">
    <view 
      wx:for="{{allTypes}}" 
      wx:key="id"
      class="type-tab {{classifyId === item.id ? 'active' : ''}}"
      style="--tab-color: {{item.color}}; --tab-bg: {{item.bgColor}};"
      bindtap="onSwitchType"
      data-id="{{item.id}}"
    >
      <text class="tab-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 分类头部信息 -->
  <view class="classify-header" style="--header-color: {{classifyData.color}}; --header-bg: {{classifyData.bgColor}};">
    <view class="header-bg-decoration"></view>
    
    <view class="header-content">
      <!-- 分类图标 -->
      <view class="classify-icon-wrapper">
        <text class="classify-icon-emoji">{{classifyData.emoji}}</text>
      </view>
      
      <!-- 分类名称 -->
      <view class="classify-title-section">
        <text class="classify-name">{{classifyData.name}}</text>
        <text class="classify-english">{{classifyData.englishName}}</text>
      </view>
    </view>
  </view>

  <!-- 分类说明卡片 -->
  <view class="section-card description-card">
    <view class="card-header">
      <view class="card-icon" style="background: {{classifyData.bgColor}};">
        <text class="icon-text" style="color: {{classifyData.color}};">📋</text>
      </view>
      <text class="card-title">分类说明</text>
    </view>
    <view class="card-content">
      <text class="description-text">{{classifyData.description}}</text>
    </view>
  </view>

  <!-- 本地分类标准差异 -->
  <view class="section-card city-standard-card">
    <view class="card-header">
      <view class="card-icon" style="background: {{classifyData.bgColor}};">
        <text class="icon-text" style="color: {{classifyData.color}};">🏙️</text>
      </view>
      <text class="card-title">本地区分类标准</text>
    </view>
    <view class="card-content">
      <!-- 城市选择器 -->
      <view class="city-selector">
        <view
          wx:for="{{cityStandards}}"
          wx:key="id"
          class="city-tab {{selectedCityId === item.id ? 'active' : ''}}"
          style="--city-color: {{item.color}};"
          bindtap="onCityChange"
          data-id="{{item.id}}"
        >
          <text class="city-emoji">{{item.emoji}}</text>
          <text class="city-name">{{item.name}}</text>
        </view>
      </view>
      <!-- 选中城市的分类标准 -->
      <view class="city-standard-content" wx:if="{{selectedCity}}">
        <view class="standard-type-item">
          <view class="standard-type-label" style="background: rgba(74, 144, 217, 0.1); color: #4A90D9;">♻️ 可回收</view>
          <text class="standard-type-text">{{selectedCity.standards.recyclable}}</text>
        </view>
        <view class="standard-type-item">
          <view class="standard-type-label" style="background: rgba(232, 93, 93, 0.1); color: #E85D5D;">☣️ 有害</view>
          <text class="standard-type-text">{{selectedCity.standards.harmful}}</text>
        </view>
        <view class="standard-type-item">
          <view class="standard-type-label" style="background: rgba(91, 189, 114, 0.1); color: #5BBD72;">🍂 厨余</view>
          <text class="standard-type-text">{{selectedCity.standards.kitchen}}</text>
        </view>
        <view class="standard-type-item">
          <view class="standard-type-label" style="background: rgba(142, 142, 147, 0.1); color: #8E8E93;">🗑️ 其他</view>
          <text class="standard-type-text">{{selectedCity.standards.other}}</text>
        </view>
        <!-- 特殊规则 -->
        <view class="special-rules" wx:if="{{selectedCity.specialRules.length > 0}}">
          <view class="special-rules-header">
            <text class="special-rules-title">⚠️ {{selectedCity.name}}特殊规则</text>
          </view>
          <view class="special-rules-list">
            <view
              wx:for="{{selectedCity.specialRules}}"
              wx:key="index"
              class="special-rule-item"
            >
              <text class="rule-bullet">•</text>
              <text class="rule-text">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 相关题目 -->
  <view class="section-card quiz-card">
    <view class="card-header">
      <view class="card-icon" style="background: {{classifyData.bgColor}};">
        <text class="icon-text" style="color: {{classifyData.color}};">❓</text>
      </view>
      <text class="card-title">相关题目</text>
      <view class="quiz-more-btn" bindtap="goToQuizPlay" style="--btn-color: {{classifyData.color}};">
        <text class="quiz-more-text">去答题</text>
      </view>
    </view>
    <view class="card-content">
      <view class="quiz-list">
        <view
          wx:for="{{relatedQuizQuestions}}"
          wx:key="id"
          class="quiz-question-item"
          bindtap="onQuizQuestionTap"
          data-item="{{item}}"
        >
          <view class="quiz-question-header">
            <text class="quiz-question-type">{{item.typeName}}</text>
            <text class="quiz-question-difficulty {{item.difficulty}}">{{item.difficultyName}}</text>
          </view>
          <text class="quiz-question-text">{{item.question}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 常见垃圾列表 -->
  <view class="section-card examples-card">
    <view class="card-header">
      <view class="card-icon" style="background: {{classifyData.bgColor}};">
        <text class="icon-text" style="color: {{classifyData.color}};">📦</text>
      </view>
      <text class="card-title">常见垃圾</text>
      <view class="practice-entry-btn" bindtap="startPractice" style="--btn-color: {{classifyData.color}};">
        <text class="practice-icon">✏️</text>
        <text class="practice-text">练一练</text>
      </view>
    </view>
    <view class="card-content">
      <view class="examples-grid">
        <view 
          wx:for="{{classifyData.examples}}" 
          wx:key="name"
          class="example-item"
          style="--item-color: {{classifyData.color}}; --item-bg: {{classifyData.bgColor}};"
          bindtap="onExampleTap"
          bindlongpress="onExampleLongPress"
          data-item="{{item}}"
        >
          <view class="example-icon-wrapper">
            <text class="example-icon">{{item.icon}}</text>
          </view>
          <view class="example-info">
            <text class="example-name">{{item.name}}</text>
            <text class="example-desc">{{item.desc}}</text>
          </view>
          <view class="example-arrow">
            <text class="arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 投放提示 -->
  <view class="section-card tips-card">
    <view class="card-header">
      <view class="card-icon" style="background: {{classifyData.bgColor}};">
        <text class="icon-text" style="color: {{classifyData.color}};">💡</text>
      </view>
      <text class="card-title">投放提示</text>
    </view>
    <view class="card-content">
      <view class="tips-list">
        <view 
          wx:for="{{classifyData.tips}}" 
          wx:key="index"
          class="tip-item"
          style="--tip-color: {{classifyData.color}};"
        >
          <view class="tip-number">{{index + 1}}</view>
          <text class="tip-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{isLoading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>
