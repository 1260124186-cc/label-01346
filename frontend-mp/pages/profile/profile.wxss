/**
 * 个人中心页面样式
 * 设计风格：轻透清新风
 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background: linear-gradient(180deg, #5BBD72 0%, #E8F5E9 25%, #F7FAF8 40%);
}

/* ==================== 用户信息卡片 ==================== */
.user-section {
  padding: 48rpx 32rpx 32rpx;
}

.user-card {
  position: relative;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(91, 189, 114, 0.15);
  overflow: hidden;
}

/* 背景装饰 */
.card-bg-decoration {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.15) 0%, rgba(91, 189, 114, 0.05) 100%);
}

.card-bg-circle {
  position: absolute;
  bottom: -60rpx;
  left: -60rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(91, 189, 114, 0.08);
}

/* 头像 */
.avatar-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 44rpx;
  height: 44rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  font-size: 22rpx;
}

.avatar-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 用户信息 */
.user-info {
  flex: 1;
  min-width: 0;
}

.nickname-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.edit-hint {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 等级标签 */
.level-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.15) 0%, rgba(91, 189, 114, 0.08) 100%);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.level-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.level-name {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 等级进度条 */
.level-progress {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(91, 189, 114, 0.15);
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* 积分徽章 */
.points-badge {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 16rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.points-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.points-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 统计数据 ==================== */
.statistics-section {
  padding: 0 32rpx 24rpx;
}

.statistics-card {
  display: flex;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: transform 0.2s ease;
}

.stat-item:active {
  transform: scale(0.95);
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.06);
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.contributor-section {
  padding: 0 32rpx 24rpx;
}

.contributor-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  border-left: 6rpx solid var(--color-primary);
}

.contributor-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.contributor-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contributor-emoji {
  font-size: 36rpx;
}

.contributor-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.contributor-title {
  font-size: 28rpx;
  font-weight: 700;
}

.contributor-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.contributor-right {
  display: flex;
  align-items: center;
}

.contributor-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

/* ==================== 碳账本入口 ==================== */
.carbon-entry-section {
  padding: 0 32rpx 24rpx;
}

.carbon-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #16A085 0%, #27AE60 100%);
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(22, 160, 133, 0.2);
  transition: transform 0.2s ease;
}

.carbon-entry-card:active {
  transform: scale(0.98);
}

.carbon-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.carbon-badge {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.carbon-emoji {
  font-size: 44rpx;
}

.carbon-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.carbon-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.carbon-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.carbon-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.carbon-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
}

.carbon-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.carbon-stat-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 2rpx;
}

.carbon-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 300;
  margin-left: 4rpx;
}

.dark-mode .carbon-entry-card {
  background: linear-gradient(135deg, #0F7361 0%, #1E8449 100%);
}

/* ==================== 签到入口 ==================== */
.signin-entry-section {
  padding: 0 32rpx 24rpx;
}

.signin-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(91, 189, 114, 0.2);
  transition: transform 0.2s ease;
}

.signin-entry-card:active {
  transform: scale(0.98);
}

.signin-entry-card.done {
  background: linear-gradient(135deg, #81C784 0%, #66BB6A 100%);
}

.signin-entry-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.signin-entry-emoji {
  font-size: 48rpx;
}

.signin-entry-text {
  flex: 1;
}

.signin-entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4rpx;
  display: block;
}

.signin-entry-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

.signin-entry-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 300;
}

/* ==================== 功能菜单（分组） ==================== */
.menu-section {
  padding: 0 32rpx 24rpx;
}

.menu-group-title {
  display: flex;
  align-items: center;
  padding: 8rpx 8rpx 20rpx;
}

.group-title-decoration {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #4AA862 100%);
  border-radius: 4rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.group-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 菜单列表容器 */
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 每个菜单项独立卡片 */
.menu-item-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.menu-item-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(91, 189, 114, 0.08);
}

/* 图标容器 */
.menu-icon-wrapper {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.menu-icon {
  width: 32rpx;
  height: 32rpx;
}

.menu-icon-emoji {
  font-size: 36rpx;
  line-height: 1;
}

/* 菜单文字内容 */
.menu-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.menu-title-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
}

/* 右侧箭头 */
.menu-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(91, 189, 114, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: 300;
  line-height: 1;
}

/* ==================== 成就勋章 ==================== */
.achievement-section {
  padding: 0 32rpx 24rpx;
}

.achievement-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 8rpx 16rpx;
}

.achievement-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
}

.achievement-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.achievement-grid {
  display: flex;
  flex-wrap: wrap;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.achievement-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  transition: transform 0.2s ease;
}

.achievement-item:active {
  transform: scale(0.95);
}

.achievement-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  transition: all 0.3s ease;
}

.achievement-item.unlocked .achievement-icon-wrapper {
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.2);
}

.achievement-item.locked .achievement-icon-wrapper {
  opacity: 0.5;
}

.achievement-icon {
  font-size: 44rpx;
  line-height: 1;
}

.achievement-name {
  font-size: 22rpx;
  color: var(--text-primary);
  text-align: center;
  line-height: 1.3;
  margin-bottom: 8rpx;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.achievement-item.locked .achievement-name {
  color: var(--text-tertiary);
}

.achievement-progress-bar {
  width: 80rpx;
  height: 6rpx;
  background: rgba(142, 142, 147, 0.15);
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 4rpx;
}

.achievement-progress-fill {
  height: 100%;
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

.achievement-progress-text {
  font-size: 18rpx;
  color: var(--text-tertiary);
}

/* ==================== 版本信息 ==================== */
.version-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
}

.version-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.copyright-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  opacity: 0.7;
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  height: 48rpx;
}

/* ==================== 菜单红点 ==================== */
.menu-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  background: #FF3B30;
  border-radius: 17rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(255, 59, 48, 0.35);
  z-index: 10;
}

.menu-badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
  line-height: 1;
}

/* ==================== 组信息入口卡片 ==================== */
.group-entry-section {
  padding: 0 32rpx 24rpx;
}

.group-entry-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.1);
  transition: transform 0.2s ease;
}

.group-entry-card:active {
  transform: scale(0.98);
}

/* 有组的样式 */
.group-entry-card.has-group {
  justify-content: space-between;
}

.group-entry-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.group-type-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.group-icon {
  font-size: 44rpx;
  line-height: 1;
}

.group-entry-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.group-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-member-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
}

.group-member-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.group-entry-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.group-action-buttons {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-right: 8rpx;
}

.group-action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}

.group-action-btn:active {
  transform: scale(0.9);
}

.group-action-btn.leaderboard {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9F43 100%);
  box-shadow: 0 4rpx 10rpx rgba(255, 159, 67, 0.3);
}

.group-action-btn.report {
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
  box-shadow: 0 4rpx 10rpx rgba(108, 92, 231, 0.3);
}

.action-btn-icon {
  font-size: 28rpx;
  line-height: 1;
}

.group-entry-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 300;
  margin-left: 4rpx;
}

/* 无组引导样式 */
.group-entry-card.no-group {
  flex-direction: column;
  align-items: center;
  padding: 40rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 154, 139, 0.1) 0%, rgba(102, 126, 234, 0.1) 100%);
  border: 2rpx dashed rgba(91, 189, 114, 0.3);
}

.no-group-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9A8B 0%, #667eea 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
}

.no-group-icon {
  font-size: 60rpx;
  line-height: 1;
}

.no-group-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.no-group-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.no-group-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.5;
}

.no-group-action {
  display: flex;
  align-items: center;
  justify-content: center;
}

.no-group-btn {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 40rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(91, 189, 114, 0.3);
}

/* ==================== 儿童模式简化样式 ==================== */

