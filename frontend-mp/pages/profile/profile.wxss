/**
 * 个人中心页面样式
 * 设计风格：轻透清新风
 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background: linear-gradient(180deg, #5BBD72 0%, #E8F5E9 25%, #F7FAF8 40%);
}

/* ==================== 用户信息卡片 ==================== */
.user-section {
  padding: 48rpx 32rpx 32rpx;
}

.user-card {
  position: relative;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(91, 189, 114, 0.15);
  overflow: hidden;
}

/* 背景装饰 */
.card-bg-decoration {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.15) 0%, rgba(91, 189, 114, 0.05) 100%);
}

.card-bg-circle {
  position: absolute;
  bottom: -60rpx;
  left: -60rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(91, 189, 114, 0.08);
}

/* 头像 */
.avatar-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 44rpx;
  height: 44rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  font-size: 22rpx;
}

.avatar-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 用户信息 */
.user-info {
  flex: 1;
  min-width: 0;
}

.nickname-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.edit-hint {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 等级标签 */
.level-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, rgba(91, 189, 114, 0.15) 0%, rgba(91, 189, 114, 0.08) 100%);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.level-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.level-name {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 等级进度条 */
.level-progress {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(91, 189, 114, 0.15);
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* 积分徽章 */
.points-badge {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #5BBD72 0%, #4AA862 100%);
  border-radius: 16rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.points-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.points-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 统计数据 ==================== */
.statistics-section {
  padding: 0 32rpx 24rpx;
}

.statistics-card {
  display: flex;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: transform 0.2s ease;
}

.stat-item:active {
  transform: scale(0.95);
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.06);
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ==================== 功能菜单 ==================== */
.menu-section {
  padding: 0 32rpx;
}

.menu-title {
  padding: 24rpx 0 16rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* weUI 样式覆盖 */
.menu-cells {
  background: rgba(255, 255, 255, 0.8) !important;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx !important;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
}

.menu-cell {
  padding: 28rpx 32rpx !important;
}

.menu-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: rgba(91, 189, 114, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon {
  width: 32rpx;
  height: 32rpx;
}

.menu-icon-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.menu-content {
  display: flex;
  flex-direction: column;
}

.menu-title-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ==================== 版本信息 ==================== */
.version-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
}

.version-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.copyright-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  opacity: 0.7;
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  height: 48rpx;
}
