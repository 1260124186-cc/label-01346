<!--
  个人中心页面
  功能：展示用户信息、头像上传、功能菜单
  考核点：view/image标签、weUI框架使用、本地图片上传
-->
<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-section">
    <view class="user-card {{childModeEnabled ? 'child-mode-card' : ''}}">
      <!-- 背景装饰 -->
      <view class="card-bg-decoration"></view>
      <view class="card-bg-circle"></view>

      <!-- 用户头像 -->
      <view class="avatar-wrapper {{childModeEnabled ? 'child-avatar-wrapper' : ''}}" bindtap="{{childModeEnabled ? '' : 'onAvatarTap'}}">
        <image
          wx:if="{{userInfo.avatarUrl && !childModeEnabled}}"
          class="avatar-image"
          src="{{userInfo.avatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="avatar-placeholder {{childModeEnabled ? 'child-avatar-placeholder' : ''}}">
          <text class="avatar-emoji {{childModeEnabled ? 'child-avatar-emoji' : ''}}">{{levelInfo.icon}}</text>
        </view>
        <view class="avatar-edit-icon" wx:if="{{!childModeEnabled}}">
          <text class="edit-icon">📷</text>
        </view>
        <!-- 上传中遮罩 -->
        <view class="avatar-loading" wx:if="{{isUploading && !childModeEnabled}}">
          <view class="loading-spinner"></view>
        </view>
      </view>

      <!-- 用户信息 -->
      <view class="user-info {{childModeEnabled ? 'child-user-info' : ''}}">
        <view class="nickname-wrapper" bindtap="{{childModeEnabled ? '' : 'onNickNameTap'}}">
          <text class="nickname {{childModeEnabled ? 'child-nickname' : ''}}">{{userInfo.nickName}}</text>
          <text class="edit-hint" wx:if="{{!childModeEnabled}}">✎</text>
        </view>

        <!-- 等级标签 -->
        <view class="level-tag" wx:if="{{!childModeEnabled}}">
          <text class="level-icon">{{levelInfo.icon}}</text>
          <text class="level-name">{{levelInfo.name}}</text>
        </view>
        <view class="level-tag child-level-tag" wx:else>
          <text class="level-name">{{levelInfo.name}}</text>
        </view>

        <!-- 等级进度条 -->
        <view class="level-progress" wx:if="{{!childModeEnabled}}">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{levelInfo.progress}}%;"></view>
          </view>
          <text class="progress-text">Lv.{{levelInfo.level}}</text>
        </view>
      </view>

      <!-- 积分展示 -->
      <view class="points-badge {{childModeEnabled ? 'child-points-badge' : ''}}">
        <text class="points-value">{{userInfo.points}}</text>
        <text class="points-label">{{childModeEnabled ? '分' : '积分'}}</text>
      </view>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="statistics-section">
    <view class="statistics-card">
      <view
        wx:for="{{statistics}}"
        wx:key="id"
        class="stat-item"
        bindtap="onStatTap"
        data-item="{{item}}"
      >
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 签到入口 -->
  <view class="signin-entry-section" bindtap="goToSignIn">
    <view class="signin-entry-card {{isSignedToday ? 'done' : ''}}">
      <view class="signin-entry-left">
        <text class="signin-entry-emoji">{{isSignedToday ? '✅' : '📅'}}</text>
        <view class="signin-entry-text">
          <text class="signin-entry-title">{{isSignedToday ? '今日已签到' : '每日签到'}}</text>
          <text class="signin-entry-subtitle">{{isSignedToday ? '明天继续打卡赢积分' : '点击签到，获得5积分奖励'}}</text>
        </view>
      </view>
      <view class="signin-entry-arrow">›</view>
    </view>
  </view>

  <!-- 组信息入口卡片 -->
  <view class="group-entry-section">
    <block wx:if="{{currentGroup}}">
      <view class="group-entry-card has-group" bindtap="goToFamilyGroup">
        <view class="group-entry-left">
          <view class="group-type-icon" style="background: {{currentGroup.type === 'family' ? 'linear-gradient(135deg, #FF9A8B 0%, #FF6A88 100%)' : 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'}};">
            <text class="group-icon">{{currentGroup.type === 'family' ? '👨‍👩‍👧‍👦' : '🏫'}}</text>
          </view>
          <view class="group-entry-info">
            <text class="group-name">{{currentGroup.name}}</text>
            <text class="group-member-count">
              <text class="group-member-icon">👥</text>
              {{currentGroup.memberCount || 0}}名成员
            </text>
          </view>
        </view>
        <view class="group-entry-right">
          <view class="group-action-buttons">
            <view class="group-action-btn leaderboard" catchtap="goToGroupLeaderboard">
              <text class="action-btn-icon">🏆</text>
            </view>
            <view class="group-action-btn report" wx:if="{{hasReportPermission}}" catchtap="goToLearningReport">
              <text class="action-btn-icon">📊</text>
            </view>
          </view>
          <text class="group-entry-arrow">›</text>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="group-entry-card no-group" bindtap="goToFamilyGroup">
        <view class="no-group-icon-wrapper">
          <text class="no-group-icon">👨‍👩‍👧‍👦</text>
        </view>
        <view class="no-group-info">
          <text class="no-group-title">创建/加入家庭/班级组</text>
          <text class="no-group-desc">和家人朋友一起学习垃圾分类，组队PK赢奖励</text>
        </view>
        <view class="no-group-action">
          <text class="no-group-btn">去创建</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 成就勋章 -->
  <view class="achievement-section">
    <view class="achievement-header">
      <text class="achievement-title">{{childModeEnabled ? '我的勋章' : '我的成就'}}</text>
      <text class="achievement-count" wx:if="{{!childModeEnabled}}">已解锁 {{unlockedAchievementCount}}/{{achievements.length}}</text>
      <text class="achievement-count" wx:else>已获得 {{unlockedAchievementCount}} 枚</text>
    </view>
    <view class="achievement-grid">
      <view
        wx:for="{{achievements}}"
        wx:key="id"
        wx:if="{{!childModeEnabled || item.unlocked}}"
        class="achievement-item {{item.unlocked ? 'unlocked' : 'locked'}} {{childModeEnabled ? 'child-achievement-item' : ''}}"
        bindtap="onAchievementTap"
        data-item="{{item}}"
      >
        <view class="achievement-icon-wrapper" style="background: {{item.unlocked ? item.bgColor : 'rgba(142, 142, 147, 0.1)'}};">
          <text class="achievement-icon">{{item.unlocked ? item.emoji : '🔒'}}</text>
        </view>
        <text class="achievement-name">{{item.name}}</text>
        <view class="achievement-progress-bar" wx:if="{{!item.unlocked && !childModeEnabled}}">
          <view class="achievement-progress-fill" style="width: {{item.progress}}%; background: {{item.color}};"></view>
        </view>
        <text class="achievement-progress-text" wx:if="{{!item.unlocked && !childModeEnabled}}">{{item.current}}/{{item.target}}</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单：消息中心 -->
  <view class="menu-section" wx:if="{{noticeMenus.length > 0}}">
    <view class="menu-group-title">
      <view class="group-title-decoration"></view>
      <text class="group-title-text">消息中心</text>
    </view>
    <view class="menu-list">
      <view
        wx:for="{{noticeMenus}}"
        wx:key="id"
        class="menu-item-card"
        bindtap="onMenuTap"
        data-item="{{item}}"
      >
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, rgba(91, 189, 114, 0.18) 0%, rgba(91, 189, 114, 0.06) 100%);">
          <text class="menu-icon-emoji">{{item.emoji}}</text>
          <view wx:if="{{item.badgeCount > 0}}" class="menu-badge">
            <text class="menu-badge-text">{{item.badgeCount > 99 ? '99+' : item.badgeCount}}</text>
          </view>
        </view>
        <view class="menu-content">
          <text class="menu-title-text">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
        <view class="menu-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单：学习中心 -->
  <view class="menu-section" wx:if="{{learnMenus.length > 0}}">
    <view class="menu-group-title">
      <view class="group-title-decoration"></view>
      <text class="group-title-text">学习中心</text>
    </view>
    <view class="menu-list">
      <view
        wx:for="{{learnMenus}}"
        wx:key="id"
        class="menu-item-card"
        bindtap="onMenuTap"
        data-item="{{item}}"
      >
        <view class="menu-icon-wrapper" style="background: {{item.iconBgColor}};">
          <text class="menu-icon-emoji">{{item.emoji}}</text>
        </view>
        <view class="menu-content">
          <text class="menu-title-text">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
        <view class="menu-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单：我的记录 -->
  <view class="menu-section" wx:if="{{recordMenus.length > 0}}">
    <view class="menu-group-title">
      <view class="group-title-decoration"></view>
      <text class="group-title-text">我的记录</text>
    </view>
    <view class="menu-list">
      <view
        wx:for="{{recordMenus}}"
        wx:key="id"
        class="menu-item-card"
        bindtap="onMenuTap"
        data-item="{{item}}"
      >
        <view class="menu-icon-wrapper" style="background: {{item.iconBgColor}};">
          <text class="menu-icon-emoji">{{item.emoji}}</text>
        </view>
        <view class="menu-content">
          <text class="menu-title-text">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
        <view class="menu-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单：我的服务 -->
  <view class="menu-section" wx:if="{{serviceMenus.length > 0 && !childModeEnabled}}">
    <view class="menu-group-title">
      <view class="group-title-decoration"></view>
      <text class="group-title-text">我的服务</text>
    </view>
    <view class="menu-list">
      <view
        wx:for="{{serviceMenus}}"
        wx:key="id"
        class="menu-item-card"
        bindtap="onMenuTap"
        data-item="{{item}}"
      >
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, rgba(230, 126, 34, 0.18) 0%, rgba(230, 126, 34, 0.06) 100%);">
          <text class="menu-icon-emoji">{{item.emoji}}</text>
        </view>
        <view class="menu-content">
          <text class="menu-title-text">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
        <view class="menu-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单：其他 -->
  <view class="menu-section" wx:if="{{otherMenus.length > 0}}">
    <view class="menu-group-title">
      <view class="group-title-decoration"></view>
      <text class="group-title-text">其他</text>
    </view>
    <view class="menu-list">
      <view
        wx:for="{{otherMenus}}"
        wx:key="id"
        class="menu-item-card"
        bindtap="onMenuTap"
        data-item="{{item}}"
      >
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, rgba(155, 89, 182, 0.18) 0%, rgba(155, 89, 182, 0.06) 100%);">
          <text class="menu-icon-emoji">{{item.emoji}}</text>
        </view>
        <view class="menu-content">
          <text class="menu-title-text">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
        <view class="menu-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-section">
    <text class="version-text">垃圾分类助手 v1.0.0</text>
    <text class="copyright-text">让垃圾分类更简单</text>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>
