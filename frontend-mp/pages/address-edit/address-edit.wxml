<view class="page-container">
  <view class="form-section">
    <view class="form-item">
      <view class="item-label">
        <text class="label-text">收货人</text>
        <text class="required">*</text>
      </view>
      <input 
        class="item-input" 
        placeholder="请输入收货人姓名" 
        placeholder-class="input-placeholder"
        value="{{form.name}}"
        bindinput="onNameInput"
      />
    </view>
    
    <view class="form-item">
      <view class="item-label">
        <text class="label-text">手机号码</text>
        <text class="required">*</text>
      </view>
      <input 
        class="item-input" 
        type="number"
        maxlength="11"
        placeholder="请输入手机号码" 
        placeholder-class="input-placeholder"
        value="{{form.phone}}"
        bindinput="onPhoneInput"
      />
    </view>
    
    <picker 
      mode="multiSelector" 
      range="{{[provinceList, cityList, districtList]}}"
      value="{{regionIndex}}"
      bindchange="onRegionChange"
    >
      <view class="form-item picker-item">
        <view class="item-label">
          <text class="label-text">所在地区</text>
          <text class="required">*</text>
        </view>
        <view class="picker-value">
          <text class="value-text {{form.province ? '' : 'placeholder'}}">
            {{regionText}}
          </text>
          <text class="arrow">></text>
        </view>
      </view>
    </picker>
    
    <view class="form-item detail-item">
      <view class="item-label">
        <text class="label-text">详细地址</text>
        <text class="required">*</text>
      </view>
      <textarea 
        class="item-textarea" 
        placeholder="请输入详细地址，如街道、门牌号等" 
        placeholder-class="input-placeholder"
        value="{{form.detail}}"
        bindinput="onDetailInput"
        maxlength="100"
        auto-height="{{true}}"
      />
    </view>
    
    <view class="form-item switch-item">
      <view class="item-label">
        <text class="label-text">设为默认地址</text>
      </view>
      <switch 
        checked="{{form.isDefault}}" 
        color="#5BBD72"
        bindchange="onDefaultChange"
      />
    </view>
  </view>
  
  <view class="bottom-bar">
    <view class="save-btn" bindtap="onSave">
      <text class="save-text">保存地址</text>
    </view>
  </view>
</view>
