/**
 * 垃圾分类小程序 - 全局样式
 * 设计风格：轻透清新风
 * 特点：浅色渐变、毛玻璃效果、柔和阴影、通透感
 */

/* ==================== 全局变量 ==================== */
page {
  --color-primary: #5BBD72;
  --color-primary-light: rgba(91, 189, 114, 0.1);
  --color-primary-dark: #4AA862;
  
  /* 垃圾分类颜色 */
  --color-recyclable: #4A90D9;
  --color-harmful: #E85D5D;
  --color-kitchen: #5BBD72;
  --color-other: #8E8E93;
  
  /* 背景色 */
  --bg-page: #F7FAF8;
  --bg-card: rgba(255, 255, 255, 0.75);
  --bg-card-solid: #FFFFFF;
  --bg-gradient-start: #E8F5E9;
  --bg-gradient-end: #F0F9FF;
  
  /* 文字颜色 */
  --text-primary: #2D3436;
  --text-secondary: #636E72;
  --text-tertiary: #B2BEC3;
  --text-white: #FFFFFF;
  
  /* 边框颜色 */
  --border-light: rgba(0, 0, 0, 0.05);
  --border-color: #E8E8E8;
  
  /* 阴影 */
  --shadow-light: 0 4rpx 20rpx rgba(91, 189, 114, 0.08);
  --shadow-medium: 0 8rpx 30rpx rgba(91, 189, 114, 0.12);
  --shadow-heavy: 0 12rpx 40rpx rgba(91, 189, 114, 0.16);
  
  /* 圆角 */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-round: 50%;
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;
  --spacing-xxl: 48rpx;
  
  /* 字体大小 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;
  
  /* 动画时长 */
  --transition-fast: 0.2s;
  --transition-normal: 0.3s;
  --transition-slow: 0.5s;
  
  /* 页面基础样式 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 
               'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', 
               Helvetica, Arial, sans-serif;
  font-size: var(--font-md);
  color: var(--text-primary);
  background: linear-gradient(180deg, var(--bg-gradient-start) 0%, var(--bg-page) 30%);
  min-height: 100vh;
  box-sizing: border-box;
}

/* ==================== 通用类 ==================== */

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.items-center {
  align-items: center;
}

.items-start {
  align-items: flex-start;
}

.items-end {
  align-items: flex-end;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-around {
  justify-content: space-around;
}

.justify-evenly {
  justify-content: space-evenly;
}

/* 文字对齐 */
.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

/* 文字大小 */
.text-xs {
  font-size: var(--font-xs);
}

.text-sm {
  font-size: var(--font-sm);
}

.text-md {
  font-size: var(--font-md);
}

.text-lg {
  font-size: var(--font-lg);
}

.text-xl {
  font-size: var(--font-xl);
}

.text-xxl {
  font-size: var(--font-xxl);
}

/* 文字颜色 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

.text-white {
  color: var(--text-white);
}

.text-green {
  color: var(--color-primary);
}

/* 文字粗细 */
.font-normal {
  font-weight: 400;
}

.font-medium {
  font-weight: 500;
}

.font-semibold {
  font-weight: 600;
}

.font-bold {
  font-weight: 700;
}

/* 间距 */
.m-0 { margin: 0; }
.m-xs { margin: var(--spacing-xs); }
.m-sm { margin: var(--spacing-sm); }
.m-md { margin: var(--spacing-md); }
.m-lg { margin: var(--spacing-lg); }
.m-xl { margin: var(--spacing-xl); }

.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }

.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }

.ml-xs { margin-left: var(--spacing-xs); }
.ml-sm { margin-left: var(--spacing-sm); }
.ml-md { margin-left: var(--spacing-md); }
.ml-lg { margin-left: var(--spacing-lg); }

.mr-xs { margin-right: var(--spacing-xs); }
.mr-sm { margin-right: var(--spacing-sm); }
.mr-md { margin-right: var(--spacing-md); }
.mr-lg { margin-right: var(--spacing-lg); }

.p-0 { padding: 0; }
.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.p-xl { padding: var(--spacing-xl); }

.pt-xs { padding-top: var(--spacing-xs); }
.pt-sm { padding-top: var(--spacing-sm); }
.pt-md { padding-top: var(--spacing-md); }
.pt-lg { padding-top: var(--spacing-lg); }

.pb-xs { padding-bottom: var(--spacing-xs); }
.pb-sm { padding-bottom: var(--spacing-sm); }
.pb-md { padding-bottom: var(--spacing-md); }
.pb-lg { padding-bottom: var(--spacing-lg); }

.px-md { padding-left: var(--spacing-md); padding-right: var(--spacing-md); }
.px-lg { padding-left: var(--spacing-lg); padding-right: var(--spacing-lg); }
.px-xl { padding-left: var(--spacing-xl); padding-right: var(--spacing-xl); }

.py-md { padding-top: var(--spacing-md); padding-bottom: var(--spacing-md); }
.py-lg { padding-top: var(--spacing-lg); padding-bottom: var(--spacing-lg); }

/* ==================== 卡片样式 ==================== */
.card {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  border: 1rpx solid var(--border-light);
  overflow: hidden;
  transition: all var(--transition-normal) ease;
}

.card-solid {
  background: var(--bg-card-solid);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  overflow: hidden;
}

.card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-medium);
}

/* ==================== 按钮样式 ==================== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-md) var(--spacing-xl);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: 500;
  transition: all var(--transition-fast) ease;
  border: none;
  outline: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--text-white);
  box-shadow: 0 4rpx 16rpx rgba(91, 189, 114, 0.3);
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(91, 189, 114, 0.2);
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-outline:active {
  background: var(--color-primary-light);
}

.btn-ghost {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.btn-disabled {
  background: #E8E8E8;
  color: var(--text-tertiary);
  box-shadow: none;
}

.btn-sm {
  padding: var(--spacing-xs) var(--spacing-md);
  font-size: var(--font-sm);
  border-radius: var(--radius-sm);
}

.btn-lg {
  padding: var(--spacing-lg) var(--spacing-xxl);
  font-size: var(--font-lg);
  border-radius: var(--radius-lg);
}

.btn-block {
  display: flex;
  width: 100%;
}

/* ==================== 标签样式 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-xs);
  font-size: var(--font-xs);
  font-weight: 500;
}

.tag-primary {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.tag-recyclable {
  background: rgba(74, 144, 217, 0.1);
  color: var(--color-recyclable);
}

.tag-harmful {
  background: rgba(232, 93, 93, 0.1);
  color: var(--color-harmful);
}

.tag-kitchen {
  background: rgba(91, 189, 114, 0.1);
  color: var(--color-kitchen);
}

.tag-other {
  background: rgba(142, 142, 147, 0.1);
  color: var(--color-other);
}

/* ==================== 分割线 ==================== */
.divider {
  height: 1rpx;
  background: var(--border-light);
  margin: var(--spacing-md) 0;
}

.divider-vertical {
  width: 1rpx;
  height: 100%;
  background: var(--border-light);
  margin: 0 var(--spacing-md);
}

/* ==================== 图片样式 ==================== */
.img-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.img-contain {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.img-circle {
  border-radius: var(--radius-round);
}

/* ==================== 动画 ==================== */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.animate-fadeIn {
  animation: fadeIn var(--transition-normal) ease;
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.animate-spin {
  animation: spin 1s linear infinite;
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 隐藏滚动条 ==================== */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* ==================== 页面容器 ==================== */
.page-container {
  min-height: 100vh;
  padding: var(--spacing-xl);
  padding-bottom: calc(var(--spacing-xl) + 120rpx);
  box-sizing: border-box;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xxl);
}

.empty-state-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.5;
}

.empty-state-text {
  font-size: var(--font-md);
  color: var(--text-tertiary);
}

/* ==================== Loading 状态 ==================== */
.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--color-primary-light);
  border-top-color: var(--color-primary);
  border-radius: var(--radius-round);
  animation: spin 0.8s linear infinite;
}
