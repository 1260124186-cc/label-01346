.guide-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.guide-mask-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.guide-content {
  position: relative;
  z-index: 10;
  width: 600rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f8fff9 100%);
  border-radius: 32rpx;
  padding: 60rpx 48rpx 48rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  animation: guideFadeIn 0.3s ease-out;
}

@keyframes guideFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.guide-emoji {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 32rpx;
  animation: guideBounce 1s ease-in-out infinite;
}

@keyframes guideBounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-12rpx);
  }
}

.guide-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.guide-description {
  font-size: 28rpx;
  color: #636E72;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.guide-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.guide-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(91, 189, 114, 0.3);
  transition: all 0.3s ease;
}

.guide-dot.active {
  width: 48rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #5BBD72 0%, #4CAF50 100%);
}

.guide-actions {
  display: flex;
  gap: 24rpx;
}

.guide-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.guide-btn:active {
  transform: scale(0.96);
}

.guide-btn-skip {
  background: rgba(91, 189, 114, 0.1);
  color: #5BBD72;
}

.guide-btn-next {
  background: linear-gradient(135deg, #5BBD72 0%, #4CAF50 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(91, 189, 114, 0.35);
}

.guide-step-indicator {
  position: absolute;
  top: 60rpx;
  right: 60rpx;
  z-index: 10;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}
